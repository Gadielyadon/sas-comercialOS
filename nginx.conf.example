# ─────────────────────────────────────────────────────────────
# Nginx — ComercialOS
# Archivo: /etc/nginx/sites-available/comercialos
#
# INSTRUCCIONES:
# 1. Reemplazá "tudominio.com" por el dominio real del cliente
# 2. cp comercialos /etc/nginx/sites-available/
# 3. ln -s /etc/nginx/sites-available/comercialos /etc/nginx/sites-enabled/
# 4. nginx -t && systemctl reload nginx
# 5. certbot --nginx -d tudominio.com   (SSL gratis con Let's Encrypt)
# ─────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name tudominio.com www.tudominio.com;

    # Redirigir todo HTTP → HTTPS (certbot lo completa automáticamente)
    location / {
        proxy_pass         http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Tamaño máximo para subida de logo/imágenes
        client_max_body_size 10M;
    }
}
