# ─────────────────────────────────────────────────────────────
# ComercialOS — Variables de entorno
# Copiá este archivo como .env y completá los valores
# NUNCA subas el archivo .env al repositorio
# ─────────────────────────────────────────────────────────────

# Entorno: development | production
NODE_ENV=production

# Puerto en el que corre la app (Nginx hace proxy a este puerto)
PORT=3000

# Secret para las sesiones — generá uno aleatorio largo y seguro
# Podés usar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-string-largo-y-aleatorio
