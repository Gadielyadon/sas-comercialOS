<%- include('../partials/head', { title, theme: 'light' }) %>

<style>
  .caja-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--bg-body); padding: 24px; }
  .caja-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 20px; box-shadow: var(--shadow-lg); padding: 44px 40px; width: 100%; max-width: 460px; }
  .caja-icon { width: 60px; height: 60px; border-radius: 16px; background: linear-gradient(135deg,#10b981,#059669); display: flex; align-items: center; justify-content: center; font-size: 26px; color: #fff; margin: 0 auto 20px; box-shadow: 0 8px 24px rgba(16,185,129,.35); }
  .caja-title { font-size: 22px; font-weight: 800; color: var(--text-primary); text-align: center; margin-bottom: 6px; letter-spacing: -.4px; }
  .caja-sub   { font-size: 13.5px; color: var(--text-secondary); text-align: center; margin-bottom: 32px; }
  .field { margin-bottom: 18px; }
  .field label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-secondary); margin-bottom: 7px; }
  .field input { width: 100%; padding: 12px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); background: var(--bg-body); color: var(--text-primary); font-family: var(--font-body); font-size: 15px; outline: none; transition: border .2s, box-shadow .2s; }
  .field input:focus { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,.12); }
  .field-prefix { position: relative; }
  .field-prefix span { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-size: 16px; font-weight: 700; color: var(--text-secondary); pointer-events: none; }
  .field-prefix input { padding-left: 30px; }
  .btn-abrir { width: 100%; padding: 14px; border: none; border-radius: var(--radius-md); background: linear-gradient(135deg,#10b981,#059669); color: #fff; font-size: 15px; font-weight: 700; font-family: var(--font-body); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 9px; transition: all .15s; box-shadow: 0 6px 18px rgba(16,185,129,.35); margin-top: 8px; }
  .btn-abrir:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(16,185,129,.45); }
  .btn-abrir:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .turno-info { display: flex; align-items: center; gap: 10px; background: rgba(16,185,129,.07); border: 1px solid rgba(16,185,129,.2); border-radius: var(--radius-md); padding: 12px 16px; margin-bottom: 24px; }
  .turno-info i { font-size: 18px; color: #10b981; }
  .turno-info span { font-size: 13px; color: var(--text-secondary); }
  .turno-info strong { color: var(--text-primary); }
</style>

<div class="caja-page">
  <div class="caja-card">
    <div class="caja-icon"><i class="bi bi-cash-coin"></i></div>
    <div class="caja-title">Abrir Caja</div>
    <div class="caja-sub">Ingresá el monto inicial en efectivo para comenzar el turno</div>

    <!-- Info cajero -->
    <div class="turno-info">
      <i class="bi bi-person-circle"></i>
      <span>Cajero: <strong><%= user.name %></strong></span>
    </div>

    <!-- Terminal -->
    <div class="field">
      <label>Terminal / Nombre de caja</label>
      <input type="text" id="inp_terminal" value="Caja Principal" placeholder="Ej: Caja 1, Mostrador...">
    </div>

    <!-- Monto inicial -->
    <div class="field">
      <label>Monto inicial en efectivo</label>
      <div class="field-prefix">
        <span>$</span>
        <input type="number" id="inp_monto" placeholder="0.00" min="0" step="0.01" value="0">
      </div>
    </div>

    <!-- Teclas rápidas -->
    <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
      <% [0, 1000, 2000, 5000, 10000].forEach(v => { %>
        <button onclick="document.getElementById('inp_monto').value='<%= v %>'"
          style="flex:1;min-width:60px;padding:7px 4px;border:1.5px solid var(--border-color);border-radius:8px;background:var(--bg-body);color:var(--text-secondary);font-size:12.5px;font-weight:600;cursor:pointer;transition:all .12s;"
          onmouseover="this.style.borderColor='#10b981';this.style.color='#10b981'"
          onmouseout="this.style.borderColor='var(--border-color)';this.style.color='var(--text-secondary)'">
          $<%= v.toLocaleString('es-AR') %>
        </button>
      <% }) %>
    </div>

    <button class="btn-abrir" id="btnAbrir" onclick="abrirCaja()">
      <i class="bi bi-unlock-fill"></i> Abrir Caja y Comenzar
    </button>

    <div id="errorMsg" style="display:none;margin-top:14px;padding:10px 14px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:8px;font-size:13px;color:#dc2626;"></div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
async function abrirCaja() {
  const btn = document.getElementById('btnAbrir');
  const errDiv = document.getElementById('errorMsg');
  const montoInicial = parseFloat(document.getElementById('inp_monto').value) || 0;
  const terminal = document.getElementById('inp_terminal').value.trim() || 'Caja Principal';

  btn.disabled = true;
  btn.innerHTML = '<span style="width:16px;height:16px;border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;display:inline-block;animation:spin .7s linear infinite;"></span> Abriendo…';
  errDiv.style.display = 'none';

  try {
    const r = await fetch('/caja/api/abrir', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ montoInicial, terminal })
    });
    const data = await r.json();
    if (data.ok) {
      window.location.href = '/ventas';
    } else {
      errDiv.textContent = data.error || 'Error al abrir la caja';
      errDiv.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-unlock-fill"></i> Abrir Caja y Comenzar';
    }
  } catch(e) {
    errDiv.textContent = 'Error de conexión';
    errDiv.style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-unlock-fill"></i> Abrir Caja y Comenzar';
  }
}
document.getElementById('inp_monto').addEventListener('keydown', e => { if (e.key === 'Enter') abrirCaja(); });
</script>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>
