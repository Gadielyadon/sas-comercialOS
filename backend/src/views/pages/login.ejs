<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión — ComercialOS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-body, #f1f5f9);
      font-family: var(--font-sans, 'Inter', sans-serif);
    }

    /* Fondo decorativo */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(0,180,216,.08) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(0,100,160,.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .login-card {
      background: var(--bg-card, #fff);
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 18px;
      box-shadow: 0 20px 60px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.04);
      padding: 44px 40px 36px;
      width: 100%;
      max-width: 420px;
      position: relative;
    }

    /* Logo */
    .login-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 32px;
    }
    .login-logo-icon {
      width: 46px;
      height: 46px;
      border-radius: 13px;
      background: linear-gradient(135deg, var(--color-action, #00b4d8), #0077a8);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 22px;
      box-shadow: 0 6px 18px rgba(0,180,216,.35);
    }
    .login-logo-text strong {
      display: block;
      font-size: 18px;
      font-weight: 800;
      color: var(--text-primary, #0f172a);
      letter-spacing: -.3px;
    }
    .login-logo-text span {
      font-size: 11.5px;
      color: var(--text-secondary, #64748b);
      font-weight: 500;
    }

    h1 {
      font-size: 22px;
      font-weight: 800;
      color: var(--text-primary, #0f172a);
      margin-bottom: 4px;
      letter-spacing: -.4px;
    }
    .login-subtitle {
      font-size: 13.5px;
      color: var(--text-secondary, #64748b);
      margin-bottom: 28px;
    }

    /* Campos */
    .field {
      margin-bottom: 16px;
    }
    .field label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: var(--text-secondary, #64748b);
      margin-bottom: 6px;
    }
    .field-input-wrap {
      position: relative;
    }
    .field-input-wrap i {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary, #94a3b8);
      font-size: 15px;
      pointer-events: none;
    }
    .field input {
      width: 100%;
      padding: 11px 12px 11px 38px;
      border-radius: 10px;
      border: 1.5px solid var(--border-color, #e2e8f0);
      background: var(--bg-body, #f8fafc);
      color: var(--text-primary, #0f172a);
      font-size: 14px;
      font-family: inherit;
      outline: none;
      transition: border .2s, box-shadow .2s;
    }
    .field input:focus {
      border-color: var(--color-action, #00b4d8);
      box-shadow: 0 0 0 3px rgba(0,180,216,.12);
      background: var(--bg-card, #fff);
    }
    .field input.input-error {
      border-color: #ef4444;
      box-shadow: 0 0 0 3px rgba(239,68,68,.1);
    }

    /* Toggle password */
    .toggle-pass {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-secondary, #94a3b8);
      font-size: 16px;
      padding: 2px;
      line-height: 1;
      transition: color .15s;
    }
    .toggle-pass:hover { color: var(--color-action, #00b4d8); }

    /* Error banner */
    .error-banner {
      display: flex;
      align-items: center;
      gap: 9px;
      background: rgba(239,68,68,.08);
      border: 1px solid rgba(239,68,68,.25);
      border-radius: 9px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 600;
      color: #dc2626;
      margin-bottom: 18px;
      animation: shake .35s ease;
    }
    @keyframes shake {
      0%,100%{ transform:translateX(0) }
      25%    { transform:translateX(-6px) }
      75%    { transform:translateX(6px) }
    }

    /* Botón */
    .btn-login {
      width: 100%;
      padding: 13px;
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--color-action, #00b4d8), #0099c0);
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 8px;
      transition: opacity .15s, transform .1s, box-shadow .2s;
      box-shadow: 0 6px 18px rgba(0,180,216,.3);
      letter-spacing: .1px;
    }
    .btn-login:hover:not(:disabled) {
      opacity: .93;
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(0,180,216,.4);
    }
    .btn-login:active:not(:disabled) { transform: translateY(0); }
    .btn-login:disabled { opacity: .6; cursor: not-allowed; }

    /* Footer */
    .login-footer {
      margin-top: 24px;
      text-align: center;
      font-size: 11.5px;
      color: var(--text-secondary, #94a3b8);
    }
  </style>
</head>
<body>
  <div class="login-card">

    <!-- Logo -->
    <div class="login-logo">
      <div class="login-logo-icon">
        <i class="bi bi-lightning-charge-fill"></i>
      </div>
      <div class="login-logo-text">
        <strong>ComercialOS</strong>
        <span>Punto de Venta</span>
      </div>
    </div>

    <h1>Bienvenido</h1>
    <p class="login-subtitle">Ingresá tus credenciales para continuar</p>

    <!-- Error -->
    <% if (error) { %>
      <div class="error-banner">
        <i class="bi bi-exclamation-circle-fill"></i>
        <%= error %>
      </div>
    <% } %>

    <!-- Formulario -->
    <form method="POST" action="/login" id="loginForm">
      <div class="field">
        <label>Usuario</label>
        <div class="field-input-wrap">
          <i class="bi bi-person"></i>
          <input type="text" name="username" id="inp_user"
            value="<%= username %>"
            placeholder="Tu nombre de usuario"
            autocomplete="username"
            autofocus
            class="<%= error ? 'input-error' : '' %>">
        </div>
      </div>

      <div class="field">
        <label>Contraseña</label>
        <div class="field-input-wrap">
          <i class="bi bi-lock"></i>
          <input type="password" name="password" id="inp_pass"
            placeholder="••••••••"
            autocomplete="current-password"
            class="<%= error ? 'input-error' : '' %>">
          <button type="button" class="toggle-pass" onclick="togglePass()" tabindex="-1">
            <i class="bi bi-eye" id="passEyeIcon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-login" id="btnLogin">
        <i class="bi bi-box-arrow-in-right"></i>
        Ingresar
      </button>
    </form>

    <div class="login-footer">
      © 2026 ComercialOS · v1.0
    </div>
  </div>

  <script>
    function togglePass() {
      const input = document.getElementById('inp_pass');
      const icon  = document.getElementById('passEyeIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
      }
    }

    // Deshabilitar botón al enviar para evitar doble click
    document.getElementById('loginForm').addEventListener('submit', function() {
      const btn = document.getElementById('btnLogin');
      btn.disabled = true;
      btn.innerHTML = '<span style="width:16px;height:16px;border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;display:inline-block;animation:spin .7s linear infinite;"></span> Ingresando…';
    });
  </script>
  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</body>
</html>
