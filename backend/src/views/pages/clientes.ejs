        </div>
      </div>
      <button onclick="cerrarModalPago()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- Saldo deudor actual -->
    <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-size:12px;color:#dc2626;font-weight:600;">Saldo deudor total</span>
      <span style="font-family:var(--font-mono);font-size:18px;font-weight:800;color:#dc2626;" id="pagoSaldoActual">$0.00</span>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      <div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
          <label style="font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;">Monto a cobrar ($)</label>
          <button onclick="pagarTodo()" style="font-size:11px;font-weight:600;color:var(--color-primary);background:rgba(27,79,216,.1);border:none;border-radius:5px;padding:2px 9px;cursor:pointer;">
            Cobrar todo
          </button>
        </div>
        <input type="number" id="p_monto" min="0.01" step="0.01" placeholder="0.00"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-mono);font-size:18px;font-weight:700;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='var(--border-color)'"
          oninput="calcRestante()">
      </div>

      <!-- Saldo pendiente tras el pago -->
      <div id="restanteWrap" style="display:none;border-radius:var(--radius-sm);padding:10px 14px;display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:12px;font-weight:600;" id="restanteLabel">Saldo pendiente tras pago</span>
        <span style="font-family:var(--font-mono);font-size:15px;font-weight:700;" id="restanteValor">$0.00</span>
      </div>

      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Descripción</label>
        <input type="text" id="p_desc" placeholder="Ej: Pago en efectivo, Transferencia…"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
    </div>

    <div style="display:flex;gap:10px;margin-top:20px;">
      <button onclick="confirmarPago()"
        style="flex:1;justify-content:center;padding:11px;background:#10b981;color:#fff;border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;">
        <i class="bi bi-check-circle-fill"></i> Confirmar pago
      </button>
      <button onclick="cerrarModalPago()" class="btn-action btn-action-outline" style="padding:11px 18px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL CUENTA CORRIENTE / MOVIMIENTOS
══════════════════════════════════════════ -->
<div class="sale-overlay" id="modalMovimientos" onclick="if(event.target.id==='modalMovimientos')cerrarModalMovimientos()">
  <div style="width:100%;max-width:900px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);box-shadow:0 20px 60px rgba(0,0,0,.2);animation:modalPop .16s ease;max-height:90vh;display:flex;flex-direction:column;overflow:hidden;">

