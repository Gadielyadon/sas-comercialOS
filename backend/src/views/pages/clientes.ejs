<%- include('../partials/head', { title: 'Clientes' }) %>
<style>
.cat-cliente-pill {
  display: inline-flex; align-items: center;
  padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
  background: rgba(27,79,216,.08); color: var(--color-primary);
  white-space: nowrap;
}
.filtro-chip {
  padding: 5px 12px;
  border-radius: 6px;
  border: none;
  background: transparent;
  color: var(--text-secondary);
  font-size: 12.5px;
  font-weight: 600;
  cursor: pointer;
  transition: all .15s;
  font-family: var(--font-body);
}
.filtro-chip:hover { background: var(--bg-surface-2); color: var(--text-primary); }
.filtro-chip.on    { background: var(--color-primary); color: #fff; }
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'clientes', user }) %>

  <div class="main-content">
    <%- include('../partials/header', { module: 'Clientes', user }) %>

    <main class="page-body">

      <div class="page-header">
        <div class="page-header-title">
          <h2>Clientes</h2>
          <p>Gestión de clientes y cuentas corrientes.</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="btn-action btn-action-outline" onclick="abrirImportarClientes()">
            <i class="bi bi-file-earmark-excel"></i> Importar Excel
          </button>
          <button class="btn-action btn-action-primary" onclick="abrirNuevo()">
            <i class="bi bi-person-plus"></i> Nuevo Cliente
          </button>
        </div>
      </div>

      <!-- Buscador + Filtros + Exportar -->
      <div class="page-toolbar" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:18px;">
        <div class="search-input-wrap" style="flex:1;min-width:200px;max-width:320px">
          <i class="bi bi-search"></i>
          <input id="q" class="search-input" placeholder="Buscar por nombre o documento…" oninput="filtrar()">
        </div>

        <!-- Filtro estado -->
        <div style="display:flex;gap:5px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:4px;">
          <button class="filtro-chip on" data-filtro="todos"    onclick="setFiltro(this)">Todos</button>
          <button class="filtro-chip"    data-filtro="deudores" onclick="setFiltro(this)"><i class="bi bi-exclamation-circle" style="color:#ef4444;margin-right:4px;"></i>Deudores</button>
          <button class="filtro-chip"    data-filtro="al-dia"   onclick="setFiltro(this)"><i class="bi bi-check-circle" style="color:#10b981;margin-right:4px;"></i>Al día</button>
        </div>

        <!-- Filtro categoría -->
        <select id="categoriaSelect" onchange="filtrar()" class="filter-select" style="padding:8px 28px 8px 12px;font-size:12.5px;">
          <option value="">Todas las categorías</option>
        </select>

        <!-- Ordenar -->
        <select id="ordenSelect" onchange="filtrar()" class="filter-select" style="padding:8px 28px 8px 12px;font-size:12.5px;">
          <option value="nombre">Ordenar: A → Z</option>
          <option value="mayor-deuda">Mayor deuda primero</option>
          <option value="menor-deuda">Menor deuda primero</option>
        </select>

        <!-- Exportar -->
        <div style="display:flex;gap:6px;margin-left:auto;">
          <button onclick="exportarClientesCSV()"
            style="display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:var(--radius-sm);border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:12.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
            <i class="bi bi-filetype-csv"></i> CSV
          </button>
          <button onclick="exportarClientesPDF()"
            style="display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:var(--radius-sm);border:1.5px solid rgba(99,102,241,.4);background:rgba(99,102,241,.07);color:#4f46e5;font-size:12.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
            <i class="bi bi-file-earmark-pdf"></i> PDF
          </button>
        </div>
      </div>

      <!-- Resumen rápido -->
      <div id="resumenClientes" style="display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap;"></div>

      <!-- Tabla -->
      <div class="card-panel">
        <div class="card-panel-body">
          <table class="sales-table" id="tablaClientes">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>CUIT / DNI</th>
                <th>Saldo</th>
                <th>Límite crédito</th>
                <th style="width:240px">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% (clientes || []).forEach(c => { %>
                <tr data-id="<%= c.id %>">
                  <td class="sale-id"><%= c.id %></td>
                  <td>
                    <strong><%= c.nombre %></strong>
                    <% if (c.id === 1) { %>
                      <span style="font-size:10px;padding:1px 7px;border-radius:20px;background:rgba(27,79,216,.1);color:var(--color-primary);margin-left:6px;font-weight:600;">Default</span>
                    <% } %>
                  </td>
                  <td style="color:var(--text-secondary);font-family:var(--font-mono)"><%= c.documento || '—' %></td>
                  <td>
                    <% if (c.categoria) { %>
                      <span class="cat-cliente-pill" data-cat="<%= c.categoria %>"><%= c.categoria %></span>
                    <% } else { %>
                      <span style="color:var(--text-muted);font-size:12px;">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.saldo > 0) { %>
                      <span class="badge-status badge-anulado">Debe $<%= Number(c.saldo).toFixed(2) %></span>
                    <% } else if (c.saldo < 0) { %>
                      <span class="badge-status badge-pendiente">A favor $<%= Math.abs(Number(c.saldo)).toFixed(2) %></span>
                    <% } else { %>
                      <span class="badge-status badge-pagado">Al día</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.limite_credito != null) { %>
                      <% const usado = Math.max(0, c.saldo || 0); %>
                      <% const pct = Math.min(100, Math.round((usado / c.limite_credito) * 100)); %>
                      <% const color = pct >= 90 ? '#ef4444' : pct >= 70 ? '#f59e0b' : '#10b981'; %>
                      <div style="font-size:11px;color:var(--text-secondary);margin-bottom:3px;">
                        $<%= Number(usado).toLocaleString('es-AR') %> / $<%= Number(c.limite_credito).toLocaleString('es-AR') %>
                      </div>
                      <div style="width:100%;max-width:120px;height:5px;background:var(--border-color);border-radius:3px;overflow:hidden;">
                        <div style="width:<%= pct %>%;height:100%;background:<%= color %>;border-radius:3px;transition:width .3s;"></div>
                      </div>
                    <% } else { %>
                      <span style="color:var(--text-muted);font-size:12px;">Sin límite</span>
                    <% } %>
                  </td>
                  <td>
                    <div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap;">
                      <button class="btn-action btn-action-outline btn-sm" onclick="verMovimientos(<%= c.id %>, '<%= c.nombre %>', <%= c.saldo %>)" title="Ver cuenta corriente">
                        <i class="bi bi-clock-history"></i> Cuenta
                      </button>
                      <% if (c.id !== 1) { %>
                        <button class="btn-action btn-action-outline btn-sm" onclick="abrirCargo(<%= c.id %>, '<%= c.nombre %>')" title="Registrar deuda manual"
                          style="color:#d97706;border-color:rgba(217,119,6,.3);">
                          <i class="bi bi-plus-circle"></i> Cargar
                        </button>
                      <% } %>
                      <% if (c.saldo > 0) { %>
                        <button class="btn-action btn-action-primary btn-sm" onclick="abrirPago(<%= c.id %>, '<%= c.nombre %>', <%= c.saldo %>)" title="Registrar pago">
                          <i class="bi bi-cash"></i> Cobrar
                        </button>
                      <% } %>
                      <% if (c.id !== 1) { %>
                        <button class="btn-action btn-action-outline btn-sm" onclick="abrirEditar(<%= JSON.stringify(c) %>)" title="Editar" style="color:var(--color-primary);border-color:rgba(27,79,216,.3);">
                          <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn-action btn-action-ghost btn-sm" onclick="eliminar(<%= c.id %>)" title="Eliminar">
                          <i class="bi bi-trash3"></i>
                        </button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL NUEVO / EDITAR CLIENTE
══════════════════════════════════════════ -->
<div class="sale-overlay" id="modalCliente" onclick="if(event.target.id==='modalCliente')cerrarModal()">
  <div class="sale-modal" style="max-width:440px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--color-primary),#0099b8);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;">
          <i class="bi bi-person"></i>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:var(--text-primary);" id="modalClienteTitulo">Nuevo Cliente</div>
          <div style="font-size:11px;color:var(--text-secondary);">Datos del cliente</div>
        </div>
      </div>
      <button onclick="cerrarModal()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Nombre *</label>
        <input type="text" id="c_nombre" placeholder="Nombre completo o razón social"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13.5px;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">CUIT / DNI</label>
          <input type="text" id="c_documento" placeholder="Opcional"
            style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-mono);font-size:13px;outline:none;transition:border .2s;"
            onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
        </div>
        <div>
          <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Teléfono</label>
          <input type="text" id="c_telefono" placeholder="Opcional"
            style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
            onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
        </div>
      </div>
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Email</label>
        <input type="email" id="c_email" placeholder="Opcional"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Dirección</label>
        <input type="text" id="c_direccion" placeholder="Opcional"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <!-- Categoría -->
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">
          Categoría <span style="font-weight:400;color:var(--text-muted);font-size:10px;">(opcional)</span>
        </label>
        <div style="display:flex;gap:6px;">
          <select id="c_categoria" class="form-input" style="flex:1;cursor:pointer;">
            <option value="">Sin categoría</option>
          </select>
          <button type="button" onclick="abrirNuevaCat()" title="Nueva categoría"
            style="width:36px;height:36px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--color-primary);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="bi bi-plus"></i>
          </button>
        </div>
        <div id="nuevaCatWrap" style="display:none;margin-top:6px;display:none;gap:6px;">
          <input type="text" id="nuevaCatInput" class="form-input" placeholder="Nombre de la categoría" style="flex:1;">
          <button type="button" onclick="guardarNuevaCat()"
            style="padding:0 14px;border-radius:var(--radius-sm);border:none;background:var(--color-primary);color:#fff;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;">
            Agregar
          </button>
        </div>
      </div>

      <!-- Límite de crédito -->
      <div style="background:rgba(27,79,216,.04);border:1.5px solid rgba(27,79,216,.15);border-radius:var(--radius-md);padding:12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <div style="font-size:11px;font-weight:700;color:var(--color-primary);text-transform:uppercase;letter-spacing:.5px;">
            <i class="bi bi-shield-check" style="margin-right:5px;"></i>Límite de crédito (cuenta corriente)
          </div>
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;color:var(--text-secondary);">
            Activar
            <input type="checkbox" id="c_limite_check" onchange="toggleLimiteCredito(this)" style="cursor:pointer;">
          </label>
        </div>
        <div id="c_limite_off" style="font-size:11.5px;color:var(--text-secondary);font-style:italic;">Sin límite — puede fiarse sin restricción</div>
        <div id="c_limite_fields" style="display:none;">
          <label style="font-size:11px;font-weight:600;color:var(--text-secondary);display:block;margin-bottom:5px;">Monto máximo de deuda ($)</label>
          <input type="number" id="c_limite_credito" placeholder="Ej: 50000" min="0" step="100"
            style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1.5px solid rgba(27,79,216,.3);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-mono);font-size:16px;font-weight:700;outline:none;transition:border .2s;"
            onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='rgba(27,79,216,.3)'">
          <div style="font-size:11px;color:var(--text-secondary);margin-top:5px;">Si el cliente supera este monto, el sistema bloquea la venta.</div>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:20px;">
      <button onclick="guardarCliente()" class="btn-action btn-action-primary" style="flex:1;justify-content:center;padding:11px;">
        <i class="bi bi-check-lg"></i> <span id="btnGuardarClienteTxt">Guardar</span>
      </button>
      <button onclick="cerrarModal()" class="btn-action btn-action-outline" style="padding:11px 18px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL CARGAR DEUDA
══════════════════════════════════════════ -->
<div class="sale-overlay" id="modalCargo" onclick="if(event.target.id==='modalCargo')cerrarModalCargo()">
  <div class="sale-modal" style="max-width:420px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;">
          <i class="bi bi-plus-circle"></i>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:var(--text-primary);">Registrar Cargo</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="cargoClienteNombre">—</div>
        </div>
      </div>
      <button onclick="cerrarModalCargo()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>

    <div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:16px;font-size:12.5px;color:#92400e;">
      <i class="bi bi-info-circle" style="margin-right:5px;"></i>
      Mercadería o servicios que el cliente lleva sin pagar ahora (fiado manual).
    </div>

    <div style="display:flex;flex-direction:column;gap:12px;">
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Monto ($) *</label>
        <input type="number" id="cargo_monto" min="0.01" step="0.01" placeholder="0.00"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-mono);font-size:18px;font-weight:700;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='#f59e0b'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <div>
        <label style="font-size:12px;font-weight:700;color:var(--text-primary);display:block;margin-bottom:6px;">Descripción</label>
        <input type="text" id="cargo_desc" placeholder="Ej: Bolsa de harina, Semana 1…"
          style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
          onfocus="this.style.borderColor='#f59e0b'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
    </div>

    <div style="display:flex;gap:10px;margin-top:20px;">
      <button onclick="confirmarCargo()"
        style="flex:1;justify-content:center;padding:11px;background:#f59e0b;color:#fff;border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;">
        <i class="bi bi-plus-circle-fill"></i> Registrar cargo
      </button>
      <button onclick="cerrarModalCargo()" class="btn-action btn-action-outline" style="padding:11px 18px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL IMPORTAR CLIENTES
══════════════════════════════════════════ -->
<div class="sale-overlay" id="modalImportarClientes" onclick="if(event.target.id==='modalImportarClientes')cerrarImportarClientes()">
  <div class="sale-modal" style="max-width:680px;text-align:left;max-height:90vh;overflow-y:auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(16,185,129,.12);display:flex;align-items:center;justify-content:center;color:#10b981;font-size:18px;">
          <i class="bi bi-file-earmark-excel"></i>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:var(--text-primary);">Importar Clientes</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="imp_cli_subtitle">Seleccioná un archivo .xlsx o .csv</div>
        </div>
      </div>
      <button onclick="cerrarImportarClientes()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- Step 1: subir archivo -->
    <div id="imp_cli_step1">
      <div style="border:2px dashed var(--border-color);border-radius:12px;padding:32px;text-align:center;cursor:pointer;transition:border-color .2s;"
        onclick="document.getElementById('imp_cli_file').click()"
        ondragover="event.preventDefault();this.style.borderColor='var(--color-primary)'"
        ondragleave="this.style.borderColor='var(--border-color)'"
        ondrop="event.preventDefault();this.style.borderColor='var(--border-color)';impCliFileSelected({target:{files:event.dataTransfer.files}})">
        <i class="bi bi-cloud-upload" style="font-size:32px;color:var(--text-muted);display:block;margin-bottom:8px;"></i>
        <div style="font-size:14px;font-weight:600;color:var(--text-primary);margin-bottom:4px;">Arrastrá el archivo o hacé click</div>
        <div style="font-size:12px;color:var(--text-secondary);">.xlsx · .xls · .csv — máx. 5MB</div>
      </div>
      <input type="file" id="imp_cli_file" accept=".xlsx,.xls,.csv" style="display:none" onchange="impCliFileSelected(event)">

      <div style="margin-top:14px;display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:12px;color:var(--text-secondary);">¿No tenés el formato? Descargá la plantilla:</span>
        <button onclick="descargarPlantillaClientes()"
          style="display:flex;align-items:center;gap:6px;padding:6px 14px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.06);color:#059669;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
          <i class="bi bi-download"></i> Plantilla Excel
        </button>
      </div>

      <div style="margin-top:12px;background:var(--bg-surface-2);border-radius:8px;padding:10px 14px;font-size:11.5px;color:var(--text-secondary);">
        <strong>Columnas reconocidas:</strong> nombre · documento · telefono · email · direccion · limite_credito<br>
        Si el cliente ya existe (mismo documento o nombre), se actualiza. Si no existe, se crea.
      </div>
    </div>

    <!-- Step 2: preview -->
    <div id="imp_cli_step2" style="display:none;">
      <div style="display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;">
        <span id="imp_cli_countNew"    style="padding:4px 12px;border-radius:20px;background:rgba(16,185,129,.1);color:#059669;font-size:12px;font-weight:700;">0 nuevos</span>
        <span id="imp_cli_countUpdate" style="padding:4px 12px;border-radius:20px;background:rgba(245,158,11,.1);color:#d97706;font-size:12px;font-weight:700;">0 actualizar</span>
        <span id="imp_cli_countError"  style="padding:4px 12px;border-radius:20px;background:rgba(239,68,68,.1);color:#ef4444;font-size:12px;font-weight:700;">0 errores</span>
      </div>
      <div style="border:1px solid var(--border-color);border-radius:10px;overflow:hidden;max-height:320px;overflow-y:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:12px;">
          <thead style="background:var(--bg-surface-2);position:sticky;top:0;">
            <tr>
              <th style="padding:8px 12px;text-align:left;font-weight:700;color:var(--text-secondary);">Estado</th>
              <th style="padding:8px 12px;text-align:left;">Nombre</th>
              <th style="padding:8px 12px;text-align:left;">Documento</th>
              <th style="padding:8px 12px;text-align:left;">Teléfono</th>
              <th style="padding:8px 12px;text-align:right;">Límite</th>
            </tr>
          </thead>
          <tbody id="imp_cli_previewBody"></tbody>
        </table>
      </div>
    </div>

    <!-- Footer -->
    <div id="imp_cli_footer" style="display:none;margin-top:16px;display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
      <span id="imp_cli_footerInfo" style="font-size:12px;color:var(--text-secondary);"></span>
      <div style="display:flex;gap:8px;">
        <button onclick="impCliVolver()" class="btn-action btn-action-outline" style="padding:9px 16px;">← Volver</button>
        <button onclick="ejecutarImportacionClientes()" id="imp_cli_btnImportar"
          style="padding:9px 20px;border-radius:var(--radius-sm);border:none;background:#10b981;color:#fff;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;font-family:var(--font-body);">
          <i class="bi bi-check-lg"></i> <span id="imp_cli_btnLabel">Importar</span>
        </button>
      </div>
    </div>
  </div>
</div>

