<%- include('../partials/scripts') %>

<script>
'use strict';
let _editClienteId  = null;
let _pagoClienteId  = null;
let _pagoSaldo      = 0;
let _cargoClienteId = null;
let _movId          = null;
let _movNombre      = '';
let _movSaldo       = 0;

/* ════════════════════════════════════
   CRUD CLIENTES
════════════════════════════════════ */
function toggleLimiteCredito(cb) {
  document.getElementById('c_limite_off').style.display    = cb.checked ? 'none'  : 'block';
  document.getElementById('c_limite_fields').style.display = cb.checked ? 'block' : 'none';
  if (!cb.checked) document.getElementById('c_limite_credito').value = '';
}

function abrirNuevo() {
  _editClienteId = null;
  document.getElementById('modalClienteTitulo').textContent   = 'Nuevo Cliente';
  document.getElementById('btnGuardarClienteTxt').textContent = 'Guardar';
  document.getElementById('c_nombre').value    = '';
  document.getElementById('c_documento').value = '';
  document.getElementById('c_telefono').value  = '';
  document.getElementById('c_email').value     = '';
  document.getElementById('c_direccion').value = '';
  document.getElementById('c_limite_check').checked = false;
  toggleLimiteCredito(document.getElementById('c_limite_check'));
  document.getElementById('c_limite_credito').value = '';
  const _catSel = document.getElementById('c_categoria');
  if (_catSel) _catSel.value = '';
  document.getElementById('modalCliente').classList.add('open');
  setTimeout(() => document.getElementById('c_nombre').focus(), 80);
}

function abrirEditar(c) {
  _editClienteId = c.id;
  document.getElementById('modalClienteTitulo').textContent   = 'Editar Cliente';
  document.getElementById('btnGuardarClienteTxt').textContent = 'Guardar cambios';
  document.getElementById('c_nombre').value    = c.nombre;
  document.getElementById('c_documento').value = c.documento || '';
  document.getElementById('c_telefono').value  = c.telefono  || '';
  document.getElementById('c_email').value     = c.email     || '';
  document.getElementById('c_direccion').value = c.direccion || '';
  const tieneLimit = c.limite_credito != null;
  document.getElementById('c_limite_check').checked = tieneLimit;
  toggleLimiteCredito(document.getElementById('c_limite_check'));
  if (tieneLimit) document.getElementById('c_limite_credito').value = c.limite_credito;
  const _catSelE = document.getElementById('c_categoria');
  if (_catSelE && c.categoria) _catSelE.value = c.categoria;
  document.getElementById('modalCliente').classList.add('open');
  setTimeout(() => document.getElementById('c_nombre').focus(), 80);
}

function cerrarModal() { document.getElementById('modalCliente').classList.remove('open'); }

async function guardarCliente() {
  const nombre    = document.getElementById('c_nombre').value.trim();
  const documento = document.getElementById('c_documento').value.trim();
  const telefono  = document.getElementById('c_telefono').value.trim();
  const email     = document.getElementById('c_email').value.trim();
  const direccion = document.getElementById('c_direccion').value.trim();
  const tieneLimit = document.getElementById('c_limite_check').checked;
  const limite_credito = tieneLimit ? (parseFloat(document.getElementById('c_limite_credito').value) || null) : null;
  if (!nombre) { alert('El nombre es obligatorio'); return; }
  const categoria = document.getElementById('c_categoria')?.value || null;
  const url    = _editClienteId ? `/api/clientes/${_editClienteId}` : '/api/clientes';
  const method = _editClienteId ? 'PUT' : 'POST';
  const r = await fetch(url, { method, headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ nombre, documento, telefono, email, direccion, limite_credito, categoria: categoria || null }) });
  if (!r.ok) { const e = await r.json().catch(()=>({})); alert(e.error || 'Error'); return; }
  location.reload();
}

async function eliminar(id) {
  if (!confirm('¿Eliminar cliente?')) return;
  const r = await fetch(`/api/clientes/${id}`, { method: 'DELETE' });
  if (!r.ok) { const e = await r.json().catch(()=>({})); alert(e.error || 'Error'); return; }
  location.reload();
}

/* ════════════════════════════════════
   CARGO (deuda manual)
════════════════════════════════════ */
function abrirCargo(id, nombre) {
  _cargoClienteId = id;
  document.getElementById('cargoClienteNombre').textContent = nombre;
  document.getElementById('cargo_monto').value = '';
  document.getElementById('cargo_desc').value  = '';
  document.getElementById('modalCargo').classList.add('open');
  setTimeout(() => document.getElementById('cargo_monto').focus(), 80);
}

function cerrarModalCargo() { document.getElementById('modalCargo').classList.remove('open'); }

async function confirmarCargo() {
  const monto = parseFloat(document.getElementById('cargo_monto').value);
  const desc  = document.getElementById('cargo_desc').value.trim();
  if (!monto || monto <= 0) { alert('Ingresá un monto válido'); return; }
  const r = await fetch(`/api/clientes/${_cargoClienteId}/cargo`, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ monto, descripcion: desc || 'Cargo manual' })
  });
  if (!r.ok) { const e = await r.json().catch(()=>({})); alert(e.error || 'Error'); return; }
  location.reload();
}

/* ════════════════════════════════════
   PAGO (parcial o total)
════════════════════════════════════ */
function abrirPago(id, nombre, saldo) {
  _pagoClienteId = id;
  _pagoSaldo     = Number(saldo);
  document.getElementById('pagoClienteNombre').textContent = nombre;
  document.getElementById('pagoSaldoActual').textContent   = '$' + _pagoSaldo.toFixed(2);
  document.getElementById('p_monto').value = '';
  document.getElementById('p_desc').value  = '';
  document.getElementById('restanteWrap').style.display = 'none';
  document.getElementById('modalPago').classList.add('open');
  setTimeout(() => document.getElementById('p_monto').focus(), 80);
}

function pagarTodo() {
  document.getElementById('p_monto').value = _pagoSaldo.toFixed(2);
  calcRestante();
}

function calcRestante() {
  const monto     = parseFloat(document.getElementById('p_monto').value) || 0;
  const restante  = _pagoSaldo - monto;
  const wrap      = document.getElementById('restanteWrap');
  const label     = document.getElementById('restanteLabel');
  const valor     = document.getElementById('restanteValor');

  if (monto <= 0) { wrap.style.display = 'none'; return; }

  wrap.style.display = 'flex';
  if (restante <= 0) {
    wrap.style.cssText  += ';background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);';
    label.style.color   = '#059669';
    valor.style.color   = '#059669';
    label.textContent   = 'Quedará al día ✓';
    valor.textContent   = '$0,00';
  } else {
    wrap.style.cssText  += ';background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);';
    label.style.color   = '#d97706';
    valor.style.color   = '#d97706';
    label.textContent   = 'Saldo pendiente tras el pago';
    valor.textContent   = '$' + restante.toFixed(2);
  }
}

function cerrarModalPago() { document.getElementById('modalPago').classList.remove('open'); }

async function confirmarPago() {
  const monto = parseFloat(document.getElementById('p_monto').value);
  const desc  = document.getElementById('p_desc').value.trim();
  if (!monto || monto <= 0) { alert('Ingresá un monto válido'); return; }
  const r = await fetch(`/api/clientes/${_pagoClienteId}/pago`, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ monto, descripcion: desc || 'Pago manual' })
  });
  if (!r.ok) { const e = await r.json().catch(()=>({})); alert(e.error || 'Error'); return; }
  location.reload();
}

/* ════════════════════════════════════
   MOVIMIENTOS / CUENTA CORRIENTE
════════════════════════════════════ */
async function verMovimientos(id, nombre, saldo) {
  _movId     = id;
  _movNombre = nombre;
  _movSaldo  = Number(saldo);

  document.getElementById('movClienteNombre').textContent = nombre;
  document.getElementById('movListado').innerHTML = '<p style="color:var(--text-secondary);text-align:center;padding:24px 0;">Cargando…</p>';
  document.getElementById('modalMovimientos').classList.add('open');

  // Banner de saldo
  const banner    = document.getElementById('movBanner');
  const bannerLbl = document.getElementById('movBannerLabel');
  const bannerVal = document.getElementById('movBannerValor');
  const btnCobrar = document.getElementById('movBtnCobrar');

  if (_movSaldo > 0) {
    banner.style.cssText    = 'border-radius:var(--radius-sm);padding:14px 18px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);';
    bannerLbl.style.color   = '#dc2626';
    bannerVal.style.color   = '#dc2626';
    bannerLbl.textContent   = 'Saldo deudor';
    bannerVal.textContent   = '$' + _movSaldo.toFixed(2);
    btnCobrar.style.display = 'flex';
  } else if (_movSaldo < 0) {
    banner.style.cssText    = 'border-radius:var(--radius-sm);padding:14px 18px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);';
    bannerLbl.style.color   = '#d97706';
    bannerVal.style.color   = '#d97706';
    bannerLbl.textContent   = 'Saldo a favor';
    bannerVal.textContent   = '$' + Math.abs(_movSaldo).toFixed(2);
    btnCobrar.style.display = 'none';
  } else {
    banner.style.cssText    = 'border-radius:var(--radius-sm);padding:14px 18px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);';
    bannerLbl.style.color   = '#10b981';
    bannerVal.style.color   = '#10b981';
    bannerLbl.textContent   = 'Al día';
    bannerVal.textContent   = '$0,00';
    btnCobrar.style.display = 'none';
  }

  // Cargar movimientos
  const r    = await fetch(`/api/clientes/${id}/movimientos`);
  const movs = await r.json();

  if (!movs.length) {
    document.getElementById('movListado').innerHTML =
      '<p style="color:var(--text-secondary);text-align:center;padding:24px 0;">Sin movimientos aún.</p>';
    return;
  }

  // Calcular saldo acumulado: movs viene DESC → invertir, acumular, volver a invertir
  const asc = [...movs].reverse();
  let acum = 0;
  const conAcum = asc.map(m => {
    acum += m.tipo === 'cargo' ? Number(m.monto) : -Number(m.monto);
    return { ...m, acum };
  });
  conAcum.reverse(); // más reciente arriba

  // Stats panel izquierdo
  const totalCargos = movs.filter(m=>m.tipo==='cargo').reduce((a,m)=>a+Number(m.monto),0);
