function _impCliNorm(k) {
  return k.toLowerCase().trim()
    .replace(/[áà]/g,'a').replace(/[éè]/g,'e').replace(/[íì]/g,'i')
    .replace(/[óò]/g,'o').replace(/[úù]/g,'u')
    .replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'');
}

async function impCliFileSelected(evt) {
  const file = evt.target.files[0];
  if (!file) return;
  document.getElementById('imp_cli_subtitle').textContent = 'Procesando…';
  if (typeof XLSX === 'undefined') {
    await new Promise((res,rej) => {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
      s.onload = res; s.onerror = rej; document.head.appendChild(s);
    });
  }
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const wb   = XLSX.read(e.target.result, { type:'array' });
      const ws   = wb.Sheets[wb.SheetNames[0]];
      const raw  = XLSX.utils.sheet_to_json(ws, { defval:'' });
      if (!raw.length) { alert('Archivo vacío'); return; }

      _impCliRows = raw.map(r => {
        const m = {};
        Object.keys(r).forEach(k => { m[_impCliNorm(k)] = r[k]; });
        // Mapear variantes de nombre en español
        const nombre   = String(m.nombre || m.name || m.cliente || '').trim();
        const documento= String(m.documento || m.cuit || m.dni || m.doc || '').trim();
        const telefono = String(m.telefono || m.tel || m.phone || '').trim();
        const email    = String(m.email || m.mail || m.correo || '').trim();
        const direccion= String(m.direccion || m.address || m.domicilio || '').trim();
        const limite   = parseFloat(m.limite_credito || m.limite || m.credito || '') || null;
        const err      = !nombre ? 'Nombre vacío' : '';
        return { nombre, documento, telefono, email, direccion, limite_credito: limite, _error: err };
      });

      // Mostrar preview
      const countNew = _impCliRows.filter(r => !r._error).length;
      const countErr = _impCliRows.filter(r => r._error).length;
      document.getElementById('imp_cli_countNew').textContent    = countNew + ' a importar';
      document.getElementById('imp_cli_countUpdate').textContent = '—';
      document.getElementById('imp_cli_countError').textContent  = countErr + ' errores';

      const tbody = document.getElementById('imp_cli_previewBody');
      const fmt = n => n ? '$' + Number(n).toLocaleString('es-AR') : '—';
      tbody.innerHTML = _impCliRows.map(r => {
        const badge = r._error
          ? `<span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;background:rgba(239,68,68,.1);color:#ef4444;">ERROR</span>`
          : `<span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;background:rgba(16,185,129,.1);color:#10b981;">OK</span>`;
        return `<tr style="border-bottom:1px solid var(--border-color);">
          <td style="padding:8px 12px;">${badge}${r._error ? `<span style="font-size:10px;color:#ef4444;margin-left:4px;">${r._error}</span>` : ''}</td>
          <td style="padding:8px 12px;font-weight:600;color:var(--text-primary);">${r.nombre||'—'}</td>
          <td style="padding:8px 12px;font-family:var(--font-mono);font-size:11px;color:var(--text-secondary);">${r.documento||'—'}</td>
          <td style="padding:8px 12px;color:var(--text-secondary);">${r.telefono||'—'}</td>
          <td style="padding:8px 12px;text-align:right;font-family:var(--font-mono);color:var(--color-primary);">${fmt(r.limite_credito)}</td>
        </tr>`;
      }).join('');

      const activos = _impCliRows.filter(r => !r._error).length;
      document.getElementById('imp_cli_footerInfo').textContent = `Se importarán ${activos} cliente${activos !== 1 ? 's' : ''}`;
      document.getElementById('imp_cli_subtitle').textContent   = `${_impCliRows.length} filas encontradas`;
      document.getElementById('imp_cli_step1').style.display    = 'none';
      document.getElementById('imp_cli_step2').style.display    = 'block';
      document.getElementById('imp_cli_footer').style.display   = 'flex';
    } catch(err) { console.error(err); alert('Error leyendo el archivo.'); }
  };
  reader.readAsArrayBuffer(file);
}

async function ejecutarImportacionClientes() {
  const btn   = document.getElementById('imp_cli_btnImportar');
  const label = document.getElementById('imp_cli_btnLabel');
  btn.disabled = true; label.textContent = 'Importando…';
  const rows = _impCliRows.filter(r => !r._error);
  try {
    const r = await fetch('/api/clientes/importar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rows })
    });
    const res = await r.json();
    cerrarImportarClientes();
    alert(`✅ Importación completada:\n• ${res.creados} creados\n• ${res.actualizados} actualizados${res.errores ? `\n• ${res.errores} errores` : ''}`);
    location.reload();
  } catch(e) {
    btn.disabled = false; label.textContent = 'Importar';
    alert('Error al importar: ' + e.message);
  }
}

function descargarPlantillaClientes() {
  const generar = () => {
