        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <button onclick="exportarEstadoCuenta('pdf')"
          style="display:flex;align-items:center;gap:5px;padding:7px 12px;border-radius:var(--radius-sm);border:1.5px solid rgba(99,102,241,.4);background:rgba(99,102,241,.07);color:#4f46e5;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
          <i class="bi bi-printer"></i> Imprimir
