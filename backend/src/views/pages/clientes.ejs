        <button onclick="exportarEstadoCuenta('csv')"
          style="display:flex;align-items:center;gap:5px;padding:7px 12px;border-radius:var(--radius-sm);border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
