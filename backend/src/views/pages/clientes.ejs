/* ════════════════════════════════════
   FILTRO LOCAL
════════════════════════════════════ */
let _filtroActivo = 'todos';

function setFiltro(btn) {
  document.querySelectorAll('.filtro-chip').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  _filtroActivo = btn.dataset.filtro;
  filtrar();
}

let _filtrarTimer = null;
function filtrar() {
  clearTimeout(_filtrarTimer);
  _filtrarTimer = setTimeout(_filtrarNow, 80);
}
function _filtrarNow() {
  const q        = (document.getElementById('q')?.value || '').toLowerCase();
  const orden    = document.getElementById('ordenSelect')?.value || 'nombre';
  const catFiltro = document.getElementById('categoriaSelect')?.value || '';
  const rows     = [...document.querySelectorAll('#tablaClientes tbody tr')];

  rows.forEach(tr => {
    const nombre   = tr.querySelector('td:nth-child(2)')?.innerText.toLowerCase() || '';
    const doc      = tr.querySelector('td:nth-child(3)')?.innerText.toLowerCase() || '';
    // Categoría está en columna 4, saldo en columna 5
    const catTxt   = tr.querySelector('td:nth-child(4)')?.innerText.trim() || '';
    const saldoTxt = tr.querySelector('td:nth-child(5)')?.innerText || '';
    const debe     = saldoTxt.toLowerCase().includes('debe');
    const alDia    = saldoTxt.toLowerCase().includes('al día') || saldoTxt.trim() === '—';

    const matchQ   = !q || nombre.includes(q) || doc.includes(q);
    const matchF   = _filtroActivo === 'todos' ||
                     (_filtroActivo === 'deudores' && debe) ||
                     (_filtroActivo === 'al-dia' && alDia);
    const matchCat = !catFiltro || catTxt === catFiltro;
    tr.style.display = (matchQ && matchF && matchCat) ? '' : 'none';
  });

  // Ordenar
  const tbody = document.querySelector('#tablaClientes tbody');
  const visible = rows.filter(tr => tr.style.display !== 'none');
  visible.sort((a, b) => {
    if (orden === 'nombre') {
      return (a.querySelector('td:nth-child(2)')?.innerText || '').localeCompare(
             b.querySelector('td:nth-child(2)')?.innerText || '');
    }
    const getSaldo = tr => {
      const t = tr.querySelector('td:nth-child(5)')?.innerText || '';
      const m = t.match(/[\d.,]+/);
      const v = m ? parseFloat(m[0].replace(/\./g,'').replace(',','.')) : 0;
      return t.toLowerCase().includes('debe') ? v : -v;
    };
    return orden === 'mayor-deuda'
      ? getSaldo(b) - getSaldo(a)
      : getSaldo(a) - getSaldo(b);
  });
  visible.forEach(tr => tbody.appendChild(tr));
}

