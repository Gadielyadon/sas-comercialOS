   CATEGORÍAS DE CLIENTES
════════════════════════════════════ */
const _CATS_KEY = 'axsoft_clientes_cats';

function _getCats() {
  try { return JSON.parse(localStorage.getItem(_CATS_KEY) || '[]'); } catch(e) { return []; }
}

function _saveCats(cats) {
  localStorage.setItem(_CATS_KEY, JSON.stringify([...new Set(cats.filter(Boolean))]));
}

function _renderCatSelects() {
  const cats = _getCats();
  const selModal  = document.getElementById('c_categoria');
  const selFiltro = document.getElementById('categoriaSelect');
  if (selModal) {
    const cur = selModal.value;
    selModal.innerHTML = '<option value="">Sin categoría</option>' +
      cats.map(c => `<option value="${c}">${c}</option>`).join('');
    if (cur) selModal.value = cur;
  }
  if (selFiltro) {
    const cur = selFiltro.value;
    selFiltro.innerHTML = '<option value="">Todas las categorías</option>' +
      cats.map(c => `<option value="${c}">${c}</option>`).join('');
    if (cur) selFiltro.value = cur;
  }
}

function abrirNuevaCat() {
  const wrap = document.getElementById('nuevaCatWrap');
  if (wrap) {
    wrap.style.display = wrap.style.display === 'none' ? 'flex' : 'none';
    if (wrap.style.display === 'flex') setTimeout(() => document.getElementById('nuevaCatInput')?.focus(), 80);
  }
}

function guardarNuevaCat() {
  const input = document.getElementById('nuevaCatInput');
  const val   = input?.value.trim();
  if (!val) return;
  const cats = _getCats();
  if (!cats.includes(val)) { cats.push(val); _saveCats(cats); }
  _renderCatSelects();
  const sel = document.getElementById('c_categoria');
  if (sel) sel.value = val;
  if (input) input.value = '';
  const wrap = document.getElementById('nuevaCatWrap');
  if (wrap) wrap.style.display = 'none';
}

// También cargar categorías que ya existen en los clientes actuales
(function() {
  const clientes = <%- JSON.stringify(clientes || []) %>;
  const existentes = [...new Set(clientes.map(c => c.categoria).filter(Boolean))];
  const guardadas  = _getCats();
  const merged     = [...new Set([...guardadas, ...existentes])].sort();
  _saveCats(merged);
