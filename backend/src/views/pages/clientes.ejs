<div class="sale-overlay" id="modalPago" onclick="if(event.target.id==='modalPago')cerrarModalPago()">
  <div class="sale-modal" style="max-width:400px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
