<%- include('../partials/head', { title: 'Proveedores' }) %>
<style>
.filtro-chip { padding:5px 12px;border-radius:6px;border:none;background:transparent;color:var(--text-secondary);font-size:12.5px;font-weight:600;cursor:pointer;transition:all .15s;font-family:var(--font-body); }
.filtro-chip:hover { background:var(--bg-body);color:var(--text-primary); }
.filtro-chip.on    { background:var(--color-action);color:#fff; }
.form-lbl { font-size:11px;font-weight:600;color:var(--text-secondary);letter-spacing:.5px;text-transform:uppercase;display:block;margin-bottom:5px; }
.form-input { width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;font-family:var(--font-body); }
.form-input:focus { border-color:var(--color-action); }
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'proveedores', user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module: 'Proveedores', user }) %>
    <main class="page-body">

      <div class="page-header">
        <div class="page-header-title">
          <h2>Proveedores</h2>
          <p>Gestión de proveedores y cuentas a pagar.</p>
        </div>
        <button class="btn-action btn-action-primary" onclick="abrirNuevo()">
          <i class="bi bi-truck"></i> Nuevo Proveedor
        </button>
      </div>

      <!-- Resumen rápido -->
      <div id="resumenProveedores" style="display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap;"></div>

      <!-- Toolbar -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:18px;">
        <div class="search-input-wrap" style="flex:1;min-width:200px;max-width:320px">
          <i class="bi bi-search"></i>
          <input id="q" class="search-input" placeholder="Buscar por nombre, CUIT o rubro…" oninput="filtrar()">
        </div>
        <div style="display:flex;gap:5px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:4px;">
          <button class="filtro-chip on" data-f="todos"    onclick="setFiltro(this)">Todos</button>
          <button class="filtro-chip"    data-f="deudores" onclick="setFiltro(this)"><i class="bi bi-exclamation-circle" style="color:#ef4444;margin-right:4px;"></i>Con deuda</button>
          <button class="filtro-chip"    data-f="ok"       onclick="setFiltro(this)"><i class="bi bi-check-circle" style="color:#10b981;margin-right:4px;"></i>Al día</button>
        </div>
        <select id="ordenSelect" onchange="filtrar()" class="filter-select" style="padding:8px 28px 8px 12px;font-size:12.5px;">
          <option value="nombre">Ordenar: A → Z</option>
          <option value="mayor-deuda">Mayor deuda primero</option>
        </select>
        <div style="display:flex;gap:6px;margin-left:auto;">
          <button onclick="exportarCSV()" style="display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:var(--radius-sm);border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:12.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
            <i class="bi bi-filetype-csv"></i> CSV
          </button>
        </div>
      </div>

      <!-- Tabla -->
      <div class="card-panel">
        <div class="card-panel-body">
          <table class="sales-table" id="tablaProveedores">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>CUIT</th>
                <th>Rubro</th>
                <th>Teléfono</th>
                <th>Saldo (debo)</th>
                <th style="width:260px">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% (proveedores||[]).forEach(p => { %>
              <tr data-id="<%= p.id %>">
                <td><strong><%= p.nombre %></strong><% if(p.notas){%><div style="font-size:11px;color:var(--text-secondary);margin-top:1px;"><%= p.notas.slice(0,40) %></div><%}%></td>
                <td style="font-family:var(--font-mono);color:var(--text-secondary);"><%= p.cuit||'—' %></td>
                <td style="color:var(--text-secondary);"><%= p.rubro||'—' %></td>
                <td style="color:var(--text-secondary);"><%= p.telefono||'—' %></td>
                <td>
                  <% if(p.saldo>0){ %><span class="badge-status badge-anulado">Debo $<%= Number(p.saldo).toLocaleString('es-AR',{minimumFractionDigits:2}) %></span>
                  <% } else { %><span class="badge-status badge-pagado">Al día</span><% } %>
                </td>
                <td>
                  <div style="display:flex;gap:5px;flex-wrap:wrap;align-items:center;">
                    <button class="btn-action btn-action-outline btn-sm"
                      onclick="verCuenta(<%= p.id %>, this.dataset.nombre, <%= p.saldo %>)"
                      data-nombre="<%= p.nombre %>">
                      <i class="bi bi-clock-history"></i> Cuenta
                    </button>
                      <i class="bi bi-clock-history"></i> Cuenta
                    </button>
                    <button class="btn-action btn-action-outline btn-sm"
                      onclick="abrirFactura(<%= p.id %>, this.dataset.nombre)"
                      data-nombre="<%= p.nombre %>"
                      style="color:#d97706;border-color:rgba(217,119,6,.3);">
                      <i class="bi bi-receipt"></i> Factura
                    </button>
                      <i class="bi bi-receipt"></i> Factura
                    </button>
                    <% if(p.saldo>0){ %>
                    <button class="btn-action btn-action-primary btn-sm"
                      onclick="abrirPago(<%= p.id %>, this.dataset.nombre, <%= p.saldo %>)"
                      data-nombre="<%= p.nombre %>">
                      <i class="bi bi-cash"></i> Pagar
                    </button>
                      <i class="bi bi-cash"></i> Pagar
                    </button>
                    <% } %>
                    <button class="btn-action btn-action-outline btn-sm" onclick="abrirEditar(<%- JSON.stringify(p) %>)" style="color:var(--color-action);border-color:rgba(0,180,216,.3);"><i class="bi bi-pencil"></i></button>
                    <button class="btn-action btn-action-ghost btn-sm" onclick="eliminar(<%= p.id %>)"><i class="bi bi-trash3"></i></button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<!-- MODAL NUEVO/EDITAR -->
<div class="sale-overlay" id="modalProv" onclick="if(event.target.id==='modalProv')cerrarModal()">
  <div class="sale-modal" style="max-width:520px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--color-action),#0099b8);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;"><i class="bi bi-truck"></i></div>
        <div>
          <div style="font-size:15px;font-weight:700;color:var(--text-primary);" id="modalProvTitulo">Nuevo Proveedor</div>
          <div style="font-size:11px;color:var(--text-secondary);">Datos del proveedor</div>
        </div>
      </div>
      <button onclick="cerrarModal()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="grid-column:1/-1">
        <label class="form-lbl">Nombre *</label>
        <input type="text" id="p_nombre" class="form-input" placeholder="Nombre o razón social">
      </div>
      <div>
        <label class="form-lbl">CUIT / RUT</label>
        <input type="text" id="p_cuit" class="form-input" placeholder="Opcional">
      </div>
      <div>
        <label class="form-lbl">Rubro</label>
        <input type="text" id="p_rubro" class="form-input" placeholder="Ej: Mayorista, Servicios...">
      </div>
      <div>
        <label class="form-lbl">Teléfono</label>
        <input type="text" id="p_telefono" class="form-input" placeholder="Opcional">
      </div>
      <div>
        <label class="form-lbl">Email</label>
        <input type="email" id="p_email" class="form-input" placeholder="Opcional">
      </div>
      <div style="grid-column:1/-1">
        <label class="form-lbl">Notas</label>
        <textarea id="p_notas" class="form-input" rows="2" placeholder="Condiciones de pago, datos extra..."></textarea>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:18px;">
      <button onclick="guardar()" class="btn-action btn-action-primary" style="flex:1;justify-content:center;padding:10px;">
        <i class="bi bi-check-lg"></i> <span id="btnProvTxt">Guardar</span>
      </button>
      <button onclick="cerrarModal()" class="btn-action btn-action-outline" style="padding:10px 16px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- MODAL CARGAR FACTURA -->
<div class="sale-overlay" id="modalFactura" onclick="if(event.target.id==='modalFactura')document.getElementById('modalFactura').classList.remove('open')">
  <div class="sale-modal" style="max-width:420px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;"><i class="bi bi-receipt"></i></div>
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--text-primary);">Registrar Factura</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="facturaProvNombre">—</div>
        </div>
      </div>
      <button onclick="document.getElementById('modalFactura').classList.remove('open')" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label class="form-lbl">Monto ($) *</label>
          <input type="number" id="f_monto" class="form-input" placeholder="0.00" min="0.01" step="0.01" style="font-size:18px;font-weight:700;">
        </div>
        <div>
          <label class="form-lbl">N° Factura</label>
          <input type="text" id="f_nro" class="form-input" placeholder="Ej: A-0001">
        </div>
      </div>
      <div>
        <label class="form-lbl">Descripción</label>
        <input type="text" id="f_desc" class="form-input" placeholder="Ej: Mercadería semana 1, Servicio X...">
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:16px;">
      <button onclick="confirmarFactura()" style="flex:1;padding:10px;background:#f59e0b;color:#fff;border:none;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;font-family:var(--font-body);">
        <i class="bi bi-receipt"></i> Registrar factura
      </button>
      <button onclick="document.getElementById('modalFactura').classList.remove('open')" class="btn-action btn-action-outline" style="padding:10px 16px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- MODAL PAGO -->
<div class="sale-overlay" id="modalPagoP" onclick="if(event.target.id==='modalPagoP')document.getElementById('modalPagoP').classList.remove('open')">
  <div class="sale-modal" style="max-width:380px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;"><i class="bi bi-cash-stack"></i></div>
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--text-primary);">Registrar Pago</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="pagoProvNombre">—</div>
        </div>
      </div>
      <button onclick="document.getElementById('modalPagoP').classList.remove('open')" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:14px;display:flex;justify-content:space-between;">
      <span style="font-size:12px;color:#dc2626;font-weight:600;">Deuda actual</span>
      <span style="font-family:var(--font-mono);font-size:17px;font-weight:800;color:#dc2626;" id="pagoProvSaldo">$0</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div>
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <label class="form-lbl" style="margin:0;">Monto a pagar ($)</label>
          <button onclick="pagarTodo()" style="font-size:11px;font-weight:600;color:var(--color-action);background:rgba(0,180,216,.1);border:none;border-radius:5px;padding:2px 8px;cursor:pointer;">Pagar todo</button>
        </div>
        <input type="number" id="pp_monto" class="form-input" placeholder="0.00" min="0.01" step="0.01" style="font-size:18px;font-weight:700;" oninput="calcResto()">
      </div>
      <div id="restoWrap" style="display:none;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid rgba(245,158,11,.25);background:rgba(245,158,11,.08);">
        <span style="font-size:12px;font-weight:600;color:#d97706;" id="restoLabel">Saldo restante</span>
        <span style="float:right;font-family:var(--font-mono);font-size:14px;font-weight:700;color:#d97706;" id="restoValor">$0</span>
      </div>
      <div>
        <label class="form-lbl">Descripción</label>
        <input type="text" id="pp_desc" class="form-input" placeholder="Ej: Transferencia, efectivo...">
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:16px;">
      <button onclick="confirmarPago()" style="flex:1;padding:10px;background:#10b981;color:#fff;border:none;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;font-family:var(--font-body);">
        <i class="bi bi-check-circle-fill"></i> Confirmar pago
      </button>
      <button onclick="document.getElementById('modalPagoP').classList.remove('open')" class="btn-action btn-action-outline" style="padding:10px 16px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- MODAL CUENTA CORRIENTE PROVEEDOR -->
