  _factId=id; _factNombre=nombre;
  document.getElementById('facturaProvNombre').textContent=nombre;
  document.getElementById('f_monto').value='';
  document.getElementById('f_nro').value='';
  document.getElementById('f_desc').value='';
  document.getElementById('modalFactura').classList.add('open');
  setTimeout(()=>document.getElementById('f_monto').focus(),80);
}
async function confirmarFactura(){
  const monto=parseFloat(document.getElementById('f_monto').value);
  if(!monto||monto<=0){alert('Ingresá un monto válido');return;}
  const r=await fetch(`/proveedores/api/${_factId}/factura`,{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({monto,nro_factura:document.getElementById('f_nro').value.trim(),descripcion:document.getElementById('f_desc').value.trim()||'Factura'})});
  if(!r.ok){const e=await r.json().catch(()=>({}));alert(e.error||'Error');return;}
  document.getElementById('modalFactura').classList.remove('open');
  location.reload();
}

// ── Pago ──
function abrirPago(id,nombre,saldo){
  _pagoId=id; _pagoNombre=nombre; _pagoSaldo=Number(saldo);
  document.getElementById('pagoProvNombre').textContent=nombre;
  document.getElementById('pagoProvSaldo').textContent='$'+_pagoSaldo.toLocaleString('es-AR',{minimumFractionDigits:2});
  document.getElementById('pp_monto').value='';
  document.getElementById('pp_desc').value='';
  document.getElementById('restoWrap').style.display='none';
  document.getElementById('modalPagoP').classList.add('open');
  setTimeout(()=>document.getElementById('pp_monto').focus(),80);
}
function pagarTodo(){ document.getElementById('pp_monto').value=_pagoSaldo.toFixed(2); calcResto(); }
function calcResto(){
  const m=parseFloat(document.getElementById('pp_monto').value)||0;
  const resto=_pagoSaldo-m;
  const wrap=document.getElementById('restoWrap');
  if(m<=0){wrap.style.display='none';return;}
  wrap.style.display='block';
  if(resto<=0){document.getElementById('restoLabel').textContent='Quedará al día ✓';document.getElementById('restoValor').textContent='$0';}
  else{document.getElementById('restoLabel').textContent='Saldo restante';document.getElementById('restoValor').textContent='$'+resto.toLocaleString('es-AR',{minimumFractionDigits:2});}
}
async function confirmarPago(){
  const monto=parseFloat(document.getElementById('pp_monto').value);
  if(!monto||monto<=0){alert('Ingresá un monto válido');return;}
  const r=await fetch(`/proveedores/api/${_pagoId}/pago`,{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({monto,descripcion:document.getElementById('pp_desc').value.trim()||'Pago'})});
  if(!r.ok){const e=await r.json().catch(()=>({}));alert(e.error||'Error');return;}
  document.getElementById('modalPagoP').classList.remove('open');
  location.reload();
}

// ── Cuenta corriente ──
async function verCuenta(id,nombre,saldo){
  _cPId=id; _cPNombre=nombre; _cPSaldo=Number(saldo);
  document.getElementById('cuentaPNombre').textContent=nombre;
  document.getElementById('cuentaPListado').innerHTML='<p style="color:var(--text-secondary);text-align:center;padding:32px;">Cargando…</p>';
  document.getElementById('modalCuentaP').classList.add('open');

  // Banner
  const banner=document.getElementById('cuentaPBanner');
  const label=document.getElementById('cuentaPLabel');
  const valor=document.getElementById('cuentaPValor');
  const btnPagar=document.getElementById('cuentaPBtnPagar');
  if(_cPSaldo>0){
    banner.style.cssText='border-radius:var(--radius-md);padding:14px;text-align:center;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);';
    label.style.color='#dc2626'; valor.style.color='#dc2626';
    label.textContent='Debo'; valor.textContent='$'+_cPSaldo.toLocaleString('es-AR',{minimumFractionDigits:2});
    btnPagar.style.display='flex';
  } else {
    banner.style.cssText='border-radius:var(--radius-md);padding:14px;text-align:center;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);';
    label.style.color='#10b981'; valor.style.color='#10b981';
    label.textContent='Al día'; valor.textContent='$0';
    btnPagar.style.display='none';
  }

  const r=await fetch(`/proveedores/api/${id}/movs`);
  const movs=await r.json();

  // Stats
  const facturas=movs.filter(m=>m.tipo==='factura').reduce((a,m)=>a+Number(m.monto),0);
  const pagos=movs.filter(m=>m.tipo==='pago').reduce((a,m)=>a+Number(m.monto),0);
  document.getElementById('cuentaPStats').innerHTML=`
    <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-sm);padding:12px;">
      <div style="font-size:10.5px;font-weight:700;text-transform:uppercase;color:var(--text-secondary);margin-bottom:8px;">Resumen</div>
      <div style="display:flex;flex-direction:column;gap:5px;font-size:12.5px;">
        <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Facturas</span><span style="font-family:var(--font-mono);font-weight:700;color:#dc2626;">+$${facturas.toLocaleString('es-AR',{minimumFractionDigits:2})}</span></div>
        <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Pagos</span><span style="font-family:var(--font-mono);font-weight:700;color:#10b981;">-$${pagos.toLocaleString('es-AR',{minimumFractionDigits:2})}</span></div>
        <div style="border-top:1px dashed var(--border-color);padding-top:5px;display:flex;justify-content:space-between;"><span style="color:var(--text-secondary);">Movimientos</span><span style="font-weight:700;">${movs.length}</span></div>
      </div>
    </div>`;
  document.getElementById('cuentaPTotal').textContent=`${movs.length} movimiento${movs.length!==1?'s':''}`;

  if(!movs.length){
    document.getElementById('cuentaPListado').innerHTML='<p style="color:var(--text-secondary);text-align:center;padding:32px;">Sin movimientos aún.</p>';
    return;
  }

  document.getElementById('cuentaPListado').innerHTML=movs.map(m=>{
    const esFact=m.tipo==='factura';
    const color=esFact?'#dc2626':'#10b981';
    const bg=esFact?'rgba(239,68,68,.04)':'rgba(16,185,129,.04)';
    const borde=esFact?'rgba(239,68,68,.15)':'rgba(16,185,129,.15)';
    const icono=esFact?'bi-receipt':'bi-cash-stack';
    const signo=esFact?'+':'-';
    const desc=m.descripcion||(esFact?'Factura':'Pago');
    const fecha=(m.created_at||'').slice(0,16).replace('T',' ');
    const [fp,hp]=fecha.split(' ');
    return `<div style="display:flex;align-items:center;gap:12px;padding:12px 14px;background:${bg};border-radius:10px;border:1px solid ${borde};">
      <i class="bi ${icono}" style="font-size:22px;color:${color};flex-shrink:0;"></i>
      <div style="flex:1;min-width:0;">
        <div style="font-size:13.5px;font-weight:700;color:var(--text-primary);margin-bottom:3px;">${desc}${m.nro_factura?` <span style="font-size:11px;font-family:var(--font-mono);color:var(--text-secondary);">#${m.nro_factura}</span>`:''}</div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
          <span style="font-size:11.5px;color:var(--text-secondary);"><i class="bi bi-calendar3" style="font-size:10px;"></i> ${fp}</span>
          <span style="font-size:11.5px;color:var(--text-secondary);"><i class="bi bi-clock" style="font-size:10px;"></i> ${hp}</span>
          <span style="font-size:11px;font-weight:600;color:${Number(m.saldo_post)>0?'#dc2626':'#10b981'};background:${Number(m.saldo_post)>0?'rgba(239,68,68,.1)':'rgba(16,185,129,.1)'};padding:1px 7px;border-radius:20px;">
            Saldo $${Number(m.saldo_post).toLocaleString('es-AR',{minimumFractionDigits:2})}
          </span>
        </div>
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <div style="font-family:var(--font-mono);font-size:17px;font-weight:800;color:${color};">${signo}$${Number(m.monto).toLocaleString('es-AR',{minimumFractionDigits:2})}</div>
        <div style="font-size:10.5px;color:var(--text-secondary);margin-top:1px;">${m.tipo}</div>
      </div>
    </div>`;
  }).join('');
}
function cerrarCuenta(){ document.getElementById('modalCuentaP').classList.remove('open'); }

function exportarCSV(){
  const rows=[...document.querySelectorAll('#tablaProveedores tbody tr')].filter(r=>r.style.display!=='none');
  let csv='\uFEFFNombre;CUIT;Rubro;Teléfono;Saldo\n';
  rows.forEach(r=>{
    const t=r.querySelectorAll('td');
    csv+=[t[0]?.innerText.trim(),t[1]?.innerText,t[2]?.innerText,t[3]?.innerText,t[4]?.innerText.trim()].join(';')+'\n';
  });
  const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'})),download:'proveedores.csv'});
  a.click();
}

document.addEventListener('keydown',e=>{if(e.key==='Escape'){cerrarModal();cerrarCuenta();document.getElementById('modalFactura').classList.remove('open');document.getElementById('modalPagoP').classList.remove('open');}});
</script>
