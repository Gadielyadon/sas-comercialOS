  <div style="width:100%;max-width:860px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-lg);box-shadow:0 20px 60px rgba(0,0,0,.2);animation:modalPop .16s ease;max-height:90vh;display:flex;flex-direction:column;overflow:hidden;">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 22px;border-bottom:1px solid var(--border-color);flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--color-action),#0099b8);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;"><i class="bi bi-truck"></i></div>
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--text-primary);">Cuenta Corriente — Proveedor</div>
          <div style="font-size:12px;color:var(--text-secondary);" id="cuentaPNombre">—</div>
        </div>
      </div>
      <button onclick="cerrarCuenta()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="display:grid;grid-template-columns:240px 1fr;flex:1;overflow:hidden;">
      <div style="padding:16px;border-right:1px solid var(--border-color);overflow-y:auto;background:var(--bg-body);display:flex;flex-direction:column;gap:12px;">
        <div id="cuentaPBanner" style="border-radius:var(--radius-md);padding:14px;text-align:center;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;opacity:.75;margin-bottom:6px;" id="cuentaPLabel">Deuda</div>
          <div style="font-size:30px;font-weight:800;font-family:var(--font-mono);letter-spacing:-1.5px;" id="cuentaPValor">$0</div>
        </div>
        <div id="cuentaPStats"></div>
        <div style="margin-top:auto;display:flex;flex-direction:column;gap:7px;">
          <button onclick="cerrarCuenta();setTimeout(()=>abrirFactura(_cPId,_cPNombre),80)" style="width:100%;padding:9px;border-radius:var(--radius-sm);border:1.5px solid #f59e0b;background:rgba(245,158,11,.1);color:#92400e;font-size:12.5px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:var(--font-body);">
            <i class="bi bi-receipt"></i> Cargar factura
          </button>
          <button id="cuentaPBtnPagar" onclick="cerrarCuenta();setTimeout(()=>abrirPago(_cPId,_cPNombre,_cPSaldo),80)" style="width:100%;padding:9px;border-radius:var(--radius-sm);border:none;background:#10b981;color:#fff;font-size:12.5px;font-weight:700;cursor:pointer;display:none;align-items:center;justify-content:center;gap:6px;font-family:var(--font-body);">
            <i class="bi bi-cash-stack"></i> Registrar pago
          </button>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;overflow:hidden;">
        <div style="padding:10px 16px;border-bottom:1px solid var(--border-color);flex-shrink:0;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text-secondary);">Historial</span>
          <span style="font-size:11.5px;color:var(--text-secondary);" id="cuentaPTotal">—</span>
        </div>
        <div style="flex:1;overflow-y:auto;padding:10px;display:flex;flex-direction:column;gap:6px;" id="cuentaPListado">
          <p style="color:var(--text-secondary);text-align:center;padding:32px;">Cargando…</p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
'use strict';
let _editId=null, _factId=null, _factNombre='', _pagoId=null, _pagoNombre='', _pagoSaldo=0;
let _cPId=null, _cPNombre='', _cPSaldo=0;
let _filtroActivo='todos';

// ── Resumen ──
(function(){
  const proveedores = <%- JSON.stringify(proveedores||[]) %>;
  const conDeuda = proveedores.filter(p=>p.saldo>0);
  const totalDeuda = conDeuda.reduce((a,p)=>a+Number(p.saldo),0);
  const el = document.getElementById('resumenProveedores');
  if(!el) return;
  const s=(icon,label,val,color)=>`<div style="display:flex;align-items:center;gap:10px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:10px 14px;">
    <i class="bi ${icon}" style="font-size:18px;color:${color};"></i>
    <div><div style="font-size:11px;color:var(--text-secondary);">${label}</div><div style="font-size:14px;font-weight:700;color:var(--text-primary);">${val}</div></div></div>`;
  el.innerHTML =
    s('bi-truck','Total proveedores',proveedores.length,'var(--color-action)')+
    s('bi-exclamation-circle','Con deuda',conDeuda.length,'#ef4444')+
    s('bi-cash-stack','Deuda total','$'+totalDeuda.toLocaleString('es-AR',{minimumFractionDigits:2}),'#dc2626');
})();

// ── Filtros ──
function setFiltro(btn) {
  document.querySelectorAll('.filtro-chip').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); _filtroActivo=btn.dataset.f; filtrar();
}
function filtrar() {
  const q=(document.getElementById('q')?.value||'').toLowerCase();
  const orden=document.getElementById('ordenSelect')?.value||'nombre';
  const rows=[...document.querySelectorAll('#tablaProveedores tbody tr')];
  rows.forEach(tr=>{
    const nombre=tr.querySelector('td')?.innerText.toLowerCase()||'';
    const saldoTxt=tr.querySelector('td:nth-child(5)')?.innerText||'';
    const debe=saldoTxt.toLowerCase().includes('debo');
    const matchQ=!q||nombre.includes(q)||tr.innerText.toLowerCase().includes(q);
    const matchF=_filtroActivo==='todos'||(_filtroActivo==='deudores'&&debe)||(_filtroActivo==='ok'&&!debe);
    tr.style.display=(matchQ&&matchF)?'':'none';
  });
  const tbody=document.querySelector('#tablaProveedores tbody');
  const vis=rows.filter(r=>r.style.display!=='none');
  if(orden==='mayor-deuda') vis.sort((a,b)=>{
    const g=tr=>{const t=tr.querySelector('td:nth-child(5)')?.innerText||'';const m=t.match(/[\d.]+/);return m?parseFloat(m[0].replace(/\./g,'')):0;};
    return g(b)-g(a);
  });
  vis.forEach(r=>tbody.appendChild(r));
}

// ── CRUD Proveedor ──
function abrirNuevo(){
  _editId=null;
  document.getElementById('modalProvTitulo').textContent='Nuevo Proveedor';
  document.getElementById('btnProvTxt').textContent='Guardar';
  ['p_nombre','p_cuit','p_rubro','p_telefono','p_email','p_notas'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  document.getElementById('modalProv').classList.add('open');
  setTimeout(()=>document.getElementById('p_nombre').focus(),80);
}
function abrirEditar(p){
  _editId=p.id;
  document.getElementById('modalProvTitulo').textContent='Editar Proveedor';
  document.getElementById('btnProvTxt').textContent='Guardar cambios';
  document.getElementById('p_nombre').value=p.nombre||'';
  document.getElementById('p_cuit').value=p.cuit||'';
  document.getElementById('p_rubro').value=p.rubro||'';
  document.getElementById('p_telefono').value=p.telefono||'';
  document.getElementById('p_email').value=p.email||'';
  document.getElementById('p_notas').value=p.notas||'';
  document.getElementById('modalProv').classList.add('open');
  setTimeout(()=>document.getElementById('p_nombre').focus(),80);
}
function cerrarModal(){ document.getElementById('modalProv').classList.remove('open'); }
async function guardar(){
  const nombre=document.getElementById('p_nombre').value.trim();
  if(!nombre){alert('El nombre es obligatorio');return;}
  const body={nombre,cuit:document.getElementById('p_cuit').value.trim(),rubro:document.getElementById('p_rubro').value.trim(),
    telefono:document.getElementById('p_telefono').value.trim(),email:document.getElementById('p_email').value.trim(),
    notas:document.getElementById('p_notas').value.trim()};
  const url=_editId?`/proveedores/api/${_editId}`:'/proveedores/api';
  const method=_editId?'PUT':'POST';
  const r=await fetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(!r.ok){const e=await r.json().catch(()=>({}));alert(e.error||'Error');return;}
  location.reload();
}
async function eliminar(id){
  if(!confirm('¿Eliminar proveedor y todo su historial?'))return;
  await fetch(`/proveedores/api/${id}`,{method:'DELETE'});
  location.reload();
}

// ── Factura ──
