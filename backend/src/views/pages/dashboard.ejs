<%- include('../partials/head', { title }) %>

<style>
.dash-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 14px;
  overflow: hidden;
}
.dash-card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border-color);
}
.dash-card-title {
  font-size: 13px; font-weight: 700; color: var(--text-primary);
  display: flex; align-items: center; gap: 7px;
}
.stat-chip {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 16px 18px;
  display: flex; flex-direction: column; gap: 6px;
  position: relative; overflow: hidden;
}
.stat-chip::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  border-radius: 12px 12px 0 0;
}
.stat-chip.cyan::before    { background: var(--color-action); }
.stat-chip.indigo::before  { background: #6366f1; }
.stat-chip.green::before   { background: #10b981; }
.stat-chip.red::before     { background: #ef4444; }
.stat-chip.orange::before  { background: #f59e0b; }
.stat-chip-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-secondary); }
.stat-chip-value { font-size: 24px; font-weight: 800; color: var(--text-primary); letter-spacing: -1px; line-height: 1; }
.stat-chip-sub   { font-size: 12px; color: var(--text-secondary); }

/* Rentabilidad widget */
.rentab-bar { height: 8px; border-radius: 4px; background: var(--border-color); overflow: hidden; margin-top: 6px; }
.rentab-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }

/* Alerta stock */
.stock-alert-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 18px;
  border-bottom: 1px solid var(--border-color);
  font-size: 13px;
}
.stock-alert-item:last-child { border-bottom: none; }

@keyframes spin { to { transform: rotate(360deg); } }
.fila-venta:hover td { background: rgba(0,0,0,.02); }
.th-v {
  padding: 10px 14px;
  font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .5px;
  color: var(--text-secondary);
  text-align: left;
}
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active, user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module, user }) %>

    <main class="page-body" style="padding:20px 24px;max-width:1400px;margin:0 auto;">

      <!-- ══ HEADER ROW ══ -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:22px;">
        <div>
          <h2 style="font-size:20px;font-weight:800;color:var(--text-primary);margin:0 0 3px;">
            Bienvenido, <%= user?.name || 'Admin' %> 👋
          </h2>
          <p style="font-size:13px;color:var(--text-secondary);margin:0;" id="fechaHoy"></p>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <% if (cajaActual) { %>
          <a href="/caja/turno"
            style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:var(--radius-md);background:rgba(16,185,129,.1);border:1.5px solid rgba(16,185,129,.3);color:#065f46;font-size:13px;font-weight:700;text-decoration:none;">
            <span style="width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 6px #10b981;"></span>
            Caja abierta — Ver turno
          </a>
          <% } else { %>
          <a href="/caja/abrir"
            style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:var(--radius-md);background:var(--bg-card);border:1.5px solid var(--border-color);color:var(--text-secondary);font-size:13px;font-weight:600;text-decoration:none;">
            <i class="bi bi-cash-coin"></i> Abrir caja
          </a>
          <% } %>
        </div>
      </div>

      <!-- ══ STATS HOY (4 chips) ══ -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px;margin-bottom:20px;">
        <% for (let si = 0; si < stats.length; si++) {
          const s = stats[si]; const i = si;
          const colors = ['cyan','indigo','green','orange'];
          const iconColors = ['var(--color-action)','#6366f1','#10b981','#f59e0b'];
        %>
        <div class="stat-chip <%= colors[i] || 'cyan' %>">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <span class="stat-chip-label"><%= s.label %></span>
            <i class="bi <%= s.icon %>" style="font-size:16px;color:<%= iconColors[i]||'var(--color-action)' %>;opacity:.8;"></i>
          </div>
          <div class="stat-chip-value"><%= s.value %></div>
          <div class="stat-chip-sub"><%= s.trend %></div>
        </div>
        <% } %>
      </div>

      <!-- ══ WIDGET RENTABILIDAD (fila completa) ══ -->
      <%
        const vm  = ventasMes?.total   || 0;
        const gm  = gastosMes?.total   || 0;
        const gan = vm - gm;
        const pct = vm > 0 ? Math.round((gan / vm) * 100) : 0;
        const rentColor    = gan >= 0 ? '#10b981' : '#ef4444';
        const rentColorBg  = gan >= 0 ? 'rgba(16,185,129,.12)' : 'rgba(239,68,68,.12)';
        const rentBg       = gan >= 0 ? 'rgba(16,185,129,.07)' : 'rgba(239,68,68,.07)';
        const rentBorde    = gan >= 0 ? 'rgba(16,185,129,.2)'  : 'rgba(239,68,68,.2)';
        const barW         = vm > 0 ? Math.max(2, Math.min(100, Math.abs(pct))) : 0;
      %>
      <div style="background:<%= rentBg %>;border:1.5px solid <%= rentBorde %>;border-radius:14px;padding:18px 22px;margin-bottom:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:42px;height:42px;border-radius:12px;background:<%= rentColorBg %>;display:flex;align-items:center;justify-content:center;font-size:20px;color:<%= rentColor %>;">
              <i class="bi bi-<%= gan >= 0 ? 'graph-up-arrow' : 'graph-down-arrow' %>"></i>
            </div>
            <div>
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:3px;">Rentabilidad del mes</div>
              <div style="font-size:28px;font-weight:800;color:<%= rentColor %>;letter-spacing:-1.5px;line-height:1;">
                <%= gan >= 0 ? '+' : '' %>$<%= Math.abs(gan).toLocaleString('es-AR', {minimumFractionDigits:2}) %>
              </div>
            </div>
          </div>
          <div style="display:flex;gap:28px;flex-wrap:wrap;">
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:3px;">Ventas</div>
              <div style="font-size:18px;font-weight:800;color:#10b981;font-family:var(--font-mono);">
                $<%= vm.toLocaleString('es-AR', {minimumFractionDigits:2}) %>
              </div>
              <div style="font-size:11px;color:var(--text-secondary);"><%= ventasMes?.count || 0 %> transacciones</div>
            </div>
            <div style="width:1px;background:var(--border-color);"></div>
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:3px;">Gastos</div>
              <div style="font-size:18px;font-weight:800;color:#ef4444;font-family:var(--font-mono);">
                $<%= gm.toLocaleString('es-AR', {minimumFractionDigits:2}) %>
              </div>
              <div style="font-size:11px;color:var(--text-secondary);"><%= gastosMes?.porCat?.length || 0 %> categorías</div>
            </div>
            <div style="width:1px;background:var(--border-color);"></div>
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:3px;">Margen</div>
              <div style="font-size:18px;font-weight:800;color:<%= rentColor %>;font-family:var(--font-mono);"><%= pct %>%</div>
              <div style="font-size:11px;color:var(--text-secondary);">del mes actual</div>
            </div>
          </div>
        </div>
        <!-- Barra visual -->
        <% if (vm > 0) { %>
        <div style="margin-top:14px;">
          <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-secondary);margin-bottom:5px;">
            <span>Ventas $<%= vm.toLocaleString('es-AR',{minimumFractionDigits:0}) %></span>
            <span>Gastos $<%= gm.toLocaleString('es-AR',{minimumFractionDigits:0}) %></span>
          </div>
          <div style="height:8px;border-radius:4px;background:rgba(239,68,68,.15);overflow:hidden;">
            <div style="height:100%;border-radius:4px;background:linear-gradient(90deg,#10b981,#059669);width:<%= Math.min(100, Math.round((vm - gm) / vm * 100)) %>%;transition:width .6s;"></div>
          </div>
        </div>
        <% } %>
      </div>

      <!-- ══ FILA: Gráficos + Gastos por categoría ══ -->
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:18px;">

        <!-- Ventas 7 días -->
        <div class="dash-card">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-bar-chart-line" style="color:#6366f1;"></i> Ventas últimos 7 días</span>
            <button onclick="exportarSemanaCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
              <i class="bi bi-download"></i> CSV
            </button>
          </div>
          <div style="padding:16px 18px;">
            <canvas id="chartSemana" height="160"></canvas>
          </div>
        </div>

        <!-- Gastos por categoría -->
        <div class="dash-card">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-receipt" style="color:#ef4444;"></i> Gastos del mes por categoría</span>
            <a href="/gastos" style="font-size:11.5px;color:var(--color-action);font-weight:600;text-decoration:none;">Ver todos →</a>
          </div>
          <div style="padding:14px 18px;display:flex;flex-direction:column;gap:10px;">
            <% if (!gastosMes?.porCat?.length) { %>
            <div style="text-align:center;padding:24px;color:var(--text-secondary);">
              <i class="bi bi-receipt" style="font-size:24px;display:block;opacity:.2;margin-bottom:6px;"></i>
              Sin gastos este mes
            </div>
            <% } else {
              const totalCatG = gastosMes.porCat.reduce((a,c) => a + Number(c.total), 0) || 1;
              const catColors = {'Alquiler':'#6366f1','Servicios':'#00b4d8','Sueldos':'#10b981','Insumos':'#f59e0b','Impuestos':'#ef4444','Mantenimiento':'#a855f7','Otros':'#9ca3af'};
            %>
            <% for (let ci = 0; ci < gastosMes.porCat.length; ci++) {
               const cat = gastosMes.porCat[ci];
               const cc = catColors[cat.categoria] || '#9ca3af';
               const w  = Math.round(Number(cat.total) / totalCatG * 100);
            %>
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                <span style="font-size:12.5px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:5px;">
                  <span style="width:8px;height:8px;border-radius:2px;background:<%= cc %>;flex-shrink:0;"></span>
                  <%= cat.categoria %>
                </span>
                <span style="font-family:var(--font-mono);font-size:12.5px;font-weight:700;color:#ef4444;">
                  $<%= Number(cat.total).toLocaleString('es-AR',{minimumFractionDigits:0}) %>
                </span>
              </div>
              <div style="height:5px;border-radius:3px;background:var(--border-color);overflow:hidden;">
                <div style="height:100%;background:<%= cc %>;width:<%= w %>%;border-radius:3px;"></div>
              </div>
            </div>
            <% } %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ══ FILA: Métodos + Top productos + Stock crítico ══ -->
      <div style="display:grid;grid-template-columns:1fr 2fr 1fr;gap:16px;margin-bottom:18px;">

        <!-- Métodos de pago hoy + comisiones -->
        <div class="dash-card" style="display:flex;flex-direction:column;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-pie-chart" style="color:#10b981;"></i> Métodos de pago hoy</span>
            <div style="display:flex;gap:6px;">
              <button onclick="exportarMetodosCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
                <i class="bi bi-download"></i> CSV
              </button>
            </div>
          </div>
          <!-- Torta -->
          <div style="padding:14px 18px 8px;">
            <canvas id="chartMetodos" height="140"></canvas>
          </div>
          <!-- Desglose comisiones -->
          <div id="metodosDesglose" style="padding:0 14px 14px;display:flex;flex-direction:column;gap:6px;">
            <div style="text-align:center;padding:10px;color:var(--text-muted);font-size:12px;">Cargando...</div>
          </div>
          <!-- Link reporte completo -->
          <div style="padding:10px 14px;border-top:1px solid var(--border-color);margin-top:auto;">
            <a href="/dashboard/reportes/metodos"
              style="display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;border-radius:8px;background:rgba(99,102,241,.07);border:1.5px solid rgba(99,102,241,.2);color:#6366f1;font-size:12px;font-weight:700;text-decoration:none;transition:background .15s;"
              onmouseenter="this.style.background='rgba(99,102,241,.13)'" onmouseleave="this.style.background='rgba(99,102,241,.07)'">
              <i class="bi bi-bar-chart-line"></i> Ver reporte completo
            </a>
          </div>
        </div>

        <!-- Top productos -->
        <div class="dash-card">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-trophy" style="color:#f59e0b;"></i> Productos más vendidos (30 días)</span>
            <button onclick="exportarTopCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
              <i class="bi bi-download"></i> CSV
            </button>
          </div>
          <div style="padding:14px 18px;">
            <canvas id="chartProductos" height="180"></canvas>
          </div>
        </div>

        <!-- Stock crítico + Deuda proveedores -->
        <div style="display:flex;flex-direction:column;gap:14px;">

          <!-- Deuda proveedores -->
          <div class="dash-card" style="flex-shrink:0;">
            <div class="dash-card-header" style="padding:12px 16px;">
              <span class="dash-card-title" style="font-size:12px;"><i class="bi bi-truck" style="color:#6366f1;"></i> Deuda proveedores</span>
              <a href="/proveedores" style="font-size:11px;color:var(--color-action);font-weight:600;text-decoration:none;">Ver →</a>
            </div>
            <div style="padding:14px 16px;text-align:center;">
              <% if (deudaProvs > 0) { %>
              <div style="font-size:22px;font-weight:800;color:#dc2626;font-family:var(--font-mono);letter-spacing:-1px;">
                $<%= Number(deudaProvs).toLocaleString('es-AR',{minimumFractionDigits:2}) %>
              </div>
              <div style="font-size:12px;color:#dc2626;margin-top:3px;">deuda pendiente</div>
              <% } else { %>
              <div style="font-size:14px;font-weight:700;color:#10b981;">✓ Sin deudas</div>
              <div style="font-size:12px;color:var(--text-secondary);margin-top:2px;">Al día con todos</div>
              <% } %>
            </div>
          </div>

          <!-- Stock crítico -->
          <div class="dash-card" style="flex:1;">
            <div class="dash-card-header" style="padding:12px 16px;">
              <span class="dash-card-title" style="font-size:12px;">
                <i class="bi bi-exclamation-triangle" style="color:#f59e0b;"></i> Stock crítico
              </span>
              <a href="/inventario" style="font-size:11px;color:var(--color-action);font-weight:600;text-decoration:none;">Ver →</a>
            </div>
            <% if (!stockCritico?.length) { %>
            <div style="padding:16px;text-align:center;color:var(--text-secondary);font-size:12.5px;">
              <i class="bi bi-check-circle" style="color:#10b981;font-size:18px;display:block;margin-bottom:4px;"></i>
              Todo el stock OK
            </div>
            <% } else { %>
            <div style="max-height:180px;overflow-y:auto;">
              <% stockCritico.slice(0,8).forEach(p => { %>
              <div class="stock-alert-item">
                <span style="font-size:12px;font-weight:600;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px;" title="<%= p.name %>">
                  <%= p.name.length > 20 ? p.name.slice(0,18)+'…' : p.name %>
                </span>
                <span style="font-size:11.5px;font-weight:800;padding:2px 8px;border-radius:20px;background:<%= p.stock<=0?'rgba(239,68,68,.12)':'rgba(245,158,11,.12)' %>;color:<%= p.stock<=0?'#dc2626':'#d97706' %>;flex-shrink:0;">
                  <%= p.stock %> ud
                </span>
              </div>
              <% }) %>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ══ HISTORIAL DE VENTAS ══ -->
      <div class="dash-card">
        <div class="dash-card-header">
          <span class="dash-card-title">
            <i class="bi bi-clock-history" style="color:#6366f1;"></i> Historial de ventas
          </span>
          <div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap;">
            <input type="date" id="filtroDesde" style="padding:6px 10px;border-radius:7px;border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-size:12px;font-family:var(--font-body);">
            <span style="font-size:12px;color:var(--text-secondary);">→</span>
            <input type="date" id="filtroHasta" style="padding:6px 10px;border-radius:7px;border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-size:12px;font-family:var(--font-body);">
            <button onclick="buscarVentas(1)" style="padding:6px 13px;border-radius:7px;border:none;background:#6366f1;color:#fff;font-size:12px;font-weight:700;font-family:var(--font-body);cursor:pointer;">
              <i class="bi bi-search"></i>
            </button>
            <button onclick="limpiarFiltros()" style="padding:6px 13px;border-radius:7px;border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-secondary);font-size:12px;font-weight:600;font-family:var(--font-body);cursor:pointer;">
              Limpiar
            </button>
            <button onclick="exportarVentasCSV()" style="padding:6px 13px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:12px;font-weight:700;font-family:var(--font-body);cursor:pointer;">
              <i class="bi bi-filetype-csv"></i>
            </button>
          </div>
        </div>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;" id="tablaVentas">
           <thead style="background:var(--bg-body);">
  <tr>
    <th class="th-v" style="width:28px;"></th>
    <th class="th-v">N°</th>
    <th class="th-v">Fecha</th>
    <th class="th-v">Hora</th>
    <th class="th-v">Método</th>
    <th class="th-v">Facturación</th>
    <th class="th-v" style="text-align:right;">Total</th>
  </tr>
</thead>
            <tbody id="tbodyVentas">
              <tr><td colspan="7" style="padding:40px;text-align:center;color:var(--text-secondary);font-size:13.5px;">
                <i class="bi bi-search" style="font-size:24px;display:block;margin-bottom:8px;opacity:.3;"></i>
                Cargando ventas de hoy...
              </td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion" style="padding:12px 18px;border-top:1px solid var(--border-color);display:none;align-items:center;justify-content:space-between;">
          <span id="infoResultados" style="font-size:12.5px;color:var(--text-secondary);"></span>
          <div style="display:flex;gap:5px;" id="btnsPagina"></div>
        </div>
      </div>

    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<%- include('../partials/scripts') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
'use strict';

// ── Fecha ──
document.getElementById('fechaHoy').textContent =
  new Date().toLocaleDateString('es-AR', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

// ── Datos ──
const dataSemana  = <%- graficoSemana %>;
const dataMetodos = <%- graficoMetodos %>;
const dataTopProd = <%- graficoTopProd %>;
const COLORS = ['#6366f1','#10b981','#f59e0b','#3b82f6','#ec4899','#8b5cf6','#14b8a6','#f97316'];

function parseFechaLocal(value) {
  if (!value) return new Date();
  return new Date(String(value).replace(' ', 'T'));
}

// ── Chart Ventas 7 días ──
(function() {
  const dias = [], totales = [];
  for (let i = 6; i >= 0; i--) {
    const d   = new Date(Date.now() - i * 86400000);
    const key = d.toISOString().split('T')[0];
    const found = dataSemana.find(r => r.fecha === key);
    dias.push(d.toLocaleDateString('es-AR', { weekday:'short', day:'numeric' }));
    totales.push(found ? found.total : 0);
  }
  new Chart(document.getElementById('chartSemana'), {
    type: 'bar',
    data: {
      labels: dias,
      datasets: [{ label: 'Ventas $', data: totales,
        backgroundColor: totales.map((v, i) => i === 6 ? 'rgba(99,102,241,.9)' : 'rgba(99,102,241,.45)'),
        borderRadius: 7, borderSkipped: false }]
    },
    options: {
      responsive: true, plugins: { legend: { display: false } },
      scales: {
        y: { ticks: { callback: v => '$' + v.toLocaleString('es-AR'), font: { size: 11 } }, grid: { color: 'rgba(0,0,0,.04)' } },
        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
      }
    }
  });
})();

// ── Chart Métodos + desglose comisiones ──
(function() {
  const desglose = document.getElementById('metodosDesglose');

  if (!dataMetodos.length) {
    document.getElementById('chartMetodos').style.display = 'none';
    desglose.innerHTML = '<p style="font-size:12px;color:var(--text-secondary);text-align:center;padding:12px 0;">Sin ventas hoy</p>';
    return;
  }

  new Chart(document.getElementById('chartMetodos'), {
    type: 'doughnut',
    data: {
      labels: dataMetodos.map(m => m.payment_method),
      datasets: [{ data: dataMetodos.map(m => m.total), backgroundColor: COLORS, borderWidth: 2, borderColor: 'var(--bg-card)' }]
    },
    options: {
      responsive: true, cutout: '68%',
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' $' + ctx.raw.toLocaleString('es-AR', {minimumFractionDigits:2}) } } }
    }
  });

  // Cargar comisiones desde la API para mostrar neto
  const hoy = new Date().toISOString().split('T')[0];
  fetch('/api/reporte/metodos?' + new URLSearchParams({ desde: hoy, hasta: hoy }))
    .then(r => r.json())
    .then(data => {
      if (!data.metodos || !data.metodos.length) {
        desglose.innerHTML = '';
        return;
      }
      const fmt = n => '$' + Number(n).toLocaleString('es-AR', { minimumFractionDigits: 2 });
      const totalBruto    = data.metodos.reduce((s, m) => s + m.total, 0);
      const totalComision = data.metodos.reduce((s, m) => s + m.comision_monto, 0);
      const totalNeto     = data.metodos.reduce((s, m) => s + m.neto, 0);

      let html = '';

      // Una fila por método
      data.metodos.forEach((m, i) => {
        const color = COLORS[i % COLORS.length];
        html += '<div style="background:var(--bg-body);border-radius:9px;padding:8px 10px;">'
          + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:' + (m.comision_pct > 0 ? '5px' : '0') + ';">'
          + '<span style="display:flex;align-items:center;gap:5px;font-size:12px;font-weight:700;color:var(--text-primary);">'
          + '<span style="width:8px;height:8px;border-radius:2px;background:' + color + ';flex-shrink:0;"></span>' + m.metodo
          + '</span>'
          + '<span style="font-family:var(--font-mono);font-size:12.5px;font-weight:800;color:var(--text-primary);">' + fmt(m.total) + '</span>'
          + '</div>';
        if (m.comision_pct > 0) {
          html += '<div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:2px;">'
            + '<span style="color:#d97706;">Comisión ' + m.comision_pct + '%</span>'
            + '<span style="color:#d97706;font-family:var(--font-mono);">− ' + fmt(m.comision_monto) + '</span>'
            + '</div>'
            + '<div style="display:flex;justify-content:space-between;font-size:11.5px;">'
            + '<span style="color:#10b981;font-weight:700;">Lo que te llega</span>'
            + '<span style="color:#10b981;font-weight:800;font-family:var(--font-mono);">' + fmt(m.neto) + '</span>'
            + '</div>';
        } else {
          html += '<div style="font-size:11px;color:#10b981;font-weight:600;">Sin comisión</div>';
        }
        html += '</div>';
      });

      // Totales si hay más de un método
      if (data.metodos.length > 1) {
        const fmt2 = n => '$' + Number(n).toLocaleString('es-AR', { minimumFractionDigits: 2 });
        html += '<div style="border-top:1.5px solid var(--border-color);padding-top:8px;margin-top:2px;">'
          + '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">'
          + '<span style="color:var(--text-secondary);font-weight:600;">Total bruto</span>'
          + '<span style="font-family:var(--font-mono);font-weight:700;">' + fmt2(totalBruto) + '</span>'
          + '</div>'
          + (totalComision > 0
            ? '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">'
              + '<span style="color:#d97706;font-weight:600;">Comisiones</span>'
              + '<span style="color:#d97706;font-family:var(--font-mono);font-weight:700;">− ' + fmt2(totalComision) + '</span>'
              + '</div>'
            : '')
          + '<div style="display:flex;justify-content:space-between;font-size:13px;">'
          + '<span style="color:#10b981;font-weight:800;">Lo que te llega</span>'
          + '<span style="color:#10b981;font-family:var(--font-mono);font-weight:800;">' + fmt2(totalNeto) + '</span>'
          + '</div>'
          + '</div>';
      }

      desglose.innerHTML = html;
    })
    .catch(() => {
      // Si falla la API de comisiones, mostrar solo leyenda simple
      desglose.innerHTML = dataMetodos.map((m, i) => {
        const tot = dataMetodos.reduce((a, x) => a + Number(x.total), 0);
        const pct = Math.round(Number(m.total) / tot * 100);
        return '<div style="display:flex;align-items:center;justify-content:space-between;font-size:12px;">'
          + '<span style="display:flex;align-items:center;gap:5px;color:var(--text-secondary);">'
          + '<span style="width:9px;height:9px;border-radius:2px;background:' + COLORS[i] + ';"></span>' + m.payment_method
          + '</span>'
          + '<span style="font-weight:700;font-family:var(--font-mono);font-size:11.5px;">' + pct + '%</span>'
          + '</div>';
      }).join('');
    });
})();

