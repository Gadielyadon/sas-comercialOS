let _ticketCfgDashboard = null;

async function loadTicketConfigDashboard() {
  if (_ticketCfgDashboard) return _ticketCfgDashboard;

  _ticketCfgDashboard = {
    formato: '80mm',
    footer: '¡Gracias por su compra!',
    nombre: 'Mi Comercio',
    direccion: '',
    telefono: '',
    logo: ''
  };

  try {
    const r = await fetch('/api/config');
    if (!r.ok) return _ticketCfgDashboard;
    const cfg = await r.json();

    _ticketCfgDashboard = {
      formato: cfg.ticket_formato || '80mm',
      footer: cfg.ticket_footer || '¡Gracias por su compra!',
      nombre: cfg.empresa_nombre || 'Mi Comercio',
      direccion: cfg.empresa_direccion || '',
      telefono: cfg.empresa_telefono || '',
      logo: cfg.empresa_logo || ''
    };
  } catch(e) {}

  return _ticketCfgDashboard;
}

function escapeHtmlTicket(str='') {
  return String(str)
    .replaceAll('&','&amp;')
    .replaceAll('<','&lt;')
    .replaceAll('>','&gt;')
    .replaceAll('"','&quot;')
    .replaceAll("'","&#039;");
}

async function reimprimirTicketVenta(saleId) {
  const venta = _lastVentas.find(v => Number(v.id) === Number(saleId));
  if (!venta) {
    alert('No se encontró la venta');
    return;
  }

  const cfg = await loadTicketConfigDashboard();

  const fechaObj = parseFechaLocal(venta.created_at);
  const fechaTxt = fechaObj.toLocaleString('es-AR', {
    day:'2-digit',
    month:'2-digit',
    year:'numeric',
    hour:'2-digit',
    minute:'2-digit'
  });

  const es80 = String(cfg.formato || '80mm').toLowerCase() === '80mm';
  const contentWidth = es80 ? '72mm' : '180mm';
  const fontSize = es80 ? '11px' : '13px';
  const titleSize = es80 ? '18px' : '24px';

  const itemsHtml = (venta.items || []).map(it => `
    <tr>
      <td style="padding:4px 0;">${escapeHtmlTicket(it.name)}</td>
      <td style="padding:4px 0;text-align:center;">${it.qty}</td>
      <td style="padding:4px 0;text-align:right;">$${Number(it.subtotal).toLocaleString('es-AR',{minimumFractionDigits:2})}</td>
    </tr>
  `).join('');

  const logoHtml = cfg.logo
    ? `<div class="center" style="margin-bottom:6px;"><img src="${escapeHtmlTicket(cfg.logo)}" style="max-width:100%;max-height:60px;object-fit:contain;"></div>`
    : '';

  const html = `
    <!DOCTYPE html>
    <html lang="es">
    <head>
      <meta charset="UTF-8">
      <title>Ticket venta #${venta.id}</title>
      <style>
        @page {
          size: ${es80 ? '80mm auto' : 'A4'};
          margin: 6mm;
        }
        body {
          font-family: monospace;
          margin: 0;
          padding: 0;
          background: #fff;
          color: #000;
          font-size: ${fontSize};
        }
        .ticket {
          width: ${contentWidth};
          max-width: 100%;
          margin: 0 auto;
        }
        .center { text-align: center; }
        .title { font-size: ${titleSize}; font-weight: 700; margin-bottom: 2px; }
        .small { font-size: ${es80 ? '10px' : '11px'}; }
        .sub { font-size: ${es80 ? '11px' : '12px'}; margin-bottom: 8px; }
        .line { border-top: 1px dashed #000; margin: 10px 0; }
        table {
          width: 100%;
          border-collapse: collapse;
          font-size: ${es80 ? '10px' : '12px'};
        }
        .tot {
          display: flex;
          justify-content: space-between;
          font-size: ${es80 ? '12px' : '13px'};
          margin: 4px 0;
        }
        .tot.main {
          font-weight: 700;
          font-size: ${es80 ? '14px' : '16px'};
        }
      </style>
    </head>
    <body>
      <div class="ticket">
        ${logoHtml}

        <div class="center">
          <div class="title">${escapeHtmlTicket(cfg.nombre || 'Mi Comercio')}</div>
          ${cfg.direccion ? `<div class="small">${escapeHtmlTicket(cfg.direccion)}</div>` : ''}
          ${cfg.telefono ? `<div class="small">${escapeHtmlTicket(cfg.telefono)}</div>` : ''}
        </div>

        <div class="line"></div>

        <div>Venta: #${venta.id}</div>
        <div>Fecha: ${escapeHtmlTicket(fechaTxt)}</div>
        <div>Método: ${escapeHtmlTicket(venta.payment_method || '-')}</div>

        <div class="line"></div>

        <table>
          <thead>
            <tr>
              <th style="text-align:left;">Producto</th>
              <th style="text-align:center;">Cant</th>
              <th style="text-align:right;">Sub</th>
            </tr>
          </thead>
          <tbody>
            ${itemsHtml}
          </tbody>
        </table>

        <div class="line"></div>

        <div class="tot main">
          <span>TOTAL:</span>
          <span>$${Number(venta.total).toLocaleString('es-AR',{minimumFractionDigits:2})}</span>
        </div>

        ${venta.cash_received ? `
          <div class="tot">
            <span>Recibido:</span>
            <span>$${Number(venta.cash_received).toLocaleString('es-AR',{minimumFractionDigits:2})}</span>
          </div>
        ` : ''}

        ${venta.cash_received ? `
          <div class="tot">
            <span>Vuelto:</span>
            <span>$${Number(venta.change_amount || 0).toLocaleString('es-AR',{minimumFractionDigits:2})}</span>
          </div>
        ` : ''}

        <div class="line"></div>
        <div class="center small">${escapeHtmlTicket(cfg.footer || '¡Gracias por su compra!')}</div>
      </div>
    </body>
    </html>
  `;

  const w = window.open('', '_blank', `width=${es80 ? 420 : 900},height=700`);
  if (!w) {
    alert('Permití ventanas emergentes para imprimir');
    return;
  }

  w.document.open();
  w.document.write(html);
  w.document.close();
  w.focus();
  setTimeout(() => w.print(), 250);
}



// Cargar ventas de hoy al entrar
window.addEventListener('DOMContentLoaded', () => {
  const hoy = new Date().toISOString().split('T')[0];
  document.getElementById('filtroDesde').value = hoy;
