// ── Historial de ventas ──
let paginaActual = 1;
let _lastVentas  = [];

async function buscarVentas(page = 1) {
  paginaActual = page;
  const desde  = document.getElementById('filtroDesde').value;
  const hasta  = document.getElementById('filtroHasta').value;
  const params = new URLSearchParams({ page });
  if (desde) params.append('desde', desde);
  if (hasta) params.append('hasta', hasta);

  const tbody = document.getElementById('tbodyVentas');
 tbody.innerHTML = `<tr><td colspan="7" style="padding:30px;text-align:center;">
    <span style="display:inline-block;width:18px;height:18px;border:2.5px solid #6366f1;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;"></span>
  </td></tr>`;

  try {
    const r    = await fetch(`/api/ventas/buscar?${params}`);
    const data = await r.json();
    _lastVentas = data.ventas || [];

    if (!_lastVentas.length) {
      tbody.innerHTML = `<tr><td colspan="6" style="padding:40px;text-align:center;color:var(--text-secondary);">
        Sin ventas para ese período</td></tr>`;
      document.getElementById('paginacion').style.display = 'none';
      return;
    }

    tbody.innerHTML = _lastVentas.map(v => {
  const badgeFact = v.facturada
    ? `<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:800;background:${
        v.factura_tipo_letra === 'A' ? 'rgba(37,99,235,.12)' :
        v.factura_tipo_letra === 'B' ? 'rgba(16,185,129,.12)' :
        'rgba(245,158,11,.14)'
      };color:${
        v.factura_tipo_letra === 'A' ? '#2563eb' :
        v.factura_tipo_letra === 'B' ? '#059669' :
        '#d97706'
      };">
        Factura ${v.factura_tipo_letra}
      </span>`
    : `<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:800;background:rgba(107,114,128,.10);color:#6b7280;">
        Sin factura
      </span>`;

  return `
    <tr class="fila-venta" style="border-bottom:1px solid var(--border-color);cursor:pointer;" onclick="toggleDetalle(${v.id}, this)">
      <td style="padding:10px 6px 10px 16px;">
        <i class="bi bi-chevron-right" id="chev-${v.id}" style="font-size:11px;color:var(--text-secondary);transition:transform .15s;"></i>
      </td>
      <td style="padding:10px 14px;font-size:13px;color:var(--text-secondary);">#${v.id}</td>
      <td style="padding:10px 14px;font-size:13.5px;">${parseFechaLocal(v.created_at).toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'numeric'})}</td>
      <td style="padding:10px 14px;font-size:13px;color:var(--text-secondary);">${parseFechaLocal(v.created_at).toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit',hour12:false})}</td>
      <td style="padding:10px 14px;">
        <span style="padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:700;background:rgba(99,102,241,.1);color:#6366f1;">${v.payment_method}</span>
      </td>
      <td style="padding:10px 14px;">${badgeFact}</td>
      <td style="padding:10px 18px 10px 14px;text-align:right;font-weight:800;font-size:14px;color:var(--text-primary);">
        $${Number(v.total).toLocaleString('es-AR',{minimumFractionDigits:2})}
      </td>
    </tr>

    <tr id="detalle-${v.id}" style="display:none;background:var(--bg-body);">
      <td colspan="7" style="padding:0;">
        <div style="padding:12px 18px 14px 48px;border-bottom:2px solid var(--border-color);">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:10px;">
            <div style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);font-weight:700;">
              Items de la venta
            </div>

            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button onclick="event.stopPropagation();reimprimirTicketVenta(${v.id})"
                style="padding:7px 12px;border-radius:8px;border:1.5px solid var(--border-color);background:var(--bg-card);color:var(--text-primary);font-size:12px;font-weight:700;cursor:pointer;">
                <i class="bi bi-printer"></i> Reimprimir ticket
              </button>

              ${v.facturada ? `
                <a href="/afip/pdf/${v.id}" target="_blank" onclick="event.stopPropagation()"
                  style="padding:7px 12px;border-radius:8px;border:1.5px solid rgba(109,40,217,.35);background:rgba(109,40,217,.07);color:#6d28d9;font-size:12px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
                  <i class="bi bi-file-earmark-pdf"></i> PDF AFIP
                </a>
              ` : ''}
            </div>
          </div>

          <table style="width:100%;border-collapse:collapse;">
            ${(v.items||[]).map(it => `
              <tr>
                <td style="padding:3px 8px 3px 0;font-size:13px;color:var(--text-primary);">${it.name}</td>
                <td style="padding:3px 8px;font-size:12px;color:var(--text-secondary);">× ${it.qty}</td>
                <td style="padding:3px 0;font-size:13px;text-align:right;font-weight:600;">$${Number(it.subtotal).toLocaleString('es-AR',{minimumFractionDigits:2})}</td>
              </tr>`).join('')}
          </table>

          <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:14px;font-size:12px;color:var(--text-secondary);">
            ${v.cash_received ? `<span>Recibido: <strong style="color:var(--text-primary)">$${Number(v.cash_received).toLocaleString('es-AR',{minimumFractionDigits:2})}</strong></span>` : ''}
            ${v.cash_received ? `<span>Vuelto: <strong style="color:var(--text-primary)">$${Number(v.change_amount||0).toLocaleString('es-AR',{minimumFractionDigits:2})}</strong></span>` : ''}
            ${v.facturada ? `<span>CAE: <strong style="color:var(--text-primary)">${v.factura_cae || '-'}</strong></span>` : ''}
          </div>
        </div>
      </td>
    </tr>`;
}).join('');

    // Paginación
    const totalPags = Math.ceil(data.total / data.limit);
    document.getElementById('infoResultados').textContent = `${data.total} resultado${data.total!==1?'s':''}`;
    const btnsPag = document.getElementById('btnsPagina');
    btnsPag.innerHTML = '';
    for (let p = 1; p <= totalPags; p++) {
      btnsPag.innerHTML += `<button onclick="buscarVentas(${p})"
        style="padding:5px 11px;border-radius:7px;border:1.5px solid ${p===page?'#6366f1':'var(--border-color)'};background:${p===page?'#6366f1':'var(--bg-body)'};color:${p===page?'#fff':'var(--text-secondary)'};font-size:12px;font-weight:600;cursor:pointer;">${p}</button>`;
    }
    document.getElementById('paginacion').style.display = 'flex';
  } catch(e) {
    tbody.innerHTML = `<tr><td colspan="7" style="padding:30px;text-align:center;color:#ef4444;">Error al cargar ventas</td></tr>`;
  }
}

function toggleDetalle(id) {
  const det  = document.getElementById(`detalle-${id}`);
  const chev = document.getElementById(`chev-${id}`);
  const open = det.style.display !== 'none';
  document.querySelectorAll('[id^="detalle-"]').forEach(el => el.style.display = 'none');
  document.querySelectorAll('[id^="chev-"]').forEach(el => el.style.transform = '');
  if (!open) { det.style.display = 'table-row'; chev.style.transform = 'rotate(90deg)'; }
}

function limpiarFiltros() {
  document.getElementById('filtroDesde').value = '';
  document.getElementById('filtroHasta').value = '';
  buscarVentas(1);
}

function exportarVentasCSV() {
  if (!_lastVentas.length) { alert('No hay ventas para exportar'); return; }
  let csv = '\uFEFFN°;Fecha;Hora;Método;Total\n';
  _lastVentas.forEach(v => {
    const d = parseFechaLocal(v.created_at);
    csv += [v.id, d.toLocaleDateString('es-AR'), d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}), v.payment_method, Number(v.total).toFixed(2)].join(';') + '\n';
  });
  const a = Object.assign(document.createElement('a'), {
    href: URL.createObjectURL(new Blob([csv], {type:'text/csv;charset=utf-8;'})),
    download: 'ventas.csv'
  });
  a.click();
}

