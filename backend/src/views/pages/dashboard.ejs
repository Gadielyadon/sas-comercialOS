<%- include('../partials/head', { title }) %>

<style>
.dash-card { background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);transition:box-shadow .18s,transform .18s; }
.dash-card:hover { box-shadow:var(--shadow-md); }
.dash-card-header { display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border-color); }
.dash-card-title  { font-size:13px;font-weight:700;color:var(--text-primary);display:flex;align-items:center;gap:7px; }

.stat-chip { border-radius:var(--radius-lg);padding:20px 22px;display:flex;flex-direction:column;gap:6px;position:relative;overflow:hidden;box-shadow:var(--shadow-md);transition:transform .15s,box-shadow .15s; }
.stat-chip:hover  { transform:translateY(-2px);box-shadow:var(--shadow-lg); }
.stat-chip.azul   { background:#1B4FD8; }
.stat-chip.indigo { background:#4F46E5; }
.stat-chip.verde  { background:#10b981; }
.stat-chip.alerta { background:#f59e0b; }
.stat-chip-label  { font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:rgba(255,255,255,.80); }
.stat-chip-value  { font-size:26px;font-weight:900;letter-spacing:-1px;line-height:1;color:#fff; }
.stat-chip-trend  { font-size:12px;color:rgba(255,255,255,.70);font-weight:500;margin-top:2px; }
.stat-chip-icon   { position:absolute;right:18px;top:50%;transform:translateY(-50%);font-size:38px;opacity:.12;color:#fff;pointer-events:none; }

.insight-card  { background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:18px 20px;display:flex;flex-direction:column;gap:4px;box-shadow:var(--shadow-sm);transition:box-shadow .15s,transform .15s; }
.insight-card:hover { box-shadow:var(--shadow-md);transform:translateY(-1px); }
.insight-label { font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted); }
.insight-value { font-size:22px;font-weight:800;color:var(--text-primary);letter-spacing:-.5px;line-height:1.1; }
.insight-sub   { font-size:12px;color:var(--text-secondary);margin-top:2px; }
.insight-icon  { width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;margin-bottom:10px; }

.rent-card { border-radius:var(--radius-lg);padding:20px 24px;border:1.5px solid;box-shadow:var(--shadow-sm); }
.rent-bar-bg { height:10px;border-radius:5px;overflow:hidden;margin-top:12px; }
.rent-bar-fg { height:100%;border-radius:5px;transition:width .8s cubic-bezier(.4,0,.2,1); }

.th-dash { padding:11px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--table-head-color);border-bottom:none; }
#tablaActividad thead tr { background:var(--table-head-bg); }
#tablaActividad thead tr th:first-child { border-radius:8px 0 0 8px; }
#tablaActividad thead tr th:last-child  { border-radius:0 8px 8px 0; }
.fila-act:hover td { background:var(--table-row-hover); }

.stock-alert-item { display:flex;align-items:center;justify-content:space-between;padding:9px 16px;border-bottom:1px solid var(--border-color);font-size:13px;transition:background .12s; }
.stock-alert-item:last-child { border-bottom:none; }
.stock-alert-item:hover { background:var(--bg-hover); }

.badge-up   { color:#10b981;font-weight:700; }
.badge-down { color:#ef4444;font-weight:700; }

@keyframes spin    { to { transform:rotate(360deg); } }
@keyframes pulse   { 0%,100%{opacity:1} 50%{opacity:.4} }
@keyframes fadeUp  { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
.fade-up { animation:fadeUp .3s ease both; }

[data-theme="dark"] .stat-chip.azul   { background:#1e40af; }
[data-theme="dark"] .stat-chip.indigo { background:#4338ca; }
[data-theme="dark"] .stat-chip.verde  { background:#059669; }
[data-theme="dark"] .stat-chip.alerta { background:#d97706; }

@media (max-width:1100px){
  .grid-3cols { grid-template-columns:1fr 1fr !important; }
  .grid-main  { grid-template-columns:1fr !important; }
}
@media (max-width:768px){
  .stat-chip-value { font-size:20px; }
  .stat-chip { padding:14px 16px; }
  .grid-chips { grid-template-columns:1fr 1fr !important; }
  .insight-value { font-size:18px; }
}
@media (max-width:480px){
  .grid-chips { grid-template-columns:1fr !important; }
}
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active, user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module, user }) %>
    <main class="page-body" style="padding:24px 28px;max-width:1440px;margin:0 auto;">

      <!-- BIENVENIDA -->
      <div class="page-header">
        <div class="page-header-title">
          <h2>Bienvenido, <%= user?.name || 'Admin' %> 👋</h2>
          <p id="fechaHoy"></p>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
          <% if (cajaActual) { %>
          <a href="/caja/turno" style="display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:var(--radius-md);background:rgba(16,185,129,.10);border:1.5px solid rgba(16,185,129,.3);color:#065f46;font-size:13px;font-weight:700;text-decoration:none;">
            <span style="width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 0 3px rgba(16,185,129,.3);display:inline-block;"></span>
            Caja abierta — Ver turno
          </a>
          <% } else { %>
          <a href="/caja/turno" style="display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:var(--radius-md);background:var(--bg-surface);border:1.5px solid var(--border-color);color:var(--text-secondary);font-size:13px;font-weight:600;text-decoration:none;">
            <i class="bi bi-cash-coin"></i> Abrir caja
          </a>
          <% } %>
          <a href="/historial" style="display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-md);background:var(--bg-surface);border:1.5px solid var(--border-color);color:var(--text-secondary);font-size:13px;font-weight:600;text-decoration:none;">
            <i class="bi bi-clock-history"></i> Historial
          </a>
        </div>
      </div>

      <!-- STAT CHIPS HOY -->
      <div class="grid-chips" style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:20px;">
        <% const chipColors = ['azul','indigo','verde','alerta'];
           for (let si = 0; si < stats.length; si++) { const s = stats[si]; %>
        <div class="stat-chip <%= chipColors[si]||'azul' %> fade-up" style="animation-delay:<%=si*.06%>s;">
          <i class="bi <%= s.icon %> stat-chip-icon"></i>
          <div class="stat-chip-label"><%= s.label %></div>
          <div class="stat-chip-value"><%= s.value %></div>
          <div class="stat-chip-trend"><%= s.trend %></div>
        </div>
        <% } %>
      </div>

      <!-- RENTABILIDAD DEL MES -->
      <%
        const vm  = ventasMes?.total || 0;
        const gm  = gastosMes?.total || 0;
        const gan = vm - gm;
        const pct = vm > 0 ? Math.round((gan/vm)*100) : 0;
        const esPos      = gan >= 0;
        const rentColor  = esPos ? '#10b981' : '#ef4444';
        const rentBg     = esPos ? 'rgba(16,185,129,.07)' : 'rgba(239,68,68,.07)';
        const rentBorde  = esPos ? 'rgba(16,185,129,.25)'  : 'rgba(239,68,68,.25)';
        const barW       = vm > 0 ? Math.min(100, Math.max(0, Math.round((vm-gm)/vm*100))) : 0;
        const fmtPesos   = n => '$' + Number(n).toLocaleString('es-AR',{minimumFractionDigits:0});
      %>
      <div class="rent-card fade-up" style="background:<%=rentBg%>;border-color:<%=rentBorde%>;margin-bottom:20px;animation-delay:.10s;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:20px;">
          <div style="display:flex;align-items:center;gap:14px;">
            <div style="width:52px;height:52px;border-radius:14px;background:<%=esPos?'rgba(16,185,129,.15)':'rgba(239,68,68,.15)'%>;display:flex;align-items:center;justify-content:center;font-size:24px;color:<%=rentColor%>;flex-shrink:0;">
              <i class="bi bi-<%=esPos?'graph-up-arrow':'graph-down-arrow'%>"></i>
            </div>
            <div>
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;">Lo que ganaste este mes</div>
              <div style="font-size:32px;font-weight:900;color:<%=rentColor%>;letter-spacing:-1.5px;line-height:1;">
                <%=esPos?'+':''%><%=fmtPesos(Math.abs(gan))%>
              </div>
              <div style="font-size:12.5px;color:var(--text-secondary);margin-top:4px;">
                De cada $100 que cobrás, te quedan <strong style="color:<%=rentColor%>;">$<%=Math.max(0,pct)%></strong> de ganancia
              </div>
            </div>
          </div>
          <div style="display:flex;gap:28px;flex-wrap:wrap;align-items:center;">
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;">Cobré en ventas</div>
              <div style="font-size:20px;font-weight:800;color:#10b981;font-family:var(--font-mono);"><%=fmtPesos(vm)%></div>
              <div style="font-size:11px;color:var(--text-secondary);"><%=ventasMes?.count||0%> ventas</div>
            </div>
            <div style="font-size:24px;color:var(--text-muted);font-weight:300;">−</div>
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;">Gasté en el negocio</div>
              <div style="font-size:20px;font-weight:800;color:#ef4444;font-family:var(--font-mono);"><%=fmtPesos(gm)%></div>
              <div style="font-size:11px;color:var(--text-secondary);"><%=gastosMes?.porCat?.length||0%> categorías</div>
            </div>
            <div style="font-size:24px;color:var(--text-muted);font-weight:300;">=</div>
            <div style="text-align:center;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;">Margen de ganancia</div>
              <div style="font-size:20px;font-weight:800;color:<%=rentColor%>;font-family:var(--font-mono);"><%=pct%>%</div>
              <div style="font-size:11px;color:var(--text-secondary);">del total vendido</div>
            </div>
          </div>
        </div>
        <% if (vm > 0) { %>
        <div style="margin-top:16px;">
          <div style="display:flex;justify-content:space-between;font-size:11.5px;color:var(--text-secondary);margin-bottom:6px;">
            <span>Ganancia <strong style="color:<%=rentColor%>;"><%=fmtPesos(Math.abs(gan))%></strong></span>
            <span>Gastos <strong style="color:#ef4444;"><%=fmtPesos(gm)%></strong></span>
          </div>
          <div class="rent-bar-bg" style="background:rgba(239,68,68,.15);">
            <div class="rent-bar-fg" style="width:<%=barW%>%;background:linear-gradient(90deg,#10b981,#059669);"></div>
          </div>
          <div style="font-size:12px;color:var(--text-secondary);margin-top:6px;">
            <% if (barW >= 50) { %>✅ Muy buen margen — más de la mitad de lo que cobrás es ganancia pura
            <% } else if (barW >= 25) { %>⚠️ Margen moderado — los gastos se llevan bastante, revisá si podés reducir alguno
            <% } else if (barW > 0) { %>🔴 Margen bajo — los gastos son casi iguales a lo que vendés
            <% } else { %>🔴 Este mes los gastos superaron las ventas — revisá los números
            <% } %>
          </div>
        </div>
        <% } %>
      </div>

      <!-- INSIGHTS -->
      <%
        const me      = metricasExtra || {};
        const semAct  = me.semanaActual || 0;
        const diffSem = me.diffSemPct;
      %>
      <div class="grid-chips" style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:20px;">

        <div class="insight-card fade-up" style="animation-delay:.15s;">
          <div class="insight-icon" style="background:rgba(99,102,241,.10);color:#6366f1;"><i class="bi bi-receipt"></i></div>
          <div class="insight-label">Ticket promedio del mes</div>
          <div class="insight-value"><%=fmtPesos(me.ticketMes||0)%></div>
          <div class="insight-sub">Lo que gasta cada cliente en promedio por visita</div>
        </div>

        <div class="insight-card fade-up" style="animation-delay:.20s;">
          <div class="insight-icon" style="background:<%=diffSem===null?'rgba(107,114,128,.1)':diffSem>=0?'rgba(16,185,129,.1)':'rgba(239,68,68,.1)'%>;color:<%=diffSem===null?'#9ca3af':diffSem>=0?'#10b981':'#ef4444'%>;"><i class="bi bi-arrow-left-right"></i></div>
          <div class="insight-label">Esta semana</div>
          <div class="insight-value"><%=fmtPesos(semAct)%></div>
          <div class="insight-sub">
            <% if (diffSem === null) { %>Sin datos de semana anterior
            <% } else if (diffSem > 0) { %><span class="badge-up">▲ <%=diffSem%>% más</span> que la semana pasada
            <% } else if (diffSem < 0) { %><span class="badge-down">▼ <%=Math.abs(diffSem)%>% menos</span> que la semana pasada
            <% } else { %>Igual que la semana pasada<% } %>
          </div>
        </div>

        <div class="insight-card fade-up" style="animation-delay:.25s;">
          <div class="insight-icon" style="background:rgba(245,158,11,.10);color:#f59e0b;"><i class="bi bi-clock"></i></div>
          <div class="insight-label">Hora de mayor venta</div>
          <div class="insight-value"><%=me.horaPico||'—'%></div>
          <div class="insight-sub">
            <% if (me.horaPico) { %>A esta hora vendés más (últimos 30 días)
            <% } else { %>Sin datos suficientes todavía<% } %>
          </div>
        </div>

        <div class="insight-card fade-up" style="animation-delay:.30s;">
          <div class="insight-icon" style="background:<%=deudaProvs>0?'rgba(239,68,68,.10)':'rgba(16,185,129,.10)'%>;color:<%=deudaProvs>0?'#ef4444':'#10b981'%>;"><i class="bi bi-truck"></i></div>
          <div class="insight-label">Deuda a proveedores</div>
          <div class="insight-value" style="color:<%=deudaProvs>0?'#ef4444':'#10b981'%>;">
            <% if (deudaProvs > 0) { %><%=fmtPesos(deudaProvs)%><% } else { %>Sin deudas<% } %>
          </div>
          <div class="insight-sub">
            <% if (deudaProvs > 0) { %>Tenés deuda pendiente con proveedores
            <% } else { %>✓ Estás al día con todos los proveedores<% } %>
          </div>
        </div>
      </div>

      <!-- GRÁFICO 7 DÍAS + GASTOS -->
      <div class="grid-main" style="display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:16px;">
        <div class="dash-card fade-up" style="animation-delay:.18s;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-bar-chart-line" style="color:var(--color-primary);"></i> Ventas de los últimos 7 días</span>
            <button onclick="exportarSemanaCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);"><i class="bi bi-download"></i> CSV</button>
          </div>
          <div style="padding:16px 18px;"><canvas id="chartSemana" height="155"></canvas></div>
        </div>
        <div class="dash-card fade-up" style="animation-delay:.22s;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-receipt" style="color:#ef4444;"></i> En qué gasté este mes</span>
            <a href="/gastos" style="font-size:11.5px;color:var(--color-primary);font-weight:600;text-decoration:none;">Ver todos →</a>
          </div>
          <div style="padding:14px 18px;display:flex;flex-direction:column;gap:10px;">
            <% if (!gastosMes?.porCat?.length) { %>
            <div style="text-align:center;padding:28px;color:var(--text-secondary);">
              <i class="bi bi-receipt" style="font-size:28px;display:block;opacity:.2;margin-bottom:8px;"></i>
              Sin gastos registrados este mes
            </div>
            <% } else {
              const totalCatG = gastosMes.porCat.reduce((a,c)=>a+Number(c.total),0)||1;
              const catColors = {'Alquiler':'#6366f1','Servicios':'#00b4d8','Sueldos':'#10b981','Insumos':'#f59e0b','Impuestos':'#ef4444','Mantenimiento':'#a855f7','Otros':'#9ca3af'};
            %>
            <% for (const cat of gastosMes.porCat) {
               const cc = catColors[cat.categoria]||'#9ca3af';
               const w  = Math.round(Number(cat.total)/totalCatG*100);
            %>
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
                <span style="font-size:12.5px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:6px;">
                  <span style="width:8px;height:8px;border-radius:2px;background:<%=cc%>;flex-shrink:0;"></span><%=cat.categoria%>
                </span>
                <span style="font-family:var(--font-mono);font-size:12.5px;font-weight:700;color:#ef4444;">$<%=Number(cat.total).toLocaleString('es-AR',{minimumFractionDigits:0})%></span>
              </div>
              <div style="height:6px;border-radius:3px;background:var(--border-color);overflow:hidden;">
                <div style="height:100%;background:<%=cc%>;width:<%=w%>%;border-radius:3px;transition:width .6s;"></div>
              </div>
            </div>
            <% } %>
            <div style="padding-top:10px;border-top:1px solid var(--border-color);display:flex;justify-content:space-between;align-items:center;">
              <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">Total gastado este mes</span>
              <span style="font-family:var(--font-mono);font-size:14px;font-weight:800;color:#ef4444;">$<%=gm.toLocaleString('es-AR',{minimumFractionDigits:0})%></span>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- MÉTODOS + TOP PRODUCTOS + STOCK -->
      <div class="grid-3cols" style="display:grid;grid-template-columns:1fr 2fr 1fr;gap:16px;margin-bottom:16px;">
        <div class="dash-card fade-up" style="display:flex;flex-direction:column;animation-delay:.24s;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-pie-chart" style="color:#10b981;"></i> Cómo te pagaron hoy</span>
            <button onclick="exportarMetodosCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);"><i class="bi bi-download"></i> CSV</button>
          </div>
          <div style="padding:14px 18px 8px;"><canvas id="chartMetodos" height="130"></canvas></div>
          <div id="metodosDesglose" style="padding:0 14px 14px;display:flex;flex-direction:column;gap:6px;">
            <div style="text-align:center;padding:10px;color:var(--text-muted);font-size:12px;">Cargando...</div>
          </div>
          <div style="padding:10px 14px;border-top:1px solid var(--border-color);margin-top:auto;">
            <a href="/dashboard/reportes/metodos" style="display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;border-radius:8px;background:rgba(99,102,241,.07);border:1.5px solid rgba(99,102,241,.2);color:#6366f1;font-size:12px;font-weight:700;text-decoration:none;">
              <i class="bi bi-bar-chart-line"></i> Ver reporte completo
            </a>
          </div>
        </div>

        <div class="dash-card fade-up" style="animation-delay:.28s;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-trophy" style="color:#f59e0b;"></i> Lo más vendido (últimos 30 días)</span>
            <button onclick="exportarTopCSV()" style="display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:7px;border:1.5px solid rgba(16,185,129,.4);background:rgba(16,185,129,.07);color:#059669;font-size:11.5px;font-weight:700;cursor:pointer;font-family:var(--font-body);"><i class="bi bi-download"></i> CSV</button>
          </div>
          <div style="padding:14px 18px;"><canvas id="chartProductos" height="170"></canvas></div>
        </div>

        <div class="dash-card fade-up" style="animation-delay:.32s;">
          <div class="dash-card-header">
            <span class="dash-card-title"><i class="bi bi-exclamation-triangle" style="color:#f59e0b;"></i> Stock a reponer</span>
            <a href="/inventario" style="font-size:11.5px;color:var(--color-primary);font-weight:600;text-decoration:none;">Ver todo →</a>
          </div>
          <% if (!stockCritico?.length) { %>
          <div style="padding:28px;text-align:center;color:var(--text-secondary);">
            <i class="bi bi-check-circle" style="color:#10b981;font-size:28px;display:block;margin-bottom:8px;"></i>
            <div style="font-size:13px;font-weight:600;">Todo el stock está bien</div>
            <div style="font-size:12px;margin-top:3px;">Ningún producto con stock crítico</div>
          </div>
          <% } else { %>
          <div style="overflow-y:auto;max-height:260px;">
            <% stockCritico.slice(0,10).forEach(p => { %>
            <div class="stock-alert-item">
              <span style="font-size:12.5px;font-weight:600;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:130px;" title="<%=p.name%>">
                <%=p.name.length>22?p.name.slice(0,20)+'…':p.name%>
              </span>
              <span style="font-size:12px;font-weight:800;padding:3px 10px;border-radius:20px;flex-shrink:0;background:<%=p.stock<=0?'rgba(239,68,68,.12)':'rgba(245,158,11,.12)'%>;color:<%=p.stock<=0?'#dc2626':'#d97706'%>;">
                <%=p.stock<=0?'Sin stock':p.stock+' ud'%>
              </span>
            </div>
            <% }) %>
          </div>
          <div style="padding:10px 16px;border-top:1px solid var(--border-color);">
            <div style="font-size:12px;color:var(--text-secondary);text-align:center;"><%=stockCritico.length%> producto<%=stockCritico.length!==1?'s':''%> con stock crítico</div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- ACTIVIDAD RECIENTE -->
      <div class="dash-card fade-up" style="animation-delay:.35s;">
        <div class="dash-card-header">
          <span class="dash-card-title"><i class="bi bi-lightning-charge" style="color:var(--color-primary);"></i> Últimas ventas de hoy</span>
          <a href="/historial" style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--radius-sm);border:1.5px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-secondary);font-size:12px;font-weight:700;text-decoration:none;">
            <i class="bi bi-clock-history"></i> Ver historial completo
          </a>
        </div>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;" id="tablaActividad">
            <thead>
              <tr>
                <th class="th-dash">N°</th>
                <th class="th-dash">Hora</th>
                <th class="th-dash">Método</th>
                <th class="th-dash">Factura</th>
                <th class="th-dash" style="text-align:right;">Total</th>
              </tr>
            </thead>
            <tbody id="tbodyActividad">
              <tr><td colspan="5" style="padding:32px;text-align:center;color:var(--text-secondary);">
                <span style="display:inline-block;width:16px;height:16px;border:2.5px solid var(--color-primary);border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;"></span>
              </td></tr>
            </tbody>
          </table>
        </div>
      </div>

    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<%- include('../partials/scripts') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
'use strict';
document.getElementById('fechaHoy').textContent =
  new Date().toLocaleDateString('es-AR',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

const dataSemana  = <%- graficoSemana %>;
const dataMetodos = <%- graficoMetodos %>;
const dataTopProd = <%- graficoTopProd %>;
const COLORS = ['#1B4FD8','#10b981','#f59e0b','#6366f1','#ec4899','#8b5cf6','#14b8a6','#f97316'];

function parseFechaLocal(v){return v?new Date(String(v).replace(' ','T')):new Date();}

// Gráfico 7 días
(function(){
  const dias=[],totales=[];
  for(let i=6;i>=0;i--){
    const d=new Date(Date.now()-i*86400000);
    const k=d.toISOString().split('T')[0];
    const f=dataSemana.find(r=>r.fecha===k);
    dias.push(d.toLocaleDateString('es-AR',{weekday:'short',day:'numeric'}));
    totales.push(f?f.total:0);
  }
  new Chart(document.getElementById('chartSemana'),{
    type:'bar',
    data:{labels:dias,datasets:[{label:'Ventas $',data:totales,
      backgroundColor:totales.map((v,i)=>i===6?'rgba(27,79,216,.9)':'rgba(27,79,216,.32)'),
      borderRadius:8,borderSkipped:false}]},
    options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' $'+Number(ctx.raw).toLocaleString('es-AR',{minimumFractionDigits:2})}}},
      scales:{y:{ticks:{callback:v=>'$'+Number(v).toLocaleString('es-AR'),font:{size:11}},grid:{color:'rgba(0,0,0,.04)'}},
              x:{grid:{display:false},ticks:{font:{size:11}}}}}
  });
})();

// Gráfico métodos
(function(){
  const desglose=document.getElementById('metodosDesglose');
  if(!dataMetodos.length){
    document.getElementById('chartMetodos').style.display='none';
    desglose.innerHTML='<p style="font-size:12px;color:var(--text-secondary);text-align:center;padding:12px 0;">Sin ventas hoy</p>';
    return;
  }
  new Chart(document.getElementById('chartMetodos'),{
    type:'doughnut',
    data:{labels:dataMetodos.map(m=>m.payment_method),
          datasets:[{data:dataMetodos.map(m=>m.total),backgroundColor:COLORS,borderWidth:2,borderColor:'var(--bg-surface)'}]},
    options:{responsive:true,cutout:'68%',plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' $'+Number(ctx.raw).toLocaleString('es-AR',{minimumFractionDigits:2})}}}}
  });
  const hoy=new Date().toISOString().split('T')[0];
  fetch('/api/reporte/metodos?'+new URLSearchParams({desde:hoy,hasta:hoy}))
    .then(r=>r.json())
    .then(data=>{
      if(!data.metodos?.length){desglose.innerHTML='';return;}
      const fmt=n=>'$'+Number(n).toLocaleString('es-AR',{minimumFractionDigits:2});
      const totalNeto=data.metodos.reduce((s,m)=>s+m.neto,0);
      let html=data.metodos.map((m,i)=>`
        <div style="background:var(--bg-surface-2);border-radius:9px;padding:8px 10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:${m.comision_pct>0?'5px':'0'};">
            <span style="display:flex;align-items:center;gap:5px;font-size:12px;font-weight:700;color:var(--text-primary);">
              <span style="width:8px;height:8px;border-radius:2px;background:${COLORS[i%COLORS.length]};flex-shrink:0;"></span>${m.metodo}
            </span>
            <span style="font-family:var(--font-mono);font-size:12.5px;font-weight:800;color:var(--text-primary);">${fmt(m.total)}</span>
          </div>
          ${m.comision_pct>0?`<div style="font-size:11px;color:#d97706;">Comisión ${m.comision_pct}% → te llegan ${fmt(m.neto)}</div>`:`<div style="font-size:11px;color:#10b981;font-weight:600;">Sin comisión</div>`}
        </div>`).join('');
      if(data.metodos.length>1)
        html+=`<div style="border-top:1px solid var(--border-color);padding-top:8px;margin-top:2px;display:flex;justify-content:space-between;font-size:13px;">
          <span style="color:#10b981;font-weight:800;">Lo que te llega</span>
          <span style="color:#10b981;font-family:var(--font-mono);font-weight:800;">${fmt(totalNeto)}</span></div>`;
      desglose.innerHTML=html;
    })
    .catch(()=>{
      const tot=dataMetodos.reduce((a,x)=>a+Number(x.total),0);
      desglose.innerHTML=dataMetodos.map((m,i)=>`
        <div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;">
          <span style="display:flex;align-items:center;gap:5px;color:var(--text-secondary);">
            <span style="width:8px;height:8px;border-radius:2px;background:${COLORS[i]};"></span>${m.payment_method}
          </span>
          <span style="font-weight:700;font-family:var(--font-mono);">${Math.round(Number(m.total)/tot*100)}%</span>
        </div>`).join('');
    });
})();

// Gráfico top productos
(function(){
  if(!dataTopProd.length)return;
  new Chart(document.getElementById('chartProductos'),{
    type:'bar',
    data:{labels:dataTopProd.map(p=>p.name.length>22?p.name.slice(0,20)+'…':p.name),
          datasets:[{label:'Unidades',data:dataTopProd.map(p=>p.cantidad),backgroundColor:COLORS,borderRadius:5,borderSkipped:false}]},
    options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false}},
      scales:{x:{grid:{color:'rgba(0,0,0,.04)'},ticks:{font:{size:11}}},y:{grid:{display:false},ticks:{font:{size:11}}}}}
  });
})();

// Actividad reciente
(function(){
  const tbody=document.getElementById('tbodyActividad');
  const hoy=new Date().toISOString().split('T')[0];
  fetch('/api/ventas/buscar?'+new URLSearchParams({desde:hoy,hasta:hoy,limit:8}))
    .then(r=>r.json())
    .then(data=>{
      const ventas=data.ventas||[];
      if(!ventas.length){
        tbody.innerHTML=`<tr><td colspan="5" style="padding:32px;text-align:center;color:var(--text-secondary);font-size:13px;">
          <i class="bi bi-bag-x" style="font-size:24px;display:block;margin-bottom:6px;opacity:.2;"></i>
          Sin ventas registradas hoy todavía</td></tr>`;
        return;
      }
      tbody.innerHTML=ventas.map(v=>{
        const hora=parseFechaLocal(v.created_at).toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit',hour12:false});
        const bf=v.facturada
          ?`<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(27,79,216,.10);color:var(--color-primary);">Factura ${v.factura_tipo_letra||''}</span>`
          :`<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:var(--bg-surface-2);color:var(--text-muted);">Ticket</span>`;
        return `<tr class="fila-act" style="border-bottom:1px solid var(--border-color);">
          <td style="padding:10px 14px;font-size:13px;color:var(--text-secondary);">#${v.id}</td>
          <td style="padding:10px 14px;font-size:13px;font-weight:600;">${hora}</td>
          <td style="padding:10px 14px;"><span style="padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:700;background:rgba(27,79,216,.08);color:var(--color-primary);">${v.payment_method}</span></td>
          <td style="padding:10px 14px;">${bf}</td>
          <td style="padding:10px 18px;text-align:right;font-weight:800;font-size:14px;">$${Number(v.total).toLocaleString('es-AR',{minimumFractionDigits:2})}</td>
        </tr>`;
      }).join('');
    })
    .catch(()=>{tbody.innerHTML=`<tr><td colspan="5" style="padding:20px;text-align:center;color:#ef4444;">Error al cargar</td></tr>`;});
})();

function descargaCSV(csv,nombre){const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'})),download:nombre});a.click();}
function exportarSemanaCSV(){let csv='\uFEFFfecha;total\n';for(let i=6;i>=0;i--){const d=new Date(Date.now()-i*86400000);const k=d.toISOString().split('T')[0];const f=dataSemana.find(r=>r.fecha===k);csv+=`${k};${f?Number(f.total).toFixed(2):'0'}\n`;}descargaCSV(csv,'ventas_semana.csv');}
function exportarTopCSV(){let csv='\uFEFFproducto;unidades\n';dataTopProd.forEach(p=>{csv+=`${p.name};${p.cantidad}\n`;});descargaCSV(csv,'top_productos.csv');}
function exportarMetodosCSV(){let csv='\uFEFFmetodo;total\n';dataMetodos.forEach(m=>{csv+=`${m.payment_method};${Number(m.total).toFixed(2)}\n`;});descargaCSV(csv,'metodos_pago.csv');}
</script>
