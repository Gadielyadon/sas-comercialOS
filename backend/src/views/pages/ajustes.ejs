      <div class="pm-form-row"><label>Color</label><div class="color-row" id="colorRow"></div><input type="hidden" id="pm_color" value="cyan"></div>
      <div class="pm-comisiones-section">
        <div class="pm-comisiones-title"><i class="bi bi-percent" style="color:#6366f1"></i> Porcentajes</div>
        <div class="pm-comision-row">
          <div class="pm-comision-icon" style="background:rgba(245,158,11,.1);color:#d97706;"><i class="bi bi-person-plus"></i></div>
          <div class="pm-comision-info">
            <div class="pm-comision-label">Recargo al cliente</div>
            <div class="pm-comision-desc">Se suma al total en la venta · ej: 5% con Naranja</div>
          </div>
          <div class="pm-comision-input-wrap">
            <input type="number" id="pm_recargo" value="0" min="0" max="100" step="0.1" oninput="actualizarPreviewComision()">
            <span>%</span>
          </div>
        </div>
        <div class="pm-comision-row">
          <div class="pm-comision-icon" style="background:rgba(99,102,241,.1);color:#6366f1;"><i class="bi bi-bank"></i></div>
          <div class="pm-comision-info">
            <div class="pm-comision-label">Comisión interna</div>
            <div class="pm-comision-desc">Lo que te cobra el banco/procesador a vos · para reportes</div>
          </div>
          <div class="pm-comision-input-wrap">
            <input type="number" id="pm_comision" value="0" min="0" max="100" step="0.1" oninput="actualizarPreviewComision()">
