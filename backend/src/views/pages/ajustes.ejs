const PM_ICONS  = ['bi-cash-stack','bi-credit-card','bi-credit-card-2-front','bi-phone','bi-qr-code','bi-clock-history','bi-wallet2','bi-bank','bi-paypal','bi-phone-fill','bi-currency-dollar','bi-coin','bi-bag-check','bi-bag','bi-cart-check','bi-tag','bi-stars','bi-gift','bi-receipt','bi-building'];
const PM_COLORS = [{key:'cyan',hex:'#06b6d4'},{key:'blue',hex:'#3b82f6'},{key:'green',hex:'#10b981'},{key:'orange',hex:'#f97316'},{key:'purple',hex:'#8b5cf6'},{key:'red',hex:'#ef4444'},{key:'yellow',hex:'#f59e0b'},{key:'pink',hex:'#ec4899'}];
const COLOR_HEX  = {cyan:'rgba(0,180,216,.12)',blue:'rgba(59,130,246,.12)',green:'rgba(16,185,129,.12)',orange:'rgba(249,115,22,.12)',purple:'rgba(139,92,246,.12)',red:'rgba(239,68,68,.12)',yellow:'rgba(245,158,11,.12)',pink:'rgba(236,72,153,.12)'};
const COLOR_TEXT = {cyan:'var(--color-action)',blue:'#3b82f6',green:'#10b981',orange:'#f97316',purple:'#8b5cf6',red:'#ef4444',yellow:'#d97706',pink:'#ec4899'};

async function cargarPM_Ajustes() {
  try { const r = await fetch('/api/payment-methods?all=1'); renderPmList(await r.json()); }
  catch(e) { document.getElementById('pmList').innerHTML = '<div style="color:#ef4444;padding:10px;">Error cargando métodos</div>'; }
}

function renderPmList(lista) {
  const cont = document.getElementById('pmList');
  if (!lista.length) { cont.innerHTML = '<div style="color:var(--text-secondary);font-size:13px;padding:12px;text-align:center;">Sin métodos configurados</div>'; return; }
  const tipos = {efectivo:'Efectivo',fiado:'Fiado',otro:'Tarjeta / Digital / Otro'};
  cont.innerHTML = lista.map(m => {
    const bg = COLOR_HEX[m.color]||COLOR_HEX.cyan, text = COLOR_TEXT[m.color]||COLOR_TEXT.cyan;
    const recargo  = m.recargo_cliente_pct  > 0 ? `<span style="font-size:10px;font-weight:700;background:rgba(245,158,11,.12);color:#d97706;padding:1px 7px;border-radius:10px;margin-left:4px">+${m.recargo_cliente_pct}% cliente</span>` : '';
    const comision = m.comision_interna_pct > 0 ? `<span style="font-size:10px;font-weight:700;background:rgba(99,102,241,.1);color:#6366f1;padding:1px 7px;border-radius:10px;margin-left:4px">${m.comision_interna_pct}% com.</span>` : '';
    return `<div class="pm-row" data-id="${m.id}">
      <span class="pm-row-drag"><i class="bi bi-grip-vertical"></i></span>
      <div class="pm-row-icon" style="background:${bg};color:${text};"><i class="bi ${m.icono}"></i></div>
      <div class="pm-row-info">
        <div class="pm-row-nombre">${m.nombre}${recargo}${comision}</div>
        <div class="pm-row-tipo">${tipos[m.tipo]||m.tipo}</div>
      </div>
      <label class="pm-toggle"><input type="checkbox" ${m.activo?'checked':''} onchange="togglePM(${m.id},this.checked)"><span class="pm-toggle-slider"></span></label>
      <div class="pm-row-actions">
        <button class="pm-btn-edit" onclick="editarPM(${m.id})"><i class="bi bi-pencil"></i></button>
        <button class="pm-btn-del"  onclick="eliminarPM(${m.id},'${m.nombre.replace(/'/g,"\\'")}')"><i class="bi bi-trash3"></i></button>
      </div>
    </div>`;
  }).join('');
}

async function togglePM(id) { await fetch(`/api/payment-methods/${id}/toggle`,{method:'PATCH'}); }

function abrirModalPM(data) {
  document.getElementById('pmModalTitle').textContent = data ? 'Editar Método' : 'Nuevo Método de Pago';
  document.getElementById('pmEditId').value  = data ? data.id     : '';
