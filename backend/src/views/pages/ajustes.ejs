  renderColorRow(data?.color || 'cyan');
  actualizarPreviewComision();
  document.getElementById('pmModalOverlay').classList.add('open');
  setTimeout(() => document.getElementById('pm_nombre').focus(), 80);
}

function cerrarModalPM() { document.getElementById('pmModalOverlay').classList.remove('open'); }

function actualizarPreviewComision() {
  const recargo  = parseFloat(document.getElementById('pm_recargo').value)  || 0;
  const comision = parseFloat(document.getElementById('pm_comision').value) || 0;
  const prev = document.getElementById('pmComisionPreview');
  if (recargo === 0 && comision === 0) { prev.classList.remove('visible'); return; }
  const ej = 100000;
  let partes = [];
  if (recargo  > 0) partes.push(`Venta de $${ej.toLocaleString('es-AR')} → cliente paga <strong>$${(ej*(1+recargo/100)).toLocaleString('es-AR')}</strong> (+${recargo}%)`);
  if (comision > 0) partes.push(`Comisión del banco: <strong>-$${(ej*comision/100).toLocaleString('es-AR')}</strong> (${comision}%)`);
  prev.innerHTML = '💡 ' + partes.join(' &nbsp;·&nbsp; ');
  prev.classList.add('visible');
}

function renderIconGrid(selected) {
  document.getElementById('iconGrid').innerHTML = PM_ICONS.map(ic =>
    `<div class="icon-opt ${ic===selected?'selected':''}" onclick="selectIcon('${ic}')"><i class="bi ${ic}"></i></div>`).join('');
}
function selectIcon(ic) { document.getElementById('pm_icono').value = ic; renderIconGrid(ic); }

function renderColorRow(selected) {
  document.getElementById('colorRow').innerHTML = PM_COLORS.map(c =>
    `<div class="color-dot ${c.key===selected?'selected':''}" style="background:${c.hex};" onclick="selectColor('${c.key}')"></div>`).join('');
}
function selectColor(key) { document.getElementById('pm_color').value = key; renderColorRow(key); }

async function editarPM(id) { const r = await fetch(`/api/payment-methods/${id}`); abrirModalPM(await r.json()); }

async function guardarPM() {
  const id     = document.getElementById('pmEditId').value;
  const nombre = document.getElementById('pm_nombre').value.trim();
  if (!nombre) { alert('El nombre es obligatorio'); return; }
  const body = JSON.stringify({
    nombre, tipo: document.getElementById('pm_tipo').value,
    icono: document.getElementById('pm_icono').value, color: document.getElementById('pm_color').value,
    recargo_cliente_pct:  parseFloat(document.getElementById('pm_recargo').value)  || 0,
    comision_interna_pct: parseFloat(document.getElementById('pm_comision').value) || 0,
  });
  const r = await fetch(id ? `/api/payment-methods/${id}` : '/api/payment-methods', {
    method: id ? 'PUT' : 'POST', headers: {'Content-Type':'application/json'}, body
  });
  if (!r.ok) { alert('Error al guardar'); return; }
  cerrarModalPM(); cargarPM_Ajustes();
}

async function eliminarPM(id, nombre) {
  if (!confirm(`¿Eliminar "${nombre}"?`)) return;
  await fetch(`/api/payment-methods/${id}`,{method:'DELETE'});
  cargarPM_Ajustes();
}

function setTema(tema) {
  document.documentElement.setAttribute('data-theme', tema);
  localStorage.setItem('theme', tema);
  actualizarBtnsTema(tema);
}

function actualizarBtnsTema(tema) {
  const btnClaro  = document.getElementById('btnTemaClaro');
  const btnOscuro = document.getElementById('btnTemaOscuro');
  if (!btnClaro || !btnOscuro) return;
  const activeStyle = 'display:flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-md);border:1.5px solid var(--color-action);background:rgba(0,180,216,.1);color:var(--color-action);font-family:var(--font-body);font-size:13px;font-weight:700;cursor:pointer;transition:all .15s;';
  const normalStyle = 'display:flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-md);border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-secondary);font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;';
  btnClaro.style.cssText  = tema === 'light' ? activeStyle : normalStyle;
  btnOscuro.style.cssText = tema === 'dark'  ? activeStyle : normalStyle;
}

document.addEventListener('DOMContentLoaded', () => {
  const temaActual = document.documentElement.getAttribute('data-theme') || localStorage.getItem('theme') || 'light';
  actualizarBtnsTema(temaActual);
});
</script>
