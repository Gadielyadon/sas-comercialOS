      <button onclick="cerrarModalPM()" class="btn-action btn-action-outline" style="padding:11px 14px;">Cancelar</button>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>

<script>
'use strict';

document.addEventListener('DOMContentLoaded', () => {
  ['aj_nombre','aj_tagline','aj_direccion','aj_telefono','aj_email','aj_footer'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', actualizarPreview);
  });
  const pvFecha = document.getElementById('pv-fecha');
  if (pvFecha) pvFecha.textContent = new Date().toLocaleString('es-AR',{dateStyle:'short',timeStyle:'short'});
  cargarConfig();
  if (document.body.dataset.userRole === 'admin') cargarUsuarios();
  cargarPM_Ajustes();
});

let _config = {};
let _logoBase64 = null;

function toggleFacturacionHabilitada(chk) {
  const track = document.getElementById('facturacion_habilitada_track');
  const thumb = document.getElementById('facturacion_habilitada_thumb');
  const wrap  = document.getElementById('afipConfigWrap');
  if (track) track.style.background = chk.checked ? 'var(--color-action)' : 'var(--border-color)';
  if (thumb) thumb.style.transform  = chk.checked ? 'translateX(24px)' : 'translateX(0)';
  if (wrap)  wrap.style.display     = chk.checked ? 'block' : 'none';
  const el = document.getElementById('afipTestResult');
  if (!chk.checked && el) el.textContent = '';
}

function syncFacturacionUI() {
  const chk = document.getElementById('facturacion_habilitada');
  if (chk) toggleFacturacionHabilitada(chk);
}

async function cargarConfig() {
  try { const r = await fetch('/api/config'); _config = await r.json(); } catch(e) { _config = {}; }

  document.getElementById('aj_nombre').value    = _config.empresa_nombre    || '';
  document.getElementById('aj_tagline').value   = _config.empresa_tagline   || '';
  document.getElementById('aj_direccion').value = _config.empresa_direccion || '';
  document.getElementById('aj_telefono').value  = _config.empresa_telefono  || '';
  document.getElementById('aj_email').value     = _config.empresa_email     || '';
  document.getElementById('aj_footer').value    = _config.ticket_footer     || '¡Gracias por su compra!';
  document.getElementById('aj_inicio_actividades').value = _config.empresa_inicio_actividades || '';
  document.getElementById('aj_iibb').value               = _config.empresa_iibb               || '';

  const formato = _config.ticket_formato || '80mm';
  document.getElementById('aj_fmt80').checked = formato === '80mm';
  document.getElementById('aj_fmtA4').checked = formato === 'A4';
  document.getElementById('fmt80card').classList.toggle('selected', formato === '80mm');
  document.getElementById('fmtA4card').classList.toggle('selected', formato === 'A4');

  const factChk = document.getElementById('facturacion_habilitada');
  if (factChk) factChk.checked = String(_config.facturacion_habilitada || '0') === '1';

  const balChk = document.getElementById('balanza_habilitada');
  if (balChk) balChk.checked = String(_config.balanza_habilitada || '0') === '1';
  const balModo = document.getElementById('balanza_modo');
  if (balModo) balModo.value = _config.balanza_modo || 'precio';
  const balPref = document.getElementById('balanza_prefijo');
  if (balPref) balPref.value = _config.balanza_prefijo || '2';

  if (_config.empresa_logo) mostrarLogoPreview(_config.empresa_logo);
  actualizarPreview();
  syncFacturacionUI();
  document.getElementById('pv-fecha').textContent = new Date().toLocaleString('es-AR',{dateStyle:'short',timeStyle:'short'});
}

function selFormatoCard(label, value) {
  document.querySelectorAll('.formato-card').forEach(c => c.classList.remove('selected'));
  label.classList.add('selected');
  label.querySelector('input').checked = true;
  actualizarPreview();
}

function handleLogoFile(file) {
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { alert('Máximo 2MB.'); return; }
  const reader = new FileReader();
  reader.onload = e => { _logoBase64 = e.target.result; mostrarLogoPreview(_logoBase64); actualizarPreview(); };
  reader.readAsDataURL(file);
}

function handleLogoDrop(e) {
  e.preventDefault();
  document.getElementById('logoZone').classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) handleLogoFile(file);
}

function mostrarLogoPreview(src) {
  document.getElementById('logoPreview').src = src;
  document.getElementById('logoPreview').classList.add('visible');
  document.getElementById('logoPlaceholder').style.display = 'none';
  document.getElementById('logoActions').style.display = 'flex';
  document.getElementById('logoZone').classList.add('has-logo');
}

function removerLogo() {
  _logoBase64 = '';
  document.getElementById('logoPreview').src = '';
  document.getElementById('logoPreview').classList.remove('visible');
  document.getElementById('logoPlaceholder').style.display = 'block';
  document.getElementById('logoActions').style.display = 'none';
  document.getElementById('logoZone').classList.remove('has-logo');
  document.getElementById('logoFileInput').value = '';
  document.getElementById('pv-logo-wrap').style.display = 'none';
}

function actualizarPreview() {
  const nombre    = document.getElementById('aj_nombre').value    || 'Mi Comercio';
  const direccion = document.getElementById('aj_direccion').value || '';
  const telefono  = document.getElementById('aj_telefono').value  || '';
  const footer    = document.getElementById('aj_footer').value    || '¡Gracias por su compra!';
  document.getElementById('pv-nombre').textContent    = nombre;
  document.getElementById('pv-direccion').textContent = direccion;
  document.getElementById('pv-telefono').textContent  = telefono ? `Tel: ${telefono}` : '';
  document.getElementById('pv-footer').textContent    = footer;
  const logoSrc = _logoBase64 !== null ? _logoBase64 : (_config.empresa_logo || '');
  const pvLogoWrap = document.getElementById('pv-logo-wrap');
  if (logoSrc && _logoBase64 !== '') {
    document.getElementById('pv-logo').src = logoSrc;
    pvLogoWrap.style.display = 'block';
  } else {
    pvLogoWrap.style.display = 'none';
  }
}

async function guardarAjustes() {
  const body = {
    empresa_nombre:               document.getElementById('aj_nombre').value.trim(),
    empresa_tagline:              document.getElementById('aj_tagline').value.trim(),
    empresa_direccion:            document.getElementById('aj_direccion').value.trim(),
    empresa_telefono:             document.getElementById('aj_telefono').value.trim(),
    empresa_email:                document.getElementById('aj_email').value.trim(),
    empresa_inicio_actividades:   document.getElementById('aj_inicio_actividades').value.trim(),
    empresa_iibb:                 document.getElementById('aj_iibb').value.trim(),
    ticket_footer:                document.getElementById('aj_footer').value.trim(),
    ticket_formato:               document.querySelector('input[name="aj_formato"]:checked')?.value || '80mm',
    facturacion_habilitada:       document.getElementById('facturacion_habilitada')?.checked ? '1' : '0',
    balanza_habilitada:           document.getElementById('balanza_habilitada')?.checked ? '1' : '0',
    balanza_modo:                 document.getElementById('balanza_modo')?.value || 'precio',
    balanza_prefijo:              document.getElementById('balanza_prefijo')?.value || '2',
    afip_cuit:                    (document.getElementById('afip_cuit')?.value        || '').trim(),
    afip_punto_venta:             (document.getElementById('afip_punto_venta')?.value || '1').trim(),
    afip_cert_path:               (document.getElementById('afip_cert_path')?.value   || 'certs/cert.crt').trim(),
    afip_key_path:                (document.getElementById('afip_key_path')?.value    || 'certs/private.key').trim(),
    afip_env:                     document.getElementById('afip_env')?.value || 'homologacion',
    empresa_cond_iva:             (document.getElementById('empresa_cond_iva')?.value || 'Responsable Inscripto').trim(),
  };

  if (_logoBase64 !== null) body.empresa_logo = _logoBase64;

  const r = await fetch('/api/config', {
    method: 'PUT',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify(body)
  });

  if (!r.ok) { showToast('Error guardando', false); return; }

  _config = await r.json();
  _logoBase64 = null;
  syncFacturacionUI();
  showToast('¡Configuración guardada correctamente!', true);
}

async function testAfipConexion() {
  const factChk = document.getElementById('facturacion_habilitada');
  const el = document.getElementById('afipTestResult');
  if (!factChk?.checked) { el.textContent = '⚪ Facturación electrónica desactivada'; el.style.color = 'var(--text-secondary)'; return; }
  el.textContent = '⏳ Probando...'; el.style.color = 'var(--text-secondary)';
  try {
    const r = await fetch('/afip/test');
    const data = await r.json();
    if (data.ok) { el.textContent = '✅ Conexión exitosa con AFIP'; el.style.color = '#10b981'; }
    else { el.textContent = '❌ ' + (data.error || 'Error de conexión'); el.style.color = '#ef4444'; }
  } catch(e) { el.textContent = '❌ Error: ' + e.message; el.style.color = '#ef4444'; }
}

