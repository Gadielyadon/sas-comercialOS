let _toastTimer = null;
function showToast(msg, success=true) {
  const toast = document.getElementById('ajToast');
  const icon  = toast.querySelector('i');
  toast.style.borderLeftColor = success ? '#10b981' : '#ef4444';
  icon.style.color = success ? '#10b981' : '#ef4444';
  icon.className = success ? 'bi bi-check-circle-fill' : 'bi bi-x-circle-fill';
  document.getElementById('ajToastMsg').textContent = msg;
  toast.classList.add('show');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
}

/* ══ USUARIOS ══ */
let _uEditId = null;

async function cargarUsuarios() {
  const res = await fetch('/api/users');
  if (!res.ok) return;
  const users = await res.json();
  const tbody = document.getElementById('usersTbody');
  if (!users.length) { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-secondary);">Sin usuarios</td></tr>'; return; }
  tbody.innerHTML = users.map(u => `
    <tr>
      <td class="sale-id">${u.username}</td>
      <td><strong>${u.nombre || '—'}</strong></td>
      <td>${u.role === 'admin' ? `<span style="font-size:11px;font-weight:700;padding:2px 9px;border-radius:4px;background:rgba(0,180,216,.1);color:var(--color-action);">Admin</span>` : `<span style="font-size:11px;font-weight:700;padding:2px 9px;border-radius:4px;background:rgba(100,116,139,.08);color:#64748b;">Empleado</span>`}</td>
      <td>${u.activo ? `<span class="badge-status badge-pagado">Activo</span>` : `<span class="badge-status badge-anulado">Inactivo</span>`}</td>
      <td><div style="display:flex;gap:6px;">
        <button onclick="abrirEditarUsuario(${JSON.stringify(u).replace(/"/g,'&quot;')})" style="padding:4px 10px;border:1px solid rgba(0,180,216,.3);border-radius:6px;background:rgba(0,180,216,.06);color:var(--color-action);font-size:12px;cursor:pointer;"><i class="bi bi-pencil"></i></button>
        <button onclick="toggleActivoUsuario(${u.id},${u.activo})" style="padding:4px 10px;border:1px solid var(--border-color);border-radius:6px;background:transparent;color:var(--text-secondary);font-size:12px;cursor:pointer;"><i class="bi bi-${u.activo?'pause-circle':'play-circle'}"></i></button>
        <button onclick="eliminarUsuario(${u.id},'${u.username}')" style="padding:4px 10px;border:1px solid rgba(239,68,68,.25);border-radius:6px;background:rgba(239,68,68,.05);color:#ef4444;font-size:12px;cursor:pointer;"><i class="bi bi-trash3"></i></button>
      </div></td>
    </tr>`).join('');
}

function setRol(rol) {
  document.getElementById('u_role_admin').checked    = rol === 'admin';
  document.getElementById('u_role_empleado').checked = rol === 'empleado';
  document.getElementById('u_role_admin_lbl').style.borderColor    = rol === 'admin'    ? 'var(--color-action)' : 'var(--border-color)';
  document.getElementById('u_role_admin_lbl').style.background     = rol === 'admin'    ? 'rgba(0,180,216,.05)' : '';
  document.getElementById('u_role_empleado_lbl').style.borderColor = rol === 'empleado' ? '#64748b' : 'var(--border-color)';
  document.getElementById('u_role_empleado_lbl').style.background  = rol === 'empleado' ? 'rgba(100,116,139,.05)' : '';
}

function toggleUPass() {
  const inp = document.getElementById('u_password');
  inp.type = inp.type === 'password' ? 'text' : 'password';
  document.getElementById('uPassEye').className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}

function abrirModalUsuario() {
  _uEditId = null;
  document.getElementById('uModalTitulo').textContent = 'Nuevo usuario';
  document.getElementById('uModalSub').textContent    = 'Completá los datos';
  document.getElementById('uBtnLabel').textContent    = 'Crear usuario';
  document.getElementById('u_username').value = '';
  document.getElementById('u_nombre').value   = '';
  document.getElementById('u_password').value = '';
  document.getElementById('u_username_wrap').style.display = '';
  document.getElementById('u_pass_hint').style.display     = 'none';
  document.getElementById('u_pass_label').textContent      = 'Contraseña';
  setRol('empleado');
  document.getElementById('modalUsuario').classList.add('open');
  setTimeout(() => document.getElementById('u_username').focus(), 80);
}

function abrirEditarUsuario(u) {
  _uEditId = u.id;
  document.getElementById('uModalTitulo').textContent = 'Editar usuario';
  document.getElementById('uModalSub').textContent    = '@' + u.username;
  document.getElementById('uBtnLabel').textContent    = 'Guardar cambios';
  document.getElementById('u_username').value = u.username;
  document.getElementById('u_nombre').value   = u.nombre || '';
  document.getElementById('u_password').value = '';
  document.getElementById('u_username_wrap').style.display = 'none';
  document.getElementById('u_pass_hint').style.display     = 'block';
  document.getElementById('u_pass_label').textContent      = 'Nueva contraseña (opcional)';
  setRol(u.role);
  document.getElementById('modalUsuario').classList.add('open');
  setTimeout(() => document.getElementById('u_nombre').focus(), 80);
}

function cerrarModalUsuario() { document.getElementById('modalUsuario').classList.remove('open'); }

async function guardarUsuario() {
  const nombre   = document.getElementById('u_nombre').value.trim();
  const role     = document.querySelector('input[name="u_role"]:checked')?.value || 'empleado';
  const password = document.getElementById('u_password').value;
  if (_uEditId) {
    const r = await fetch(`/api/users/${_uEditId}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({nombre,role}) });
    if (!r.ok) { const e = await r.json(); alert(e.error||'Error'); return; }
    if (password) {
      const rp = await fetch(`/api/users/${_uEditId}/password`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password}) });
      if (!rp.ok) { const e = await rp.json(); alert(e.error||'Error'); return; }
    }
  } else {
    const username = document.getElementById('u_username').value.trim();
    if (!username) { alert('El nombre de usuario es obligatorio'); return; }
    if (!password || password.length < 4) { alert('La contraseña debe tener al menos 4 caracteres'); return; }
    const r = await fetch('/api/users', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({username,nombre:nombre||username,role,password}) });
    if (!r.ok) { const e = await r.json(); alert(e.error||'Error'); return; }
  }
  cerrarModalUsuario();
  cargarUsuarios();
}

async function toggleActivoUsuario(id, activo) {
  const r = await fetch(`/api/users/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({activo:activo?0:1}) });
  if (!r.ok) { const e = await r.json(); alert(e.error||'Error'); return; }
  cargarUsuarios();
}

async function eliminarUsuario(id, username) {
  if (!confirm(`¿Eliminar el usuario "${username}"?`)) return;
  const r = await fetch(`/api/users/${id}`, { method:'DELETE' });
  if (!r.ok) { const e = await r.json(); alert(e.error||'Error'); return; }
  cargarUsuarios();
}

