<%- include('../partials/head', { title: 'Ajustes' }) %>

<style>
  .main-content { min-height: 100vh; display: flex; flex-direction: column; padding-top: var(--header-height); background: var(--bg-body); }
  .page-body { flex: 1; padding: 28px 32px; max-width: 860px; width: 100%; margin: 0 auto; }

  .aj-section { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 20px; box-shadow: var(--shadow-sm); }
  .aj-section-header { display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--border-color); background: var(--bg-body); }
  .aj-section-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #fff; flex-shrink: 0; }
  .aj-section-icon.blue   { background: linear-gradient(135deg, var(--color-action), #0099b8); }
  .aj-section-icon.purple { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
  .aj-section-icon.green  { background: linear-gradient(135deg, #10b981, #059669); }
  .aj-section-title { font-size: 14px; font-weight: 700; color: var(--text-primary); }
  .aj-section-desc  { font-size: 12px; color: var(--text-secondary); margin-top: 1px; }
  .aj-section-body  { padding: 20px; }

  .aj-grid { display: grid; gap: 14px; }
  .aj-grid-2 { grid-template-columns: 1fr 1fr; }
  .aj-grid-3 { grid-template-columns: 1fr 1fr 1fr; }

  .aj-field label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-secondary); margin-bottom: 6px; }
  .aj-field input, .aj-field textarea, .aj-field select {
    width: 100%; padding: 10px 13px; border-radius: var(--radius-sm);
    border: 1.5px solid var(--border-color); background: var(--bg-body);
    color: var(--text-primary); font-family: var(--font-body); font-size: 13.5px;
    outline: none; transition: border-color .15s, box-shadow .15s;
  }
  .aj-field input:focus, .aj-field textarea:focus, .aj-field select:focus {
    border-color: var(--color-action); box-shadow: 0 0 0 3px rgba(0,180,216,.1);
  }
  .aj-field textarea { resize: vertical; min-height: 64px; }
  .aj-field .field-hint { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

  .logo-zone { border: 2px dashed var(--border-color); border-radius: var(--radius-md); padding: 24px; text-align: center; cursor: pointer; transition: all .2s; background: var(--bg-body); position: relative; }
  .logo-zone:hover, .logo-zone.drag-over { border-color: var(--color-action); background: rgba(0,180,216,.04); }
  .logo-zone.has-logo { border-style: solid; border-color: rgba(0,180,216,.3); background: rgba(0,180,216,.03); }
  .logo-preview { max-height: 80px; max-width: 100%; object-fit: contain; margin-bottom: 10px; display: none; border-radius: 6px; }
  .logo-preview.visible { display: inline-block; }
  .logo-zone-icon { font-size: 32px; color: var(--text-secondary); opacity: .4; margin-bottom: 8px; }
  .logo-zone-text { font-size: 13px; color: var(--text-secondary); }
  .logo-zone-sub  { font-size: 11px; color: var(--text-secondary); opacity: .6; margin-top: 3px; }
  .logo-actions { display: flex; gap: 8px; justify-content: center; margin-top: 10px; }
  .btn-logo-change { font-size: 12px; font-weight: 600; color: var(--color-action); background: rgba(0,180,216,.1); border: none; border-radius: 6px; padding: 5px 12px; cursor: pointer; transition: background .15s; }
  .btn-logo-change:hover { background: rgba(0,180,216,.18); }
  .btn-logo-remove { font-size: 12px; font-weight: 600; color: #ef4444; background: rgba(239,68,68,.08); border: none; border-radius: 6px; padding: 5px 12px; cursor: pointer; transition: background .15s; }
  .btn-logo-remove:hover { background: rgba(239,68,68,.16); }
  #logoFileInput { display: none; }

  .formato-options { display: flex; gap: 10px; }
  .formato-card { flex: 1; border: 2px solid var(--border-color); border-radius: var(--radius-md); padding: 14px 12px; cursor: pointer; transition: all .18s; text-align: center; background: var(--bg-body); position: relative; }
  .formato-card:hover { border-color: rgba(0,180,216,.4); }
  .formato-card.selected { border-color: var(--color-action); background: rgba(0,180,216,.05); }
  .formato-card.selected::after { content: ''; position: absolute; top: 8px; right: 8px; width: 8px; height: 8px; border-radius: 50%; background: var(--color-action); }
  .formato-card input { display: none; }
  .formato-icon { font-size: 28px; margin-bottom: 6px; }
  .formato-name { font-size: 13px; font-weight: 700; color: var(--text-primary); }
  .formato-desc { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }

  .ticket-preview-wrap { background: var(--bg-body); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 16px; }
  .ticket-preview-label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--text-secondary); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .ticket-paper { font-family: 'Courier New', monospace; font-size: 11px; line-height: 1.5; color: #111; background: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 12px 10px; box-shadow: 0 2px 8px rgba(0,0,0,.08); max-width: 260px; margin: 0 auto; }
  .ticket-paper .t-center { text-align: center; }
  .ticket-paper .t-sep { border: none; border-top: 1px dashed #aaa; margin: 6px 0; }
  .ticket-paper .t-bold { font-weight: 700; }
  .ticket-paper .t-small { font-size: 9px; color: #666; }
  .ticket-paper .t-row { display: flex; justify-content: space-between; }

  .aj-actions { display: flex; gap: 10px; padding: 0 0 28px; }
  .btn-guardar { padding: 12px 28px; border-radius: var(--radius-md); border: none; background: linear-gradient(135deg,var(--color-action),#0099b8); color: #fff; font-family: var(--font-body); font-size: 14px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all .18s; box-shadow: 0 4px 14px rgba(0,180,216,.3); }
  .btn-guardar:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,180,216,.4); }
  .btn-guardar:active { transform: translateY(0); }
  .btn-test-ticket { padding: 12px 20px; border-radius: var(--radius-md); border: 1.5px solid var(--border-color); background: transparent; color: var(--text-secondary); font-family: var(--font-body); font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all .15s; }
  .btn-test-ticket:hover { border-color: var(--color-action); color: var(--color-action); background: rgba(0,180,216,.05); }

  .aj-toast { position: fixed; bottom: 24px; right: 24px; background: var(--bg-card); border: 1px solid var(--border-color); border-left: 3px solid #10b981; border-radius: var(--radius-sm); padding: 12px 18px; display: flex; align-items: center; gap: 10px; font-size: 13.5px; font-weight: 500; color: var(--text-primary); box-shadow: var(--shadow-lg); z-index: 999; transform: translateY(80px); opacity: 0; transition: transform .22s ease, opacity .22s ease; }
  .aj-toast.show { transform: translateY(0); opacity: 1; }
  .aj-toast i { font-size: 16px; color: #10b981; }

  /* Divisor interno dentro de sección */
  .aj-divider { border: none; border-top: 1px solid var(--border-color); margin: 18px 0; }

  /* Métodos de pago */
  .pm-list { display: flex; flex-direction: column; gap: 8px; }
  .pm-row { display: flex; align-items: center; gap: 14px; padding: 12px 16px; background: var(--bg-body); border: 1px solid var(--border-color); border-radius: var(--radius-md); transition: all .15s; }
  .pm-row:hover { border-color: rgba(0,180,216,.3); box-shadow: 0 2px 8px rgba(0,0,0,.05); }
  .pm-row-drag { cursor: grab; color: var(--text-secondary); font-size: 16px; flex-shrink: 0; }
  .pm-row-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0; }
  .pm-row-info { flex: 1; min-width: 0; }
  .pm-row-nombre { font-size: 14px; font-weight: 600; color: var(--text-primary); }
  .pm-row-tipo   { font-size: 11px; color: var(--text-secondary); }
  .pm-toggle { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
  .pm-toggle input { opacity: 0; width: 0; height: 0; }
  .pm-toggle-slider { position: absolute; inset: 0; background: var(--border-color); border-radius: 24px; cursor: pointer; transition: .2s; }
  .pm-toggle-slider::before { content:''; position:absolute; width:18px; height:18px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.2s; }
  .pm-toggle input:checked + .pm-toggle-slider { background: var(--color-action); }
  .pm-toggle input:checked + .pm-toggle-slider::before { transform: translateX(20px); }
  .pm-row-actions { display: flex; gap: 5px; flex-shrink: 0; }
  .pm-btn-edit, .pm-btn-del { width: 30px; height: 30px; border-radius: 7px; border: none; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 14px; transition: all .12s; }
  .pm-btn-edit { color: var(--text-secondary); }
  .pm-btn-edit:hover { background: rgba(0,180,216,.1); color: var(--color-action); }
  .pm-btn-del  { color: var(--text-secondary); }
  .pm-btn-del:hover  { background: rgba(239,68,68,.1); color: #ef4444; }
  .btn-add-pm { display: flex; align-items: center; gap: 8px; padding: 10px 18px; border: 2px dashed var(--border-color); border-radius: var(--radius-md); background: transparent; color: var(--text-secondary); font-family: var(--font-body); font-size: 13px; font-weight: 600; cursor: pointer; transition: all .15s; width: 100%; justify-content: center; margin-top: 6px; }
  .btn-add-pm:hover { border-color: var(--color-action); color: var(--color-action); background: rgba(0,180,216,.04); }
  .pm-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 400; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .2s; backdrop-filter: blur(3px); }
  .pm-modal-overlay.open { opacity: 1; pointer-events: all; }
  .pm-modal { background: var(--bg-card); border-radius: 16px; padding: 28px; width: 460px; max-width: 95vw; max-height: 90vh; overflow-y: auto; transform: scale(.93); transition: transform .22s; border: 1px solid var(--border-color); box-shadow: 0 16px 50px rgba(0,0,0,.15); }
  .pm-modal-overlay.open .pm-modal { transform: scale(1); }
  .pm-form-row { display: flex; flex-direction: column; gap: 5px; }
  .pm-form-row label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-secondary); }
  .pm-form-row input, .pm-form-row select { padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); background: var(--bg-body); color: var(--text-primary); font-family: var(--font-body); font-size: 13.5px; outline: none; transition: border-color .15s; }
  .pm-form-row input:focus, .pm-form-row select:focus { border-color: var(--color-action); }
  .icon-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; margin-top: 4px; max-height: 180px; overflow-y: auto; padding: 2px; }
  .icon-opt { width: 36px; height: 36px; border: 1.5px solid var(--border-color); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--text-secondary); cursor: pointer; }
  .icon-opt:hover { border-color: var(--color-action); color: var(--color-action); background: rgba(0,180,216,.07); }
  .icon-opt.selected { border-color: var(--color-action); background: rgba(0,180,216,.12); color: var(--color-action); }
  .color-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .color-dot { width: 28px; height: 28px; border-radius: 50%; cursor: pointer; border: 2.5px solid transparent; transition: all .12s; }
  .color-dot.selected { border-color: var(--text-primary); transform: scale(1.1); }
  .pm-comisiones-section { background: var(--bg-body); border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden; }
  .pm-comisiones-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-secondary); padding: 10px 14px 8px; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; gap: 6px; }
  .pm-comision-row { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-bottom: 1px solid var(--border-color); }
  .pm-comision-row:last-child { border-bottom: none; }
  .pm-comision-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
  .pm-comision-info { flex: 1; min-width: 0; }
  .pm-comision-label { font-size: 13px; font-weight: 600; color: var(--text-primary); }
  .pm-comision-desc  { font-size: 11px; color: var(--text-secondary); margin-top: 1px; }
  .pm-comision-input-wrap { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
  .pm-comision-input-wrap input { width: 72px; padding: 7px 8px; border-radius: 7px; border: 1.5px solid var(--border-color); background: var(--bg-card); color: var(--text-primary); font-family: var(--font-mono); font-size: 14px; font-weight: 700; text-align: right; outline: none; transition: border-color .15s; }
  .pm-comision-input-wrap input:focus { border-color: var(--color-action); }
  .pm-comision-input-wrap span { font-size: 13px; font-weight: 700; color: var(--text-secondary); }
  .pm-comision-preview { font-size: 11px; color: var(--text-secondary); padding: 8px 14px; background: rgba(99,102,241,.04); border-top: 1px solid var(--border-color); display: none; }
  .pm-comision-preview.visible { display: block; }
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'ajustes', user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module: 'Ajustes', user }) %>
    <div class="page-body">

      <!-- ══════════════════════════════════════
           DATOS DE LA EMPRESA
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon blue"><i class="bi bi-building"></i></div>
          <div>
            <div class="aj-section-title">Datos de la empresa</div>
            <div class="aj-section-desc">Información que aparece en el encabezado de tickets y presupuestos</div>
          </div>
        </div>
        <div class="aj-section-body">

          <!-- Nombre + Tagline -->
          <div class="aj-grid" style="margin-bottom:14px;">
            <div class="aj-field">
              <label>Nombre del negocio *</label>
              <input type="text" id="aj_nombre" placeholder="Ej: Green Team">
            </div>
          </div>
          <div class="aj-grid" style="margin-bottom:14px;">
            <div class="aj-field">
              <label>Descripción / Tagline <span style="font-weight:400;opacity:.6;">(opcional)</span></label>
              <input type="text" id="aj_tagline" placeholder="Ej: Mantenimiento integral de espacios verdes">
              <div class="field-hint">Aparece debajo del nombre en el encabezado del presupuesto.</div>
            </div>
          </div>

          <!-- Dirección -->
          <div class="aj-grid" style="margin-bottom:14px;">
            <div class="aj-field">
              <label>Dirección</label>
              <input type="text" id="aj_direccion" placeholder="Ej: Av. San Martín 123, Catamarca">
            </div>
          </div>

          <!-- Teléfono + Email -->
          <div class="aj-grid aj-grid-2" style="margin-bottom:14px;">
            <div class="aj-field">
              <label>Teléfono</label>
              <input type="text" id="aj_telefono" placeholder="Ej: 383-4123456">
            </div>
            <div class="aj-field">
              <label>Email</label>
              <input type="text" id="aj_email" placeholder="Ej: local@email.com">
            </div>
          </div>

          <hr class="aj-divider">

          <!-- Datos fiscales -->
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text-secondary);margin-bottom:12px;">
            <i class="bi bi-file-earmark-text" style="margin-right:5px;"></i> Datos fiscales (opcionales — aparecen en presupuestos)
          </div>
          <div class="aj-grid aj-grid-2" style="margin-bottom:14px;">
            <div class="aj-field">
              <label>Inicio de actividades</label>
              <input type="text" id="aj_inicio_actividades" placeholder="Ej: 10/2025">
            </div>
            <div class="aj-field">
              <label>Ingresos Brutos (IIBB)</label>
              <input type="text" id="aj_iibb" placeholder="Ej: 76771">
            </div>
          </div>

        </div>
      </div>

      <!-- ══════════════════════════════════════
           LOGO
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon purple"><i class="bi bi-image"></i></div>
          <div>
            <div class="aj-section-title">Logo del negocio</div>
            <div class="aj-section-desc">Se mostrará en tickets y presupuestos. PNG, JPG o SVG, máx. 2MB.</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div class="logo-zone" id="logoZone"
            onclick="document.getElementById('logoFileInput').click()"
            ondragover="event.preventDefault();this.classList.add('drag-over')"
            ondragleave="this.classList.remove('drag-over')"
            ondrop="handleLogoDrop(event)">
            <img id="logoPreview" class="logo-preview" src="" alt="Logo">
            <div id="logoPlaceholder">
              <div class="logo-zone-icon"><i class="bi bi-cloud-upload"></i></div>
              <div class="logo-zone-text">Arrastrá tu logo acá o hacé click para seleccionar</div>
              <div class="logo-zone-sub">PNG, JPG, SVG — máx. 2MB</div>
            </div>
            <div class="logo-actions" id="logoActions" style="display:none;">
              <button class="btn-logo-change" onclick="event.stopPropagation();document.getElementById('logoFileInput').click()"><i class="bi bi-pencil"></i> Cambiar</button>
              <button class="btn-logo-remove" onclick="event.stopPropagation();removerLogo()"><i class="bi bi-trash3"></i> Quitar</button>
            </div>
          </div>
          <input type="file" id="logoFileInput" accept="image/png,image/jpeg,image/svg+xml,image/webp" onchange="handleLogoFile(this.files[0])">
        </div>
      </div>

      <!-- ══════════════════════════════════════
           TICKET
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon green"><i class="bi bi-receipt"></i></div>
          <div>
            <div class="aj-section-title">Configuración del ticket</div>
            <div class="aj-section-desc">Formato de impresión y mensaje al pie</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div style="margin-bottom:18px;">
            <div class="aj-field" style="margin-bottom:0;"><label>Formato de impresión</label></div>
            <div class="formato-options" style="margin-top:8px;">
              <label class="formato-card selected" id="fmt80card" onclick="selFormatoCard(this,'80mm')">
                <input type="radio" name="aj_formato" value="80mm" id="aj_fmt80" checked>
                <div class="formato-icon">🧾</div>
                <div class="formato-name">Térmica 80mm</div>
                <div class="formato-desc">Impresora de tickets, rollos</div>
              </label>
              <label class="formato-card" id="fmtA4card" onclick="selFormatoCard(this,'A4')">
                <input type="radio" name="aj_formato" value="A4" id="aj_fmtA4">
                <div class="formato-icon">📄</div>
                <div class="formato-name">Normal A4</div>
                <div class="formato-desc">Impresora de escritorio</div>
              </label>
            </div>
          </div>
          <div class="aj-field" style="margin-bottom:18px;">
            <label>Mensaje al pie del ticket</label>
            <input type="text" id="aj_footer" placeholder="Ej: ¡Gracias por su compra! Volvé pronto 😊">
          </div>
          <div class="ticket-preview-wrap">
            <div class="ticket-preview-label"><i class="bi bi-eye"></i> Vista previa</div>
            <div class="ticket-paper" id="ticketPreview">
              <div class="t-center" id="pv-logo-wrap" style="display:none;margin-bottom:4px;">
                <img id="pv-logo" src="" style="max-width:100%;max-height:50px;object-fit:contain;">
              </div>
              <div class="t-center">
                <span class="t-bold" id="pv-nombre">Mi Comercio</span><br>
                <span class="t-small" id="pv-direccion"></span><br>
                <span class="t-small" id="pv-telefono"></span>
              </div>
              <hr class="t-sep">
              <div>Ticket N°: <span class="t-bold">0001</span></div>
              <div>Fecha: <span id="pv-fecha"></span></div>
              <div>Cliente: Consumidor Final</div>
              <hr class="t-sep">
              <table style="width:100%;font-size:10px;">
                <tr><th style="text-align:left;">Producto</th><th style="text-align:center;">Cant</th><th style="text-align:right;">Sub</th></tr>
                <tr><td>Producto ejemplo</td><td style="text-align:center;">2</td><td style="text-align:right;">$200,00</td></tr>
              </table>
              <hr class="t-sep">
              <div class="t-row"><span>Subtotal:</span><span>$200,00</span></div>
              <div class="t-row t-bold"><span>TOTAL:</span><span>$200,00</span></div>
              <hr class="t-sep">
              <div>Pago: <span class="t-bold">Efectivo</span></div>
              <hr class="t-sep">
              <div class="t-center t-small" id="pv-footer">¡Gracias por su compra!</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════════════════════════════════
           USUARIOS
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon" style="background:linear-gradient(135deg,#6366f1,#4f46e5);"><i class="bi bi-people"></i></div>
          <div>
            <div class="aj-section-title">Usuarios del sistema</div>
            <div class="aj-section-desc">Gestioná quién puede acceder y con qué permisos.</div>
          </div>
          <button onclick="abrirModalUsuario()" style="margin-left:auto;display:flex;align-items:center;gap:7px;padding:8px 14px;background:var(--color-action);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 12px rgba(0,180,216,.3);">
            <i class="bi bi-person-plus-fill"></i> Nuevo usuario
          </button>
        </div>
        <div class="aj-section-body" style="padding:0;">
          <table class="sales-table" id="usersTable">
            <thead>
              <tr>
                <th>Usuario</th><th>Nombre</th><th>Rol</th><th>Estado</th>
                <th style="width:140px;">Acciones</th>
              </tr>
            </thead>
            <tbody id="usersTbody">
              <tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-secondary);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ══════════════════════════════════════
           MÉTODOS DE PAGO
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon" style="background:linear-gradient(135deg,#10b981,#059669);"><i class="bi bi-credit-card"></i></div>
          <div>
            <div class="aj-section-title">Métodos de Pago</div>
            <div class="aj-section-desc">Configurá los métodos disponibles en el punto de venta, con sus recargos y comisiones.</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div class="pm-list" id="pmList">
            <div style="text-align:center;padding:20px;color:var(--text-secondary);font-size:13px;">
              <i class="bi bi-arrow-repeat" style="display:inline-block;animation:spin2 1s linear infinite;"></i> Cargando…
              <style>@keyframes spin2{to{transform:rotate(360deg)}}</style>
            </div>
          </div>
          <button class="btn-add-pm" onclick="abrirModalPM()">
            <i class="bi bi-plus-circle"></i> Agregar método de pago
          </button>
        </div>
      </div>

      <!-- ══════════════════════════════════════
           FACTURA ELECTRÓNICA AFIP
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon" style="background:linear-gradient(135deg,#6d28d9,#5b21b6);">
            <i class="bi bi-shield-check"></i>
          </div>
          <div>
            <div class="aj-section-title">Factura Electrónica AFIP / ARCA</div>
            <div class="aj-section-desc">Configuración para emisión de comprobantes electrónicos</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div style="margin-bottom:16px;background:rgba(109,40,217,.05);border:1px solid rgba(109,40,217,.18);border-radius:12px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;">
            <div>
              <div style="font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:3px;">Activar facturación electrónica</div>
              <div style="font-size:12px;color:var(--text-secondary);line-height:1.45;">Si está desactivada, el sistema seguirá vendiendo normal pero no usará AFIP/ARCA.</div>
            </div>
            <div style="position:relative;width:54px;height:30px;flex-shrink:0;">
              <input type="checkbox" id="facturacion_habilitada"
                <%= String(config.facturacion_habilitada || '0') === '1' ? 'checked' : '' %>
                style="opacity:0;width:0;height:0;position:absolute;"
                onchange="toggleFacturacionHabilitada(this)">
              <label for="facturacion_habilitada" id="facturacion_habilitada_track"
                style="position:absolute;inset:0;border-radius:20px;background:<%= String(config.facturacion_habilitada || '0') === '1' ? 'var(--color-action)' : 'var(--border-color)' %>;cursor:pointer;transition:background .2s;">
                <span id="facturacion_habilitada_thumb"
                  style="position:absolute;top:3px;left:3px;width:24px;height:24px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.2);display:block;transform:<%= String(config.facturacion_habilitada || '0') === '1' ? 'translateX(24px)' : 'translateX(0)' %>;"></span>
              </label>
            </div>
          </div>

          <div id="afipConfigWrap">
            <div class="aj-grid aj-grid-2" style="margin-bottom:14px;">
              <div class="aj-field">
                <label>CUIT del emisor</label>
                <input type="text" id="afip_cuit" placeholder="20-12345678-9" maxlength="13" value="<%= config.afip_cuit || '' %>"/>
              </div>
              <div class="aj-field">
                <label>Punto de venta (nro.)</label>
                <input type="number" id="afip_punto_venta" placeholder="1" min="1" max="9999" value="<%= config.afip_punto_venta || '1' %>"/>
              </div>
            </div>
            <div class="aj-grid aj-grid-2" style="margin-bottom:14px;">
              <div class="aj-field">
                <label>Ruta certificado (.crt)</label>
                <input type="text" id="afip_cert_path" placeholder="certs/cert.crt" value="<%= config.afip_cert_path || 'certs/cert.crt' %>"/>
              </div>
              <div class="aj-field">
                <label>Ruta clave privada (.key)</label>
                <input type="text" id="afip_key_path" placeholder="certs/private.key" value="<%= config.afip_key_path || 'certs/private.key' %>"/>
              </div>
            </div>
            <div class="aj-grid aj-grid-2" style="margin-bottom:14px;">
              <div class="aj-field">
                <label>Condición IVA del emisor</label>
                <input type="text" id="empresa_cond_iva" placeholder="Responsable Inscripto" value="<%= config.empresa_cond_iva || 'Responsable Inscripto' %>"/>
              </div>
              <div class="aj-field">
                <label>Ambiente AFIP</label>
                <select id="afip_env">
                  <option value="homologacion" <%= config.afip_env !== 'produccion' ? 'selected' : '' %>>🧪 Homologación (testing)</option>
                  <option value="produccion"   <%= config.afip_env === 'produccion'  ? 'selected' : '' %>>🚀 Producción</option>
                </select>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;padding:12px;background:rgba(109,40,217,.06);border:1px solid rgba(109,40,217,.2);border-radius:10px;">
              <i class="bi bi-info-circle" style="color:#6d28d9;font-size:18px;flex-shrink:0;"></i>
              <div style="font-size:12px;color:var(--text-secondary);line-height:1.5;">
                Los certificados deben estar en la carpeta indicada dentro del proyecto.
                Generá el CSR con <code style="background:var(--bg-body);padding:1px 5px;border-radius:4px;font-size:11px;">openssl req -new -newkey rsa:2048 -keyout private.key -out cert.csr</code>
                y luego cargalo en el portal de ARCA.
              </div>
            </div>
            <div style="margin-top:14px;">
              <button onclick="testAfipConexion()" style="padding:10px 18px;border-radius:8px;border:1.5px solid #6d28d9;background:rgba(109,40,217,.07);color:#6d28d9;font-family:var(--font-body);font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .15s;">
                <i class="bi bi-wifi"></i> Probar conexión con AFIP
              </button>
              <span id="afipTestResult" style="margin-left:12px;font-size:13px;font-weight:600;"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════════════════════════════════
           BALANZA
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon" style="background:linear-gradient(135deg,#d97706,#b45309);">
            <i class="bi bi-speedometer2"></i>
          </div>
          <div>
            <div class="aj-section-title">Balanza electrónica</div>
            <div class="aj-section-desc">Soporte para balanzas que imprimen etiquetas con código EAN-13 (prefijo 2).</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div class="aj-grid aj-grid-2" style="align-items:start;">
            <div style="display:flex;flex-direction:column;gap:14px;">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--bg-body);border:1.5px solid var(--border-color);border-radius:var(--radius-md);">
                <div>
                  <div style="font-size:13.5px;font-weight:700;color:var(--text-primary);">Activar soporte de balanza</div>
                  <div style="font-size:11.5px;color:var(--text-secondary);margin-top:2px;">Se mostrará el chip ⚖️ en el punto de venta</div>
                </div>
                <label class="pm-toggle" style="flex-shrink:0;">
                  <input type="checkbox" id="balanza_habilitada">
                  <span class="pm-toggle-slider"></span>
                </label>
              </div>
              <div class="aj-field">
                <label>Modo del código EAN-13</label>
                <select id="balanza_modo">
                  <option value="precio">Precio — los últimos 5 dígitos son el precio (más común)</option>
                  <option value="peso">Peso — los últimos 5 dígitos son el peso en gramos</option>
                </select>
                <div class="field-hint">Consultá el manual de tu balanza. La mayoría usa <strong>modo precio</strong>.</div>
              </div>
              <div class="aj-field">
                <label>Prefijo EAN-13</label>
                <input type="number" id="balanza_prefijo" value="2" min="2" max="29" step="1" style="width:80px;" placeholder="2">
                <div class="field-hint">Normalmente es <strong>2</strong>. Cambiá solo si tu balanza usa otro prefijo.</div>
              </div>
            </div>
            <div style="background:var(--bg-body);border:1.5px solid var(--border-color);border-radius:var(--radius-md);padding:16px;">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text-secondary);margin-bottom:12px;">¿Cómo funciona?</div>
              <div style="font-size:12.5px;color:var(--text-primary);line-height:1.7;">
                La balanza imprime etiquetas con un <strong>código EAN-13</strong>. Al escanearlo en ventas, el sistema detecta automáticamente el PLU y el precio/peso.<br><br>
                <span style="font-family:monospace;font-size:13px;background:rgba(0,0,0,.05);padding:4px 8px;border-radius:5px;display:inline-block;margin-bottom:8px;letter-spacing:1px;">
                  2 <span style="color:#6366f1;">00123</span> <span style="color:#10b981;">01599</span> 4
                </span><br>
                <span style="font-size:11.5px;color:var(--text-secondary);">
                  <span style="color:#6366f1;">■</span> PLU del producto (00123)<br>
                  <span style="color:#10b981;">■</span> Precio $15,99 (01599)<br>
                  ■ Dígito de control (4)
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════════════════════════════════
           APARIENCIA
      ══════════════════════════════════════ -->
      <div class="aj-section">
        <div class="aj-section-header">
          <div class="aj-section-icon" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);">
            <i class="bi bi-moon-stars"></i>
          </div>
          <div>
            <div class="aj-section-title">Apariencia</div>
            <div class="aj-section-desc">Tema visual del sistema. Se aplica a todas las pantallas.</div>
          </div>
        </div>
        <div class="aj-section-body">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div>
              <div style="font-size:13.5px;font-weight:700;color:var(--text-primary);margin-bottom:3px;">Tema del sistema</div>
              <div style="font-size:12px;color:var(--text-secondary);">Elegí entre modo claro u oscuro para todo el sistema</div>
            </div>
            <div style="display:flex;gap:8px;">
              <button id="btnTemaClaro" onclick="setTema('light')" style="display:flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-md);border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-secondary);font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;">
                <i class="bi bi-sun"></i> Claro
              </button>
              <button id="btnTemaOscuro" onclick="setTema('dark')" style="display:flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--radius-md);border:1.5px solid var(--border-color);background:var(--bg-body);color:var(--text-secondary);font-family:var(--font-body);font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;">
                <i class="bi bi-moon-stars"></i> Oscuro
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Botones -->
      <div class="aj-actions">
        <button class="btn-guardar" onclick="guardarAjustes()">
          <i class="bi bi-check-circle-fill"></i> Guardar cambios
        </button>
        <button class="btn-test-ticket" onclick="imprimirTicketTest()">
          <i class="bi bi-printer"></i> Imprimir ticket de prueba
        </button>
      </div>

    </div>
  </div>
</div>

<div class="aj-toast" id="ajToast"><i class="bi bi-check-circle-fill"></i><span id="ajToastMsg">Guardado</span></div>

<!-- ══ MODAL USUARIO ══ -->
<div class="sale-overlay" id="modalUsuario" onclick="if(event.target.id==='modalUsuario')cerrarModalUsuario()">
  <div class="sale-modal" style="max-width:480px;text-align:left;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--color-action),#0099b8);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;"><i class="bi bi-person-badge"></i></div>
        <div>
          <div style="font-size:16px;font-weight:700;color:var(--text-primary);" id="uModalTitulo">Nuevo usuario</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="uModalSub">Completá los datos</div>
        </div>
      </div>
      <button onclick="cerrarModalUsuario()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;padding:4px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <div style="display:flex;flex-direction:column;gap:14px;">
      <div id="u_username_wrap">
        <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:5px;">Nombre de usuario</label>
        <input type="text" id="u_username" placeholder="ej: cajero1" autocomplete="off" style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-family:var(--font-mono);font-size:13px;outline:none;" onfocus="this.style.borderColor='var(--color-action)'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <div>
        <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:5px;">Nombre visible</label>
        <input type="text" id="u_nombre" placeholder="ej: Juan Pérez" style="width:100%;padding:9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-size:13.5px;outline:none;" onfocus="this.style.borderColor='var(--color-action)'" onblur="this.style.borderColor='var(--border-color)'">
      </div>
      <div>
        <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:5px;">Rol</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <label id="u_role_admin_lbl" onclick="setRol('admin')" style="display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border:1.5px solid var(--border-color);border-radius:10px;cursor:pointer;">
            <input type="radio" name="u_role" value="admin" id="u_role_admin" style="display:none">
            <div style="width:34px;height:34px;border-radius:8px;background:rgba(0,180,216,.1);display:flex;align-items:center;justify-content:center;color:var(--color-action);font-size:16px;flex-shrink:0;"><i class="bi bi-shield-check"></i></div>
            <div><div style="font-size:13px;font-weight:700;">Admin</div><div style="font-size:11px;color:var(--text-secondary);">Acceso completo</div></div>
          </label>
          <label id="u_role_empleado_lbl" onclick="setRol('empleado')" style="display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border:1.5px solid var(--border-color);border-radius:10px;cursor:pointer;">
            <input type="radio" name="u_role" value="empleado" id="u_role_empleado" style="display:none">
            <div style="width:34px;height:34px;border-radius:8px;background:rgba(100,116,139,.08);display:flex;align-items:center;justify-content:center;color:#64748b;font-size:16px;flex-shrink:0;"><i class="bi bi-person-workspace"></i></div>
            <div><div style="font-size:13px;font-weight:700;">Empleado</div><div style="font-size:11px;color:var(--text-secondary);">Ventas y caja</div></div>
          </label>
        </div>
      </div>
      <div id="u_pass_wrap">
        <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:5px;" id="u_pass_label">Contraseña</label>
        <div style="position:relative;">
          <input type="password" id="u_password" placeholder="Mínimo 4 caracteres" style="width:100%;padding:9px 36px 9px 12px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-body);color:var(--text-primary);font-size:13.5px;outline:none;" onfocus="this.style.borderColor='var(--color-action)'" onblur="this.style.borderColor='var(--border-color)'">
          <button type="button" onclick="toggleUPass()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:15px;"><i class="bi bi-eye" id="uPassEye"></i></button>
        </div>
        <small id="u_pass_hint" style="font-size:11px;color:var(--text-secondary);margin-top:4px;display:none;">Dejá vacío para no cambiar la contraseña</small>
      </div>
    </div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:22px;">
      <button onclick="cerrarModalUsuario()" style="padding:9px 18px;border:1.5px solid var(--border-color);border-radius:var(--radius-sm);background:none;color:var(--text-secondary);font-size:13px;font-weight:600;cursor:pointer;">Cancelar</button>
      <button onclick="guardarUsuario()" style="padding:9px 20px;border:none;border-radius:var(--radius-sm);background:linear-gradient(135deg,var(--color-action),#0099b8);color:#fff;font-size:13px;font-weight:700;cursor:pointer;"><span id="uBtnLabel">Crear usuario</span></button>
    </div>
  </div>
</div>

<!-- ══ MODAL MÉTODO DE PAGO ══ -->
<div class="pm-modal-overlay" id="pmModalOverlay" onclick="if(event.target.id==='pmModalOverlay')cerrarModalPM()">
  <div class="pm-modal">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <h3 style="font-size:16px;font-weight:700;color:var(--text-primary);margin:0;" id="pmModalTitle">Nuevo Método de Pago</h3>
      <button onclick="cerrarModalPM()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;"><i class="bi bi-x-lg"></i></button>
    </div>
    <input type="hidden" id="pmEditId" value="">
    <div style="display:flex;flex-direction:column;gap:14px;">
      <div class="pm-form-row"><label>Nombre *</label><input type="text" id="pm_nombre" placeholder="Ej: Naranja X, Clover…"></div>
      <div class="pm-form-row">
        <label>Tipo</label>
        <select id="pm_tipo">
