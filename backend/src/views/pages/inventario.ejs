<script>
let _impRows = [];

function abrirImportar() {
  _impRows = [];
  document.getElementById('imp_step1').style.display = 'block';
  document.getElementById('imp_step2').style.display = 'none';
  document.getElementById('imp_footer').style.display = 'none';
  document.getElementById('imp_subtitle').textContent = 'Seleccioná un archivo .xlsx o .csv';
  document.getElementById('imp_fileInput').value = '';
  document.getElementById('modalImportar').classList.add('open');
}
function cerrarImportar() { document.getElementById('modalImportar').classList.remove('open'); }
function impDragOver(e) { e.preventDefault(); e.stopPropagation(); document.getElementById('imp_dropzone').style.borderColor='#10b981'; document.getElementById('imp_dropzone').style.background='rgba(16,185,129,.04)'; }
function impDragLeave(e) { document.getElementById('imp_dropzone').style.borderColor='var(--border-color)'; document.getElementById('imp_dropzone').style.background='var(--bg-body)'; }
function impDrop(e) { e.preventDefault(); impDragLeave(e); const file=e.dataTransfer.files[0]; if(file)impProcesarArchivo(file); }
function impFileSelected(e) { const file=e.target.files[0]; if(file)impProcesarArchivo(file); }
function impNormHeader(h) {
  const s = String(h||'').toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]/g,'');
  const map = { sku:'sku',codigo:'sku',code:'sku',cod:'sku',barcode:'sku', nombre:'name',name:'name',producto:'name', precio:'price',price:'price',costo:'price',valor:'price', categoria:'category',category:'category',rubro:'category',tipo:'category', stock:'stock',cantidad:'stock',qty:'stock',existencia:'stock', iva:'iva',impuesto:'iva', ieps:'ieps', ventapormayor:'price_mayorista',mayorista:'price_mayorista',preciomayorista:'price_mayorista',preciocosto:'price_cost',costo:'price_cost',preciominorista:'price',minorista:'price',margen:'margen',ganancia:'margen',gananciaporc:'margen',margenporc:'margen' };
  return map[s] || s;
}
async function impProcesarArchivo(file) {
  if (file.size > 5*1024*1024) { alert('El archivo supera 5MB'); return; }
  document.getElementById('imp_subtitle').textContent = 'Leyendo archivo…';
  if (typeof XLSX === 'undefined') {
    await new Promise((res,rej) => { const s=document.createElement('script'); s.src='https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js'; s.onload=res; s.onerror=rej; document.head.appendChild(s); });
  }
  const reader = new FileReader();
  reader.onload = async (e) => {
    try {
      const workbook = XLSX.read(e.target.result, { type: 'array' });
      const sheet    = workbook.Sheets[workbook.SheetNames[0]];
      const raw      = XLSX.utils.sheet_to_json(sheet, { defval: '' });
      if (!raw.length) { alert('El archivo está vacío o no tiene datos válidos.'); return; }
      const rows = raw.map(r => {
        const mapped = {};
        Object.keys(r).forEach(k => { mapped[impNormHeader(k)] = r[k]; });
        return { sku:String(mapped.sku||'').trim(), name:String(mapped.name||'').trim(), price:parseFloat(mapped.price)||0, category:String(mapped.category||'').trim(), stock:parseInt(mapped.stock)||0, iva:parseFloat(mapped.iva)||0, ieps:parseFloat(mapped.ieps)||0, price_mayorista:parseFloat(mapped.price_mayorista)||0, price_tarjeta:parseFloat(mapped.price_tarjeta)||0, price_cost:parseFloat(mapped.price_cost)||null, margen:parseFloat(mapped.margen)||null, _action:'new', _status:'new', _error:'' };
      });
      rows.forEach(r => { if(!r.sku){r._status='error';r._error='SKU vacío';} if(!r.name){r._status='error';r._error=(r._error?r._error+', ':'')+'Nombre vacío';} });
      document.getElementById('imp_subtitle').textContent = 'Verificando SKUs existentes…';
      const skusValidos = rows.filter(r=>r._status!=='error').map(r=>r.sku);
      const checks = await Promise.allSettled(skusValidos.map(sku=>fetch(`/api/products/${encodeURIComponent(sku)}`).then(r=>({sku,exists:r.ok}))));
      const existentes = new Set(checks.filter(c=>c.status==='fulfilled'&&c.value.exists).map(c=>c.value.sku));
      rows.forEach(r => { if(r._status==='error')return; if(existentes.has(r.sku)){r._status='conflict';r._action='update';} });
      _impRows = rows;
      impMostrarPreview();
    } catch(err) { console.error(err); alert('Error leyendo el archivo.'); }
  };
  reader.readAsArrayBuffer(file);
}
function impMostrarPreview() {
  const countNew=_impRows.filter(r=>r._status==='new').length;
  const countConflict=_impRows.filter(r=>r._status==='conflict').length;
  const countError=_impRows.filter(r=>r._status==='error').length;
  document.getElementById('imp_countNew').textContent=countNew+' nuevos';
  document.getElementById('imp_countConflict').textContent=countConflict+' conflictos';
  document.getElementById('imp_countError').textContent=countError+' errores';
  document.getElementById('imp_resolveAll').style.display=countConflict>1?'flex':'none';
  const tbody=document.getElementById('imp_previewBody');
  tbody.innerHTML=_impRows.map((r,i)=>{
    const statusBadge={new:`<span style="font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:4px;background:rgba(16,185,129,.1);color:#10b981;">NUEVO</span>`,conflict:`<span style="font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:4px;background:rgba(245,158,11,.1);color:#d97706;">CONFLICTO</span>`,error:`<span style="font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:4px;background:rgba(239,68,68,.1);color:#ef4444;">ERROR</span>`}[r._status]||'';
    const accion=r._status==='conflict'?`<div style="display:flex;gap:5px;justify-content:center;"><button onclick="setAccion(${i},'update')" style="font-size:11px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;border:1.5px solid ${r._action==='update'?'#10b981':'var(--border-color)'};background:${r._action==='update'?'rgba(16,185,129,.1)':'transparent'};color:${r._action==='update'?'#10b981':'var(--text-secondary)'};">Actualizar</button><button onclick="setAccion(${i},'skip')" style="font-size:11px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;border:1.5px solid ${r._action==='skip'?'#94a3b8':'var(--border-color)'};background:${r._action==='skip'?'rgba(100,116,139,.1)':'transparent'};color:${r._action==='skip'?'#64748b':'var(--text-secondary)'};">Ignorar</button></div>`:r._status==='error'?`<span style="font-size:11px;color:#ef4444;">${r._error}</span>`:`<span style="font-size:11px;color:#10b981;font-weight:600;">Crear</span>`;
    const rowBg=r._status==='error'?'rgba(239,68,68,.04)':r._status==='conflict'?'rgba(245,158,11,.03)':'';
    return `<tr style="border-bottom:1px solid var(--border-color);background:${rowBg};" id="imp_row_${i}"><td style="padding:10px 14px;">${statusBadge}</td><td style="padding:10px 14px;font-family:var(--font-mono);font-size:12px;color:var(--text-secondary);">${r.sku}</td><td style="padding:10px 14px;font-weight:600;color:var(--text-primary);">${r.name||'—'}</td><td style="padding:10px 14px;text-align:right;font-family:var(--font-mono);font-weight:700;">$${Number(r.price).toFixed(2)}</td><td style="padding:10px 14px;color:var(--text-secondary);">${r.category||'—'}</td><td style="padding:10px 14px;text-align:right;">${r.stock}</td><td style="padding:10px 14px;text-align:right;color:#6366f1;font-family:var(--font-mono);">${r.price_mayorista>0?'$'+r.price_mayorista.toFixed(2):'—'}</td><td style="padding:10px 14px;text-align:right;color:#d97706;font-family:var(--font-mono);">${r.price_tarjeta>0?'$'+r.price_tarjeta.toFixed(2):'—'}</td><td style="padding:10px 14px;text-align:center;">${accion}</td></tr>`;
  }).join('');
  const activas=_impRows.filter(r=>r._status!=='error'&&r._action!=='skip').length;
  document.getElementById('imp_footerInfo').textContent=`Se procesarán ${activas} producto${activas!==1?'s':''}`;
  document.getElementById('imp_subtitle').textContent=`${_impRows.length} filas encontradas`;
  document.getElementById('imp_step1').style.display='none';
  document.getElementById('imp_step2').style.display='block';
  document.getElementById('imp_footer').style.display='flex';
}
function setAccion(i,accion){_impRows[i]._action=accion;impMostrarPreview();}
function resolverTodos(accion){_impRows.forEach(r=>{if(r._status==='conflict')r._action=accion;});impMostrarPreview();}
function impVolver(){document.getElementById('imp_step1').style.display='block';document.getElementById('imp_step2').style.display='none';document.getElementById('imp_footer').style.display='none';}
async function ejecutarImportacion() {
  const btn=document.getElementById('imp_btnImportar');
  const label=document.getElementById('imp_btnLabel');
  btn.disabled=true; label.textContent='Importando…';
  const toCreate=_impRows.filter(r=>r._status==='new');
  const toUpdate=_impRows.filter(r=>r._status==='conflict'&&r._action==='update');
  let ok=0,err=0;
  for(const r of toCreate){
    const res=await fetch('/api/products',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sku:r.sku,name:r.name,price:r.price,category:r.category,stock:r.stock,iva:r.iva,ieps:r.ieps,pesable:0,price_mayorista:r.price_mayorista||null,price_tarjeta:r.price_tarjeta||null,price_cost:r.price_cost||null,margen:r.margen||null})});
    res.ok?ok++:err++;
  }
  for(const r of toUpdate){
    const res=await fetch(`/api/products/${encodeURIComponent(r.sku)}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:r.name,price:r.price,category:r.category,stock:r.stock,iva:r.iva,ieps:r.ieps,price_mayorista:r.price_mayorista||null,price_tarjeta:r.price_tarjeta||null,price_cost:r.price_cost||null,margen:r.margen||null})});
    res.ok?ok++:err++;
  }
  cerrarImportar();
  if(err)alert(`Importación completada:\n✅ ${ok} productos procesados\n❌ ${err} errores`);
  // Refrescar desde server una sola vez (importación masiva justifica un fetch)
  try {
    const r = await fetch('/api/products?limit=9999');
    if (r.ok) { _allProducts = await r.json(); renderTable(_allProducts); }
  } catch(e) { location.reload(); }
}
function descargarPlantilla(){
  // Cargar SheetJS si no está
  const generar = () => {
    const data = [
      {
        SKU: 'ABC-001',
        Nombre: 'Coca Cola 1.5L',
        'Precio Minorista': 1500,
        'Precio Mayorista': 1200,
        'Precio Tarjeta': 1650,
        'Precio Costo': 900,
        'Cantidad Min. Mayorista': 6,
        Stock: 20,
        Categoria: 'Bebidas',
        IVA: 0,
        IEPS: 0,
        Pesable: 'NO',
        Descripcion: '',
        'En Promo': 'NO',
        'Precio Promo': '',
      },
      {
        SKU: 'ABC-024',
        Nombre: 'Crema Tregar 200g',
        'Precio Minorista': 2500,
        'Precio Mayorista': 2000,
        'Precio Tarjeta': 2750,
        'Precio Costo': 1500,
        'Cantidad Min. Mayorista': 4,
        Stock: 24,
        Categoria: 'LACTEOS',
        IVA: 0,
        IEPS: 0,
        Pesable: 'NO',
        Descripcion: 'Crema entera 200g',
        'En Promo': 'NO',
        'Precio Promo': '',
      },
      {
        SKU: 'ABC-039',
        Nombre: 'Salchichas 500g',
        'Precio Minorista': 1200,
        'Precio Mayorista': 950,
        'Precio Tarjeta': 1300,
        'Precio Costo': 700,
        'Cantidad Min. Mayorista': 3,
        Stock: 105,
        Categoria: 'CARNES',
        IVA: 0,
        IEPS: 0,
        Pesable: 'NO',
        Descripcion: '',
        'En Promo': 'SI',
        'Precio Promo': 1100,
      },
    ];

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.json_to_sheet(data);
    ws['!cols'] = [
      {wch:18},{wch:30},{wch:16},{wch:16},{wch:14},{wch:13},{wch:22},
      {wch:7},{wch:16},{wch:5},{wch:5},{wch:8},{wch:30},{wch:8},{wch:13}
    ];
    XLSX.utils.book_append_sheet(wb, ws, 'Productos');
    XLSX.writeFile(wb, 'plantilla_productos.xlsx');
  };

  if (typeof XLSX === 'undefined') {
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
    s.onload = generar;
    document.head.appendChild(s);
  } else {
    generar();
  }
}
</script>

<!-- MODAL STOCK (sin cambios) -->
<div class="stock-modal-overlay" id="modalStock" onclick="if(event.target===this)cerrarModalStock()">
  <div class="stock-modal-box">
