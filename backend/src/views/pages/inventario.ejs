      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(16,185,129,.15);display:flex;align-items:center;justify-content:center;color:#10b981;font-size:18px;flex-shrink:0;"><i class="bi bi-upc-scan"></i></div>
        <div>
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);">Ajuste de stock</div>
          <div class="stock-modal-producto" id="smNombre">—</div>
        </div>
      </div>
      <div class="stock-modal-meta"><span><i class="bi bi-upc"></i> <span id="smSku">—</span></span><span id="smCategoria" style="display:none"><i class="bi bi-tag"></i> <span id="smCatVal">—</span></span></div>
    </div>
    <div class="stock-modal-body">
      <div class="stock-actual-wrap">
        <div><div class="stock-actual-label">Stock actual</div><div class="stock-actual-val" id="smStockActual" style="color:var(--text-primary)">—</div></div>
        <div id="smStockBadge"></div>
      </div>
      <div class="stock-ajuste-grid">
        <button class="btn-ajuste resta" onclick="ajustarStock(-5)"><span style="font-size:20px;">−5</span><span class="btn-ajuste-label">Restar</span></button>
        <button class="btn-ajuste resta" onclick="ajustarStock(-1)"><span style="font-size:20px;">−1</span><span class="btn-ajuste-label">Restar</span></button>
        <button class="btn-ajuste suma"  onclick="ajustarStock(1)"><span style="font-size:20px;">+1</span><span class="btn-ajuste-label">Sumar</span></button>
      </div>
      <div class="stock-ajuste-grid" style="grid-template-columns:1fr 1fr;margin-bottom:18px;">
        <button class="btn-ajuste suma" onclick="ajustarStock(5)"><span style="font-size:20px;">+5</span><span class="btn-ajuste-label">Sumar</span></button>
        <button class="btn-ajuste suma" onclick="ajustarStock(10)"><span style="font-size:20px;">+10</span><span class="btn-ajuste-label">Sumar</span></button>
      </div>
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:8px;">Cantidad personalizada</div>
      <div class="stock-custom-row">
        <select id="smSigno" style="padding:10px 12px;border:2px solid var(--border-color);border-radius:10px;background:var(--bg-surface-2);color:var(--text-primary);font-size:14px;font-weight:700;outline:none;cursor:pointer;"><option value="1">+ Sumar</option><option value="-1">− Restar</option><option value="set">= Establecer</option></select>
        <input type="number" id="smCantidad" class="stock-custom-input" placeholder="0" min="0" step="1" onkeydown="if(event.key==='Enter'){event.preventDefault();aplicarPersonalizado();}">
        <button class="btn-stock-set" onclick="aplicarPersonalizado()"><i class="bi bi-check-lg"></i> Aplicar</button>
      </div>
    </div>
    <div class="stock-modal-footer">
      <button class="btn-stock-cancel" onclick="cerrarModalStock()"><i class="bi bi-x-lg"></i> Cerrar</button>
      <button class="btn-stock-cancel" onclick="cerrarModalStock();setTimeout(()=>document.getElementById('q').focus(),100);" style="border-color:rgba(16,185,129,.4);color:#10b981;"><i class="bi bi-upc-scan"></i> Escanear otro</button>
    </div>
  </div>
</div>

<script>
let _smSku=null,_smStock=0;
function abrirModalStock(producto){_smSku=producto.sku;_smStock=Number(producto.stock);document.getElementById('smNombre').textContent=producto.name;document.getElementById('smSku').textContent=producto.sku;const catSpan=document.getElementById('smCategoria');if(producto.category){document.getElementById('smCatVal').textContent=producto.category;catSpan.style.display='';}else{catSpan.style.display='none';}actualizarStockModal(_smStock);document.getElementById('smCantidad').value='';document.getElementById('smSigno').value='1';document.getElementById('modalStock').classList.add('open');setTimeout(()=>document.getElementById('smCantidad').focus(),120);}
function actualizarStockModal(stock){_smStock=stock;const el=document.getElementById('smStockActual');const badge=document.getElementById('smStockBadge');el.textContent=stock;const clase=stock<=0?'vacio':stock<=3?'bajo':'ok';el.style.color={vacio:'#dc2626',bajo:'#d97706',ok:'#059669'}[clase];badge.innerHTML=`<span class="stock-badge ${clase}"><span class="stock-dot ${clase}"></span>${stock}</span>`;}
function cerrarModalStock(){document.getElementById('modalStock').classList.remove('open');_smSku=null;}
async function ajustarStock(delta){if(!_smSku)return;try{const r=await fetch(`/api/products/${encodeURIComponent(_smSku)}/stock`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({delta})});if(!r.ok){alert('Error actualizando stock');return;}const nuevoStock=_smStock+delta;actualizarStockModal(Math.max(0,nuevoStock));actualizarFilaStock(_smSku,Math.max(0,nuevoStock));}catch(e){alert('Error de red');}}
async function aplicarPersonalizado(){const cant=parseInt(document.getElementById('smCantidad').value)||0;const signo=document.getElementById('smSigno').value;if(!cant&&signo!=='set')return;if(signo==='set'){const nuevo=Math.max(0,cant);const delta=nuevo-_smStock;await ajustarStock(delta);}else{await ajustarStock(Number(signo)*cant);}document.getElementById('smCantidad').value='';document.getElementById('smCantidad').focus();}
function actualizarFilaStock(sku,nuevoStock){const row=document.querySelector(`[data-sku="${sku}"]`);if(!row)return;const td=row.querySelector('[data-stock]');if(!td)return;td.setAttribute('data-stock',nuevoStock);const clase=nuevoStock<=0?'vacio':nuevoStock<=3?'bajo':'ok';td.innerHTML=`<span class="stock-badge ${clase}"><span class="stock-dot ${clase}"></span>${nuevoStock}</span>`;row.classList.remove('row-flash');void row.offsetWidth;row.classList.add('row-flash');}

let _scanBuffer='',_scanTimer=null;
const SCAN_SPEED=80;
document.addEventListener('DOMContentLoaded',()=>{
  const searchInput=document.getElementById('q');
  searchInput.addEventListener('keydown',(e)=>{if(_scanTimer)clearTimeout(_scanTimer);if(e.key==='Enter'){e.preventDefault();const code=searchInput.value.trim();if(!code)return;procesarCodigoScanner(code);return;}_scanTimer=setTimeout(()=>{const val=searchInput.value.trim();if(val.length>3)document.getElementById('scanHint').style.display='block';},300);});
  document.addEventListener('keydown',async(e)=>{const activeTag=document.activeElement?.tagName;if(['INPUT','TEXTAREA','SELECT'].includes(activeTag))return;if(document.getElementById('modalProducto').classList.contains('open'))return;if(document.getElementById('modalStock').classList.contains('open'))return;if(e.key==='Escape'){cerrarModalStock();return;}if(e.key.length===1){_scanBuffer+=e.key;if(_scanTimer)clearTimeout(_scanTimer);_scanTimer=setTimeout(async()=>{const code=_scanBuffer.trim();_scanBuffer='';if(code.length>=3){searchInput.value=code;filterRows();await procesarCodigoScanner(code);}},100);}});
});
async function procesarCodigoScanner(code){try{const res=await fetch(`/api/products/${encodeURIComponent(code)}`);if(res.ok){const product=await res.json();const row=document.querySelector(`[data-sku="${product.sku}"]`);if(row){row.scrollIntoView({behavior:'smooth',block:'center'});}abrirModalStock(product);}else if(res.status===404){abrirModal(code);}}catch(err){console.error(err);}}

let _filtroStockActivo='todos';
function setFiltroStock(filtro,btn){_filtroStockActivo=filtro;document.querySelectorAll('.btn-filtro-stock').forEach(b=>b.classList.remove('active'));btn.classList.add('active');filterRows();}
function filterRows(){ renderTable(_allProducts); }
</script>

<!-- ══ MODAL CARGA RÁPIDA DE VARIANTES ══ -->
<div class="modal-overlay" id="modalVariantes" onclick="if(event.target===this)cerrarVariantes()">
  <div class="modal-box" style="max-width:620px;">
    <div class="modal-header">
      <span class="modal-title"><i class="bi bi-stack" style="color:#6366f1;"></i> Carga rápida de variantes</span>
      <button class="modal-close" onclick="cerrarVariantes()">✕</button>
    </div>
    <div class="modal-body" style="padding:22px;display:flex;flex-direction:column;gap:16px;">

      <!-- Nombre base -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:5px;">Nombre base del producto *</label>
          <input type="text" id="vr_nombre" placeholder="Ej: Llave Ferrawi, Aceite 1L..." style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);">
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:5px;">Categoría</label>
          <input type="text" id="vr_categoria" placeholder="Ej: Herramientas, Fiambres..." style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);">
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:5px;">Precio *</label>
          <input type="number" id="vr_precio" placeholder="0.00" min="0" step="0.01" style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);">
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:5px;">Stock inicial</label>
          <input type="number" id="vr_stock" placeholder="0" min="0" value="1" style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);">
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:5px;">SKU base (opcional)</label>
          <input type="text" id="vr_sku_base" placeholder="Ej: FERR, QUESO..." style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);">
        </div>
      </div>

      <!-- Variantes -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);">Variantes (una por línea)</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <button onclick="vrAgregarSugeridas(['S','M','L','XL'])" style="padding:3px 10px;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-surface-2);font-size:11px;font-weight:600;cursor:pointer;color:var(--text-secondary);">S M L XL</button>
            <button onclick="vrAgregarSugeridas(['11mm','12mm','13mm','14mm','17mm','19mm'])" style="padding:3px 10px;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-surface-2);font-size:11px;font-weight:600;cursor:pointer;color:var(--text-secondary);">Medidas mm</button>
            <button onclick="vrAgregarSugeridas(['Rojo','Azul','Verde','Negro','Blanco'])" style="padding:3px 10px;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-surface-2);font-size:11px;font-weight:600;cursor:pointer;color:var(--text-secondary);">Colores</button>
            <button onclick="vrAgregarSugeridas(['500g','1kg','2kg','5kg'])" style="padding:3px 10px;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-surface-2);font-size:11px;font-weight:600;cursor:pointer;color:var(--text-secondary);">Pesos</button>
          </div>
        </div>
        <textarea id="vr_variantes" rows="5" placeholder="Escribí una variante por línea. Ejemplo:&#10;11mm&#10;12mm&#10;13mm&#10;14mm"
          style="width:100%;padding:10px 12px;border-radius:var(--radius-sm);resize:vertical;font-family:var(--font-body);font-size:13px;"></textarea>
        <div style="font-size:11.5px;color:var(--text-muted);margin-top:4px;">
          Se crearán productos con nombre: <strong id="vr_preview_nombre" style="color:var(--color-primary);">Nombre base</strong> + cada variante. Ej: "Llave Ferrawi 11mm"
        </div>
      </div>

      <!-- Opciones -->
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;">
          <input type="checkbox" id="vr_sin_stock" style="width:14px;height:14px;accent-color:var(--color-primary);">
          <span>Vender sin control de stock</span>
        </label>
        <label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;">
          <input type="checkbox" id="vr_pesable" style="width:14px;height:14px;accent-color:var(--color-primary);">
          <span>Producto pesable</span>
        </label>
      </div>

      <!-- Preview -->
      <div id="vr_preview_list" style="display:none;background:var(--bg-surface-2);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:12px 14px;max-height:160px;overflow-y:auto;">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:8px;">Se van a crear estos productos:</div>
        <div id="vr_preview_items" style="display:flex;flex-direction:column;gap:4px;"></div>
      </div>

      <div id="vr_error" style="display:none;padding:10px 14px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:var(--radius-sm);font-size:13px;color:#dc2626;"></div>

      <!-- Botones -->
      <div style="display:flex;gap:10px;margin-top:4px;">
        <button onclick="vrPreview()" style="flex:1;padding:11px;border-radius:var(--radius-sm);border:1.5px solid #6366f1;background:rgba(99,102,241,.07);color:#6366f1;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font-body);">
          <i class="bi bi-eye"></i> Previsualizar
        </button>
        <button onclick="vrGuardar()" id="btnVrGuardar" style="flex:2;padding:11px;border-radius:var(--radius-sm);border:none;background:var(--color-primary);color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font-body);display:flex;align-items:center;justify-content:center;gap:7px;">
          <i class="bi bi-check-circle"></i> Crear productos
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
// ══ CARGA RÁPIDA DE VARIANTES ══
function abrirVariantes() {
  document.getElementById('vr_nombre').value    = '';
  document.getElementById('vr_categoria').value = '';
  document.getElementById('vr_precio').value    = '';
  document.getElementById('vr_stock').value     = '1';
  document.getElementById('vr_sku_base').value  = '';
  document.getElementById('vr_variantes').value = '';
  document.getElementById('vr_sin_stock').checked = false;
  document.getElementById('vr_pesable').checked   = false;
  document.getElementById('vr_preview_list').style.display = 'none';
  document.getElementById('vr_error').style.display = 'none';
  document.getElementById('vr_preview_nombre').textContent = 'Nombre base';
  document.getElementById('modalVariantes').classList.add('active');
  setTimeout(() => document.getElementById('vr_nombre').focus(), 150);
}

function cerrarVariantes() {
  document.getElementById('modalVariantes').classList.remove('active');
}

document.getElementById('vr_nombre').addEventListener('input', function() {
  document.getElementById('vr_preview_nombre').textContent = this.value.trim() || 'Nombre base';
});

function vrAgregarSugeridas(lista) {
  const ta   = document.getElementById('vr_variantes');
  const prev = ta.value.trim();
  ta.value   = prev ? prev + '\n' + lista.join('\n') : lista.join('\n');
}

function vrObtenerVariantes() {
  return document.getElementById('vr_variantes').value
    .split('\n')
    .map(v => v.trim())
    .filter(v => v.length > 0);
}

function vrPreview() {
  const nombre    = document.getElementById('vr_nombre').value.trim();
  const precio    = parseFloat(document.getElementById('vr_precio').value);
  const variantes = vrObtenerVariantes();
  const errEl     = document.getElementById('vr_error');

  errEl.style.display = 'none';

  if (!nombre) { errEl.textContent = 'El nombre base es obligatorio'; errEl.style.display = 'block'; return; }
  if (!precio || precio <= 0) { errEl.textContent = 'El precio es obligatorio'; errEl.style.display = 'block'; return; }
  if (!variantes.length) { errEl.textContent = 'Agregá al menos una variante'; errEl.style.display = 'block'; return; }

  const skuBase = document.getElementById('vr_sku_base').value.trim();
  const stock   = parseInt(document.getElementById('vr_stock').value) || 0;
  const fmt     = n => '$' + Number(n).toLocaleString('es-AR', {minimumFractionDigits:0});

  const items = variantes.map((v, i) => {
    const sku = skuBase ? `${skuBase}-${v.replace(/\s+/g,'-').toUpperCase()}` : `VAR-${Date.now()}-${i}`;
    return { nombre: `${nombre} ${v}`, sku, precio, stock };
  });

  document.getElementById('vr_preview_items').innerHTML = items.map(it =>
    `<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:0.5px solid var(--border-color);font-size:13px;">
      <span style="color:var(--text-primary);font-weight:600;">${it.nombre}</span>
      <div style="display:flex;gap:12px;color:var(--text-secondary);font-size:12px;">
        <span style="font-family:var(--font-mono);">${it.sku}</span>
        <span style="color:var(--color-primary);font-weight:700;">${fmt(it.precio)}</span>
        <span>Stock: ${it.stock}</span>
      </div>
    </div>`
  ).join('');

  document.getElementById('vr_preview_list').style.display = 'block';
}

async function vrGuardar() {
  const nombre    = document.getElementById('vr_nombre').value.trim();
  const precio    = parseFloat(document.getElementById('vr_precio').value);
  const variantes = vrObtenerVariantes();
  const errEl     = document.getElementById('vr_error');
  const btn       = document.getElementById('btnVrGuardar');

  errEl.style.display = 'none';
  if (!nombre) { errEl.textContent = 'El nombre base es obligatorio'; errEl.style.display = 'block'; return; }
  if (!precio || precio <= 0) { errEl.textContent = 'El precio es obligatorio'; errEl.style.display = 'block'; return; }
  if (!variantes.length) { errEl.textContent = 'Agregá al menos una variante'; errEl.style.display = 'block'; return; }

  const skuBase       = document.getElementById('vr_sku_base').value.trim();
  const stock         = parseInt(document.getElementById('vr_stock').value) || 0;
  const categoria     = document.getElementById('vr_categoria').value.trim();
  const sinStock      = document.getElementById('vr_sin_stock').checked ? 1 : 0;
  const pesable       = document.getElementById('vr_pesable').checked ? 1 : 0;

  btn.disabled = true;
  btn.innerHTML = '<span style="width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;display:inline-block;animation:modalSpin .7s linear infinite;"></span> Creando...';

  let ok = 0, errors = [];

  for (let i = 0; i < variantes.length; i++) {
    const v   = variantes[i];
    const sku = skuBase
      ? `${skuBase}-${v.replace(/\s+/g,'-').toUpperCase()}`
      : `VAR-${Date.now()}-${i}`;

    try {
      const r = await fetch('/api/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sku,
          name: `${nombre} ${v}`,
          price: precio,
          category: categoria || null,
          stock,
          pesable,
          venta_sin_stock: sinStock,
          descripcion: null,
        })
      });
      if (r.ok) { ok++; }
      else {
        const d = await r.json();
        errors.push(`${v}: ${d.error || 'Error'}`);
      }
    } catch(e) {
      errors.push(`${v}: ${e.message}`);
    }
  }

  btn.disabled = false;
  btn.innerHTML = '<i class="bi bi-check-circle"></i> Crear productos';

  if (errors.length) {
    errEl.textContent = `${ok} creados. Errores: ${errors.join(', ')}`;
    errEl.style.display = 'block';
  }

  if (ok > 0) {
    cerrarVariantes();
    try {
      const rv = await fetch('/api/products?limit=9999');
      if (rv.ok) { _allProducts = await rv.json(); renderTable(_allProducts); }
    } catch(e) { location.reload(); }
    showToast(`✅ ${ok} producto${ok!==1?'s':''} creado${ok!==1?'s':''}`, 'success');
  }
}
</script>
