      </div>

      <!-- ── COLUMNA DERECHA ── -->
      <div style="padding:18px 20px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;">

        <div style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--text-secondary);margin-bottom:2px;">Precios y promoción</div>

        <div>
          <label class="form-lbl">Precio Costo ($) <span style="font-weight:400;text-transform:none;font-size:10px;">(opcional)</span></label>
          <input type="number" id="m_price_cost" placeholder="0.00" min="0" step="0.01"
            style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
            onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'"
            oninput="calcPrecioVenta()">
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div>
            <label class="form-lbl">Margen (%)</label>
            <div style="display:flex;align-items:center;gap:5px;">
              <input type="number" id="m_margen" placeholder="50" min="0" step="0.1" value="50"
                style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
                onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='var(--border-color)'"
                oninput="calcPrecioVenta()">
              <span style="font-size:13px;color:var(--text-secondary);flex-shrink:0;">%</span>
            </div>
          </div>
          <div>
            <label class="form-lbl">Precio Venta Final ($) *</label>
            <input type="number" id="m_price" placeholder="0.00" min="0" step="0.01"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1.5px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;font-weight:700;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'"
