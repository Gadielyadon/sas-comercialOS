        <div id="margenIndicador" style="display:none;padding:7px 11px;border-radius:var(--radius-sm);background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);font-size:12px;color:#059669;font-weight:600;"></div>

        <div id="m_preview" style="display:none;background:rgba(27,79,216,.06);border:1px solid rgba(27,79,216,.2);border-radius:var(--radius-md);padding:11px;">
          <div style="font-size:10.5px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;margin-bottom:7px;">Desglose fiscal estimado</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 14px;align-items:center;">
            <div><span style="font-size:11px;color:var(--text-secondary);">Precio cargado: </span><span id="prev_base" style="font-weight:700;color:var(--text-primary);"></span></div>
            <div><span style="font-size:11px;color:var(--text-secondary);">Neto estimado: </span><span id="prev_neto" style="font-weight:600;color:var(--text-primary);"></span></div>
            <div><span style="font-size:11px;color:var(--text-secondary);">IVA incluido: </span><span id="prev_iva" style="font-weight:600;color:var(--color-primary);"></span></div>
            <div><span style="font-size:11px;color:var(--text-secondary);">IEPS incluido: </span><span id="prev_ieps" style="font-weight:600;color:#d97706;"></span></div>
            <div style="grid-column:1 / -1;border-top:1px dashed rgba(0,0,0,.08);padding-top:8px;">
              <span style="font-size:11px;color:var(--text-secondary);">Total facturado: </span><span id="prev_total" style="font-weight:700;font-size:14px;color:var(--text-primary);"></span>
            </div>
          </div>
        </div>

        <!-- ══ PRECIO TARJETA ══ -->
        <div style="background:var(--bg-card);border:1.5px solid rgba(16,185,129,.35);border-radius:var(--radius-md);padding:14px;">
          <div style="font-size:11px;font-weight:700;color:#065f46;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">
            <i class="bi bi-credit-card" style="margin-right:5px;color:#10b981;"></i>Precio Tarjeta <span style="font-weight:400;font-size:10px;text-transform:none;">(opcional)</span>
          </div>
          <input type="number" id="m_price_tarjeta" placeholder="0.00 — dejar vacío para usar precio normal" min="0" step="0.01"
            style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1.5px solid rgba(16,185,129,.3);background:var(--bg-surface-2);color:var(--text-primary);font-size:14px;font-weight:700;outline:none;transition:border .2s;"
            onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='rgba(16,185,129,.3)'">
          <div style="font-size:11px;color:var(--text-secondary);margin-top:6px;">Se usa cuando el POS está en modo <strong>Tarjeta</strong>. Si está vacío usa el precio minorista.</div>
        </div>

        <!-- ══ PRECIO MAYORISTA ══ -->
        <div style="background:var(--bg-card);border:1.5px solid rgba(99,102,241,.35);border-radius:var(--radius-md);padding:14px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <div style="font-size:11px;font-weight:700;color:#4338ca;text-transform:uppercase;letter-spacing:.5px;">
              <i class="bi bi-shop" style="margin-right:5px;color:#6366f1;"></i>Precio Mayorista
            </div>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;">
              <span style="font-size:12px;color:var(--text-secondary);">Activar</span>
              <div style="position:relative;width:40px;height:22px;">
                <input type="checkbox" id="m_mayorista_check" style="opacity:0;width:0;height:0;position:absolute;" onchange="toggleMayorista(this)">
                <label for="m_mayorista_check" id="m_mayorista_track"
                  style="position:absolute;inset:0;border-radius:11px;background:var(--border-color);cursor:pointer;transition:background .2s;">
                  <span id="m_mayorista_thumb" style="position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;"></span>
                </label>
              </div>
            </label>
          </div>
          <div id="mayoristaOffMsg" style="font-size:12px;color:var(--text-secondary);font-style:italic;">Sin precio mayorista — se usa el precio minorista siempre</div>
          <div id="mayoristaFields" style="display:none;display:flex;flex-direction:column;gap:10px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <div>
                <label class="form-lbl" style="color:#4338ca;">Precio Mayorista ($)</label>
                <input type="number" id="m_price_mayorista" placeholder="0.00" min="0" step="0.01"
                  style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1.5px solid rgba(99,102,241,.4);background:var(--bg-surface-2);color:var(--text-primary);font-size:14px;font-weight:700;outline:none;transition:border .2s;"
                  onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='rgba(99,102,241,.4)'"
                  oninput="mostrarAhorroMayorista()">
              </div>
              <div>
                <label class="form-lbl" style="color:#4338ca;">Cantidad mínima (unidades)</label>
                <input type="number" id="m_qty_mayorista" placeholder="Ej: 4" min="2" step="1"
                  style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1.5px solid rgba(99,102,241,.4);background:var(--bg-surface-2);color:var(--text-primary);font-size:14px;font-weight:700;outline:none;transition:border .2s;"
                  onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='rgba(99,102,241,.4)'"
                  oninput="mostrarAhorroMayorista()">
              </div>
            </div>
            <div id="mayoristaInfo" style="display:none;padding:8px 11px;background:rgba(99,102,241,.08);border-radius:var(--radius-sm);font-size:12.5px;font-weight:700;color:#4338ca;"></div>
          </div>
        </div>

        <!-- Promo -->
        <div style="background:var(--bg-card);border:1.5px solid rgba(245,158,11,.35);border-radius:var(--radius-md);padding:14px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <div style="font-size:11px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:.5px;">
              <i class="bi bi-tag-fill" style="margin-right:5px;color:#f59e0b;"></i>Promoción
            </div>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;">
              <span style="font-size:12px;color:var(--text-secondary);">Activar</span>
              <div style="position:relative;width:40px;height:22px;">
                <input type="checkbox" id="m_en_promo" style="opacity:0;width:0;height:0;position:absolute;" onchange="togglePromo(this)">
                <label for="m_en_promo" id="m_promo_track"
                  style="position:absolute;inset:0;border-radius:11px;background:var(--border-color);cursor:pointer;transition:background .2s;">
                  <span id="m_promo_thumb" style="position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;"></span>
                </label>
              </div>
            </label>
          </div>
          <div id="promoOffMsg" style="font-size:12px;color:var(--text-secondary);font-style:italic;">Sin promoción activa — el precio normal se usa en el POS</div>
          <div id="promoFields" style="display:none;">
            <label class="form-lbl" style="color:#92400e;">Precio Promo ($)</label>
            <input type="number" id="m_price_promo" placeholder="0.00" min="0" step="0.01"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1.5px solid rgba(245,158,11,.4);background:var(--bg-surface-2);color:var(--text-primary);font-size:14px;font-weight:700;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='#f59e0b'" onblur="this.style.borderColor='rgba(245,158,11,.4)'"
              oninput="mostrarAhorroPromo()">
            <div id="promoAhorro" style="display:none;margin-top:8px;padding:8px 11px;background:rgba(245,158,11,.1);border-radius:var(--radius-sm);font-size:12.5px;font-weight:700;color:#d97706;"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- Footer botones -->
    <div style="display:flex;gap:10px;padding:14px 20px;border-top:1px solid var(--border-color);background:var(--bg-surface-2);flex-shrink:0;">
      <button onclick="guardarProducto()" class="btn-action btn-action-primary" style="flex:1;justify-content:center;padding:10px;">
        <i class="bi bi-check-lg"></i> <span id="btnGuardarTexto">Guardar producto</span>
      </button>
      <button onclick="cerrarModal()" class="btn-action btn-action-outline" style="padding:10px 18px;">
        <i class="bi bi-x-lg"></i> Cancelar
      </button>
    </div>

  </div>
</div>

<script>
let _editSku = null;

// Catálogo en memoria — inicializado desde server, sin reload
let _allProducts = <%- JSON.stringify(products) %>;

const _fmt = n => '$' + Number(n).toLocaleString('es-AR', {minimumFractionDigits:2});

/* ── Lista de precio activa en inventario ── */
let _listaInv = 'minorista';

function setListaInventario(lista) {
  _listaInv = lista;

  // Actualizar botones
  const btns = { minorista:'btnListaMin', mayorista:'btnListaMay', tarjeta:'btnListaTar' };
  const colores = { minorista:'var(--color-primary)', mayorista:'#6366f1', tarjeta:'#f59e0b' };
  Object.entries(btns).forEach(([key, id]) => {
    const btn = document.getElementById(id);
    if (!btn) return;
    const activo = key === lista;
    btn.style.background   = activo ? colores[key] : 'transparent';
    btn.style.borderColor  = activo ? colores[key] : 'var(--border-color)';
    btn.style.color        = activo ? '#fff' : 'var(--text-secondary)';
  });

  // Actualizar headers de tabla
  const labels = { minorista:'Precio Minorista', mayorista:'Precio Mayorista', tarjeta:'Precio Tarjeta' };
  const thP = document.getElementById('thPrecio');
  if (thP) thP.textContent = labels[lista];

  // En mayorista/tarjeta ocultar columnas que no aplican
  const esMini = lista === 'minorista';
  ['thCosto','thMayorista','thMargen','thPromo'].forEach(id => {
    const th = document.getElementById(id);
    if (th) th.style.display = esMini ? '' : 'none';
  });

  // Info hint
  const info = document.getElementById('listaInfoTxt');
  if (info) {
    const conPrecio = _allProducts.filter(p => {
      if (lista === 'mayorista') return p.price_mayorista && Number(p.price_mayorista) > 0;
      if (lista === 'tarjeta')   return p.price_tarjeta   && Number(p.price_tarjeta)   > 0;
      return true;
    }).length;
    info.textContent = lista !== 'minorista'
      ? `${conPrecio} de ${_allProducts.length} productos con precio cargado`
      : '';
  }

  renderTable(_allProducts);
}

function renderTable(list) {
  const tbody = document.querySelector('#productsTable tbody');
  if (!tbody) return;

  const q   = (document.getElementById('q')?.value || '').trim().toLowerCase();
  const cat = (document.getElementById('filtroCat')?.value || '').toLowerCase();

  const filtered = list.filter(p => {
    const matchQ   = !q   || p.name.toLowerCase().includes(q) || p.sku.toLowerCase().includes(q);
    const matchCat = !cat || (p.category || '').toLowerCase().includes(cat);
    let matchF = true;
    if (typeof _filtroStockActivo !== 'undefined') {
      if (_filtroStockActivo === 'sinstock') matchF = p.stock <= 0;
      if (_filtroStockActivo === 'bajo')     matchF = p.stock > 0 && p.stock <= 3;
    }
    return matchQ && matchCat && matchF;
  });

  tbody.innerHTML = filtered.map(p => {
    const sc = p.pesable ? '' : (p.stock <= 0 ? 'vacio' : p.stock <= 3 ? 'bajo' : 'ok');
    const hayVal = p.hay == null || p.hay == 1;
    const stockCell = p.pesable
      ? `<span id="hayBadge_${p.id}" class="stock-badge ${hayVal?'ok':'vacio'}" style="cursor:pointer;user-select:none;" onclick="toggleHayInventario(${p.id},this)">
           <span class="stock-dot ${hayVal?'ok':'vacio'}"></span>${hayVal?'Hay':'No hay'}
         </span>`
      : `<span class="stock-badge ${sc}"><span class="stock-dot ${sc}"></span>${p.stock}</span>`;

    const mayorCell = p.price_mayorista && p.qty_mayorista
      ? `<div><span style="font-size:10px;font-weight:800;padding:1px 6px;border-radius:20px;background:rgba(99,102,241,.12);color:#6366f1;">🏪 MAYOR</span>
           <div style="font-family:var(--font-mono);font-size:12px;color:#6366f1;font-weight:700;margin-top:2px;">${_fmt(p.price_mayorista)} <span style="font-size:10px;color:var(--text-secondary);font-weight:600;">x≥${p.qty_mayorista}</span></div></div>`
      : `<span style="color:var(--text-secondary);font-size:12px">—</span>`;

    const promoCell = p.en_promo && p.price_promo
      ? `<div><span style="font-size:10px;font-weight:800;padding:1px 6px;border-radius:20px;background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;">🏷️ PROMO</span>
           <div style="font-family:var(--font-mono);font-size:12px;color:#d97706;font-weight:700;margin-top:2px;">${_fmt(p.price_promo)}</div></div>`
      : `<span style="color:var(--text-secondary);font-size:12px">—</span>`;

    const margenCell = p.margen
      ? `<span style="font-size:11.5px;font-weight:700;padding:2px 8px;border-radius:20px;background:rgba(16,185,129,.1);color:#059669;">${Number(p.margen).toFixed(1)}%</span>`
      : `<span style="color:var(--text-secondary);font-size:12px">—</span>`;

    const descHTML = p.descripcion
      ? `<div style="font-size:11px;color:var(--text-secondary);margin-top:2px;font-style:italic;">${(p.descripcion.length>50?p.descripcion.slice(0,50)+'…':p.descripcion)}</div>`
      : '';

    const pesableBadge = p.pesable
      ? `<span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:4px;background:rgba(16,185,129,.12);color:#059669;margin-left:5px;"><i class="bi bi-scales"></i> Pesable</span>`
      : '';

    const pEsc = JSON.stringify(p).replace(/"/g, '&quot;');
    const esMini = _listaInv === 'minorista';

    let precioCell;
    if (_listaInv === 'mayorista') {
      precioCell = p.price_mayorista && Number(p.price_mayorista) > 0
        ? `<strong style="font-family:var(--font-mono);color:#6366f1;">${_fmt(p.price_mayorista)}</strong>${p.qty_mayorista ? `<div style="font-size:10px;color:var(--text-secondary);">x≥${p.qty_mayorista}</div>` : ''}`
        : `<span style="color:var(--text-muted);font-size:12px;font-style:italic;">Sin precio</span>`;
    } else if (_listaInv === 'tarjeta') {
      precioCell = p.price_tarjeta && Number(p.price_tarjeta) > 0
        ? `<strong style="font-family:var(--font-mono);color:#d97706;">${_fmt(p.price_tarjeta)}</strong>`
        : `<span style="color:var(--text-muted);font-size:12px;font-style:italic;">Sin precio</span>`;
    } else {
      precioCell = `<strong style="font-family:var(--font-mono);">${_fmt(p.price)}</strong>`;
    }

    const costoTd  = esMini ? `<td style="font-family:var(--font-mono);font-size:13px;color:var(--text-secondary)">${p.price_cost?_fmt(p.price_cost):'—'}</td>` : '';
    const mayorTd  = esMini ? `<td>${mayorCell}</td>` : '';
    const margenTd = esMini ? `<td>${margenCell}</td>` : '';
    const promoTd  = esMini ? `<td>${promoCell}</td>` : '';

    return `<tr data-sku="${p.sku}">
      <td class="sale-id">${p.id}</td>
      <td class="sale-id">${p.sku}</td>
      <td><strong>${p.name}</strong>${pesableBadge}${descHTML}</td>
      <td style="color:var(--text-secondary);font-size:12.5px">${p.category||'—'}</td>
      ${costoTd}
      <td>${precioCell}</td>
      ${mayorTd}
      ${margenTd}
      ${promoTd}
      <td data-stock="${p.stock}">${stockCell}</td>
      <td>
        <div style="display:flex;gap:6px;align-items:center">
          <button type="button" class="btn-action btn-action-outline btn-sm" onclick="stockDelta('${p.sku}',1)" title="Sumar stock">+1</button>
          <button type="button" class="btn-action btn-action-outline btn-sm" onclick="stockDelta('${p.sku}',-1)" title="Restar stock">-1</button>
          <button type="button" class="btn-action btn-action-outline btn-sm" onclick='abrirEditar(${pEsc})' title="Editar producto" style="color:var(--color-primary);border-color:rgba(27,79,216,.3);"><i class="bi bi-pencil"></i></button>
          <button type="button" class="btn-action btn-action-ghost btn-sm" onclick="removeProduct('${p.sku}')" title="Eliminar"><i class="bi bi-trash3"></i></button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function toggleIva(cb) {
  const input = document.getElementById('m_iva');
  input.disabled = !cb.checked;
  input.style.color = cb.checked ? 'var(--text-primary)' : 'var(--text-secondary)';
  input.style.background = cb.checked ? 'var(--bg-body)' : 'var(--bg-card)';
  actualizarBadge('m_iva', 'm_iva_badge', 'm_iva_check');
}
function toggleIeps(cb) { actualizarPreview(); }
function actualizarBadge(inputId, badgeId, checkId) {
  const check = document.getElementById(checkId);
  const val = (check && check.checked) ? (parseFloat(document.getElementById(inputId).value) || 0) : 0;
  const badge = document.getElementById(badgeId);
  if (badge) badge.textContent = val + '%';
  actualizarPreview();
}
function togglePesable(cb) {
  document.getElementById('m_pesable_track').style.background = cb.checked ? 'var(--color-primary)' : 'var(--border-color)';
  document.getElementById('m_pesable_thumb').style.transform = cb.checked ? 'translateX(20px)' : 'translateX(0)';
}

function toggleVentaSinStock(cb) {
  document.getElementById('m_vss_track').style.background = cb.checked ? '#f59e0b' : 'var(--border-color)';
  document.getElementById('m_vss_thumb').style.transform  = cb.checked ? 'translateX(20px)' : 'translateX(0)';
}

/* ── Toggle mayorista ── */
function toggleMayorista(cb) {
  const fields  = document.getElementById('mayoristaFields');
  const offMsg  = document.getElementById('mayoristaOffMsg');
  const track   = document.getElementById('m_mayorista_track');
  const thumb   = document.getElementById('m_mayorista_thumb');
  if (cb.checked) {
    fields.style.display = 'flex';
    offMsg.style.display = 'none';
    track.style.background = '#6366f1';
    thumb.style.transform  = 'translateX(18px)';
  } else {
    fields.style.display = 'none';
    offMsg.style.display = 'block';
    track.style.background = 'var(--border-color)';
    thumb.style.transform  = 'translateX(0)';
    document.getElementById('mayoristaInfo').style.display = 'none';
  }
}

function mostrarAhorroMayorista() {
  const precio    = parseFloat(document.getElementById('m_price')?.value) || 0;
  const mayorista = parseFloat(document.getElementById('m_price_mayorista')?.value) || 0;
  const qty       = parseInt(document.getElementById('m_qty_mayorista')?.value) || 0;
  const el        = document.getElementById('mayoristaInfo');
  if (!el) return;
  if (precio > 0 && mayorista > 0 && qty >= 2) {
    const ahorro = precio - mayorista;
    const pct    = ((ahorro / precio) * 100).toFixed(0);
    el.style.display = 'block';
    el.innerHTML = `🏪 A partir de <strong>${qty} unidades</strong> → $${mayorista.toLocaleString('es-AR',{minimumFractionDigits:2})} c/u${ahorro > 0 ? ` · Descuento <strong>${pct}%</strong>` : ''}`;
  } else {
    el.style.display = 'none';
  }
}

function actualizarPreview() {
  const precioFinal = parseFloat(document.getElementById('m_price').value) || 0;
  const ivaCheck    = document.getElementById('m_iva_check').checked;
  const ivaPct      = ivaCheck ? (parseFloat(document.getElementById('m_iva').value) || 0) : 0;
  let neto = precioFinal, ivaIncluido = 0;
  if (precioFinal > 0 && ivaPct > 0) {
    const divisor = 1 + (ivaPct / 100);
    neto = precioFinal / divisor;
    ivaIncluido = precioFinal - neto;
  }
  const fmt = (n) => '$' + Number(n || 0).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  document.getElementById('m_preview').style.display = (precioFinal > 0 && ivaCheck) ? 'block' : 'none';
  document.getElementById('prev_base').textContent  = fmt(precioFinal);
  document.getElementById('prev_neto').textContent  = fmt(neto);
  document.getElementById('prev_iva').textContent   = fmt(ivaIncluido);
  const prevIeps = document.getElementById('prev_ieps');
  if (prevIeps) prevIeps.textContent = fmt(0);
  document.getElementById('prev_total').textContent = fmt(precioFinal);
}

function calcPrecioVenta() {
  const costo  = parseFloat(document.getElementById('m_price_cost')?.value) || 0;
  const margen = parseFloat(document.getElementById('m_margen')?.value) || 0;
  const ind    = document.getElementById('margenIndicador');
  if (costo > 0 && margen > 0) {
    const precioVenta = costo * (1 + margen / 100);
    document.getElementById('m_price').value = precioVenta.toFixed(2);
    if (ind) {
      ind.style.display = 'block';
      ind.innerHTML = `Costo $${costo.toLocaleString('es-AR',{minimumFractionDigits:2})} + ${margen}% = <strong>$${precioVenta.toLocaleString('es-AR',{minimumFractionDigits:2})}</strong> precio final cargado`;
    }
    actualizarPreview();
  } else if (ind) { ind.style.display = 'none'; }
}

document.addEventListener('DOMContentLoaded', () => {
  const priceInput = document.getElementById('m_price');
  if (priceInput) {
    priceInput.addEventListener('input', () => {
      const costo = parseFloat(document.getElementById('m_price_cost')?.value) || 0;
      const venta = parseFloat(priceInput.value) || 0;
      const ind   = document.getElementById('margenIndicador');
      if (costo > 0 && venta > 0) {
        const margenCalc = ((venta - costo) / costo) * 100;
        if (document.getElementById('m_margen')) document.getElementById('m_margen').value = margenCalc.toFixed(1);
        if (ind) {
          ind.style.display = 'block';
          ind.innerHTML = `Margen calculado: <strong>${margenCalc.toFixed(1)}%</strong> sobre costo $${costo.toLocaleString('es-AR',{minimumFractionDigits:2})}`;
        }
      }
    });
  }
});

function togglePromo(chk) {
  const fields = document.getElementById('promoFields');
  const offMsg = document.getElementById('promoOffMsg');
  const track  = document.getElementById('m_promo_track');
  const thumb  = document.getElementById('m_promo_thumb');
  if (chk.checked) {
    if (fields) fields.style.display = 'block';
    if (offMsg) offMsg.style.display = 'none';
    if (track)  track.style.background = '#f59e0b';
    if (thumb)  thumb.style.transform  = 'translateX(18px)';
  } else {
    if (fields) fields.style.display = 'none';
    if (offMsg) offMsg.style.display = 'block';
    if (track)  track.style.background = 'var(--border-color)';
    if (thumb)  thumb.style.transform  = 'translateX(0)';
  }
}

function mostrarAhorroPromo() {
  const precio = parseFloat(document.getElementById('m_price')?.value) || 0;
  const promo  = parseFloat(document.getElementById('m_price_promo')?.value) || 0;
  const el     = document.getElementById('promoAhorro');
  if (!el) return;
  if (precio > 0 && promo > 0 && promo < precio) {
    const ahorro = precio - promo;
    const pct    = ((ahorro / precio) * 100).toFixed(0);
    el.style.display = 'block';
    el.innerHTML = `🏷️ Descuento: <strong>${pct}%</strong><br>Ahorro: $${ahorro.toLocaleString('es-AR',{minimumFractionDigits:2})}`;
  } else { el.style.display = 'none'; }
}

function abrirModal(prefillSku = '') {
  _editSku = null;
  document.getElementById('modalTitulo').textContent    = 'Nuevo Producto';
  document.getElementById('modalSubtitulo').textContent = 'Completá los datos del producto';
  document.getElementById('btnGuardarTexto').textContent = 'Guardar producto';
  document.getElementById('m_sku').value      = prefillSku || '';
  document.getElementById('m_sku').disabled   = false;
  document.getElementById('m_name').value     = '';
  document.getElementById('m_price').value    = '';
  document.getElementById('m_category').value = '';
  document.getElementById('m_stock').value    = '0';
  if (document.getElementById('m_price_cost'))  document.getElementById('m_price_cost').value  = '';
  if (document.getElementById('m_margen'))       document.getElementById('m_margen').value       = '50';
  if (document.getElementById('m_en_promo'))   { document.getElementById('m_en_promo').checked = false; togglePromo(document.getElementById('m_en_promo')); }
  if (document.getElementById('m_price_promo')) document.getElementById('m_price_promo').value = '';
  if (document.getElementById('m_descripcion')) document.getElementById('m_descripcion').value = '';
  document.getElementById('margenIndicador').style.display = 'none';
  document.getElementById('m_iva_check').checked  = false;
  document.getElementById('m_ieps_check').checked = false;
  document.getElementById('m_pesable').checked    = false;
  toggleIva(document.getElementById('m_iva_check'));
  toggleIeps(document.getElementById('m_ieps_check'));
  togglePesable(document.getElementById('m_pesable'));
  document.getElementById('m_venta_sin_stock').checked = false;
  toggleVentaSinStock(document.getElementById('m_venta_sin_stock'));
  document.getElementById('m_preview').style.display = 'none';
  // Resetear mayorista
  document.getElementById('m_mayorista_check').checked = false;
  toggleMayorista(document.getElementById('m_mayorista_check'));
  if (document.getElementById('m_price_mayorista')) document.getElementById('m_price_mayorista').value = '';
  if (document.getElementById('m_qty_mayorista'))   document.getElementById('m_qty_mayorista').value   = '';
  if (document.getElementById('m_price_tarjeta'))   document.getElementById('m_price_tarjeta').value   = '';
  setImagenPreview(null);
  document.getElementById('modalProducto').classList.add('open');
  setTimeout(() => document.getElementById(prefillSku ? 'm_name' : 'm_sku').focus(), 80);
}

function abrirEditar(p) {
  _editSku = p.sku;
  document.getElementById('modalTitulo').textContent    = 'Editar Producto';
  document.getElementById('modalSubtitulo').textContent = 'SKU: ' + p.sku;
  document.getElementById('btnGuardarTexto').textContent = 'Guardar cambios';
  document.getElementById('m_sku').value      = p.sku;
  document.getElementById('m_sku').disabled   = false;
  document.getElementById('m_name').value     = p.name;
  if (document.getElementById('m_descripcion')) document.getElementById('m_descripcion').value = p.descripcion || '';
  document.getElementById('m_price').value    = p.price;
  document.getElementById('m_category').value = p.category || '';
  document.getElementById('m_stock').value    = p.stock;
  if (document.getElementById('m_price_cost')) document.getElementById('m_price_cost').value = p.price_cost || '';
  if (document.getElementById('m_margen'))     document.getElementById('m_margen').value     = p.margen || 50;
  const enPromo = p.en_promo === 1 || p.en_promo === true;
  if (document.getElementById('m_en_promo')) {
    document.getElementById('m_en_promo').checked = enPromo;
    togglePromo(document.getElementById('m_en_promo'));
  }
  if (enPromo && document.getElementById('m_price_promo')) document.getElementById('m_price_promo').value = p.price_promo || '';
  mostrarAhorroPromo();
  calcPrecioVenta();
  const ivaCheck = p.iva > 0;
  document.getElementById('m_iva_check').checked = ivaCheck;
  document.getElementById('m_iva').value = p.iva || 16;
  toggleIva(document.getElementById('m_iva_check'));
  const iepsCheck = p.ieps > 0;
  document.getElementById('m_ieps_check').checked = iepsCheck;
  document.getElementById('m_ieps').value = p.ieps || 3;
  toggleIeps(document.getElementById('m_ieps_check'));
  document.getElementById('m_pesable').checked = Boolean(p.pesable);
  togglePesable(document.getElementById('m_pesable'));
  document.getElementById('m_venta_sin_stock').checked = Boolean(p.venta_sin_stock);
  toggleVentaSinStock(document.getElementById('m_venta_sin_stock'));
  // Mayorista
  const tieneMayorista = !!(p.price_mayorista && p.qty_mayorista);
  document.getElementById('m_mayorista_check').checked = tieneMayorista;
  toggleMayorista(document.getElementById('m_mayorista_check'));
  if (tieneMayorista) {
    if (document.getElementById('m_price_mayorista')) document.getElementById('m_price_mayorista').value = p.price_mayorista || '';
    if (document.getElementById('m_qty_mayorista'))   document.getElementById('m_qty_mayorista').value   = p.qty_mayorista   || '';
    mostrarAhorroMayorista();
  }
  // Tarjeta
  if (document.getElementById('m_price_tarjeta')) document.getElementById('m_price_tarjeta').value = p.price_tarjeta || '';
  setImagenPreview(p.imagen || null);
  actualizarPreview();
  document.getElementById('modalProducto').classList.add('open');
  setTimeout(() => document.getElementById('m_name').focus(), 80);
}

function cerrarModal() { document.getElementById('modalProducto').classList.remove('open'); }
function cerrarModalSiOverlay(e) { if (e.target.id === 'modalProducto') cerrarModal(); }

async function guardarProducto() {
  const sku         = document.getElementById('m_sku').value.trim();
  const name        = document.getElementById('m_name').value.trim();
  const price       = parseFloat(document.getElementById('m_price').value) || 0;
  const category    = document.getElementById('m_category').value.trim();
  const stock       = parseInt(document.getElementById('m_stock').value) || 0;
  const ivaCheck    = document.getElementById('m_iva_check').checked;
  const iepsCheck   = document.getElementById('m_ieps_check').checked;
  const iva         = ivaCheck  ? (parseFloat(document.getElementById('m_iva').value)  || 0) : 0;
  const ieps        = iepsCheck ? (parseFloat(document.getElementById('m_ieps').value) || 0) : 0;
  const pesable         = document.getElementById('m_pesable').checked ? 1 : 0;
  const venta_sin_stock = document.getElementById('m_venta_sin_stock').checked ? 1 : 0;
  const descripcion = document.getElementById('m_descripcion')?.value.trim() || null;
  const price_cost  = document.getElementById('m_price_cost')?.value.trim()
    ? (parseFloat(document.getElementById('m_price_cost').value) || null) : null;
  const margen      = document.getElementById('m_margen')?.value.trim()
    ? (parseFloat(document.getElementById('m_margen').value) || null) : null;
  const en_promo    = document.getElementById('m_en_promo')?.checked ? 1 : 0;
  const price_promo = en_promo ? (parseFloat(document.getElementById('m_price_promo')?.value) || null) : null;
  const imagen      = document.getElementById('m_imagen')?.value || null;
  // Mayorista
  const tieneMayorista   = document.getElementById('m_mayorista_check')?.checked;
  const price_mayorista  = tieneMayorista ? (parseFloat(document.getElementById('m_price_mayorista')?.value) || null) : null;
  const qty_mayorista    = tieneMayorista ? (parseInt(document.getElementById('m_qty_mayorista')?.value)    || null) : null;
  // Tarjeta — leer explícitamente: vacío = null, número = número
  const _tarjetaVal = document.getElementById('m_price_tarjeta')?.value.trim();
  const price_tarjeta = _tarjetaVal ? (parseFloat(_tarjetaVal) || null) : null;

  if (!sku || !name) { alert('SKU y Nombre son obligatorios.'); return; }

  try {
    let saved;
    if (_editSku) {
      const r = await fetch(`/api/products/${encodeURIComponent(_editSku)}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku, name, price, category, stock, iva, ieps, pesable, venta_sin_stock, descripcion, price_cost, margen, en_promo, price_promo, imagen, price_mayorista, qty_mayorista, price_tarjeta })
      });
      if (!r.ok) { const e = await r.json().catch(()=>({error:`HTTP ${r.status}`})); alert('Error editando: ' + (e.error || r.status)); return; }
      saved = await r.json();
      const idx = _allProducts.findIndex(p => p.sku === _editSku);
      if (idx !== -1) _allProducts[idx] = saved;
      else _allProducts.push(saved);
    } else {
      const r = await fetch('/api/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku, name, price, category, stock, iva, ieps, pesable, venta_sin_stock, descripcion, imagen, price_cost, margen, price_mayorista, qty_mayorista, price_tarjeta })
      });
      if (!r.ok) { const e = await r.json().catch(()=>({error:`HTTP ${r.status}`})); alert('Error creando: ' + (e.error || r.status)); return; }
      saved = await r.json();
      _allProducts.push(saved);
    }
    cerrarModal();
    renderTable(_allProducts);
  } catch(err) { alert('Error de red: ' + err.message); }
}

function setImagenPreview(src) {
  const preview  = document.getElementById('img-preview');
  const icon     = document.getElementById('img-placeholder-icon');
  const removeBtn = document.getElementById('img-remove-btn');
  const hidden   = document.getElementById('m_imagen');
  if (src) {
    preview.src = src; preview.style.display = 'block'; icon.style.display = 'none';
    removeBtn.style.display = 'flex'; hidden.value = src;
  } else {
    preview.src = ''; preview.style.display = 'none'; icon.style.display = 'block';
    removeBtn.style.display = 'none'; hidden.value = '';
    document.getElementById('img-filename').style.display = 'none';
    document.getElementById('img-filename').textContent = '';
  }
}

function onImageFileSelected(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (file.size > 5 * 1024 * 1024) { alert('La imagen no puede superar 5MB.'); event.target.value = ''; return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = new Image();
    img.onload = function() {
      const canvas = document.createElement('canvas');
      const MAX = 600; let w = img.width, h = img.height;
      if (w > MAX || h > MAX) { if (w > h) { h = Math.round(h * MAX / w); w = MAX; } else { w = Math.round(w * MAX / h); h = MAX; } }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      const compressed = canvas.toDataURL('image/jpeg', 0.75);
      setImagenPreview(compressed);
      const fname = document.getElementById('img-filename');
      fname.textContent = file.name; fname.style.display = 'block';
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
  event.target.value = '';
}

function removerImagen() { setImagenPreview(null); }
async function toggleHayInventario(id, badge) {
  const esHay = badge.textContent.trim().startsWith('Hay');
  const nuevoHay = esHay ? 0 : 1;
  try {
    const r = await fetch('/stock/hay', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, hay: nuevoHay })
    });
    const data = await r.json();
    if (data.ok) {
      badge.className = 'stock-badge ' + (nuevoHay ? 'ok' : 'vacio');
      badge.innerHTML = `<span class="stock-dot ${nuevoHay ? 'ok' : 'vacio'}"></span>${nuevoHay ? 'Hay' : 'No hay'}`;
      badge.onclick = () => toggleHayInventario(id, badge);
    }
  } catch(e) {}
}
let _invFiltrarTimer = null;
function debFilterRows() { clearTimeout(_invFiltrarTimer); _invFiltrarTimer = setTimeout(filterRows, 80); }

function filterRows() {
  const q = document.getElementById('q').value.trim().toLowerCase();
  document.querySelectorAll('#productsTable tbody tr').forEach(tr => {
    const sku  = tr.children[1].innerText.toLowerCase();
    const name = tr.children[2].innerText.toLowerCase();
    tr.style.display = (sku.includes(q) || name.includes(q)) ? '' : 'none';
  });
}
async function stockDelta(sku, delta) {
  const r = await fetch(`/api/products/${encodeURIComponent(sku)}/stock`, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ delta })
  });
  if (!r.ok) { const e = await r.json().catch(()=>({error:'Error'})); alert(e.error || 'Error'); return; }
  const updated = await r.json();
  const idx = _allProducts.findIndex(p => p.sku === sku);
  if (idx !== -1) _allProducts[idx] = updated;
  renderTable(_allProducts);
}
async function removeProduct(sku) {
  if (!confirm('¿Eliminar producto ' + sku + '?')) return;
  const r = await fetch(`/api/products/${encodeURIComponent(sku)}`, { method: 'DELETE' });
  if (!r.ok) { const e = await r.json().catch(()=>({error:'Error'})); alert(e.error || 'Error eliminando'); return; }
  _allProducts = _allProducts.filter(p => p.sku !== sku);
  renderTable(_allProducts);
}
function exportCSV() { window.location.href = '/api/products.xlsx'; }
document.addEventListener('keydown', e => { if (e.key === 'Escape') { cerrarModal(); cerrarImportar(); } });
