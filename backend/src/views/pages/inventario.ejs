<%- include('../partials/head', { title }) %>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active, user }) %>

  <div class="main-content">
    <%- include('../partials/header', { module, user }) %>

    <main class="page-body">

      <div class="page-header">
        <div class="page-header-title">
          <h2>Productos</h2>
          <p><%= products.length %> productos registrados en el sistema.</p>
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap">
          <button type="button" class="btn-action btn-action-outline" onclick="exportCSV()">
            <i class="bi bi-file-earmark-excel"></i> Exportar XLSX
          </button>
          <button type="button" class="btn-action btn-action-outline" onclick="abrirImportar()"
            style="color:#10b981;border-color:rgba(16,185,129,.4);">
            <i class="bi bi-file-earmark-excel"></i> Importar Excel
          </button>
          <button type="button" class="btn-action btn-action-primary" onclick="abrirModal()">
            <i class="bi bi-plus-lg"></i> Nuevo Producto
          </button>
          <button type="button" onclick="abrirVariantes()" style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:var(--radius-sm);border:1.5px solid rgba(99,102,241,.35);background:rgba(99,102,241,.07);color:#6366f1;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:all .15s;" title="Crear múltiples variantes de un mismo producto">
            <i class="bi bi-stack"></i> Carga rápida
          </button>
        </div>
      </div>

      <!-- TOOLBAR -->
      <div class="page-toolbar" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:16px;">
        <div style="position:relative;flex:1;min-width:260px;">
          <div style="position:absolute;left:12px;top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;pointer-events:none;">
            <i class="bi bi-search" id="searchIcoNormal" style="color:var(--text-muted);font-size:14px;"></i>
            <i class="bi bi-upc-scan" id="searchIcoScan" style="color:#10b981;font-size:14px;display:none;"></i>
          </div>
          <input id="q" class="search-input"
            placeholder="Buscar por nombre, SKU o escaneá un código de barras…"
            oninput="debFilterRows()" autocomplete="off" spellcheck="false"
            style="padding-left:36px;width:100%;">
          <div id="scanModeBadge" style="display:none;position:absolute;right:10px;top:50%;transform:translateY(-50%);
            background:rgba(16,185,129,.12);color:#10b981;border-radius:20px;padding:3px 10px;
            font-size:11px;font-weight:700;border:1px solid rgba(16,185,129,.3);">
            <i class="bi bi-upc-scan"></i> Scanner activo
          </div>
        </div>

        <div style="display:flex;gap:6px;flex-shrink:0;align-items:center;flex-wrap:wrap;">
          <button class="btn-filtro-stock active" id="filtroTodos"    onclick="setFiltroStock('todos',   this)">Todos</button>
          <button class="btn-filtro-stock"         id="filtroSinStock" onclick="setFiltroStock('sinstock', this)">
            <span class="dot-stock rojo"></span> Sin stock
          </button>
          <button class="btn-filtro-stock"         id="filtroStockBajo" onclick="setFiltroStock('bajo', this)">
            <span class="dot-stock naranja"></span> Stock bajo
          </button>
          <select id="filtroCat" onchange="filterRows()"
            style="height:34px;padding:0 10px;border-radius:8px;border:1.5px solid var(--border-color);background:var(--bg-surface);color:var(--text-primary);font-family:var(--font-body);font-size:12.5px;font-weight:600;cursor:pointer;outline:none;transition:border-color .15s;">
            <option value="">Todas las categorías</option>
            <% const cats = [...new Set(products.map(p => p.category).filter(Boolean))].sort(); %>
            <% cats.forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <div id="scanHint" style="width:100%;font-size:11.5px;color:var(--text-muted);margin-top:-6px;display:none;">
          <i class="bi bi-upc-scan" style="color:#10b981;"></i>
          Scanner listo — escaneá un código de barras para ajustar stock al instante
        </div>
      </div>

      <style>
        /* Fondo modal producto — solo modo claro */
        :root:not([data-theme="dark"]) #modalProducto > div {
          background: #bbc3ca !important;
        }
        :root:not([data-theme="dark"]) #modalProducto > div > div[style*="padding:18px"] {
          background: #f1f5f9;
        }
        .btn-filtro-stock {
          display: inline-flex; align-items: center; gap: 6px;
          padding: 7px 14px; border-radius: 20px; border: 1.5px solid var(--border-color);
          background: var(--bg-surface); color: var(--text-secondary);
          font-size: 12.5px; font-weight: 600; cursor: pointer; transition: all .15s;
          white-space: nowrap;
        }
        .btn-filtro-stock:hover { border-color: var(--color-primary); color: var(--color-primary); }
        .btn-filtro-stock.active { border-color: var(--color-primary); background: var(--color-primary); color: #fff; }
        .btn-filtro-stock.active .dot-stock { border-color: rgba(255,255,255,.6); }
        .dot-stock { width: 8px; height: 8px; border-radius: 50%; border: 1.5px solid transparent; display: inline-block; }
        .dot-stock.rojo    { background: #ef4444; }
        .dot-stock.naranja { background: #f59e0b; }
        .stock-badge {
          display: inline-flex; align-items: center; gap: 6px;
          padding: 5px 14px; border-radius: 20px; font-size: 13px;
          font-weight: 800; font-family: var(--font-mono);
          min-width: 60px; justify-content: center;
        }
        .stock-badge.ok     { background: #10b981; color: #fff; border: none; }
        .stock-badge.bajo   { background: #f59e0b; color: #fff; border: none; }
        .stock-badge.vacio  { background: #ef4444; color: #fff; border: none; }
        .stock-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .stock-dot.ok     { background: rgba(255,255,255,.7); box-shadow: 0 0 5px rgba(255,255,255,.5); animation: stockPulse 2s infinite; }
        .stock-dot.bajo   { background: rgba(255,255,255,.7); }
        .stock-dot.vacio  { background: rgba(255,255,255,.7); }
        @keyframes stockPulse { 0%,100%{opacity:1} 50%{opacity:.4} }
        .stock-modal-overlay {
          display: none; position: fixed; inset: 0;
          background: rgba(0,0,0,.55); z-index: 300;
          align-items: center; justify-content: center; padding: 20px;
        }
        .stock-modal-overlay.open { display: flex; }
        .stock-modal-box {
          background: var(--bg-surface); border: 1px solid var(--border-color);
          border-radius: 20px; width: 100%; max-width: 420px;
          box-shadow: 0 24px 80px rgba(0,0,0,.3);
          animation: modalPop .16s ease; overflow: hidden;
        }
        .stock-modal-header {
          padding: 20px 24px 16px; border-bottom: 1px solid var(--border-color);
          background: linear-gradient(135deg, rgba(16,185,129,.06), rgba(27,79,216,.04));
        }
        .stock-modal-producto { font-size: 17px; font-weight: 800; color: var(--text-primary); margin-bottom: 4px; }
        .stock-modal-meta { font-size: 12.5px; color: var(--text-secondary); display: flex; gap: 12px; }
        .stock-modal-body { padding: 20px 24px; }
        .stock-actual-wrap {
          display: flex; align-items: center; justify-content: space-between;
          background: var(--bg-surface-2); border-radius: 12px; padding: 14px 18px;
          margin-bottom: 18px; border: 1px solid var(--border-color);
        }
        .stock-actual-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-secondary); margin-bottom: 4px; }
        .stock-actual-val { font-size: 28px; font-weight: 900; font-family: var(--font-mono); }
        .stock-ajuste-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 14px; }
        .btn-ajuste {
          padding: 14px 8px; border-radius: 12px; border: 2px solid var(--border-color);
          background: var(--bg-surface-2); cursor: pointer; transition: all .15s;
          font-size: 15px; font-weight: 800; display: flex; flex-direction: column;
          align-items: center; gap: 4px; color: var(--text-primary);
        }
        .btn-ajuste:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
        .btn-ajuste.suma  { border-color: rgba(16,185,129,.4); color: #059669; }
        .btn-ajuste.suma:hover  { background: rgba(16,185,129,.08); border-color: #10b981; }
        .btn-ajuste.resta { border-color: rgba(239,68,68,.3); color: #dc2626; }
        .btn-ajuste.resta:hover { background: rgba(239,68,68,.06); border-color: #ef4444; }
        .btn-ajuste-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-secondary); }
        .stock-custom-row { display: flex; gap: 8px; align-items: center; }
        .stock-custom-input {
          flex: 1; padding: 10px 14px; border: 2px solid var(--border-color);
          border-radius: 10px; background: var(--bg-surface-2); color: var(--text-primary);
          font-size: 16px; font-weight: 700; font-family: var(--font-mono);
          text-align: center; outline: none; transition: border-color .15s;
        }
        .stock-custom-input:focus { border-color: var(--color-primary); }
        .btn-stock-set {
          padding: 10px 18px; border-radius: 10px; border: none;
          background: var(--color-primary); color: #fff; font-size: 13.5px;
          font-weight: 700; cursor: pointer; white-space: nowrap; transition: opacity .15s;
        }
        .btn-stock-set:hover { opacity: .88; }
        .stock-modal-footer {
          padding: 12px 24px; border-top: 1px solid var(--border-color);
          display: flex; gap: 8px; justify-content: flex-end; background: var(--bg-surface-2);
        }
        .btn-stock-cancel { padding: 9px 18px; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 13px; font-weight: 600; cursor: pointer; }
      </style>

      <!-- TABLA -->
      <!-- ── Selector de lista de precio ── -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
        <span style="font-size:11.5px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;">Lista de precios:</span>
        <div style="display:flex;gap:5px;">
          <button id="btnListaMin" onclick="setListaInventario('minorista')"
            style="padding:5px 14px;border-radius:20px;border:1.5px solid var(--color-primary);background:var(--color-primary);color:#fff;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:all .15s;">
            <i class="bi bi-person"></i> Minorista
          </button>
          <button id="btnListaMay" onclick="setListaInventario('mayorista')"
            style="padding:5px 14px;border-radius:20px;border:1.5px solid var(--border-color);background:transparent;color:var(--text-secondary);font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:all .15s;">
            <i class="bi bi-building"></i> Mayorista
          </button>
          <button id="btnListaTar" onclick="setListaInventario('tarjeta')"
            style="padding:5px 14px;border-radius:20px;border:1.5px solid var(--border-color);background:transparent;color:var(--text-secondary);font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:all .15s;">
            <i class="bi bi-credit-card"></i> Tarjeta
          </button>
        </div>
        <span id="listaInfoTxt" style="font-size:11px;color:var(--text-muted);"></span>
      </div>

      <div class="card-panel">
        <div class="card-panel-body">
          <table class="sales-table" id="productsTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>SKU</th>
                <th>Nombre / Descripción</th>
                <th>Categoría</th>
                <th id="thCosto">Costo</th>
                <th id="thPrecio">Precio Minorista</th>
                <th id="thMayorista">Mayorista</th>
                <th id="thMargen">Margen</th>
                <th id="thPromo">Promo</th>
                <th>Stock</th>
                <th style="width:150px">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(p => { %>
                <tr data-sku="<%= p.sku %>">
                  <td class="sale-id"><%= p.id %></td>
                  <td class="sale-id"><%= p.sku %></td>
                  <td>
                    <strong><%= p.name %></strong>
                    <% if (p.pesable) { %>
                      <span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:4px;background:rgba(16,185,129,.12);color:#059669;margin-left:5px;">
                        <i class="bi bi-scales"></i> Pesable
                      </span>
                    <% } %>
                    <% if (p.descripcion) { %>
                      <div style="font-size:11px;color:var(--text-secondary);margin-top:2px;font-style:italic;"><%= p.descripcion.length > 50 ? p.descripcion.slice(0,50) + '…' : p.descripcion %></div>
                    <% } %>
                  </td>
                  <td style="color:var(--text-secondary);font-size:12.5px"><%= p.category || '—' %></td>
                  <td style="font-family:var(--font-mono);font-size:13px;color:var(--text-secondary)">
                    <%= p.price_cost ? '$' + Number(p.price_cost).toLocaleString('es-AR',{minimumFractionDigits:2}) : '—' %>
                  </td>
                  <td><strong style="font-family:var(--font-mono);">$<%= Number(p.price).toLocaleString('es-AR',{minimumFractionDigits:2}) %></strong></td>
                  <td>
                    <% if (p.price_mayorista && p.qty_mayorista) { %>
                      <div>
                        <span style="font-size:10px;font-weight:800;padding:1px 6px;border-radius:20px;background:rgba(99,102,241,.12);color:#6366f1;">🏪 MAYOR</span>
                        <div style="font-family:var(--font-mono);font-size:12px;color:#6366f1;font-weight:700;margin-top:2px;">
                          $<%= Number(p.price_mayorista).toLocaleString('es-AR',{minimumFractionDigits:2}) %>
                          <span style="font-size:10px;color:var(--text-secondary);font-weight:600;">x≥<%= p.qty_mayorista %></span>
                        </div>
                      </div>
                    <% } else { %>
                      <span style="color:var(--text-secondary);font-size:12px">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (p.margen) { %>
                      <span style="font-size:11.5px;font-weight:700;padding:2px 8px;border-radius:20px;background:rgba(16,185,129,.1);color:#059669;">
                        <%= Number(p.margen).toFixed(1) %>%
                      </span>
                    <% } else { %>
                      <span style="color:var(--text-secondary);font-size:12px">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (p.en_promo && p.price_promo) { %>
                      <div>
                        <span style="font-size:10px;font-weight:800;padding:1px 6px;border-radius:20px;background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;">🏷️ PROMO</span>
                        <div style="font-family:var(--font-mono);font-size:12px;color:#d97706;font-weight:700;margin-top:2px;">$<%= Number(p.price_promo).toLocaleString('es-AR',{minimumFractionDigits:2}) %></div>
                      </div>
                    <% } else { %>
                      <span style="color:var(--text-secondary);font-size:12px">—</span>
                    <% } %>
                  </td>
                  <td data-stock="<%= p.stock %>">
                    <% if (p.pesable) { %>
                      <% const hayVal = (p.hay == null || p.hay == 1); %>
                      <span id="hayBadge_<%= p.id %>" class="stock-badge <%= hayVal ? 'ok' : 'vacio' %>"
                        style="cursor:pointer;user-select:none;" title="Click para cambiar"
                        onclick="toggleHayInventario(<%= p.id %>, this)">
                        <span class="stock-dot <%= hayVal ? 'ok' : 'vacio' %>"></span>
                        <%= hayVal ? 'Hay' : 'No hay' %>
                      </span>
                    <% } else { %>
                      <% const sc = p.stock <= 0 ? 'vacio' : (p.stock <= 3 ? 'bajo' : 'ok'); %>
                      <span class="stock-badge <%= sc %>">
                        <span class="stock-dot <%= sc %>"></span>
                        <%= p.stock %>
                      </span>
                    <% } %>
                  </td>
                  <td>
                    <div style="display:flex; gap:6px; align-items:center">
                      <button type="button" class="btn-action btn-action-outline btn-sm" onclick="stockDelta('<%= p.sku %>', 1)" title="Sumar stock">+1</button>
                      <button type="button" class="btn-action btn-action-outline btn-sm" onclick="stockDelta('<%= p.sku %>', -1)" title="Restar stock">-1</button>
                      <button type="button" class="btn-action btn-action-outline btn-sm" onclick="abrirEditar(<%= JSON.stringify(p) %>)" title="Editar producto"
                        style="color:var(--color-primary); border-color:rgba(27,79,216,.3);">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <button type="button" class="btn-action btn-action-ghost btn-sm" onclick="removeProduct('<%= p.sku %>')" title="Eliminar">
                        <i class="bi bi-trash3"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     MODAL NUEVO / EDITAR PRODUCTO
══════════════════════════════════════════════════════ -->
<div class="sale-overlay" id="modalProducto" onclick="cerrarModalSiOverlay(event)">
  <div style="width:100%;max-width:860px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:var(--radius-lg);box-shadow:0 20px 60px rgba(0,0,0,.2);animation:modalPop .16s ease;max-height:92vh;display:flex;flex-direction:column;overflow:hidden;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 22px;border-bottom:1px solid var(--border-color);flex-shrink:0;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--color-primary),#0099b8);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;flex-shrink:0;">
          <i class="bi bi-box-seam"></i>
        </div>
        <div>
          <div style="font-size:15px;font-weight:700;color:var(--text-primary);" id="modalTitulo">Nuevo Producto</div>
          <div style="font-size:11px;color:var(--text-secondary);" id="modalSubtitulo">Completá los datos del producto</div>
        </div>
      </div>
      <button onclick="cerrarModal()" style="background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:20px;padding:4px;line-height:1;">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <!-- Body en dos columnas -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;flex:1;overflow:hidden;">

      <!-- ── COLUMNA IZQUIERDA ── -->
      <div style="padding:18px 20px;overflow-y:auto;border-right:1px solid var(--border-color);display:flex;flex-direction:column;gap:12px;">

        <div style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--text-secondary);margin-bottom:2px;">Datos del producto</div>

        <div style="display:grid;grid-template-columns:1fr 2fr;gap:10px;">
          <div>
            <label class="form-lbl">SKU / Código</label>
            <input type="text" id="m_sku" placeholder="ABC-001"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-mono);font-size:12.5px;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
          </div>
          <div>
            <label class="form-lbl">Nombre *</label>
            <input type="text" id="m_name" placeholder="Nombre del producto"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div>
            <label class="form-lbl">Categoría</label>
            <input type="text" id="m_category" placeholder="Ej: Bebidas"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
          </div>
          <div>
            <label class="form-lbl">Stock inicial</label>
            <input type="number" id="m_stock" placeholder="0" min="0" step="1" value="0"
              style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:13px;outline:none;transition:border .2s;"
              onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <div id="m_stock_edit_wrap" style="margin-top:6px;"></div>
          </div>
        </div>

        <div>
          <label class="form-lbl">Descripción <span style="font-weight:400;text-transform:none;font-size:10px;">(opcional)</span></label>
          <textarea id="m_descripcion" placeholder="Ej: Pack de 10 unidades..." rows="2"
            style="width:100%;padding:8px 11px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-size:12.5px;outline:none;transition:border .2s;font-family:var(--font-body);resize:vertical;"
            onfocus="this.style.borderColor='var(--color-primary)'" onblur="this.style.borderColor='var(--border-color)'"></textarea>
        </div>

        <div>
          <label class="form-lbl">Imagen del producto <span style="font-weight:400;text-transform:none;font-size:10px;">(opcional)</span></label>
          <div id="img-upload-area" style="border:1.5px dashed var(--border-color);border-radius:var(--radius-md);padding:12px;display:flex;align-items:center;gap:12px;background:var(--bg-surface-2);transition:border-color .2s;">
            <div id="img-preview-wrap" style="width:64px;height:64px;border-radius:var(--radius-sm);background:var(--bg-surface);border:1px solid var(--border-color);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;position:relative;">
              <i id="img-placeholder-icon" class="bi bi-image" style="font-size:22px;color:var(--text-secondary);opacity:.4;"></i>
              <img id="img-preview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:var(--radius-sm);">
              <button id="img-remove-btn" onclick="removerImagen()" style="display:none;position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:#ef4444;border:none;color:#fff;font-size:10px;cursor:pointer;line-height:1;padding:0;" title="Quitar imagen">✕</button>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;gap:6px;">
              <input type="file" id="img-file-input" accept="image/*" style="display:none;" onchange="onImageFileSelected(event)">
              <button type="button" onclick="document.getElementById('img-file-input').click()"
                style="width:100%;padding:7px 10px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface);color:var(--text-primary);font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:var(--font-body);">
                <i class="bi bi-images" style="font-size:14px;color:var(--color-primary);"></i> Galería / Archivo
              </button>
              <input type="file" id="img-camera-input" accept="image/*" capture="environment" style="display:none;" onchange="onImageFileSelected(event)">
              <button type="button" id="btn-camara" onclick="document.getElementById('img-camera-input').click()"
                style="width:100%;padding:7px 10px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface);color:var(--text-primary);font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:var(--font-body);">
                <i class="bi bi-camera" style="font-size:14px;color:#10b981;"></i> Sacar foto
              </button>
              <span id="img-filename" style="font-size:10.5px;color:var(--text-secondary);display:none;"></span>
            </div>
          </div>
          <input type="hidden" id="m_imagen" value="">
        </div>

        <div style="background:var(--bg-surface-2);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:10px 12px;display:flex;align-items:center;justify-content:space-between;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;flex:1;" for="m_pesable">
            <i class="bi bi-scales" style="color:#10b981;font-size:16px;"></i>
            <div>
              <div style="font-size:12.5px;font-weight:600;color:var(--text-primary);">Producto Pesable</div>
              <div style="font-size:11px;color:var(--text-secondary);">Precio por kg/gramo</div>
            </div>
          </label>
          <div style="position:relative;width:40px;height:22px;flex-shrink:0;">
            <input type="checkbox" id="m_pesable" style="opacity:0;width:0;height:0;position:absolute;" onchange="togglePesable(this)">
            <label for="m_pesable" id="m_pesable_track" style="position:absolute;inset:0;border-radius:11px;background:var(--border-color);cursor:pointer;transition:background .2s;">
              <span id="m_pesable_thumb" style="position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;"></span>
            </label>
          </div>
        </div>

        <!-- Toggle venta sin control de stock -->
        <div style="background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:var(--radius-md);padding:10px 12px;display:flex;align-items:center;justify-content:space-between;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;flex:1;" for="m_venta_sin_stock">
            <i class="bi bi-cart-check" style="color:#f59e0b;font-size:16px;"></i>
            <div>
              <div style="font-size:12.5px;font-weight:600;color:var(--text-primary);">Vender sin control de stock</div>
              <div style="font-size:11px;color:var(--text-secondary);">Permite vender aunque el stock esté en 0 — útil para fiambres, productos a granel, etc.</div>
            </div>
          </label>
          <div style="position:relative;width:40px;height:22px;flex-shrink:0;">
            <input type="checkbox" id="m_venta_sin_stock" style="opacity:0;width:0;height:0;position:absolute;" onchange="toggleVentaSinStock(this)">
            <label for="m_venta_sin_stock" id="m_vss_track" style="position:absolute;inset:0;border-radius:11px;background:var(--border-color);cursor:pointer;transition:background .2s;">
              <span id="m_vss_thumb" style="position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;"></span>
            </label>
          </div>
        </div>

        <div style="border-top:1px solid var(--border-color);padding-top:12px;">
          <div style="font-size:10.5px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;"><i class="bi bi-percent" style="margin-right:4px;"></i>IVA (opcional)</div>
          <div style="background:var(--bg-surface-2);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:10px;display:flex;align-items:center;gap:12px;">
            <label style="font-size:12.5px;font-weight:600;color:var(--text-primary);display:flex;align-items:center;gap:6px;cursor:pointer;flex-shrink:0;">
              <input type="checkbox" id="m_iva_check" onchange="toggleIva(this)" style="width:14px;height:14px;accent-color:var(--color-primary);cursor:pointer;">
              IVA <span style="font-size:10.5px;font-weight:700;padding:1px 7px;border-radius:20px;background:rgba(27,79,216,.1);color:var(--color-primary);" id="m_iva_badge">0%</span>
            </label>
            <div style="display:flex;align-items:center;gap:5px;flex:1;">
              <input type="number" id="m_iva" value="21" min="0" max="100" step="0.01" disabled
                style="width:100%;padding:6px 9px;border-radius:var(--radius-sm);border:1px solid var(--border-color);background:var(--bg-surface);color:var(--text-secondary);font-size:12.5px;outline:none;"
                oninput="actualizarBadge('m_iva','m_iva_badge','m_iva_check')">
              <span style="font-size:12px;color:var(--text-secondary);">%</span>
            </div>
          </div>
          <input type="checkbox" id="m_ieps_check" style="display:none;" value="0">
          <input type="number" id="m_ieps" value="0" style="display:none;">
