<%- include('../partials/head', { title: 'Presupuestos' }) %>

<style>
  /* ── Solo lo que no está en el sistema global ── */
  .stats-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--page-gap); }
  .stat-sub  { font-size: 11.5px; color: var(--text-muted); margin-top: 3px; }

  .toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .toolbar-left { display: flex; align-items: center; gap: 10px; }
  .search-wrap { position: relative; }
  .search-wrap input { padding: 9px 14px 9px 36px; width: 240px; }
  .search-wrap i { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }

  /* card-table usa la clase ax-card del sistema */
  .card-table { overflow-x: auto; -webkit-overflow-scrolling: touch; }

  /* Tabla — header azul via el sistema global */
  .data-table thead th {
    background: var(--table-head-bg) !important;
    color: var(--table-head-color) !important;
    font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .07em;
    padding: 11px 16px; border-bottom: none;
    text-align: left;
  }
  .data-table thead th:first-child { border-radius: 8px 0 0 8px; }
  .data-table thead th:last-child  { border-radius: 0 8px 8px 0; }
  .data-table tbody td { padding: 13px 16px; font-size: 13.5px; border-bottom: 1px solid var(--border-color); color: var(--text-primary); vertical-align: middle; transition: background .12s; }
  .data-table tbody tr:last-child td { border-bottom: none; }
  .data-table tbody tr:hover td { background: var(--table-row-hover); }

  /* Badges */
  .badge-estado { display: inline-flex; align-items: center; gap: 5px; padding: 4px 11px; border-radius: 20px; font-size: 11.5px; font-weight: 700; }
  .badge-Borrador  { background: rgba(107,114,128,.1); color: #6b7280; }
  .badge-Enviado   { background: rgba(59,130,246,.1);  color: #3b82f6; }
  .badge-Aprobado  { background: rgba(16,185,129,.1);  color: #10b981; }
  .badge-Rechazado { background: rgba(239,68,68,.1);   color: #ef4444; }

  /* Botones */
  .btn-accion { display: inline-flex; align-items: center; gap: 5px; padding: 5px 11px; border-radius: 7px; border: 1.5px solid var(--border-color); background: var(--bg-surface-2); color: var(--text-secondary); font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all .15s; }
  .btn-accion:hover { border-color: var(--color-primary); color: var(--color-primary); background: rgba(27,79,216,.06); }
  .btn-accion.danger:hover { border-color: #ef4444; color: #ef4444; background: rgba(239,68,68,.06); }
  .acciones-cell { display: flex; gap: 5px; align-items: center; }
  .btn-nuevo { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--color-primary); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 13.5px; font-weight: 700; cursor: pointer; text-decoration: none; transition: opacity .15s; }
  .btn-nuevo:hover { opacity: .88; color: #fff; }

  .btn-cancel { padding: 9px 18px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 13px; font-weight: 600; cursor: pointer; }
  .btn-save   { padding: 9px 20px; border-radius: var(--radius-sm); border: none; background: var(--color-primary); color: #fff; font-size: 13px; font-weight: 700; cursor: pointer; }
  .modal-footer { padding: 14px 20px; border-top: 1px solid var(--border-color); display: flex; gap: 10px; justify-content: flex-end; }

  .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
  .empty-state i { font-size: 48px; display: block; margin-bottom: 12px; opacity: .3; }

  @media (max-width: 700px) {
    #tablaPresupuestos thead th:nth-child(4), #tablaPresupuestos thead th:nth-child(7),
    #tablaPresupuestos tbody td:nth-child(4), #tablaPresupuestos tbody td:nth-child(7) { display: none; }
    .acciones-cell { gap: 3px; }
    .btn-accion { padding: 5px 8px; font-size: 13px; }
  }
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'presupuestos', user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module: 'Presupuestos', user }) %>
    <div class="page-body">

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">Total presupuestos</div>
          <div class="stat-value"><%= stats.total %></div>
          <div class="stat-sub">en historial</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Aprobados</div>
          <div class="stat-value" style="color:#10b981"><%= stats.aprobados %></div>
          <div class="stat-sub">$<%= stats.montoAprobado.toLocaleString('es-AR',{minimumFractionDigits:0}) %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Enviados</div>
          <div class="stat-value" style="color:#3b82f6"><%= stats.enviados %></div>
          <div class="stat-sub">pendientes</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Monto total</div>
          <div class="stat-value" style="font-size:18px">$<%= stats.montoTotal.toLocaleString('es-AR',{minimumFractionDigits:0}) %></div>
          <div class="stat-sub">todos los estados</div>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="toolbar">
        <div class="toolbar-left">
          <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="buscador" placeholder="Buscar cliente, número..." oninput="filtrar()">
          </div>
          <select class="filter-select" id="filtroEstado" onchange="filtrar()">
            <option value="">Todos los estados</option>
            <option value="Borrador">Borrador</option>
            <option value="Enviado">Enviado</option>
            <option value="Aprobado">Aprobado</option>
            <option value="Rechazado">Rechazado</option>
          </select>
        </div>
        <a href="/presupuestos/nuevo" class="btn-nuevo">
          <i class="bi bi-plus-lg"></i> Nuevo presupuesto
        </a>
      </div>

      <!-- Tabla -->
      <div class="card-table ax-card">
        <% if (!lista.length) { %>
        <div class="empty-state">
          <i class="bi bi-file-earmark-text"></i>
          <strong style="display:block;font-size:16px;color:var(--text-primary);margin-bottom:6px;">Sin presupuestos todavía</strong>
          <span>Creá tu primer presupuesto para comenzar</span><br>
          <a href="/presupuestos/nuevo" class="btn-nuevo" style="margin-top:18px;display:inline-flex;">
            <i class="bi bi-plus-lg"></i> Crear presupuesto
          </a>
        </div>
        <% } else { %>
        <table class="data-table" id="tablaPresupuestos">
          <thead>
            <tr>
              <th>N°</th>
              <th>Cliente</th>
              <th>Fecha</th>
              <th>Ítems</th>
              <th style="text-align:right">Total</th>
              <th>Estado</th>
              <th>Sucursal</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% lista.forEach(p => { %>
            <tr data-cliente="<%= (p.cliente_nombre||'').toLowerCase() %>" data-numero="<%= p.numero.toLowerCase() %>" data-estado="<%= p.estado %>">
              <td style="font-family:var(--font-mono);font-weight:700;color:var(--color-primary)"><%= p.numero %></td>
              <td>
                <strong><%= p.cliente_nombre || 'Sin nombre' %></strong>
                <% if (p.cliente_cuit) { %><div style="font-size:11.5px;color:var(--text-muted)">CUIT: <%= p.cliente_cuit %></div><% } %>
              </td>
              <td style="color:var(--text-secondary);font-size:13px">
                <%= new Date(p.created_at).toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'2-digit'}) %>
              </td>
              <td style="color:var(--text-muted);font-size:13px"><%= p.cant_items %> ítem<%= p.cant_items !== 1 ? 's' : '' %></td>
              <td style="text-align:right;font-family:var(--font-mono);font-weight:800;font-size:15px">
                $<%= Number(p.total).toLocaleString('es-AR',{minimumFractionDigits:0}) %>
              </td>
              <td>
                <span class="badge-estado badge-<%= p.estado %>">
                  <% if(p.estado==='Aprobado'){%><i class="bi bi-check-circle-fill"></i><%}%>
                  <% if(p.estado==='Enviado'){%><i class="bi bi-send-fill"></i><%}%>
                  <% if(p.estado==='Borrador'){%><i class="bi bi-pencil-fill"></i><%}%>
                  <% if(p.estado==='Rechazado'){%><i class="bi bi-x-circle-fill"></i><%}%>
                  <%= p.estado %>
                </span>
              </td>
              <td style="font-size:12px;color:var(--text-muted)"><%= p.sucursal_nombre %></td>
              <td>
                <div class="acciones-cell">
                  <a href="/presupuestos/ver/<%= p.id %>" class="btn-accion" title="Ver"><i class="bi bi-eye"></i></a>
                  <a href="/presupuestos/editar/<%= p.id %>" class="btn-accion" title="Editar"><i class="bi bi-pencil"></i></a>
                  <button class="btn-accion" onclick="abrirEstado(<%= p.id %>, '<%= p.estado %>')" title="Cambiar estado"><i class="bi bi-arrow-repeat"></i></button>
                  <form method="POST" action="/presupuestos/eliminar/<%= p.id %>" style="margin:0" onsubmit="return confirm('¿Eliminar este presupuesto?')">
                    <button type="submit" class="btn-accion danger" title="Eliminar"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>

    </div>
  </div>
</div>

<!-- Modal cambiar estado -->
<div class="modal-overlay" id="modalEstado">
  <div class="modal-box">
    <div class="modal-header">
      <span class="modal-title"><i class="bi bi-arrow-repeat"></i> Cambiar estado</span>
      <button class="modal-close" onclick="document.getElementById('modalEstado').classList.remove('active')">✕</button>
    </div>
    <form method="POST" id="formEstado">
      <div class="modal-body">
        <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;display:block;">Nuevo estado</label>
        <select name="estado" id="selectEstado" style="width:100%;padding:10px 12px;border:1.5px solid var(--border-color);border-radius:var(--radius-sm);background:var(--bg-body);color:var(--text-primary);font-size:14px;outline:none;">
          <option value="Borrador">📝 Borrador</option>
          <option value="Enviado">📤 Enviado</option>
          <option value="Aprobado">✅ Aprobado</option>
          <option value="Rechazado">❌ Rechazado</option>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="document.getElementById('modalEstado').classList.remove('active')">Cancelar</button>
        <button type="submit" class="btn-save">Guardar</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
function filtrar() {
  const q     = document.getElementById('buscador').value.toLowerCase();
  const est   = document.getElementById('filtroEstado').value;
  document.querySelectorAll('#tablaPresupuestos tbody tr').forEach(tr => {
    const cliente = tr.dataset.cliente || '';
    const numero  = tr.dataset.numero  || '';
    const estado  = tr.dataset.estado  || '';
    const matchQ  = !q || cliente.includes(q) || numero.includes(q);
    const matchE  = !est || estado === est;
    tr.style.display = (matchQ && matchE) ? '' : 'none';
  });
}

function abrirEstado(id, estadoActual) {
  document.getElementById('formEstado').action = `/presupuestos/estado/${id}`;
  document.getElementById('selectEstado').value = estadoActual;
  document.getElementById('modalEstado').classList.add('active');
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('modalEstado').classList.remove('active');
});
</script>
