<div class="depto-price-overlay" id="deptoPriceOverlay" onclick="if(event.target===this)cerrarDeptoPrecio()">
  <div class="depto-price-modal">
    <div class="depto-price-header">
      <div class="depto-price-icon" id="deptoPriceIcon">🛒</div>
      <div>
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);">Ingreso manual</div>
        <div class="depto-price-name" id="deptoPriceName">Departamento</div>
      </div>
    </div>
    <div class="depto-price-body">
      <div class="depto-price-label">Precio</div>
      <div class="depto-price-input-wrap">
        <span class="depto-price-prefix">$</span>
        <input type="number" id="deptoPriceInput" class="depto-price-input"
