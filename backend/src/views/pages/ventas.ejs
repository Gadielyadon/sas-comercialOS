<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'ventas', user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module: 'Punto de Venta', user }) %>
    <div class="pos-wrapper">

      <!-- IZQUIERDA -->
      <div class="pos-left">
        <div class="pos-topbar">
          <div class="scan-zone" id="scanZone">
            <span class="scan-dot" id="scanDot"></span>
            <i class="bi bi-upc-scan scan-icon"></i>
            <input type="text" id="barcodeInput" placeholder="Escaneá código o buscá por nombre…" autocomplete="off" spellcheck="false" autofocus>
          </div>
          <div class="sc-chips">
            <div class="sc-chip chip-cobrar" onclick="cart.length?openCobroModal():showToast('Carrito vacío','warn')" title="F4 — Cobrar"><kbd>F4</kbd> Cobrar</div>
            <div class="sc-chip chip-limpiar" onclick="clearCart()" title="Esc — Limpiar carrito"><kbd>Esc</kbd> Limpiar</div>
            <div class="sc-chip chip-deptos" id="chipDeptos" onclick="toggleDeptosChip(this)" title="F5 — Departamentos">
              <kbd>F5</kbd> Departamentos
            </div>
          </div>
        </div>
        <!-- ── DEPARTAMENTOS DE PRECIO MANUAL ── -->
        <div class="deptos-bar" id="deptosBar" style="display:none;">
          <div class="deptos-label"><i class="bi bi-grid-3x3-gap-fill"></i> Departamentos</div>
          <div class="deptos-grid" id="deptosGrid"></div>
        </div>

        <div class="products-scroll">
          <div class="products-grid" id="productsGrid">
            <div class="products-empty">
              <i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite;display:block"></i>
              <p>Cargando productos…</p>
              <style>@keyframes spin{to{transform:rotate(360deg)}}</style>
            </div>
          </div>
        </div>
      </div>

      <!-- DERECHA -->
      <div class="pos-right">
