<%- include('../partials/head', { title: 'Ventas' }) %>

<style>
  body { overflow:hidden; }
  .main-content {
    margin-left:var(--sidebar-width);
    height:calc(100vh - var(--header-height));
    margin-top:var(--header-height);
    display:flex; flex-direction:column; overflow:hidden;
  }
  .pos-wrapper { display:flex; flex:1; min-height:0; overflow:hidden; height:100%; }

  /* IZQUIERDA */
  .pos-left { width:62%;display:flex;flex-direction:column;background:var(--bg-body);border-right:1px solid var(--border-color);overflow:hidden;min-height:0;flex-shrink:0; }
  .pos-topbar { display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border-color);background:var(--bg-card);flex-shrink:0; }
  .scan-zone { flex:1;display:flex;align-items:center;gap:9px;background:var(--bg-body);border:1.5px solid var(--border-color);border-radius:var(--radius-md);padding:0 12px;height:42px;transition:border-color .15s,box-shadow .15s; }
  .scan-zone:focus-within { border-color:var(--color-action);box-shadow:0 0 0 3px rgba(0,180,216,.1); }
  .scan-dot { width:7px;height:7px;border-radius:50%;background:var(--color-action);flex-shrink:0;animation:pulseDot 2s ease-in-out infinite; }
  .scan-dot.scanner-mode { background:#10b981;animation:pulseDotGreen 1s ease-in-out infinite; }
  @keyframes pulseDot{0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 rgba(0,180,216,.4)}50%{opacity:.8;transform:scale(1.2);box-shadow:0 0 0 5px rgba(0,180,216,0)}}
  @keyframes pulseDotGreen{0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 rgba(16,185,129,.4)}50%{opacity:.8;transform:scale(1.2);box-shadow:0 0 0 5px rgba(16,185,129,0)}}
  .scan-icon { font-size:16px;color:var(--color-action);flex-shrink:0; }
  #barcodeInput { flex:1;border:none;background:transparent;font-family:var(--font-body);font-size:14px;font-weight:500;color:var(--text-primary);outline:none; }
  #barcodeInput::placeholder { color:var(--text-secondary);font-weight:400;font-size:13px; }
  .sc-chips { display:flex;gap:6px;flex-shrink:0; }
  .sc-chip {
    display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;
    color:var(--text-secondary);background:var(--bg-card);
    border:1.5px solid var(--border-color);border-radius:8px;
    padding:5px 10px;white-space:nowrap;cursor:pointer;
    transition:all .15s;user-select:none;
  }
  .sc-chip:hover { border-color:var(--color-action);color:var(--color-action);background:rgba(0,180,216,.05); }
  .sc-chip kbd {
    font-family:var(--font-mono);font-size:10px;font-weight:800;
    background:var(--color-primary);color:#fff;
    border-radius:5px;padding:2px 6px;letter-spacing:.3px;
  }
  .sc-chip.chip-cobrar kbd { background:#10b981; }
  .sc-chip.chip-limpiar kbd { background:#6b7280; }
  .sc-chip.chip-deptos {
    border-color:rgba(31,60,136,.3);color:var(--color-primary);
    background:rgba(31,60,136,.05);
  }
  .sc-chip.chip-deptos.active {
    border-color:var(--color-primary);background:var(--color-primary);color:#fff;
  }
  .sc-chip.chip-deptos.active kbd { background:rgba(255,255,255,.2); }
  .products-scroll { flex:1;overflow-y:auto;padding:12px 14px;min-height:0; }
  .products-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px; }

  /* CARD PRODUCTO */
  .prod-card { background:var(--bg-card);border:1.5px solid var(--border-color);border-radius:10px;padding:10px 10px 9px;cursor:pointer;transition:all .15s;position:relative;display:flex;flex-direction:row;gap:8px;min-height:80px;align-items:stretch; }
  .prod-card:hover { border-color:var(--color-action);box-shadow:0 3px 12px rgba(0,180,216,.13);transform:translateY(-1px); }
  .prod-card:active { transform:translateY(0); }
  .prod-card.in-cart { border-color:var(--color-action);background:rgba(0,180,216,.03); }
  .prod-card.out-stock { opacity:.4;cursor:not-allowed; }
  .prod-card.out-stock:hover { transform:none;box-shadow:none;border-color:var(--border-color); }
  .prod-card.kb-selected {
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 0 3px rgba(31,60,136,.18), 0 4px 16px rgba(31,60,136,.15) !important;
    transform: translateY(-2px);
    outline: none;
  }
  /* info column inside card */
  .prod-info { flex:1;display:flex;flex-direction:column;gap:2px;min-width:0; }
  /* imagen thumbnail */
  .prod-thumb { width:48px;height:48px;flex-shrink:0;border-radius:6px;background:var(--bg-body);border:1px solid var(--border-color);display:flex;align-items:center;justify-content:center;align-self:center;overflow:hidden;position:relative;cursor:zoom-in; }
  .prod-thumb img { width:100%;height:100%;object-fit:cover;border-radius:5px; }
  .prod-thumb-empty { display:none; }
  /* zoom overlay al hacer tap largo / click en la miniatura */
  .prod-zoom-overlay { display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);align-items:center;justify-content:center; }
  .prod-zoom-overlay.open { display:flex; }
  .prod-zoom-box { background:var(--bg-card);border-radius:14px;padding:12px;max-width:280px;width:90%;display:flex;flex-direction:column;align-items:center;gap:8px; }
  .prod-zoom-box img { width:100%;max-height:260px;object-fit:contain;border-radius:10px; }
  .prod-zoom-name { font-size:13px;font-weight:700;color:var(--text-primary);text-align:center; }
  .prod-zoom-close { font-size:11px;color:var(--text-secondary);cursor:pointer;padding:4px 12px;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-body); }

  .prod-badge-promo { position:absolute;top:4px;right:4px;font-size:8px;font-weight:800;text-transform:uppercase;background:#f59e0b;color:#fff;padding:2px 5px;border-radius:6px;z-index:2; }
  .prod-badge-qty { position:absolute;top:4px;left:4px;width:18px;height:18px;border-radius:50%;background:var(--color-action);color:#fff;font-size:9px;font-weight:800;display:none;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,180,216,.4);z-index:2; }
  .prod-card.in-cart .prod-badge-qty { display:flex; }
  .prod-sin-stock { font-size:10px;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:.3px; }
  .prod-name { font-size:12.5px;font-weight:700;color:var(--text-primary);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }
  .prod-desc { font-size:10.5px;color:var(--text-secondary);line-height:1.3;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;margin-top:1px; }
  .prod-price-old { font-family:var(--font-mono);font-size:10px;color:var(--text-secondary);text-decoration:line-through;padding-top:4px; }
  .prod-price { font-family:var(--font-mono);font-size:14px;font-weight:800;color:var(--color-action);line-height:1; }
  .prod-stock { font-size:10px;font-weight:600;margin-top:2px; }
  .prod-stock.ok  { color:#10b981; }
  .prod-stock.low { color:#f59e0b; }
  .prod-stock.zero{ color:#ef4444; }
  .products-empty { grid-column:1/-1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:50px 20px;gap:10px;color:var(--text-secondary); }
  .products-empty i { font-size:42px;opacity:.18; }
  .products-empty p { font-size:13px;opacity:.5; }

  /* DERECHA */
  .pos-right { width:38%;display:flex;flex-direction:column;background:var(--bg-body);overflow:hidden;min-height:0;flex-shrink:0; }
  .cart-header { display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--border-color);background:var(--bg-card);flex-shrink:0; }
  .cart-title-wrap { display:flex;align-items:center;gap:9px; }
  .cart-title-icon { width:32px;height:32px;border-radius:8px;background:rgba(0,180,216,.1);display:flex;align-items:center;justify-content:center;color:var(--color-action);font-size:16px; }
  .cart-title-txt  { font-size:15px;font-weight:700;color:var(--text-primary); }
  .cart-count-badge { font-family:var(--font-mono);font-size:11px;font-weight:700;background:rgba(0,180,216,.12);color:var(--color-action);padding:2px 8px;border-radius:20px;margin-left:4px; }
  .cart-sub { font-size:11px;color:var(--text-secondary);margin-top:1px; }
  .btn-clear-sm { padding:5px 11px;border-radius:6px;border:1.5px solid var(--border-color);background:transparent;color:var(--text-secondary);font-size:11.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .12s;font-family:var(--font-body); }
  .btn-clear-sm:hover { border-color:#ef4444;color:#ef4444;background:rgba(239,68,68,.05); }
  .cart-list { flex:1;overflow-y:auto;min-height:0;padding:10px 14px; }
  .cart-items-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px; }
  .cart-empty-state { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--text-secondary);text-align:center;padding:40px 20px;height:100%; }
  .cart-empty-state i { font-size:48px;opacity:.15; }
  .cart-empty-state p { font-size:13px;opacity:.5;line-height:1.5; }

  .cart-card {
    background:var(--bg-card); border:1.5px solid rgba(0,180,216,.35);
    border-radius:10px; padding:10px 10px 9px;
    display:flex; flex-direction:column; gap:3px;
    position:relative; animation:cardIn .18s ease both;
    transition:border-color .12s,box-shadow .12s; cursor:default;
  }
  @keyframes cardIn { from{opacity:0;transform:scale(.94)} to{opacity:1;transform:scale(1)} }
  .cart-card:hover { border-color:var(--color-action); box-shadow:0 2px 10px rgba(0,180,216,.15); }
  .cart-card-name { font-size:12px;font-weight:700;color:var(--text-primary);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }
  .cart-card-desc { font-size:10px;color:var(--text-secondary);line-height:1.3;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;margin-top:1px; }
  .cart-card-price { font-family:var(--font-mono);font-size:13px;font-weight:800;color:var(--color-action);margin-top:auto;padding-top:5px; }
  .cart-card-sub   { font-family:var(--font-mono);font-size:11px;font-weight:600;color:var(--text-secondary);margin-top:1px; }
  .cart-card-bottom { display:flex;align-items:center;justify-content:space-between;margin-top:6px;gap:4px; }
  .qty-ctrl { display:inline-flex;align-items:center;border:1px solid var(--border-color);border-radius:6px;overflow:hidden;background:var(--bg-body); }
  .qty-btn  { width:22px;height:22px;display:flex;align-items:center;justify-content:center;background:transparent;border:none;color:var(--text-secondary);font-size:12px;cursor:pointer;transition:all .1s; }
  .qty-btn:hover { background:rgba(0,180,216,.1);color:var(--color-action); }
  .qty-val  { min-width:22px;text-align:center;font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--text-primary);border-left:1px solid var(--border-color);border-right:1px solid var(--border-color);height:22px;line-height:22px; }
  .btn-del  { width:22px;height:22px;border:none;background:transparent;color:var(--text-secondary);border-radius:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .1s;flex-shrink:0; }
  .btn-del:hover { background:rgba(239,68,68,.1);color:#ef4444; }
  .cart-promo-tag { position:absolute;top:5px;right:5px;font-size:8px;font-weight:800;background:#f59e0b;color:#fff;padding:1px 5px;border-radius:5px;text-transform:uppercase; }

  .mixto-row { display:none;gap:8px;flex-wrap:wrap;margin-bottom:14px; }
  .mixto-row.visible { display:flex; }
  .mixto-method { flex:1;min-width:120px; }
  .mixto-method label { font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:4px; }
  .mixto-method input,
  .mixto-method select {
    width:100%;padding:10px 11px;border:1.5px solid var(--border-color);border-radius:10px;background:var(--bg-body);
    color:var(--text-primary);font-family:var(--font-body);font-size:14px;outline:none;box-sizing:border-box;
  }
  .mixto-method input { font-family:var(--font-mono);font-weight:700; }
  .mixto-method input:focus,
  .mixto-method select:focus { border-color:var(--color-action); }
  .mixto-resto { font-size:14px;font-weight:700;color:#10b981;text-align:left;padding:2px 0 0; }
  .mixto-resto.negativo { color:#ef4444; }

  .cart-footer { flex-shrink:0;border-top:1px solid var(--border-color);background:var(--bg-card);padding:12px 16px;display:flex;flex-direction:column;gap:9px; }
  .field-label { font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px; }
  .cart-cliente-wrap { position:relative; }
  .cart-cliente-inp { width:100%;padding:7px 10px 7px 28px;border:1.5px solid var(--border-color);border-radius:var(--radius-sm);background:var(--bg-body);color:var(--text-primary);font-family:var(--font-body);font-size:13px;outline:none;transition:border-color .15s;box-sizing:border-box; }
  .cart-cliente-inp:focus { border-color:var(--color-action); }
  .cart-cliente-ico { position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--text-secondary);font-size:13px;pointer-events:none; }
  .cart-cliente-drop { display:none;position:absolute;bottom:calc(100%+4px);left:0;right:0;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-sm);box-shadow:0 -8px 24px rgba(0,0,0,.1);z-index:60;max-height:140px;overflow-y:auto; }
  .cart-cliente-drop.visible { display:block; }
  .cart-cliente-sel { display:none;margin-top:3px;padding:4px 9px;background:rgba(0,180,216,.07);border:1px solid rgba(0,180,216,.2);border-radius:var(--radius-sm);align-items:center;justify-content:space-between;font-size:11.5px; }
  .disc-bar { display:flex;gap:5px;align-items:center;background:var(--bg-body);border-radius:var(--radius-sm);border:1px solid var(--border-color);padding:5px 9px; }
  .disc-bar label { font-size:11px;color:var(--text-secondary);font-weight:600;flex-shrink:0; }
  .disc-type-btn { padding:2px 7px;border-radius:4px;border:1.5px solid var(--border-color);background:var(--bg-card);font-size:11px;font-weight:700;color:var(--text-secondary);cursor:pointer;transition:all .1s; }
  .disc-type-btn.on { border-color:var(--color-action);background:rgba(0,180,216,.1);color:var(--color-action); }
  .disc-input { flex:1;border:1.5px solid var(--border-color);background:var(--bg-body);border-radius:4px;padding:3px 6px;font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--text-primary);outline:none;text-align:right;width:0; }
  .disc-input:focus { border-color:var(--color-action); }
  .disc-suffix { font-size:12px;font-weight:700;color:var(--text-secondary);flex-shrink:0; }
  /* ── Panel cobro ── */
  .cart-footer {
    background: var(--bg-card) !important;
    border-top: 2px solid var(--border-color) !important;
  }

  /* Sección cliente */
  .cobro-section-cliente {
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 10px 12px;
  }
  .cobro-section-descuento {
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 10px 12px;
  }

  .totals-block {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #16a34a;
    border: none;
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(22,163,74,.35);
  }

  .tot-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    padding: 9px 16px;
    background: rgba(0,0,0,.12);
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .tot-row span:first-child { color: rgba(255,255,255,.85); font-weight: 600; }
  .tot-row span:last-child { font-weight: 800; color: #fff; font-family: var(--font-mono); }

  .total-highlight {
    padding: 14px 16px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: transparent;
    border-top: none;
    margin-top: 0;
  }

  .total-highlight-label {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .8px;
    color: rgba(255,255,255,.9);
  }

  .total-highlight-value {
    font-size: 32px;
    line-height: 1;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-mono);
    letter-spacing: -1px;
    text-shadow: 0 1px 3px rgba(0,0,0,.15);
  }

  @media (max-width: 860px) {
    .total-highlight-value { font-size: 26px; }
  }

  .btn-confirm { width:100%;padding:13px;border-radius:10px;border:none;background:linear-gradient(135deg,var(--color-action),#0099ba);color:#fff;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(0,180,216,.28); }
  .btn-confirm:hover:not(:disabled) { transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,180,216,.4); }
  .btn-confirm:disabled { opacity:.35;cursor:not-allowed;box-shadow:none;transform:none; }
  .kbd-hint { font-size:10px;opacity:.75;background:rgba(255,255,255,.2);border-radius:4px;padding:1px 5px;font-family:var(--font-mono); }

  .pos-toast { position:fixed;bottom:18px;left:calc(var(--sidebar-width)+18px);background:var(--bg-card);border:1px solid var(--border-color);border-left:3px solid var(--color-action);border-radius:var(--radius-sm);padding:9px 13px;display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--text-primary);box-shadow:var(--shadow-lg);z-index:999;transform:translateY(80px);opacity:0;transition:transform .22s ease,opacity .22s ease;min-width:200px; }
  .pos-toast.show { transform:translateY(0);opacity:1; }
  .pos-toast.toast-success { border-left-color:#10b981; }
  .pos-toast.toast-error   { border-left-color:#ef4444; }
  .pos-toast.toast-warn    { border-left-color:var(--color-alert); }
  .pos-toast i { font-size:15px; }
  .pos-toast.toast-success i { color:#10b981; }
  .pos-toast.toast-error   i { color:#ef4444; }
  .pos-toast.toast-warn    i { color:var(--color-alert); }

  /* MODAL COBRO NUEVO */
  .cobro-overlay { position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;display:none;align-items:center;justify-content:center;backdrop-filter:blur(3px); }
  .cobro-overlay.open { display:flex; }
  .cobro-modal {
    background:var(--bg-card);
    border-radius:22px;
    width:min(1040px,96vw);
    max-height:92vh;
    overflow:hidden;
    box-shadow:0 24px 64px rgba(0,0,0,.25);
    animation:modalIn .2s ease;
    display:flex;
    flex-direction:column;
  }
  @keyframes modalIn { from{transform:scale(.96);opacity:0}to{transform:scale(1);opacity:1} }
  .cobro-header {
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 22px;border-bottom:1px solid var(--border-color);flex-shrink:0;
  }
  .cobro-title  { font-size:17px;font-weight:800;color:var(--text-primary); }
  .cobro-close  { width:36px;height:36px;border:none;background:var(--bg-body);border-radius:10px;cursor:pointer;font-size:15px;color:var(--text-secondary);display:flex;align-items:center;justify-content:center; }

  .cobro-layout {
    display:grid;
    grid-template-columns: 1.08fr .92fr;
    min-height:0;
    flex:1;
    overflow:hidden;
  }
  .cobro-left,
  .cobro-right {
    min-height:0;
    overflow-y:auto;
    padding:20px 22px 22px;
  }
  .cobro-left { border-right:1px solid var(--border-color); }
  .cobro-right { background:rgba(0,0,0,.012); }

  .cobro-total-box {
    background:linear-gradient(180deg, rgba(0,180,216,.08), rgba(0,180,216,.04));
    border:1.5px solid rgba(0,180,216,.22);
    border-radius:18px;
    padding:18px;
    margin-bottom:16px;
  }
  .cobro-total-lbl {
    font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--color-action);
    margin-bottom:6px;
  }
  .cobro-total-amt {
    font-size:54px;
    line-height:1;
    font-weight:900;
    font-family:var(--font-mono);
    color:var(--text-primary);
    letter-spacing:-2px;
  }
  .cobro-total-disc { font-size:12px;color:#10b981;margin-top:10px;font-weight:700; }

  .cobro-section {
    background:var(--bg-body);
    border:1px solid var(--border-color);
    border-radius:16px;
    padding:16px;
    margin-bottom:14px;
  }
  .cobro-stitle {
    font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--text-secondary);
    margin:0 0 12px;
  }

