    <span id="discVal" style="color:#fde68a">-$0,00</span>
  </div>

  <div class="total-highlight">
    <div class="total-highlight-label">Total</div>
    <div class="total-highlight-value" id="totalVal">$0,00</div>
  </div>
</div>

          <button class="btn-confirm" id="btnConfirm" disabled onclick="openCobroModal()">
