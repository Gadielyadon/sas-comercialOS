              <button class="disc-type-btn" id="btnFixed" onclick="setDiscType('fixed')">$</button>
              <input type="number" class="disc-input" id="discInput" placeholder="0" min="0" step="0.01" oninput="updateTotals()">
              <span class="disc-suffix" id="discSuffix">%</span>
            </div>
          </div>
        <div class="totals-block">
  <div class="tot-row">
    <span>Subtotal</span>
    <span id="subtotalVal">$0,00</span>
  </div>

  <div class="tot-row" id="discRow" style="display:none">
