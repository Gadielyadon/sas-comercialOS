<!-- JS FACTURA ELECTRÓNICA AFIP                               -->
<!-- ══════════════════════════════════════════════════════════ -->
<script>
'use strict';

let afipTipoSel          = 'B';
let afipSaleId           = null;
let afipEmitido          = false;
let afipFacturaExistente = null;
let facturarEnCobro      = false;
let tipoMiniSel          = 'B';

/* ── Toggle facturación dentro del modal de cobro ── */
function toggleFacturacionEnCobro(activo) {
  facturarEnCobro = activo;
  const label = document.getElementById('facturaTglLabel');
  const opts  = document.getElementById('facturaOpciones');
  if (activo) {
    label.textContent = 'Emitir factura';
    label.style.color = 'var(--color-primary)';
    opts.style.display = 'block';
  } else {
    label.textContent = 'No emitir';
    label.style.color = '';
    opts.style.display = 'none';
  }
}

function selTipoMini(tipo) {
  tipoMiniSel = tipo;
  ['A','B','C'].forEach(t => {
    const btn = document.getElementById('tipoMini'+t);
    if (btn) btn.classList.toggle('on', t === tipo);
  });
  const cuitWrap = document.getElementById('cuitMiniWrap');
  if (cuitWrap) cuitWrap.style.display = tipo === 'A' ? 'block' : 'none';
}

/* Resetear el toggle al abrir el modal de cobro — se llama directamente desde openCobroModal */
function resetFacturacionToggle() {
  const tgl = document.getElementById('facturaTgl');
  if (tgl) { tgl.checked = false; toggleFacturacionEnCobro(false); }
  selTipoMini('B');
}

/* ── Después de confirmar venta, si tenía facturación activada → emitir ── */
async function enviarComprobantePorEmail() {
  const emailInp = document.getElementById('emailDestinoInput');
  const result   = document.getElementById('emailEnvioResult');
  const email    = (emailInp?.value || '').trim();

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    result.textContent = '⚠️ Ingresá un email válido';
    result.style.color = '#f59e0b';
    return;
  }

  if (!afipSaleId) {
    result.textContent = '⚠️ No hay venta activa';
    result.style.color = '#f59e0b';
    return;
  }

  result.textContent = '⏳ Enviando...';
  result.style.color = 'var(--text-muted)';

  try {
    const r = await fetch('/api/email/comprobante', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ sale_id: afipSaleId, email_destino: email }),
    });
    const d = await r.json();
    if (d.ok) {
      result.textContent = `✅ Comprobante enviado a ${email}${d.adjuntos > 0 ? ' (con PDF de factura)' : ''}`;
      result.style.color = '#10b981';
      emailInp.value = '';
    } else {
      result.textContent = '❌ ' + (d.error || 'Error al enviar');
      result.style.color = '#ef4444';
    }
  } catch(e) {
    result.textContent = '❌ ' + e.message;
    result.style.color = '#ef4444';
  }
}

async function emitirFacturaPosCobro(saleId) {
  if (!saleId) return;
  const cuit   = (document.getElementById('cuitMiniInp')?.value||'').trim();
  const nombre = (document.getElementById('receptorMiniNombre')?.value||'').trim()||'Consumidor Final';

  const estadoEl = document.getElementById('exitoFacturaEstado');
  if (estadoEl) estadoEl.innerHTML = '<span style="font-size:12px;color:var(--text-muted);">Emitiendo factura con AFIP...</span>';

  try {
    const r = await fetch('/afip/emitir', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ sale_id: saleId, tipo: tipoMiniSel, cliente: { cuit: cuit||null, nombre } })
    });
    const data = await r.json();
    if (!r.ok) throw new Error(data.error || 'Error AFIP');

    const tipoLetra = tipoMiniSel;
    const nro = String(data.nro_cbte).padStart(8,'0');
    const pv  = String(data.punto_venta).padStart(4,'0');
    if (estadoEl) estadoEl.innerHTML =
      `<span class="fact-badge-ok"><i class="bi bi-patch-check-fill"></i> Factura ${tipoLetra} N° ${pv}-${nro} emitida</span>`;

    // Ocultar botón de emitir, mostrar ver PDF
    const btnEmitir = document.getElementById('btnEmitirFactura');
    const btnVer    = document.getElementById('btnVerFacturaAfip');
    if (btnEmitir) btnEmitir.style.display = 'none';
    if (btnVer)    { btnVer.style.display = 'flex'; }

    afipFacturaExistente = data.factura || {};
    afipSaleId = saleId;

  } catch(e) {
    if (estadoEl) estadoEl.innerHTML =
      `<span class="fact-badge-pend"><i class="bi bi-exclamation-circle"></i> Error al emitir: ${e.message}</span>`;
  }
}

function selTipo(tipo) {
  afipTipoSel = tipo;
  ['A','B','C'].forEach(function(t) {
    var el = document.getElementById('tipo' + t);
    if (el) el.classList.toggle('sel', t === tipo);
  });
  var cuitField = document.getElementById('afipCuitField');
  if (cuitField) cuitField.style.display = tipo === 'A' ? 'block' : 'none';
}

async function actualizarEstadoFacturaVenta() {
  var btnEmitir = document.getElementById('btnEmitirFactura');
  var btnVer    = document.getElementById('btnVerFacturaAfip');
  afipFacturaExistente = null;
  if (!btnEmitir || !btnVer) return;
  if (!afipSaleId) {
    btnEmitir.style.display = 'none';
    btnVer.style.display    = 'none';
    return;
  }
  try {
    var r    = await fetch('/afip/factura/' + afipSaleId);
    var data = await r.json();
    if (r.ok && data && data.factura) {
      afipFacturaExistente = data.factura;
      btnEmitir.style.display = 'none';
      btnVer.style.display    = 'flex';
    } else {
      btnEmitir.style.display = 'flex';
      btnVer.style.display    = 'none';
    }
  } catch(e) {
    btnEmitir.style.display = 'flex';
    btnVer.style.display    = 'none';
  }
}

function abrirPdfFacturaExistente() {
  if (!afipSaleId) return;
  window.open('/afip/pdf/' + afipSaleId, '_blank');
}

async function abrirModalFactura() {
  if (!afipSaleId) {
    showToast('No hay venta activa para facturar', 'warn');
    return;
  }
  await actualizarEstadoFacturaVenta();
  if (afipFacturaExistente) {
    showToast('Esta venta ya tiene factura emitida', 'warn');
    abrirPdfFacturaExistente();
    return;
  }
  afipEmitido = false;
  document.getElementById('afipResult').classList.remove('show');
  document.getElementById('afipActions').style.display = 'flex';
  document.getElementById('afipSpinner').classList.remove('show');
  document.getElementById('btnAfipEmit').disabled = false;
  document.getElementById('afipCuit').value = '';
  document.getElementById('afipReceptorNombre').value = '';
  selTipo('B');
  if (lastSaleData && lastSaleData.cliente && lastSaleData.cliente !== 'Consumidor Final') {
    document.getElementById('afipReceptorNombre').value = lastSaleData.cliente;
  }
  document.getElementById('afipOverlay').classList.add('open');
}

function cerrarModalFactura() {
  document.getElementById('afipOverlay').classList.remove('open');
}

async function emitirFacturaAfip() {
  if (afipEmitido) return;
  await actualizarEstadoFacturaVenta();
  if (afipFacturaExistente) {
    showToast('Esta venta ya fue facturada', 'warn');
    cerrarModalFactura();
    abrirPdfFacturaExistente();
    return;
  }
  var cuit   = document.getElementById('afipCuit').value.trim().replace(/\D/g,'');
  var nombre = document.getElementById('afipReceptorNombre').value.trim() || 'Consumidor Final';
  if (afipTipoSel === 'A' && cuit.length < 11) {
    showToast('Para Factura A ingresa el CUIT del receptor', 'warn');
    document.getElementById('afipCuit').focus();
    return;
  }
  document.getElementById('btnAfipEmit').disabled = true;
  document.getElementById('afipSpinner').classList.add('show');
  try {
    var payload = JSON.stringify({ sale_id: afipSaleId, tipo: afipTipoSel, cliente: { cuit: cuit || null, nombre: nombre } });
    var r = await fetch('/afip/emitir', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: payload
    });
    var data = await r.json();
    document.getElementById('afipSpinner').classList.remove('show');
    if (!r.ok) throw new Error(data.error || 'Error al comunicarse con AFIP');
    afipEmitido = true;
    var vto = '';
    if (data.cae_vto) {
      vto = data.cae_vto.slice(6,8) + '/' + data.cae_vto.slice(4,6) + '/' + data.cae_vto.slice(0,4);
    } else {
      vto = data.cae_vto;
    }
    document.getElementById('afipCaeVal').textContent  = data.cae;
    document.getElementById('afipCaeVto').textContent  = vto;
    var nroPadded = String(data.nro_cbte).padStart(8,'0');
    var pvPadded  = String(data.punto_venta).padStart(4,'0');
    document.getElementById('afipNroCbte').textContent = 'Fact. ' + data.tipo_letra + ' N ' + pvPadded + '-' + nroPadded;
    document.getElementById('afipResult').classList.add('show');
    document.getElementById('afipActions').style.display = 'none';
    showToast('Factura emitida con CAE', 'success');
    await actualizarEstadoFacturaVenta();
  } catch(e) {
    document.getElementById('afipSpinner').classList.remove('show');
    document.getElementById('btnAfipEmit').disabled = false;
    showToast('Error: ' + e.message, 'error');
  }
}

function descargarPdfFactura() {
  if (!afipSaleId) { showToast('No hay factura para descargar', 'warn'); return; }
  window.open('/afip/pdf/' + afipSaleId, '_blank');
}

document.getElementById('afipOverlay').addEventListener('click', function(e) {
  if (e.target === this) cerrarModalFactura();
});
</script>

