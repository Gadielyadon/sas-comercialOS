  const logoHtml = cfg.logo
    ? `<div class="center" style="margin-bottom:6px;"><img src="${escapeHtml(cfg.logo)}" style="max-width:100%;max-height:60px;object-fit:contain;"></div>`
    : '';

  const html = `
    <!DOCTYPE html>
    <html lang="es">
    <head>
      <meta charset="UTF-8">
      <title>Ticket</title>
      <style>
        @page {
          size: ${es80 ? '80mm auto' : 'A4'};
          margin: 6mm;
        }
        body {
          font-family: monospace;
          margin: 0;
          padding: 0;
          background: #fff;
          color: #000;
