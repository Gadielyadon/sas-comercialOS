async function confirmSale() {
  if (!cart.length) return;

  const isCuentaCorriente = payTipo==='cuenta_corriente' || payTipo==='fiado'
    || payMethod.toLowerCase().includes('cuenta') || payMethod.toLowerCase().includes('fiado');
  if(isCuentaCorriente && (!clienteId || clienteId===1)){
    showToast('Debés seleccionar un cliente para cobrar en Cuenta Corriente','error');
    beep('error');
    const inp=document.getElementById('cartClienteInp');
    if(inp){ inp.focus(); inp.style.borderColor='#ef4444'; setTimeout(()=>inp.style.borderColor='',3000); }
    return;
  }

  // ── Verificar límite de crédito (solo para cuenta corriente/fiado) ──
  if (isCuentaCorriente && clienteId && clienteId !== 1) {
    try {
      const { total } = getBaseTotal();
      const conRec = total * (1 + recargoVal / 100);
      const r = await fetch(`/api/clientes/${clienteId}/check-limite`, {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ monto: conRec })
      });
      if (r.ok) {
        const check = await r.json();
        if (!check.ok) {
          const fmtN = n => '$' + Number(n).toLocaleString('es-AR', {minimumFractionDigits:2});
          // BLOQUEO — modal de error, no confirm
          showToast(`Límite de crédito superado — disponible ${fmtN(Math.max(0, check.disponible))}`, 'error');
          beep('error');
          // Mostrar modal de bloqueo
          _mostrarBloqueoLimite(check, conRec);
          return;
        }
      }
    } catch(e) { /* si falla el check, continuar */ }
  }

  const { total } = getBaseTotal();
  const conRecargo = total * (1 + recargoVal / 100);
  const isEfectivo = payMethod.toLowerCase() === 'efectivo';
  const received = parseFloat(document.getElementById('cashReceived').value) || 0;

  if (isEfectivo && !mixtoActivo && received > 0 && (received - conRecargo) < 0) {
    showToast(`Faltan ${fmt(conRecargo - received)}`, 'error');
    beep('error');
    return;
  }

  if (mixtoActivo) {
    const m1 = parseFloat(document.getElementById('mixtoMonto1').value) || 0;
    const m2 = parseFloat(document.getElementById('mixtoMonto2').value) || 0;

    if (m1 <= 0) {
      showToast('Ingresá el monto del primer método', 'warn');
      return;
    }

    if ((m1 + m2) < (conRecargo - 0.01)) {
      showToast(`Faltan ${fmt(conRecargo - m1 - m2)}`, 'error');
      return;
    }
  }

  const pctVal = discType === 'pct'
    ? (parseFloat(document.getElementById('discInput').value) || 0)
    : 0;

  const fixedVal = discType === 'fixed'
    ? (parseFloat(document.getElementById('discInput').value) || 0)
    : 0;

  let paymentMethod = payMethod;
  let cashReceived = isEfectivo ? received : null;
  let changeAmount = isEfectivo ? Math.max(received - conRecargo, 0) : null;
  let montoMixto2 = null;

  if (mixtoActivo) {
    const m1  = parseFloat(document.getElementById('mixtoMonto1').value) || 0;
    const m2  = parseFloat(document.getElementById('mixtoMonto2').value) || 0;
    const m2v = document.getElementById('mixtoMetodo2').value;

    paymentMethod = `${payMethod} + ${m2v}`;
    cashReceived  = m1;
    montoMixto2   = m2;
    changeAmount  = Math.max((m1 + m2) - conRecargo, 0);
  }

  const payload = {
    payment_method: paymentMethod,
    cash_received: cashReceived,
    change_amount: changeAmount,
    monto_mixto2: montoMixto2,
    discount_pct: pctVal,
    discount_fixed: fixedVal,
    recargo_pct: recargoVal,
    cliente_id: clienteId || null,
    es_cuenta_corriente: isCuentaCorriente ? 1 : 0,
    items: cart.map(i => ({
      sku: i.sku,
      name: i.name,
      price: i.price,
      qty: i.qty
    }))
  };

  if (!navigator.onLine) {
    await window.OfflineQueue?.guardarVentaPendiente({ payload });
    await window.OfflineQueue?.actualizarBadgeOffline();
    afipSaleId = null;
    mostrarExito(conRecargo, paymentMethod, isEfectivo, received, true);
    return;
  }

  try {
    const r = await fetch('/api/sales', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    const rawText = await r.text();
    let data = {};

    try {
      data = rawText ? JSON.parse(rawText) : {};
    } catch (_) {
      data = {};
    }

    if (!r.ok) {
      throw new Error(data.error || `Error ${r.status} al guardar la venta`);
    }

    afipSaleId = data?.sale?.id || data?.id || data?.sale_id || null;

    if (!afipSaleId) {
      showToast('Venta guardada, pero el servidor no devolvió el ID', 'warn');
    }

    mostrarExito(conRecargo, paymentMethod, isEfectivo, received, false);

  } catch (e) {
    const msg = String(e?.message || e || '');
    const esErrorRed =
      !navigator.onLine ||
      /Failed to fetch|NetworkError|Load failed/i.test(msg);

    if (esErrorRed) {
      await window.OfflineQueue?.guardarVentaPendiente({ payload });
      await window.OfflineQueue?.actualizarBadgeOffline();
      afipSaleId = null;
      showToast('⚠ Sin conexión', 'warn');
      mostrarExito(conRecargo, paymentMethod, isEfectivo, received, true);
      return;
    }

    showToast(msg || 'Error al guardar la venta', 'error');
  }
}

function mostrarExito(conRecargo,metodoFinal,isEfectivo,received,offline){
  const { sub, disc } = getBaseTotal();
  const clienteNombre = (document.getElementById('posClienteSearch')?.value || '').trim() || 'Consumidor Final';
  const vuelto = isEfectivo && !mixtoActivo && received > 0 ? Math.max(received-conRecargo,0) : 0;

  lastSaleData = {
    fecha: new Date(),
    cliente: clienteNombre,
    metodo: metodoFinal,
    subtotal: sub,
    descuento: disc,
    total: conRecargo,
    recibido: isEfectivo && !mixtoActivo ? received : null,
    vuelto,
    offline: !!offline,
   
items: cart.map(i => ({
  sku: i.sku,
  name: i.name,
  qty: i.qty,
  price: i.price,
  price_base: i.price_base,
  subtotal: i.price * i.qty,
  isPromo: !!i.isPromo,
  isMayorista: !!i.isMayorista,
  price_mayorista: i.price_mayorista || null,
  qty_mayorista: i.qty_mayorista || null
}))
  };

  document.getElementById('cobroOverlay').classList.remove('open');
  document.getElementById('exitoTotal').textContent=fmt(conRecargo);
  document.getElementById('exitoDetalle').textContent=`Método: ${metodoFinal}${recargoVal>0?` (+${recargoVal}% recargo)`:''}${offline?' · ⚠ Offline':''}`;
  document.getElementById('exitoVuelto').textContent=isEfectivo&&!mixtoActivo&&received>0?`Vuelto: ${fmt(vuelto)}`:'';

  /* Reset estado factura */
  const estadoEl = document.getElementById('exitoFacturaEstado');
  if (estadoEl) estadoEl.innerHTML = '';
  const btnVer = document.getElementById('btnVerFacturaAfip');
  if (btnVer) btnVer.style.display = 'none';
  const btnEmitir = document.getElementById('btnEmitirFactura');
  if (btnEmitir) btnEmitir.style.display = 'flex';

  document.getElementById('exitoOverlay').classList.add('open');
  beep('confirm');

  /* Si el usuario activó facturación durante el cobro → emitir automáticamente */
  if (facturarEnCobro && afipSaleId && !offline) {
    emitirFacturaPosCobro(afipSaleId);
  }
}

function escapeHtml(str=''){
  return String(str)
    .replaceAll('&','&amp;')
    .replaceAll('<','&lt;')
    .replaceAll('>','&gt;')
    .replaceAll('"','&quot;')
    .replaceAll("'","&#039;");
}

function imprimirTicket(){
