function calcMixto(){
  const {total}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  const m1=parseFloat(document.getElementById('mixtoMonto1').value)||0;
  const resto=conRecargo-m1;
  const restoEl=document.getElementById('mixtoResto');
  const m2Input=document.getElementById('mixtoMonto2');
  m2Input.value=resto>0?resto.toFixed(2):'0.00';
  m2Input.disabled=false;
  m2Input.style.opacity='1';
  if(resto<-0.01){
    restoEl.textContent=`Exceso: ${fmt(Math.abs(resto))}`;
    restoEl.className='mixto-resto negativo';
  } else if(Math.abs(resto)<0.01){
    restoEl.textContent='✓ Total cubierto';
    restoEl.className='mixto-resto';
  } else {
    restoEl.textContent=`Resta: ${fmt(resto)}`;
    restoEl.className='mixto-resto';
  }
}

function updateCobroTotals(){
  const{total,disc}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  document.getElementById('cobroTotalAmt').textContent=fmt(conRecargo);
  const di=document.getElementById('cobroDiscInfo');
  if(disc>0||recargoVal>0){
    di.style.display='block';
    const p=[];
    if(disc>0)p.push(`Descuento: -${fmt(disc)}`);
    if(recargoVal>0)p.push(`Recargo ${recargoVal}%: +${fmt(total*recargoVal/100)}`);
    di.textContent=p.join(' · ');
  }else di.style.display='none';
  document.getElementById('btnCobrarTxt').textContent=`Cobrar ${fmt(conRecargo)}`;
  calcVuelto();
}
function setRecargo(pct,btn){
  recargoVal=pct;
  document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
  if(btn)btn.classList.add('on');
  document.getElementById('recargoCustom').value='';
  const res=document.getElementById('recargoResult'),{total}=getBaseTotal();
  if(pct>0){
    res.style.display='block';
    res.textContent=`Total: ${fmt(total*(1+pct/100))}`;
  }else res.style.display='none';
  updateCobroTotals();
}
function setRecargoCustom(){
  const v=parseFloat(document.getElementById('recargoCustom').value)||0;
  recargoVal=v;
  document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
  const res=document.getElementById('recargoResult'),{total}=getBaseTotal();
  if(v>0){
    res.style.display='block';
    res.textContent=`Total: ${fmt(total*(1+v/100))}`;
  }else res.style.display='none';
  updateCobroTotals();
}
function calcVuelto(){
  const{total}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  const recibido=parseFloat(document.getElementById('cashReceived').value)||0;
  const display=document.getElementById('vueltoDisplay'),
        isEfectivo=payMethod.toLowerCase()==='efectivo';
  if(!isEfectivo||recibido<=0){display.style.display='none';return;}
  display.style.display='flex';
  const vuelto=recibido-conRecargo,amt=document.getElementById('vueltoAmt');
  if(vuelto>=0){
    amt.textContent=fmt(vuelto);
    display.style.background='rgba(16,185,129,.08)';
    amt.style.color='#059669';
    display.querySelector('span').style.color='#059669';
  }else{
    amt.textContent=`Faltan ${fmt(Math.abs(vuelto))}`;
    display.style.background='rgba(239,68,68,.08)';
    amt.style.color='#ef4444';
    display.querySelector('span').style.color='#ef4444';
  }
}

async function loadPaymentMethods(){
  const fb=[
    {nombre:'Efectivo',icono:'bi-cash-stack',tipo:'efectivo',recargo_cliente_pct:0},
    {nombre:'Débito',icono:'bi-credit-card',tipo:'otro',recargo_cliente_pct:0},
    {nombre:'Crédito',icono:'bi-credit-card-2-front',tipo:'otro',recargo_cliente_pct:0},
    {nombre:'Transferencia',icono:'bi-phone',tipo:'otro',recargo_cliente_pct:0}
  ];
  payMethods=fb;
  try{
    const r=await fetch('/api/payment-methods');
    if(r.ok){
      const d=await r.json();
      if(Array.isArray(d)&&d.length)payMethods=d.map(m=>({
        nombre:m.nombre||m.name||'Pago',
        icono:m.icono||m.icon||'bi-wallet2',
        tipo:m.tipo||'otro',
        recargo_cliente_pct:m.recargo_cliente_pct||0
      }));
    }
  }catch(e){}

  const grid=document.getElementById('pmGrid');
  grid.innerHTML=payMethods.map((m,i)=>`<button type="button" class="pm-btn ${i===0?'on':''}" tabindex="-1" data-pm-idx="${i}" data-method="${m.nombre}" data-tipo="${m.tipo}" data-recargo="${m.recargo_cliente_pct}" onclick="selectPayMethod(this)"><i class="bi ${m.icono}"></i><span>${m.nombre}</span>${m.recargo_cliente_pct>0?`<small>+${m.recargo_cliente_pct}%</small>`:''}</button>`).join('');
  payMethod=payMethods[0].nombre;
  recargoVal=payMethods[0].recargo_cliente_pct||0;
  const isEfectivo=payMethods[0].tipo==='efectivo'||payMethods[0].nombre.toLowerCase()==='efectivo';
  document.getElementById('efectivoRow').classList.toggle('visible',isEfectivo);
  if(recargoVal>0)updateCobroTotals();
  pmFocusIdx = 0;
}

function selectPayMethod(btn){
  document.querySelectorAll('#pmGrid .pm-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  payMethod=btn.dataset.method;
  payTipo=btn.dataset.tipo||'';
  pmFocusIdx = Number(btn.dataset.pmIdx || 0);

  const tipo=payTipo,
        rc=parseFloat(btn.dataset.recargo)||0;
  const isEfectivo=tipo==='efectivo'||payMethod.toLowerCase()==='efectivo';
  const isCuentaCorriente=tipo==='cuenta_corriente'||tipo==='fiado';
  const isCard=!isEfectivo&&!isCuentaCorriente;

  if(isCuentaCorriente && (!clienteId || clienteId===1)){
    showToast('Seleccioná un cliente para usar Cuenta Corriente','warn');
    const inp=document.getElementById('cartClienteInp');
    if(inp){ inp.focus(); inp.style.borderColor='#f59e0b'; setTimeout(()=>inp.style.borderColor='',2500); }
  }

  const banner=document.getElementById('recargoInfoBanner');

  if(rc>0){
    recargoVal=rc;
    document.getElementById('recargoRow').classList.remove('visible');
    const{total}=getBaseTotal();
    banner.innerHTML=`<i class="bi bi-info-circle" style="color:#d97706;flex-shrink:0"></i> Recargo <strong>${rc}%</strong> → <strong>${fmt(total*(1+rc/100))}</strong>`;
    banner.classList.add('visible');
  }else{
    recargoVal=0;
    document.getElementById('recargoRow').classList.toggle('visible',isCard);
    banner.classList.remove('visible');
    document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
    document.getElementById('recargoCustom').value='';
    document.getElementById('recargoResult').style.display='none';
  }

  document.getElementById('efectivoRow').classList.toggle('visible',isEfectivo);
  updateCobroTotals();
  calcVuelto();
  focusPmButton(pmFocusIdx);

  if(mixtoActivo){
    document.getElementById('mixtoMetodo1Nombre').textContent = payMethod;
    const sel=document.getElementById('mixtoMetodo2');
    sel.innerHTML=payMethods
      .filter(m=>m.nombre!==payMethod)
      .map(m=>`<option value="${m.nombre}">${m.nombre}</option>`).join('');
    calcMixto();
  }
}

function renderClienteDrop(list){
