  drop.innerHTML=list.map(c=>{
    const nom=c.nombre||'',tel=c.telefono||'',saldo=Number(c.saldo||0);
    const sTag=saldo>0?`<span style="font-size:10px;font-weight:700;color:#dc2626;background:rgba(239,68,68,.1);padding:1px 5px;border-radius:8px">Debe ${fmt(saldo)}</span>`:'';
    const dTag=c.id===1?`<span style="font-size:10px;font-weight:700;color:var(--color-action);background:rgba(0,180,216,.1);padding:1px 5px;border-radius:8px;margin-left:4px">Default</span>`:'';
    return `<div style="padding:7px 11px;cursor:pointer;border-bottom:1px solid var(--border-color);font-size:12.5px;display:flex;align-items:center;justify-content:space-between;gap:8px;transition:background .1s" onmouseenter="this.style.background='rgba(0,180,216,.06)'" onmouseleave="this.style.background=''" onmousedown="selClientePos(${c.id},'${nom.replace(/'/g,"\\'")}','${tel.replace(/'/g,"\\'")}')"><div><strong>${nom}</strong>${dTag}${tel?`<span style="color:var(--text-secondary);font-size:10.5px;margin-left:5px">${tel}</span>`:''}</div>${sTag}</div>`;
  }).join('');
  drop.classList.add('visible');
}
