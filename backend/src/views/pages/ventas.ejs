              <div class="cart-sub" id="cartSub">Sin productos</div>
            </div>
          </div>
          <button class="btn-clear-sm" onclick="clearCart()"><i class="bi bi-x-circle"></i> Limpiar</button>
        </div>
        <div class="cart-list" id="cartList">
          <div class="cart-empty-state" id="cartEmptyState">
            <i class="bi bi-cart3"></i>
            <p>Tocá un producto<br>para agregarlo al carrito</p>
          </div>
          <div class="cart-items-grid" id="cartItemsGrid"></div>
        </div>
        <div class="cart-footer">
          <div class="cobro-section-cliente">
            <div class="field-label" style="margin-bottom:6px;display:flex;align-items:center;gap:5px;">
              <i class="bi bi-person" style="color:var(--color-action);font-size:12px;"></i> Cliente
            </div>
            <div class="cart-cliente-wrap">
              <i class="bi bi-person cart-cliente-ico"></i>
              <input type="text" class="cart-cliente-inp" id="posClienteSearch" placeholder="Consumidor Final" autocomplete="off" oninput="buscarClientePos(this.value)" onfocus="mostrarTodosClientes()" onblur="setTimeout(cerrarDropCliente,200)">
              <div class="cart-cliente-drop" id="posClienteResultados"></div>
              <div class="cart-cliente-sel" id="posClienteSeleccionado">
                <span id="posClienteNombre" style="font-weight:600;color:var(--text-primary)"></span>
                <span style="font-size:10px;font-weight:700;color:var(--color-action);background:rgba(0,180,216,.1);padding:1px 6px;border-radius:10px">✓</span>
              </div>
            </div>
          </div>
          <div class="cobro-section-descuento">
            <div class="field-label" style="margin-bottom:6px;display:flex;align-items:center;gap:5px;">
              <i class="bi bi-percent" style="color:var(--color-alert);font-size:12px;"></i> Descuento
            </div>
            <div class="disc-bar" style="border:none;background:transparent;padding:0;">
              <label>Tipo</label>
