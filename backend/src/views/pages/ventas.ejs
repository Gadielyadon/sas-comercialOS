}).join('');

  const logoHtml = cfg.logo
    ? `<div class="center" style="margin-bottom:6px;"><img src="${escapeHtml(cfg.logo)}" style="max-width:100%;max-height:60px;object-fit:contain;"></div>`
    : '';

  const html = `
    <!DOCTYPE html>
    <html lang="es">
    <head>
      <meta charset="UTF-8">
      <title>Ticket</title>
      <style>
        * { box-sizing: border-box; }
@page {
  size: ${paperWidth} auto;
  margin: ${pageMargin};
}
@media print {
  html, body { width: ${paperWidth}; }
}
body {
  font-family: 'Courier New', Courier, monospace;
  margin: 0;
  padding: ${es80 ? '4px 3px' : '12px'};
  background: #fff;
  color: #000;
  font-size: ${fontSize};
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}
.ticket {
  width: ${es80 ? '74mm' : '180mm'};
  max-width: 100%;
  margin: 0 auto;
}
        .center { text-align: center; }
        .title { font-size: ${titleSize}; font-weight: 700; margin-bottom: 2px; }
        .sub { font-size: ${es80 ? '11px' : '12px'}; margin-bottom: 10px; }
        .line { border-top: 1px dashed #000; margin: 10px 0; }
        table {
          width: 100%;
          border-collapse: collapse;
          font-size: ${es80 ? '10px' : '12px'};
        }
        th, td { vertical-align: top; }
        .tot {
          display: flex;
          justify-content: space-between;
          font-size: ${es80 ? '12px' : '13px'};
          margin: 4px 0;
        }
        .tot.main {
          font-weight: 700;
          font-size: ${es80 ? '14px' : '16px'};
        }
        .small { font-size: ${es80 ? '10px' : '11px'}; }
      </style>
    </head>
    <body>
      <div class="ticket">
        ${logoHtml}

        <div class="center">
          <div class="title">${escapeHtml(cfg.nombre || 'Mi Comercio')}</div>
          ${cfg.direccion ? `<div class="small">${escapeHtml(cfg.direccion)}</div>` : ''}
          ${cfg.telefono ? `<div class="small">${escapeHtml(cfg.telefono)}</div>` : ''}
        </div>

        <div class="line"></div>

        <div>Fecha: ${escapeHtml(fechaTxt)}</div>
        <div>Cliente: ${escapeHtml(lastSaleData.cliente)}</div>
        <div>Método: ${escapeHtml(lastSaleData.metodo)}</div>
        ${lastSaleData.offline ? `<div>Estado: OFFLINE</div>` : ''}

        <div class="line"></div>

        <table>
          <thead>
            <tr>
              <th style="text-align:left;">Producto</th>
              <th style="text-align:center;">Cant</th>
              <th style="text-align:right;">Sub</th>
            </tr>
          </thead>
          <tbody>
            ${itemsHtml}
          </tbody>
        </table>

        <div class="line"></div>

        <div class="tot"><span>Subtotal:</span><span>${fmt(lastSaleData.subtotal)}</span></div>
        ${lastSaleData.descuento > 0 ? `<div class="tot"><span>Descuento:</span><span>-${fmt(lastSaleData.descuento)}</span></div>` : ''}
        <div class="tot main"><span>TOTAL:</span><span>${fmt(lastSaleData.total)}</span></div>
        ${lastSaleData.recibido !== null ? `<div class="tot"><span>Recibido:</span><span>${fmt(lastSaleData.recibido)}</span></div>` : ''}
        ${lastSaleData.vuelto > 0 ? `<div class="tot"><span>Vuelto:</span><span>${fmt(lastSaleData.vuelto)}</span></div>` : ''}

        <div class="line"></div>
        <div class="center small">${escapeHtml(cfg.footer || '¡Gracias por su compra!')}</div>
      </div>
    </body>
    </html>
  `;
const w = window.open('', '_blank', `width=${winWidth},height=800,left=0,top=0`);

  if(!w){
    showToast('Permití ventanas emergentes para imprimir','warn');
    return;
  }

  w.document.open();
  w.document.write(html);
  w.document.close();
  w.focus();
  setTimeout(() => w.print(), 250);
}

