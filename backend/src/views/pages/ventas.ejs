/* ══════════════════════════════════════════════════════
   DEPARTAMENTOS DE PRECIO MANUAL
══════════════════════════════════════════════════════ */

let _deptoActual = null;

function _getDeptos() {
  try { return JSON.parse(localStorage.getItem('pos_deptos') || '[]'); } catch(e){ return []; }
}
function _saveDeptos(arr) {
  localStorage.setItem('pos_deptos', JSON.stringify(arr));
}

function toggleDeptosChip(btn) {
  const bar  = document.getElementById('deptosBar');
  const isOpen = btn.classList.toggle('active');
  const scroll = document.querySelector('.products-scroll');
  if (isOpen) {
    bar.style.display  = 'block';
    if(scroll) scroll.style.display = 'none';
    renderDeptosGrid();
  } else {
    bar.style.display  = 'none';
    if(scroll) scroll.style.display = '';
  }
}

function renderDeptosGrid() {
  const deptos = _getDeptos();
  const container = document.getElementById('deptosGrid');
  if (!container) return;

  if (!deptos.length) {
    container.innerHTML = `
      <div style="grid-column:1/-1;text-align:center;padding:24px;color:var(--text-secondary);">
        <div style="font-size:32px;margin-bottom:8px;">🏪</div>
        <div style="font-size:13px;font-weight:600;">Sin departamentos</div>
        <div style="font-size:12px;margin-top:4px;opacity:.7;">Agregá uno con el botón +</div>
        <button onclick="abrirGestorDeptos()" style="margin-top:12px;padding:7px 16px;border-radius:8px;border:1.5px solid var(--border-color);background:var(--bg-card);color:var(--text-primary);font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font-body);">
          + Agregar departamento
        </button>
      </div>`;
    return;
  }

  container.innerHTML = deptos.map(d => `
    <button class="depto-btn" onclick="abrirDeptoPrecio('${d.id}','${escapeHtml(d.nombre)}','${d.icono||'🏷️'}')">
      <span class="depto-btn-icon">${d.icono || '🏷️'}</span>
      <span class="depto-btn-label">${escapeHtml(d.nombre)}</span>
      <button class="depto-btn-edit" onclick="event.stopPropagation();eliminarDepto('${d.id}')" title="Eliminar" style="position:absolute;top:4px;right:4px;width:18px;height:18px;border-radius:50%;border:none;background:rgba(239,68,68,.15);color:#ef4444;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>
    </button>
  `).join('') + `
    <button class="depto-btn" onclick="abrirGestorDeptos()" style="border-style:dashed;opacity:.6;">
      <span class="depto-btn-icon">➕</span>
      <span class="depto-btn-label">Agregar</span>
    </button>`;
}

function abrirDeptoPrecio(id, nombre, icono) {
  _deptoActual = { id, nombre, icono };
  const overlay = document.getElementById('deptoPriceOverlay');
  if (!overlay) return;
  const header = overlay.querySelector('.depto-price-header');
  if (header) header.innerHTML = `<span>${icono} ${nombre}</span>`;
  const priceInp = document.getElementById('deptoPriceInput');
  const qtyInp   = document.getElementById('deptoQtyInput');
  const addBtn   = document.getElementById('btnDeptoAdd');
  if (priceInp) { priceInp.value = ''; }
  if (qtyInp)   { qtyInp.value  = '1'; }
  if (addBtn)   { addBtn.disabled = true; }
  overlay.style.display = 'flex';
  setTimeout(() => { if (priceInp) priceInp.focus(); }, 80);
}

function cerrarDeptoPrecio() {
  const overlay = document.getElementById('deptoPriceOverlay');
  if (overlay) overlay.style.display = 'none';
  _deptoActual = null;
}

function actualizarBtnDepto() {
  const priceInp = document.getElementById('deptoPriceInput');
  const addBtn   = document.getElementById('btnDeptoAdd');
  if (!priceInp || !addBtn) return;
  addBtn.disabled = !(parseFloat(priceInp.value) > 0);
}

function agregarDepto() {
  if (!_deptoActual) return;
  const price = parseFloat(document.getElementById('deptoPriceInput')?.value) || 0;
  const qty   = parseInt(document.getElementById('deptoQtyInput')?.value)     || 1;
  if (price <= 0) return;

  const product = {
    sku:     `DEPTO-${_deptoActual.id}-${Date.now()}`,
    name:    _deptoActual.nombre,
    price:   price,
    stock:   9999,
    isDepto: true,
    en_promo: 0,
    price_promo: null,
  };

  for (let i = 0; i < qty; i++) addToCart(product);
  cerrarDeptoPrecio();
  showToast(`${_deptoActual.icono} ${_deptoActual.nombre} — ${fmt(price)} × ${qty}`, 'success');
}

function abrirGestorDeptos() {
  const overlay = document.getElementById('deptosMgrOverlay');
  if (!overlay) return;
  renderDeptosMgrList();
  overlay.classList.add('open');
}

function cerrarGestorDeptos() {
  const overlay = document.getElementById('deptosMgrOverlay');
  if (overlay) overlay.classList.remove('open');
  renderDeptosGrid();
}

function renderDeptosMgrList() {
  const list   = document.getElementById('deptosMgrList');
  const deptos = _getDeptos();
  if (!list) return;
  if (!deptos.length) {
    list.innerHTML = '<p style="font-size:12px;color:var(--text-secondary);text-align:center;">Sin departamentos</p>';
    return;
  }
  list.innerHTML = deptos.map(d => `
    <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--bg-body);border-radius:8px;border:1px solid var(--border-color);">
      <span style="font-size:20px;">${d.icono || '🏷️'}</span>
      <span style="flex:1;font-size:13px;font-weight:600;color:var(--text-primary);">${escapeHtml(d.nombre)}</span>
      <button onclick="eliminarDepto('${d.id}')" style="padding:3px 8px;border-radius:6px;border:1px solid rgba(239,68,68,.3);background:rgba(239,68,68,.08);color:#ef4444;font-size:11px;cursor:pointer;">Eliminar</button>
    </div>`).join('');
}

function agregarNuevoDepto() {
  const nombreInp = document.getElementById('newDeptoName');
  const iconoInp  = document.getElementById('newDeptoIcon');
  if (!nombreInp) return;
  const nombre = nombreInp.value.trim();
  if (!nombre) return;
  const icono  = iconoInp?.value.trim() || '🏷️';
  const deptos = _getDeptos();
  deptos.push({ id: Date.now().toString(), nombre, icono });
  _saveDeptos(deptos);
  nombreInp.value = '';
  if (iconoInp) iconoInp.value = '';
  renderDeptosMgrList();
  showToast(`Departamento "${nombre}" creado`, 'success');
}

function eliminarDepto(id) {
  const deptos = _getDeptos().filter(d => d.id !== id);
  _saveDeptos(deptos);
  renderDeptosMgrList();
  renderDeptosGrid();
}


