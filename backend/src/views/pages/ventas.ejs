const es58 = formato === '58mm';
const es80 = formato === '80mm';
const fmtA4 = formato === 'a4';

const paperWidth   = es58 ? '58mm' : es80 ? '80mm' : '210mm';
const contentWidth = es58 ? '52mm' : es80 ? '74mm' : '180mm';
const winWidth     = es58 ? 240    : es80 ? 340    : 900;
const fontSize     = fmtA4 ? '13px' : es58 ? '10px' : '11px';
const titleSize    = fmtA4 ? '24px' : es58 ? '13px' : '18px';
const pageMargin   = fmtA4 ? '12mm' : es58 ? '1mm 2mm' : '2mm 3mm';
const bodyPadding  = fmtA4 ? '12px' : es58 ? '3px 2px' : '4px 3px';

const itemsHtml = lastSaleData.items.map(it => {
  let badge = '';
  if (it.isMayorista) badge = ' <span style="font-size:9px;font-weight:800;">[MAYOR]</span>';
  else if (it.isPromo) badge = ' <span style="font-size:9px;font-weight:800;">[PROMO]</span>';

  let precioExtra = '';
