<%- include('../partials/scripts') %>

<script>
'use strict';
let cart=[],clienteId=1,discType='pct',payMethod='efectivo',recargoVal=0,payTipo='';
let toastTimer=null,searchDeb=null,lastKeyTime=0,keyCount=0,isScanMode=false;
let posClienteDebounce=null,allProducts=[],catActiva='';
let mixtoActivo=false, payMethods=[], lastSaleData=null, ticketConfig=null;
let pmFocusIdx = 0;

// ══════════════════════════════════════════════════════════
// ⚖️  SOPORTE BALANZA EAN-13
// Lee la configuración inyectada por EJS desde /api/config
// ══════════════════════════════════════════════════════════
const BALANZA_CFG = {
  habilitada : <%- String(config && config.balanza_habilitada  ? config.balanza_habilitada  : '0') %> === 1
               || String(<%- JSON.stringify(config && config.balanza_habilitada  ? config.balanza_habilitada  : '0') %>) === '1',
  prefijo    : parseInt('<%- (config && config.balanza_prefijo)  ? config.balanza_prefijo  : 2 %>', 10) || 2,
  modo       : '<%- (config && config.balanza_modo) ? config.balanza_modo : "precio" %>',
};

/**
 * tryDecodeBalanza(code)
 * Intenta interpretar un código EAN-13 como ticket de balanza.
 * Retorna { sku, precio, peso } o null si no aplica.
 *
 * Estructura EAN-13 balanza (modo precio):
 *   [ prefijo 1d ][ PLU 5d ][ precio 5d ][ control 1d ]
 *   Ej: 2 01029 01599 4  →  PLU=1029, precio=$15.99
 *
 * Estructura EAN-13 balanza (modo peso):
 *   [ prefijo 1d ][ PLU 5d ][ peso gramos 5d ][ control 1d ]
 *   Ej: 2 01029 01500 4  →  PLU=1029, peso=1.500 kg
 */
function tryDecodeBalanza(code) {
  if (!BALANZA_CFG.habilitada) return null;
  if (!code || code.length !== 13) return null;
  if (!/^\d{13}$/.test(code)) return null;

  const primerDigito = parseInt(code.charAt(0), 10);
  if (primerDigito !== BALANZA_CFG.prefijo) return null;

 const plu   = parseInt(code.slice(1, 6), 10);  // PLU=4 ✅
const valor = parseInt(code.slice(6, 12), 10); // 001617 ✅


// dígito 13 (índice 12) = dígito de control, no lo usamos
  // dígito 12 (índice 12) = dígito de control, no lo usamos

  if (isNaN(plu) || isNaN(valor)) return null;

  return {
    sku   : String(plu),                                           // PLU como string
    precio: BALANZA_CFG.modo === 'precio' ? valor : null,
    peso  : BALANZA_CFG.modo === 'peso'   ? valor / 1000 : null,
  };
}
// ══════════════════════════════════════════════════════════

const fmt=n=>'$'+Number(n).toFixed(2).replace('.',',').replace(/\B(?=(\d{3})+(?!\d))/g,'.');

function beep(type){try{const ctx=new(window.AudioContext||window.webkitAudioContext)();const osc=ctx.createOscillator(),gain=ctx.createGain();osc.connect(gain);gain.connect(ctx.destination);if(type==='add'){osc.frequency.setValueAtTime(880,ctx.currentTime);osc.frequency.setValueAtTime(1100,ctx.currentTime+.06);gain.gain.setValueAtTime(.08,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.18);osc.start();osc.stop(ctx.currentTime+.18);}else if(type==='confirm'){[660,880,1100].forEach((f,i)=>osc.frequency.setValueAtTime(f,ctx.currentTime+i*.08));gain.gain.setValueAtTime(.08,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.35);osc.start();osc.stop(ctx.currentTime+.35);}else{osc.type='sawtooth';osc.frequency.setValueAtTime(200,ctx.currentTime);gain.gain.setValueAtTime(.06,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.25);osc.start();osc.stop(ctx.currentTime+.25);}}catch(e){}}

const apiBySku=async sku=>{try{const r=await fetch(`/api/products/${encodeURIComponent(sku)}`);return r.ok?r.json():null;}catch(e){return null;}};

async function loadCatalog(){
  // Mostrar skeleton mientras carga
  const grid = document.getElementById('productsGrid');
  if (grid) {
    grid.innerHTML = '<div style="padding:24px 16px;display:flex;flex-direction:column;gap:8px;">'
      + Array(6).fill('<div style="height:44px;border-radius:8px;background:var(--bg-hover);animation:shimmer 1.2s infinite;"></div>').join('')
      + '</div>';
  }
  try {
    const r = await fetch('/api/products');
    allProducts = r.ok ? await r.json() : [];
  } catch(e) {
    allProducts = [];
  }
  actualizarChipLista();
  buildCatBar();
  renderGrid(allProducts);
}

/* ══════════════════════════════════════════════
   LISTAS DE PRECIO — Minorista / Mayorista / Tarjeta
   F6 cicla entre las listas disponibles
══════════════════════════════════════════════ */
const LISTAS = [
  { key: 'minorista', label: 'Minorista', icon: 'bi-person',       campo: 'price',          clase: '' },
  { key: 'mayorista', label: 'Mayorista', icon: 'bi-building',     campo: 'price_mayorista', clase: 'lista-mayorista' },
  { key: 'tarjeta',   label: 'Tarjeta',   icon: 'bi-credit-card',  campo: 'price_tarjeta',   clase: 'lista-tarjeta' },
];
let _listaIdx = 0; // índice activo

function getPrecioLista(product) {
  const lista = LISTAS[_listaIdx];
  const val   = product[lista.campo];
  // Si no tiene precio en esa lista → fallback al precio base
  return (val && Number(val) > 0) ? Number(val) : Number(product.price);
}

function toggleDropLista() {
  const drop = document.getElementById('dropLista');
  if (!drop) return;
  drop.style.display = drop.style.display === 'none' ? 'block' : 'none';
}

function selLista(idx) {
  _listaIdx = idx;
  document.getElementById('dropLista').style.display = 'none';
  actualizarChipLista();
  renderGrid(catActiva ? allProducts.filter(p => p.category === catActiva) : allProducts);
  if (cart.length) recalcularPreciosCarrito();
}

// F6 — cicla entre listas disponibles
function ciclarLista() {
  const listasDisponibles = LISTAS.filter((l, i) => {
    if (i === 0) return true;
    return allProducts.some(p => p[l.campo] && Number(p[l.campo]) > 0);
  });
  if (listasDisponibles.length <= 1) { showToast('Sin otras listas. Cargá precios en Inventario.', 'warn'); return; }
  const currentKey   = LISTAS[_listaIdx].key;
  const currentInD   = listasDisponibles.findIndex(l => l.key === currentKey);
  const nextLista    = listasDisponibles[(currentInD + 1) % listasDisponibles.length];
  selLista(LISTAS.findIndex(l => l.key === nextLista.key));
  showToast(`Lista: ${LISTAS[_listaIdx].label}`, 'info');
}

function actualizarChipLista() {
  const lista  = LISTAS[_listaIdx];
  const btn    = document.getElementById('btnLista');
  const nombre = document.getElementById('listaNombre');
  const icon   = document.getElementById('listaIcon');
  if (!btn) return;

  // Colores por lista
  const estilos = {
    minorista: { border:'rgba(16,185,129,.35)', bg:'rgba(16,185,129,.06)', color:'#059669', kbdBg:'#10b981' },
    mayorista: { border:'rgba(99,102,241,.4)',  bg:'rgba(99,102,241,.07)', color:'#4f46e5', kbdBg:'#6366f1' },
    tarjeta:   { border:'rgba(245,158,11,.4)',  bg:'rgba(245,158,11,.07)', color:'#d97706', kbdBg:'#f59e0b' },
  };
  const s = estilos[lista.key] || estilos.minorista;
  btn.style.borderColor = s.border;
  btn.style.background  = s.bg;
  btn.style.color       = s.color;
  const kbd = btn.querySelector('kbd');
  if (kbd) kbd.style.background = s.kbdBg;
  if (nombre) nombre.textContent = lista.label;
  if (icon)   icon.className = `bi ${lista.icon}`;

  // Marcar la opción activa en el dropdown
  LISTAS.forEach((l, i) => {
    const opt = document.getElementById(`listaOpt${i}`);
    if (opt) opt.style.fontWeight = i === _listaIdx ? '800' : '600';
  });
}

function recalcularPreciosCarrito() {
  cart.forEach(item => {
    const prod = allProducts.find(p => p.sku === item.sku);
    if (!prod) return;
    const nuevoPrecio = getPrecioLista(prod);
    item.price      = nuevoPrecio;
    item.price_base = nuevoPrecio;
    item.isMayorista = false;
  });
  renderCartList();
  updateTotals();
  showToast('Precios del carrito actualizados', 'info');
}

/* ── Toggle mobile: alterna entre catálogo y carrito ── */
let _showingCart = false;
function togglePanelMobile() {
  const left   = document.querySelector('.pos-left');
  const right  = document.getElementById('posRight');
  const icon   = document.getElementById('fabIcon');
  const label  = document.getElementById('fabLabel');
  if (!left || !right) return;
  _showingCart = !_showingCart;
  if (_showingCart) {
    left.classList.add('panel-hidden');
    right.classList.add('panel-visible');
    icon.className  = 'bi bi-grid-3x3-gap';
    label.textContent = 'Catálogo';
  } else {
    left.classList.remove('panel-hidden');
    right.classList.remove('panel-visible');
    icon.className  = 'bi bi-cart3';
    label.textContent = 'Carrito';
  }
}
// Al cobrar en mobile, volver al catálogo automáticamente
function _resetMobilePanel() {
  _showingCart = false;
  const left  = document.querySelector('.pos-left');
  const right = document.getElementById('posRight');
  if (left)  left.classList.remove('panel-hidden');
  if (right) right.classList.remove('panel-visible');
  const icon  = document.getElementById('fabIcon');
  const label = document.getElementById('fabLabel');
  if (icon)  icon.className = 'bi bi-cart3';
  if (label) label.textContent = 'Carrito';
}

async function loadTicketConfig(){
  ticketConfig = {
    formato: '80mm',
    footer: '¡Gracias por su compra!',
    nombre: 'Mi Comercio',
    direccion: '',
    telefono: '',
    logo: ''
  };

  try{
    const r = await fetch('/api/config');
    if(!r.ok) return;
    const cfg = await r.json();

    ticketConfig = {
      formato: cfg.ticket_formato || cfg.aj_formato || '80mm',
      footer: cfg.ticket_footer || cfg.aj_footer || '¡Gracias por su compra!',
      nombre: cfg.empresa_nombre || 'Mi Comercio',
      direccion: cfg.empresa_direccion || '',
      telefono: cfg.empresa_telefono || '',
      logo: cfg.empresa_logo || cfg.logo || ''
    };
  }catch(e){}
}

// cat-bar eliminada
function buildCatBar(){ /* eliminado */ }

function filterCat(cat,btn){
  catActiva=cat;
  document.getElementById('barcodeInput').value='';
  renderGrid(cat?allProducts.filter(p=>p.category===cat):allProducts);
}
function renderGrid(products){
  const grid=document.getElementById('productsGrid');
  if(!products.length){
    grid.innerHTML='<div class="products-empty"><i class="bi bi-box-seam"></i><p>Sin productos</p></div>';
    return;
  }
  const header=`<div class="prod-table-head">
    <div class="prod-th th-img"></div>
    <div class="prod-th">Producto</div>
    <div class="prod-th th-stock" style="text-align:center;">Stock</div>
    <div class="prod-th th-price" style="text-align:right;">Precio</div>
  </div>`;
  const rows=products.map(p=>{
    const ep = getPrecioLista(p);
    const esPromo = p.en_promo && p.price_promo && _listaIdx === 0;
    const lista   = LISTAS[_listaIdx];
    // Precio tachado: si es lista base y hay promo → tachar precio normal
    // Si es lista mayorista/tarjeta y tiene precio propio → tachar minorista
    const precioBase = Number(p.price);
    const tienePrecioEspecial = lista.campo !== 'price' && p[lista.campo] && Number(p[lista.campo]) > 0;
    const promoOld = esPromo
      ? `<span class="prod-price-old">${fmt(p.price)}</span>`
      : tienePrecioEspecial
        ? `<span class="prod-price-old" style="font-size:9px;">${fmt(precioBase)}</span>`
        : '';
    const promoBadge = esPromo
      ? '<span class="prod-badge-promo">Promo</span>'
      : tienePrecioEspecial
        ? `<span class="prod-badge-promo" style="background:${_listaIdx===1?'#6366f1':'#f59e0b'};font-size:8px;">${lista.label}</span>`
        : '';
    const stock=Number(p.stock??0),sinStock=stock<=0 && !p.venta_sin_stock;
    const inCart=cart.find(i=>i.sku===p.sku);
    const stockCls=stock<=0?'zero':stock<=5?'low':'ok';
    const stockTxt=stock<=0?'0':String(stock);
    const skuSafe=p.sku.replace(/'/g,"\\'");
    const nameSafe=p.name.replace(/"/g,'&quot;');
    const imgSafe=p.imagen?p.imagen.replace(/"/g,'&quot;'):'';
    const inCartBadge=inCart?`<span class="prod-badge-qty">${inCart.qty}</span>`:'';
    const descHTML=p.descripcion?`<div class="prod-desc">${p.descripcion}</div>`:'';
    const sinStockBadge=sinStock?'<span class="prod-sin-stock">Sin stock</span>':'';
    const thumbCell=p.imagen
      ? `<div class="prod-td-img"><div class="prod-thumb" onclick="event.stopPropagation();abrirZoom('${nameSafe}','${imgSafe}')" title="Ver imagen"><img src="${imgSafe}" alt="" loading="lazy"></div></div>`
      : `<div class="prod-td-img"><div class="prod-thumb-empty"><i class="bi bi-box-seam"></i></div></div>`;
    return `<div class="prod-card ${sinStock?'out-stock':''} ${inCart?'in-cart':''}" id="pcard-${CSS.escape(p.sku)}" onclick="${sinStock?'':` addBySku('${skuSafe}',this)`}">
      ${thumbCell}
      <div class="prod-td">
        ${sinStockBadge}
        <div class="prod-name">${p.name}${inCartBadge}${promoBadge}</div>
        ${descHTML}
      </div>
      <div class="prod-td" style="text-align:center;"><span class="prod-stock-badge ${stockCls}">${stockTxt}</span></div>
      <div class="prod-td" style="text-align:right;">${promoOld}<div class="prod-price">${fmt(ep)}</div></div>
    </div>`;
  }).join('');
  grid.innerHTML=header+rows;
}


function updateCardState(sku){
  const card = document.getElementById('pcard-' + CSS.escape(sku));
  if (!card) return;
  const item = cart.find(i => i.sku === sku);
  card.classList.toggle('in-cart', !!item);
  // Actualizar solo el badge de qty en la card — sin re-renderizar todo el grid
  const nameDiv = card.querySelector('.prod-name');
  if (nameDiv) {
    // Remover badge viejo
    const oldBadge = nameDiv.querySelector('.prod-badge-qty');
    if (oldBadge) oldBadge.remove();
    // Agregar badge nuevo si está en carrito
    if (item) {
      const badge = document.createElement('span');
      badge.className = 'prod-badge-qty';
      badge.textContent = item.qty;
      nameDiv.appendChild(badge);
    }
  }
}

function addBySku(sku,el){
  if(el){el.style.transform='scale(.95)';setTimeout(()=>el.style.transform='',130);}
  const p=allProducts.find(x=>x.sku===sku);
  if(p)addToCart(p);
}

function aplicarPrecioMayorista(item) {
  if (!item.price_mayorista || !item.qty_mayorista) return;
  const esMayorista = item.qty >= item.qty_mayorista;
  if (esMayorista && !item.isMayorista) {
    item.price     = item.price_mayorista;
    item.isMayorista = true;
    showToast(`🏪 ${item.name} — precio mayorista aplicado`, 'info');
  } else if (!esMayorista && item.isMayorista) {
    item.price     = item.price_base;
    item.isMayorista = false;
    showToast(`${item.name} — precio minorista`, 'info');
  }
}

function addToCart(product){
  const ep = getPrecioLista(product);
  const existing=cart.find(i=>i.sku===product.sku);
  if(existing){
    existing.qty++;
    aplicarPrecioMayorista(existing);
    showToast(`${existing.name} — x${existing.qty}`,'info');
  } else {
    cart.push({
      sku: product.sku,
      name: product.name,
      price: ep,
      price_base: ep,
      price_mayorista: product.price_mayorista ? Number(product.price_mayorista) : null,
      qty_mayorista: product.qty_mayorista ? Number(product.qty_mayorista) : null,
      isMayorista: false,
      descripcion: product.descripcion || null,
      isPromo: !!(product.en_promo && product.price_promo),
      qty: 1
    });
    showToast(`${product.name}${product.en_promo?' 🏷️':''} agregado`,'success');
  }
  beep('add');
  updateCardState(product.sku);
  renderCartList();
  updateTotals();
  // En mobile: al agregar el primer item, mostrar el FAB animado
  if (window.innerWidth <= 860) {
    const fab = document.getElementById('fabBtn');
    if (fab) { fab.style.transform = 'scale(1.2)'; setTimeout(()=>fab.style.transform='', 200); }
  }
}

function renderCartList(){
  const emptyState = document.getElementById('cartEmptyState');
  const grid       = document.getElementById('cartItemsGrid');
  if (!emptyState || !grid) return;

  if (!cart.length) {
    emptyState.style.display = 'flex';
    grid.innerHTML = '';
    document.getElementById('cartSub').textContent = 'Sin productos';
    return;
  }
  emptyState.style.display = 'none';

  grid.querySelectorAll('.cart-card').forEach(el => {
    if (!cart.find(i => 'ci-' + CSS.escape(i.sku) === el.id)) el.remove();
  });

  cart.forEach(item => {
    const id = 'ci-' + CSS.escape(item.sku);
    let el = document.getElementById(id);
    if (!el) {
      el = document.createElement('div');
      el.id = id; el.className = 'cart-card';
      grid.appendChild(el);
    }
    el.innerHTML = `
      ${item.isPromo ? '<span class="cart-promo-tag">Promo</span>' : ''}
      ${item.isMayorista ? '<span class="cart-promo-tag" style="background:#6366f1;right:8px;">Mayor</span>' : ''}
      <div class="cart-card-top">
        <div class="cart-card-name">${item.name}</div>
        <button class="btn-del" onclick="removeItem('${item.sku}')"><i class="bi bi-trash3"></i></button>
      </div>
      <div class="cart-card-unit">Precio unitario: <span>${fmt(item.price)}${item.isMayorista ? ' <span style="color:#6366f1;font-size:9px;font-weight:800;">MAYOR</span>' : ''}</span></div>
      <div class="cart-card-bottom">
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="chgQty('${item.sku}',-1)"><i class="bi bi-dash"></i></button>
          <span class="qty-val" onclick="abrirTecladoCantidad('${item.sku}',${item.qty})" title="Tocá para cambiar cantidad" style="cursor:pointer;background:var(--color-primary);color:#fff;border-radius:4px;padding:0 4px;">${item.qty}</span>
          <button class="qty-btn" onclick="chgQty('${item.sku}',1)"><i class="bi bi-plus"></i></button>
        </div>
        <div class="cart-card-price">${fmt(item.price * item.qty)}</div>
      </div>`;
  });

  const total = cart.reduce((s,i) => s+i.qty, 0);
  document.getElementById('cartSub').textContent = `${cart.length} prod. · ${total} ud.`;
  document.getElementById('cartCount').textContent = total;
  // Actualizar badge del FAB
  const badge = document.getElementById('fabBadge');
  if (badge) {
    if (total > 0) { badge.textContent = total > 99 ? '99+' : total; badge.style.display = 'flex'; }
    else { badge.style.display = 'none'; }
  }
}

function chgQty(sku,d){
  const item=cart.find(i=>i.sku===sku);
  if(!item)return;
  item.qty+=d;
  if(item.qty<=0){removeItem(sku);return;}
  aplicarPrecioMayorista(item);
  updateCardState(sku);
  renderCartList();
  updateTotals();
}

function removeItem(sku){
  cart=cart.filter(i=>i.sku!==sku);
  const el=document.getElementById('ci-'+CSS.escape(sku));
  if(el){
    el.style.cssText='transition:opacity .15s,transform .15s;opacity:0;transform:translateX(10px)';
    setTimeout(()=>{el.remove();renderCartList();},150);
  }
  updateCardState(sku);
  updateTotals();
}

function clearCart(){
  const skus=cart.map(i=>i.sku);
  cart=[];
  skus.forEach(updateCardState);
  renderCartList();
  document.getElementById('discInput').value='';
  limpiarClientePos();
  updateTotals();
  focusScanner();
}

function setDiscType(t){
  discType=t;
  document.getElementById('btnPct').classList.toggle('on',t==='pct');
  document.getElementById('btnFixed').classList.toggle('on',t==='fixed');
  document.getElementById('discSuffix').textContent=t==='pct'?'%':'$';
  document.getElementById('discInput').value='';
  updateTotals();
}
function getDiscount(sub){
  const v=parseFloat(document.getElementById('discInput').value)||0;
  if(v<=0)return 0;
  return discType==='pct'?sub*(Math.min(v,100)/100):Math.min(v,sub);
}
function getBaseTotal(){
  const sub=cart.reduce((s,i)=>s+i.price*i.qty,0),disc=getDiscount(sub);
  return{sub,disc,total:Math.max(0,sub-disc)};
}
/* ── Tipo de comprobante ── */
let _tipoComprobante = 'venta';
function setComprobante(tipo) {
  _tipoComprobante = tipo;
  document.getElementById('compVenta').classList.toggle('active', tipo === 'venta');
  document.getElementById('compFactura').classList.toggle('active', tipo === 'factura');
  updateTotals();
}

function updateTotals(){
  const{sub,disc,total}=getBaseTotal();
  document.getElementById('subtotalVal').textContent=fmt(sub);
  document.getElementById('totalVal').textContent=fmt(total);

  const dr=document.getElementById('discRow');
  dr.style.display=disc>0?'flex':'none';
  document.getElementById('discVal').textContent='-'+fmt(disc);

  // Neto e IVA — solo si hay productos con IVA y es factura
  const tieneIva = cart.some(i => {
    const prod = allProducts.find(p => p.sku === i.sku);
    return prod && Number(prod.iva) > 0;
  });
  const mostrarFiscal = _tipoComprobante === 'factura' && tieneIva;
  let netoTotal = 0, ivaTotal = 0;
  if (mostrarFiscal) {
    cart.forEach(i => {
      const prod = allProducts.find(p => p.sku === i.sku);
      const iva  = prod ? Number(prod.iva || 0) : 0;
      const linea = i.price * i.qty;
      if (iva > 0) {
        const neto = linea / (1 + iva / 100);
        netoTotal += neto;
        ivaTotal  += linea - neto;
      } else {
        netoTotal += linea;
      }
    });
    if (disc > 0) { const r = (total / sub); netoTotal *= r; ivaTotal *= r; }
  }
  const netoRow = document.getElementById('netoRow');
  const ivaRow  = document.getElementById('ivaRow');
  if (netoRow) { netoRow.style.display = mostrarFiscal ? 'flex' : 'none'; document.getElementById('netoVal').textContent = fmt(netoTotal); }
  if (ivaRow)  { ivaRow.style.display  = mostrarFiscal ? 'flex' : 'none'; document.getElementById('ivaVal').textContent  = fmt(ivaTotal); }

  const cnt = cart.reduce((s,i)=>s+i.qty,0);
  const badge = document.getElementById('cartCount');
  if (badge) { badge.textContent = cnt; badge.style.display = cnt > 0 ? 'inline-flex' : 'none'; }
  document.getElementById('btnConfirm').disabled=cart.length===0;
  updateCobroTotals();
}

/* Navegación teclado métodos de pago */
function getPmButtons(){ return [...document.querySelectorAll('#pmGrid .pm-btn')]; }
function clearPmFocus(){ getPmButtons().forEach(b => b.classList.remove('kbd-focus')); }
function focusPmButton(index){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  if(index < 0) index = 0;
  if(index >= buttons.length) index = buttons.length - 1;
  pmFocusIdx = index;
  clearPmFocus();
  const btn = buttons[pmFocusIdx];
  btn.classList.add('kbd-focus');
  btn.focus({ preventScroll:true });
  btn.scrollIntoView({ block:'nearest', inline:'nearest' });
}
function syncPmFocusWithSelected(){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  const idx = buttons.findIndex(b => b.classList.contains('on'));
  focusPmButton(idx >= 0 ? idx : 0);
}
function movePmFocus(delta){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  let next = pmFocusIdx + delta;
  if(next < 0) next = buttons.length - 1;
  if(next >= buttons.length) next = 0;
  focusPmButton(next);
}
function movePmFocusVertical(deltaRows){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  const cols = 2;
  let next = pmFocusIdx + (deltaRows * cols);
  if(next < 0) next = pmFocusIdx;
  if(next >= buttons.length) next = pmFocusIdx;
  focusPmButton(next);
}

async function openCobroModal(){
  if(!cart.length)return;

  // Aviso preventivo si el cliente tiene límite configurado
  if (clienteId && clienteId !== 1) {
    try {
      const {total} = getBaseTotal();
      const r = await fetch(`/api/clientes/${clienteId}/check-limite`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ monto: total })
      });
      if (r.ok) {
        const check = await r.json();
        if (!check.ok) {
          const fmtN = n => '$' + Number(n).toLocaleString('es-AR',{minimumFractionDigits:2});
          showToast(`⚠️ Cliente supera límite — disponible ${fmtN(Math.max(0,check.disponible))}`, 'warn');
        }
      }
    } catch(e) {}
  }

  recargoVal=0;
  mixtoActivo=false;
  resetFacturacionToggle();
  document.getElementById('mixtoRow').classList.remove('visible');
  document.getElementById('btnMixto').innerHTML='<i class="bi bi-plus-circle"></i> Activar';
  document.getElementById('btnMixto').style.borderColor='';
  document.getElementById('btnMixto').style.color='';
  document.getElementById('vueltoDisplay').style.display='none';
  document.getElementById('recargoResult').style.display='none';
  document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
  document.getElementById('recargoCustom').value='';
  document.getElementById('cashReceived').value='';
  document.getElementById('mixtoMonto1').value='';
  document.getElementById('mixtoMonto2').value='';
  document.getElementById('mixtoResto').textContent='';
  updateCobroTotals();
  document.getElementById('cobroOverlay').classList.add('open');
  setTimeout(()=>syncPmFocusWithSelected(),100);
}

function closeCobroModal(){
  document.getElementById('cobroOverlay').classList.remove('open');
  focusScanner();
}

function toggleMixto(){
  mixtoActivo=!mixtoActivo;
  const row=document.getElementById('mixtoRow');
  const btn=document.getElementById('btnMixto');
  row.classList.toggle('visible',mixtoActivo);
  if(mixtoActivo){
    btn.innerHTML='<i class="bi bi-x-circle"></i> Desactivar';
    btn.style.borderColor='#ef4444';
    btn.style.color='#ef4444';
    const sel=document.getElementById('mixtoMetodo2');
    sel.innerHTML=payMethods
      .filter(m=>m.nombre!==payMethod)
      .map(m=>`<option value="${m.nombre}">${m.nombre}</option>`).join('');
    document.getElementById('mixtoMetodo1Nombre').textContent=payMethod;
    calcMixto();
  } else {
    btn.innerHTML='<i class="bi bi-plus-circle"></i> Activar';
    btn.style.borderColor='';
    btn.style.color='';
    document.getElementById('mixtoMonto1').value='';
    document.getElementById('mixtoMonto2').value='';
    document.getElementById('mixtoResto').textContent='';
    document.getElementById('mixtoMonto2').disabled=true;
    document.getElementById('mixtoMonto2').style.opacity='.65';
  }
}

function calcMixto(){
  const {total}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  const m1=parseFloat(document.getElementById('mixtoMonto1').value)||0;
  const resto=conRecargo-m1;
  const restoEl=document.getElementById('mixtoResto');
  const m2Input=document.getElementById('mixtoMonto2');
  m2Input.value=resto>0?resto.toFixed(2):'0.00';
  m2Input.disabled=false;
  m2Input.style.opacity='1';
  if(resto<-0.01){
    restoEl.textContent=`Exceso: ${fmt(Math.abs(resto))}`;
    restoEl.className='mixto-resto negativo';
  } else if(Math.abs(resto)<0.01){
    restoEl.textContent='✓ Total cubierto';
    restoEl.className='mixto-resto';
  } else {
    restoEl.textContent=`Resta: ${fmt(resto)}`;
    restoEl.className='mixto-resto';
  }
}

function updateCobroTotals(){
  const{total,disc}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  document.getElementById('cobroTotalAmt').textContent=fmt(conRecargo);
  const di=document.getElementById('cobroDiscInfo');
  if(disc>0||recargoVal>0){
    di.style.display='block';
    const p=[];
    if(disc>0)p.push(`Descuento: -${fmt(disc)}`);
    if(recargoVal>0)p.push(`Recargo ${recargoVal}%: +${fmt(total*recargoVal/100)}`);
    di.textContent=p.join(' · ');
  }else di.style.display='none';
  document.getElementById('btnCobrarTxt').textContent=`Cobrar ${fmt(conRecargo)}`;
  calcVuelto();
}
function setRecargo(pct,btn){
  recargoVal=pct;
  document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
  if(btn)btn.classList.add('on');
  document.getElementById('recargoCustom').value='';
  const res=document.getElementById('recargoResult'),{total}=getBaseTotal();
  if(pct>0){
    res.style.display='block';
    res.textContent=`Total: ${fmt(total*(1+pct/100))}`;
  }else res.style.display='none';
  updateCobroTotals();
}
function setRecargoCustom(){
  const v=parseFloat(document.getElementById('recargoCustom').value)||0;
  recargoVal=v;
  document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
  const res=document.getElementById('recargoResult'),{total}=getBaseTotal();
  if(v>0){
    res.style.display='block';
    res.textContent=`Total: ${fmt(total*(1+v/100))}`;
  }else res.style.display='none';
  updateCobroTotals();
}
function calcVuelto(){
  const{total}=getBaseTotal(),conRecargo=total*(1+recargoVal/100);
  const recibido=parseFloat(document.getElementById('cashReceived').value)||0;
  const display=document.getElementById('vueltoDisplay'),
        isEfectivo=payMethod.toLowerCase()==='efectivo';
  if(!isEfectivo||recibido<=0){display.style.display='none';return;}
  display.style.display='flex';
  const vuelto=recibido-conRecargo,amt=document.getElementById('vueltoAmt');
  if(vuelto>=0){
    amt.textContent=fmt(vuelto);
    display.style.background='rgba(16,185,129,.08)';
    amt.style.color='#059669';
    display.querySelector('span').style.color='#059669';
  }else{
    amt.textContent=`Faltan ${fmt(Math.abs(vuelto))}`;
    display.style.background='rgba(239,68,68,.08)';
    amt.style.color='#ef4444';
    display.querySelector('span').style.color='#ef4444';
  }
}

async function loadPaymentMethods(){
  const fb=[
    {nombre:'Efectivo',icono:'bi-cash-stack',tipo:'efectivo',recargo_cliente_pct:0},
    {nombre:'Débito',icono:'bi-credit-card',tipo:'otro',recargo_cliente_pct:0},
    {nombre:'Crédito',icono:'bi-credit-card-2-front',tipo:'otro',recargo_cliente_pct:0},
    {nombre:'Transferencia',icono:'bi-phone',tipo:'otro',recargo_cliente_pct:0}
  ];
  payMethods=fb;
  try{
    const r=await fetch('/api/payment-methods');
    if(r.ok){
      const d=await r.json();
      if(Array.isArray(d)&&d.length)payMethods=d.map(m=>({
        nombre:m.nombre||m.name||'Pago',
        icono:m.icono||m.icon||'bi-wallet2',
        tipo:m.tipo||'otro',
        recargo_cliente_pct:m.recargo_cliente_pct||0
      }));
    }
  }catch(e){}

  const grid=document.getElementById('pmGrid');
  grid.innerHTML=payMethods.map((m,i)=>`<button type="button" class="pm-btn ${i===0?'on':''}" tabindex="-1" data-pm-idx="${i}" data-method="${m.nombre}" data-tipo="${m.tipo}" data-recargo="${m.recargo_cliente_pct}" onclick="selectPayMethod(this)"><i class="bi ${m.icono}"></i><span>${m.nombre}</span>${m.recargo_cliente_pct>0?`<small>+${m.recargo_cliente_pct}%</small>`:''}</button>`).join('');
  payMethod=payMethods[0].nombre;
  recargoVal=payMethods[0].recargo_cliente_pct||0;
  const isEfectivo=payMethods[0].tipo==='efectivo'||payMethods[0].nombre.toLowerCase()==='efectivo';
  document.getElementById('efectivoRow').classList.toggle('visible',isEfectivo);
  if(recargoVal>0)updateCobroTotals();
  pmFocusIdx = 0;
}

function selectPayMethod(btn){
  document.querySelectorAll('#pmGrid .pm-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  payMethod=btn.dataset.method;
  payTipo=btn.dataset.tipo||'';
  pmFocusIdx = Number(btn.dataset.pmIdx || 0);

  const tipo=payTipo,
        rc=parseFloat(btn.dataset.recargo)||0;
  const isEfectivo=tipo==='efectivo'||payMethod.toLowerCase()==='efectivo';
  const isCuentaCorriente=tipo==='cuenta_corriente'||tipo==='fiado';
  const isCard=!isEfectivo&&!isCuentaCorriente;

  if(isCuentaCorriente && (!clienteId || clienteId===1)){
    showToast('Seleccioná un cliente para usar Cuenta Corriente','warn');
    const inp=document.getElementById('cartClienteInp');
    if(inp){ inp.focus(); inp.style.borderColor='#f59e0b'; setTimeout(()=>inp.style.borderColor='',2500); }
  }

  const banner=document.getElementById('recargoInfoBanner');

  if(rc>0){
    recargoVal=rc;
    document.getElementById('recargoRow').classList.remove('visible');
    const{total}=getBaseTotal();
    banner.innerHTML=`<i class="bi bi-info-circle" style="color:#d97706;flex-shrink:0"></i> Recargo <strong>${rc}%</strong> → <strong>${fmt(total*(1+rc/100))}</strong>`;
    banner.classList.add('visible');
  }else{
    recargoVal=0;
    document.getElementById('recargoRow').classList.toggle('visible',isCard);
    banner.classList.remove('visible');
    document.querySelectorAll('.recargo-chip').forEach(c=>c.classList.remove('on'));
    document.getElementById('recargoCustom').value='';
    document.getElementById('recargoResult').style.display='none';
  }

  document.getElementById('efectivoRow').classList.toggle('visible',isEfectivo);
  updateCobroTotals();
  calcVuelto();
  focusPmButton(pmFocusIdx);

  if(mixtoActivo){
    document.getElementById('mixtoMetodo1Nombre').textContent = payMethod;
    const sel=document.getElementById('mixtoMetodo2');
    sel.innerHTML=payMethods
      .filter(m=>m.nombre!==payMethod)
      .map(m=>`<option value="${m.nombre}">${m.nombre}</option>`).join('');
    calcMixto();
  }
}

