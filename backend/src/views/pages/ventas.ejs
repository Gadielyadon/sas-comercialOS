<!-- MODAL FACTURA ELECTRÓNICA AFIP                            -->
<!-- ══════════════════════════════════════════════════════════ -->
<style>
  .afip-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:3000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
  .afip-overlay.open{opacity:1;pointer-events:all;}
  .afip-modal{background:var(--bg-card);border-radius:var(--radius-xl);padding:28px;width:420px;max-width:95vw;box-shadow:var(--shadow-xl);animation:modalIn .2s ease;}
  .afip-modal h3{font-size:17px;font-weight:700;color:var(--text-primary);margin:0 0 4px;}
  .afip-modal .afip-sub{font-size:12px;color:var(--text-secondary);margin-bottom:20px;}
  .afip-tipo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
  .afip-tipo-btn{padding:14px 8px;border-radius:12px;border:2px solid var(--border-color);background:var(--bg-surface-2);cursor:pointer;text-align:center;transition:all .15s;font-family:var(--font-body);}
  .afip-tipo-btn:hover{border-color:var(--color-primary);background:rgba(27,79,216,.05);}
  .afip-tipo-btn.sel{border-color:var(--color-primary);background:rgba(27,79,216,.08);}
  .afip-tipo-letra{font-size:28px;font-weight:800;color:var(--color-primary);line-height:1;}
  .afip-tipo-desc{font-size:10px;color:var(--text-secondary);margin-top:4px;line-height:1.3;}
  .afip-field{margin-bottom:14px;}
  .afip-field label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:5px;}
  .afip-field input{width:100%;padding:10px 12px;border-radius:8px;border:1.5px solid var(--border-color);background:var(--bg-surface-2);color:var(--text-primary);font-family:var(--font-body);font-size:13.5px;outline:none;box-sizing:border-box;transition:border-color .15s;}
  .afip-field input:focus{border-color:var(--color-primary);box-shadow:0 0 0 3px rgba(27,79,216,.12);}
  .afip-actions{display:flex;gap:10px;margin-top:20px;}
  .btn-afip-emit{flex:1;padding:12px;border-radius:10px;border:none;background:var(--color-primary);color:#fff;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s;}
  .btn-afip-emit:hover{background:#1540b8;}
  .btn-afip-emit:disabled{opacity:.5;cursor:not-allowed;}
  .btn-afip-cancel{padding:12px 18px;border-radius:10px;border:1.5px solid var(--border-color);background:transparent;color:var(--text-secondary);font-family:var(--font-body);font-size:14px;font-weight:600;cursor:pointer;transition:all .15s;}
  .btn-afip-cancel:hover{border-color:var(--text-secondary);color:var(--text-primary);}
  .afip-result{display:none;text-align:center;padding:10px 0;}
  .afip-result.show{display:block;}
  .afip-cae-box{background:var(--bg-surface-2);border:1.5px solid var(--border-color);border-radius:12px;padding:14px;margin-top:12px;font-family:var(--font-mono);font-size:13px;word-break:break-all;}
  .afip-cae-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px;}
  .afip-cae-val{font-size:15px;font-weight:800;color:var(--color-primary);}
  .afip-spinner{display:none;align-items:center;justify-content:center;gap:8px;font-size:13px;color:var(--text-secondary);margin:8px 0;}
  .afip-spinner.show{display:flex;}
  .afip-spin-icon{width:18px;height:18px;border:2px solid var(--color-primary);border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;}

  /* ── Toggle facturación dentro del cobro ── */
  .afip-tgl-switch{position:relative;width:40px;height:22px;flex-shrink:0;}
  .afip-tgl-slider{position:absolute;inset:0;border-radius:11px;background:var(--border-strong);cursor:pointer;transition:background .2s;}
  .afip-tgl-slider::before{content:'';position:absolute;width:16px;height:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);}
  #facturaTgl:checked + .afip-tgl-slider{background:var(--color-primary);}
  #facturaTgl:checked + .afip-tgl-slider::before{transform:translateX(18px);}

  /* Botones tipo mini dentro del cobro */
  .afip-tipo-mini{padding:10px 6px;border-radius:10px;border:1.5px solid var(--border-color);background:var(--bg-surface-2);cursor:pointer;text-align:center;transition:all .15s;font-family:var(--font-body);color:var(--text-primary);width:100%;}
  .afip-tipo-mini:hover{border-color:var(--color-primary);background:rgba(27,79,216,.05);}
  .afip-tipo-mini.on{border-color:var(--color-primary);background:rgba(27,79,216,.10);color:var(--color-primary);}

  /* Badge factura en modal de éxito */
