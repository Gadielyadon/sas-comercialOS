      <button class="numpad-key" onclick="numpadKey(4)">4</button>
      <button class="numpad-key" onclick="numpadKey(5)">5</button>
      <button class="numpad-key" onclick="numpadKey(6)">6</button>
      <button class="numpad-key" onclick="numpadKey(1)">1</button>
      <button class="numpad-key" onclick="numpadKey(2)">2</button>
      <button class="numpad-key" onclick="numpadKey(3)">3</button>
      <button class="numpad-key key-del" onclick="numpadDel()">⌫ DEL</button>
      <button class="numpad-key" onclick="numpadKey(0)">0</button>
      <button class="numpad-key key-ok" onclick="numpadOk()">✓ OK</button>
    </div>
  </div>
</div>

<script>
let _numpadSku = null;
let _numpadVal = '';

function abrirTecladoCantidad(sku, qtyActual) {
  _numpadSku = sku;
  _numpadVal = String(qtyActual);
  const item = cart.find(i => i.sku === sku);
  const nombre = document.getElementById('numpadProductName');
  if (nombre && item) nombre.textContent = item.name;
  const display = document.getElementById('numpadDisplay');
  if (display) display.textContent = _numpadVal;
  document.getElementById('numpadOverlay').classList.add('open');
}

function cerrarNumpad() {
  document.getElementById('numpadOverlay').classList.remove('open');
  _numpadSku = null;
  _numpadVal = '';
}

function numpadKey(digit) {
  if (_numpadVal === '0' || _numpadVal === '') {
    _numpadVal = String(digit);
  } else {
    if (_numpadVal.length >= 4) return;
    _numpadVal += String(digit);
  }
  document.getElementById('numpadDisplay').textContent = _numpadVal;
}

function numpadDel() {
  if (_numpadVal.length <= 1) {
    _numpadVal = '0';
  } else {
    _numpadVal = _numpadVal.slice(0, -1);
  }
  document.getElementById('numpadDisplay').textContent = _numpadVal;
}

function numpadOk() {
  if (!_numpadSku) { cerrarNumpad(); return; }
  const nueva = parseInt(_numpadVal) || 0;
  if (nueva <= 0) {
    removeItem(_numpadSku);
    cerrarNumpad();
    return;
  }
  const item = cart.find(i => i.sku === _numpadSku);
  if (item) {
    item.qty = nueva;
    aplicarPrecioMayorista(item);
    updateCardState(_numpadSku);
    renderCartList();
    updateTotals();
  }
  cerrarNumpad();
}

// Cerrar con Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && document.getElementById('numpadOverlay')?.classList.contains('open')) {
    cerrarNumpad();
  }
  // Teclado físico también funciona en el numpad
  if (document.getElementById('numpadOverlay')?.classList.contains('open')) {
    if (/^[0-9]$/.test(e.key)) { e.preventDefault(); numpadKey(parseInt(e.key)); }
    if (e.key === 'Backspace')  { e.preventDefault(); numpadDel(); }
    if (e.key === 'Enter')      { e.preventDefault(); numpadOk(); }
  }
}, true);
</script>

