    precioExtra = `<br><span style="font-size:9px;text-decoration:line-through;color:#999;">${fmt(it.price_base)}</span> → ${fmt(it.price)} c/u`;
  } else {
    precioExtra = `<br><span style="font-size:9px;color:#666;">${fmt(it.price)} c/u</span>`;
  }

  return `
    <tr>
      <td style="padding:4px 0;">${escapeHtml(it.name)}${badge}${precioExtra}</td>
      <td style="padding:4px 0;text-align:center;">${it.qty}</td>
      <td style="padding:4px 0;text-align:right;font-weight:700;">${fmt(it.subtotal)}</td>
    </tr>
