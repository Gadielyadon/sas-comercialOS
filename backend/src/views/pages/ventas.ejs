<%- include('../partials/scripts') %>

<script>
'use strict';
let cart=[],clienteId=1,discType='pct',payMethod='efectivo',recargoVal=0,payTipo='';
let toastTimer=null,searchDeb=null,lastKeyTime=0,keyCount=0,isScanMode=false;
let posClienteDebounce=null,allProducts=[],catActiva='';
let mixtoActivo=false, payMethods=[], lastSaleData=null, ticketConfig=null;
let pmFocusIdx = 0;

// ══════════════════════════════════════════════════════════
// ⚖️  SOPORTE BALANZA EAN-13
// Lee la configuración inyectada por EJS desde /api/config
// ══════════════════════════════════════════════════════════
const BALANZA_CFG = {
  habilitada : <%- String(config && config.balanza_habilitada  ? config.balanza_habilitada  : '0') %> === 1
               || String(<%- JSON.stringify(config && config.balanza_habilitada  ? config.balanza_habilitada  : '0') %>) === '1',
  prefijo    : parseInt('<%- (config && config.balanza_prefijo)  ? config.balanza_prefijo  : 2 %>', 10) || 2,
  modo       : '<%- (config && config.balanza_modo) ? config.balanza_modo : "precio" %>',
};

/**
 * tryDecodeBalanza(code)
 * Intenta interpretar un código EAN-13 como ticket de balanza.
 * Retorna { sku, precio, peso } o null si no aplica.
 *
 * Estructura EAN-13 balanza (modo precio):
 *   [ prefijo 1d ][ PLU 5d ][ precio 5d ][ control 1d ]
 *   Ej: 2 01029 01599 4  →  PLU=1029, precio=$15.99
 *
 * Estructura EAN-13 balanza (modo peso):
 *   [ prefijo 1d ][ PLU 5d ][ peso gramos 5d ][ control 1d ]
 *   Ej: 2 01029 01500 4  →  PLU=1029, peso=1.500 kg
 */
function tryDecodeBalanza(code) {
  if (!BALANZA_CFG.habilitada) return null;
  if (!code || code.length !== 13) return null;
  if (!/^\d{13}$/.test(code)) return null;

  const primerDigito = parseInt(code.charAt(0), 10);
  if (primerDigito !== BALANZA_CFG.prefijo) return null;

 const plu   = parseInt(code.slice(1, 6), 10);  // PLU=4 ✅
const valor = parseInt(code.slice(6, 12), 10); // 001617 ✅


// dígito 13 (índice 12) = dígito de control, no lo usamos
  // dígito 12 (índice 12) = dígito de control, no lo usamos

  if (isNaN(plu) || isNaN(valor)) return null;

  return {
    sku   : String(plu),                                           // PLU como string
    precio: BALANZA_CFG.modo === 'precio' ? valor : null,
    peso  : BALANZA_CFG.modo === 'peso'   ? valor / 1000 : null,
  };
}
// ══════════════════════════════════════════════════════════

const fmt=n=>'$'+Number(n).toFixed(2).replace('.',',').replace(/\B(?=(\d{3})+(?!\d))/g,'.');

function beep(type){try{const ctx=new(window.AudioContext||window.webkitAudioContext)();const osc=ctx.createOscillator(),gain=ctx.createGain();osc.connect(gain);gain.connect(ctx.destination);if(type==='add'){osc.frequency.setValueAtTime(880,ctx.currentTime);osc.frequency.setValueAtTime(1100,ctx.currentTime+.06);gain.gain.setValueAtTime(.08,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.18);osc.start();osc.stop(ctx.currentTime+.18);}else if(type==='confirm'){[660,880,1100].forEach((f,i)=>osc.frequency.setValueAtTime(f,ctx.currentTime+i*.08));gain.gain.setValueAtTime(.08,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.35);osc.start();osc.stop(ctx.currentTime+.35);}else{osc.type='sawtooth';osc.frequency.setValueAtTime(200,ctx.currentTime);gain.gain.setValueAtTime(.06,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.25);osc.start();osc.stop(ctx.currentTime+.25);}}catch(e){}}

const apiBySku=async sku=>{try{const r=await fetch(`/api/products/${encodeURIComponent(sku)}`);return r.ok?r.json():null;}catch(e){return null;}};

async function loadCatalog(){try{const r=await fetch('/api/products?limit=1000');allProducts=r.ok?await r.json():[];}catch(e){allProducts=[];}buildCatBar();renderGrid(allProducts);}

async function loadTicketConfig(){
  ticketConfig = {
    formato: '80mm',
    footer: '¡Gracias por su compra!',
    nombre: 'Mi Comercio',
    direccion: '',
    telefono: '',
    logo: ''
  };

  try{
    const r = await fetch('/api/config');
    if(!r.ok) return;
    const cfg = await r.json();

    ticketConfig = {
      formato: cfg.ticket_formato || cfg.aj_formato || '80mm',
      footer: cfg.ticket_footer || cfg.aj_footer || '¡Gracias por su compra!',
      nombre: cfg.empresa_nombre || 'Mi Comercio',
      direccion: cfg.empresa_direccion || '',
      telefono: cfg.empresa_telefono || '',
      logo: cfg.empresa_logo || cfg.logo || ''
    };
  }catch(e){}
}

// cat-bar eliminada
function buildCatBar(){ /* eliminado */ }

function filterCat(cat,btn){
  catActiva=cat;
  document.getElementById('barcodeInput').value='';
  renderGrid(cat?allProducts.filter(p=>p.category===cat):allProducts);
}
function renderGrid(products){
  const grid=document.getElementById('productsGrid');
  if(!products.length){
    grid.innerHTML='<div class="products-empty"><i class="bi bi-box-seam"></i><p>Sin productos</p></div>';
    return;
  }
  grid.innerHTML=products.map(p=>{
    const ep=p.en_promo&&p.price_promo?Number(p.price_promo):Number(p.price);
    const stock=Number(p.stock??0),sinStock=stock<=0;
    const inCart=cart.find(i=>i.sku===p.sku);
    const stockCls=stock<=0?'zero':stock<=5?'low':'ok';
    const stockTxt=stock<=0?'Sin stock':stock<=5?`Stock: ${stock} (bajo)`:`Stock: ${stock}`;
    const descHTML=p.descripcion?`<div class="prod-desc">${p.descripcion}</div>`:'';
    const promoOld=p.en_promo&&p.price_promo?`<div class="prod-price-old">${fmt(p.price)}</div>`:'';
    const skuSafe=p.sku.replace(/'/g,"\\'");
    const nameSafe=p.name.replace(/"/g,'&quot;');
    const imgSafe=p.imagen?p.imagen.replace(/"/g,'&quot;'):'';
    const thumbHTML=p.imagen
      ? `<div class="prod-thumb" data-zoom-sku="${nameSafe}" data-zoom-img="${imgSafe}"><img src="${imgSafe}" alt="" loading="lazy"></div>`
      : ``;
    return `<div class="prod-card ${sinStock?'out-stock':''} ${inCart?'in-cart':''}" id="pcard-${CSS.escape(p.sku)}" data-name="${nameSafe}" data-img="${imgSafe}" onclick="${sinStock?'':` addBySku('${skuSafe}',this)`}">
      <span class="prod-badge-qty" id="badge-${CSS.escape(p.sku)}">${inCart?inCart.qty:''}</span>
      ${p.en_promo&&p.price_promo?'<span class="prod-badge-promo">Promo</span>':''}
      <div class="prod-info">
        ${sinStock?'<div class="prod-sin-stock">Sin stock</div>':''}
        <div class="prod-name">${p.name}</div>
        ${descHTML}
        <div style="margin-top:auto;padding-top:5px;">${promoOld}<div class="prod-price">${fmt(ep)}</div><div class="prod-stock ${stockCls}">${stockTxt}</div></div>
      </div>
      ${thumbHTML}
    </div>`;
  }).join('');
}

function updateCardState(sku){
  const card=document.getElementById('pcard-'+CSS.escape(sku));
  const badge=document.getElementById('badge-'+CSS.escape(sku));
  if(!card)return;
  const item=cart.find(i=>i.sku===sku);
  card.classList.toggle('in-cart',!!item);
  if(badge){
    badge.style.display=item?'flex':'';
    badge.textContent=item?item.qty:'';
  }
}

function addBySku(sku,el){
  if(el){el.style.transform='scale(.95)';setTimeout(()=>el.style.transform='',130);}
  const p=allProducts.find(x=>x.sku===sku);
  if(p)addToCart(p);
}

function addToCart(product){
 const ep = product.precio_efectivo !== undefined ? Number(product.precio_efectivo) : Number(product.price);
  const existing=cart.find(i=>i.sku===product.sku);
  if(existing){
    existing.qty++;
    showToast(`${existing.name} — x${existing.qty}`,'info');
  } else {
    cart.push({sku:product.sku,name:product.name,price:ep,descripcion:product.descripcion||null,isPromo:!!(product.en_promo&&product.price_promo),qty:1});
    showToast(`${product.name}${product.en_promo?' 🏷️':''} agregado`,'success');
  }
  beep('add');
  updateCardState(product.sku);
  renderCartList();
  updateTotals();
}

function renderCartList(){
  const emptyState = document.getElementById('cartEmptyState');
  const grid       = document.getElementById('cartItemsGrid');
  if (!emptyState || !grid) return;

  if (!cart.length) {
    emptyState.style.display = 'flex';
    grid.innerHTML = '';
    document.getElementById('cartSub').textContent = 'Sin productos';
    return;
  }
  emptyState.style.display = 'none';

  grid.querySelectorAll('.cart-card').forEach(el => {
    if (!cart.find(i => 'ci-' + CSS.escape(i.sku) === el.id)) el.remove();
  });

  cart.forEach(item => {
    const id = 'ci-' + CSS.escape(item.sku);
    let el = document.getElementById(id);
    if (!el) {
      el = document.createElement('div');
      el.id = id; el.className = 'cart-card';
      grid.appendChild(el);
    }
    el.innerHTML = `
      ${item.isPromo ? '<span class="cart-promo-tag">Promo</span>' : ''}
      <div class="cart-card-name">${item.name}</div>
      ${item.descripcion ? `<div class="cart-card-desc">${item.descripcion}</div>` : ''}
      <div class="cart-card-price">${fmt(item.price * item.qty)}</div>
      <div class="cart-card-sub">${item.qty} × ${fmt(item.price)}</div>
      <div class="cart-card-bottom">
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="chgQty('${item.sku}',-1)"><i class="bi bi-dash"></i></button>
          <span class="qty-val">${item.qty}</span>
          <button class="qty-btn" onclick="chgQty('${item.sku}',1)"><i class="bi bi-plus"></i></button>
        </div>
        <button class="btn-del" onclick="removeItem('${item.sku}')"><i class="bi bi-trash3"></i></button>
      </div>`;
  });

  const total = cart.reduce((s,i) => s+i.qty, 0);
  document.getElementById('cartSub').textContent = `${cart.length} prod. · ${total} ud.`;
  document.getElementById('cartCount').textContent = total;
}

function chgQty(sku,d){
  const item=cart.find(i=>i.sku===sku);
  if(!item)return;
  item.qty+=d;
  if(item.qty<=0){removeItem(sku);return;}
  updateCardState(sku);
  renderCartList();
  updateTotals();
}

function removeItem(sku){
  cart=cart.filter(i=>i.sku!==sku);
  const el=document.getElementById('ci-'+CSS.escape(sku));
  if(el){
    el.style.cssText='transition:opacity .15s,transform .15s;opacity:0;transform:translateX(10px)';
    setTimeout(()=>{el.remove();renderCartList();},150);
  }
  updateCardState(sku);
  updateTotals();
}

function clearCart(){
  const skus=cart.map(i=>i.sku);
  cart=[];
  skus.forEach(updateCardState);
  renderCartList();
  document.getElementById('discInput').value='';
  limpiarClientePos();
  updateTotals();
  focusScanner();
}

function setDiscType(t){
  discType=t;
  document.getElementById('btnPct').classList.toggle('on',t==='pct');
  document.getElementById('btnFixed').classList.toggle('on',t==='fixed');
  document.getElementById('discSuffix').textContent=t==='pct'?'%':'$';
  document.getElementById('discInput').value='';
  updateTotals();
}
function getDiscount(sub){
  const v=parseFloat(document.getElementById('discInput').value)||0;
  if(v<=0)return 0;
  return discType==='pct'?sub*(Math.min(v,100)/100):Math.min(v,sub);
}
function getBaseTotal(){
  const sub=cart.reduce((s,i)=>s+i.price*i.qty,0),disc=getDiscount(sub);
  return{sub,disc,total:Math.max(0,sub-disc)};
}
function updateTotals(){
  const{sub,disc,total}=getBaseTotal();
  document.getElementById('subtotalVal').textContent=fmt(sub);
  document.getElementById('totalVal').textContent=fmt(total);
  const dr=document.getElementById('discRow');
  dr.style.display=disc>0?'flex':'none';
  document.getElementById('discVal').textContent='-'+fmt(disc);
  document.getElementById('cartCount').textContent=cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('btnConfirm').disabled=cart.length===0;
  updateCobroTotals();
}

/* Navegación teclado métodos de pago */
function getPmButtons(){ return [...document.querySelectorAll('#pmGrid .pm-btn')]; }
function clearPmFocus(){ getPmButtons().forEach(b => b.classList.remove('kbd-focus')); }
function focusPmButton(index){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  if(index < 0) index = 0;
  if(index >= buttons.length) index = buttons.length - 1;
  pmFocusIdx = index;
  clearPmFocus();
  const btn = buttons[pmFocusIdx];
  btn.classList.add('kbd-focus');
  btn.focus({ preventScroll:true });
  btn.scrollIntoView({ block:'nearest', inline:'nearest' });
}
function syncPmFocusWithSelected(){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  const idx = buttons.findIndex(b => b.classList.contains('on'));
  focusPmButton(idx >= 0 ? idx : 0);
}
function movePmFocus(delta){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  let next = pmFocusIdx + delta;
  if(next < 0) next = buttons.length - 1;
  if(next >= buttons.length) next = 0;
  focusPmButton(next);
}
function movePmFocusVertical(deltaRows){
  const buttons = getPmButtons();
  if(!buttons.length) return;
  const cols = 2;
  let next = pmFocusIdx + (deltaRows * cols);
  if(next < 0) next = pmFocusIdx;
  if(next >= buttons.length) next = pmFocusIdx;
  focusPmButton(next);
}

