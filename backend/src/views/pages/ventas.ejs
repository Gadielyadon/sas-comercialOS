  .cart-promo-tag{ position:absolute;top:2px;right:28px;font-size:7px;font-weight:800;background:#f59e0b;color:#fff;padding:1px 4px;border-radius:4px;text-transform:uppercase; }

  /* Footer */
  .cart-footer{ flex-shrink:0;border-top:1px solid var(--border-color);background:transparent;padding:8px 10px;display:flex;flex-direction:column;gap:5px; }

  /* Descuento */
  .cart-disc-row{ display:flex;align-items:center;justify-content:space-between;gap:8px; }
  .cart-disc-lbl{ font-size:10.5px;font-weight:700;color:var(--text-secondary);display:flex;align-items:center;gap:4px;white-space:nowrap; }
  .disc-bar{ display:flex;gap:4px;align-items:center; }
  .disc-type-btn{ padding:2px 7px;border-radius:5px;border:1.5px solid var(--border-color);background:var(--bg-body);font-size:11px;font-weight:700;color:var(--text-secondary);cursor:pointer;transition:all .1s; }
  .disc-type-btn.on{ border-color:var(--color-primary);background:rgba(27,79,216,.08);color:var(--color-primary); }
  .disc-input{ width:50px;border:1.5px solid var(--border-color);background:var(--bg-body);border-radius:5px;padding:2px 5px;font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--text-primary);outline:none;text-align:right; }
  .disc-input:focus{ border-color:var(--color-primary); }
  .disc-suffix{ font-size:11px;font-weight:700;color:var(--text-secondary);flex-shrink:0; }

  /* Resumen numérico */
  .cart-resumen{ background:var(--bg-body);border:1px solid var(--border-color);border-radius:9px;overflow:hidden; }
  .res-row{ display:flex;justify-content:space-between;align-items:center;padding:5px 11px;font-size:12px;border-bottom:1px solid var(--border-color); }
  .res-row span:first-child{ color:var(--text-secondary);font-weight:500; }
  .res-row span:last-child{ font-family:var(--font-mono);font-weight:700;color:var(--text-primary); }
  .res-total{ display:flex;justify-content:space-between;align-items:center;padding:9px 11px;background:var(--color-primary); }
  .res-total span:first-child{ font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.6px;color:rgba(255,255,255,.85); }
  .res-total span:last-child{ font-family:var(--font-mono);font-size:20px;font-weight:900;color:#fff;letter-spacing:-1px; }

  /* Botón */
  .btn-confirm{ width:100%;padding:11px;border-radius:9px;border:none;background:var(--color-primary);color:#fff;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 3px 12px rgba(27,79,216,.3); }
  .btn-confirm:hover:not(:disabled){ transform:translateY(-1px);box-shadow:0 5px 18px rgba(27,79,216,.45); }
  .btn-confirm:disabled{ opacity:.35;cursor:not-allowed;box-shadow:none;transform:none; }
  .kbd-hint{ font-size:10px;opacity:.75;background:rgba(255,255,255,.2);border-radius:4px;padding:1px 5px;font-family:var(--font-mono); }

  }

  /* Bloque total */
  .totals-block{
    border-radius:18px;
    overflow:hidden;
    box-shadow:0 14px 30px rgba(22,163,74,.22);
    background:linear-gradient(135deg,#169c45 0%, #22c55e 100%);
  }
  .tot-row{
    padding:11px 16px;
    background:rgba(0,0,0,.10);
    font-size:14px;
  }
  .tot-row span:first-child{
    color:rgba(255,255,255,.86);
    font-weight:700;
  }
  .tot-row span:last-child{
    color:#fff;
    font-size:15px;
    font-weight:800;
  }
  .total-highlight{
    padding:16px;
    align-items:flex-end;
  }
  .total-highlight-label{
    font-size:14px;
    font-weight:900;
    letter-spacing:1px;
  }
  .total-highlight-value{
    font-size:42px;
    font-weight:900;
    letter-spacing:-2px;
  }

  .btn-confirm{
    min-height:54px;
    border-radius:16px;
    background:var(--color-primary);
    box-shadow:0 10px 24px rgba(27,79,216,.25);
    font-size:16px;
    font-weight:800;
  }
  .btn-confirm:hover:not(:disabled){
    box-shadow:0 14px 30px rgba(27,79,216,.35);
  }
  .btn-confirm:disabled{
    background:linear-gradient(135deg,#fecaca,#fca5a5);
    opacity:.9;
  }
  /* Cobro modal */
  .cobro-modal{
    border-radius:24px;
    background:var(--bg-card);
  }
  .cobro-header{
    background:var(--bg-card);
    border-bottom:1px solid var(--border-color);
  }
  .cobro-title{
    font-size:19px;
    font-weight:900;
    color:var(--text-primary);
  }
  .cobro-left{
    background:var(--bg-body);
  }
  .cobro-right{
    background:var(--bg-card);
  }
  .cobro-total-box{
    background:#1fa24f;
    border:none;
    box-shadow:0 4px 16px rgba(0,0,0,.25);
  }
  .cobro-total-lbl{
    color:rgba(255,255,255,.65);
  }
  .cobro-total-amt{
    color:#ffffff;
  }
  .cobro-section{
    background:var(--bg-card);
    border:1px solid var(--border-color);
    box-shadow:none;
  }
  .pm-btn{
    min-height:110px;
    border-radius:16px;
    background:var(--bg-card);
    border:1.5px solid var(--border-color);
    box-shadow:none;
  }
  .pm-btn i { color:var(--text-secondary); }
  .pm-btn span { color:var(--text-secondary); }
  .pm-btn:hover{
    background:var(--bg-hover);
    border-color:var(--color-primary);
  }
  .pm-btn.on{
    background:rgba(27,79,216,.1);
    border-color:var(--color-primary);
    box-shadow:0 0 0 3px rgba(27,79,216,.12);
  }
  .pm-btn.on i,.pm-btn.on span{ color:var(--color-primary); }
  .btn-cobrar{
    border-radius:16px;
    box-shadow:0 8px 20px rgba(16,185,129,.2);
  }

  /* Modal éxito */
  .exito-modal{
    width:340px;
    border-radius:24px;
    box-shadow:0 24px 64px rgba(15,23,42,.18);
  }
  .exito-total{
    font-size:34px;
    font-weight:900;
    color:var(--color-primary);
  }

  /* Modal AFIP */
  .afip-modal{
    border-radius:22px;
    box-shadow:0 24px 64px rgba(15,23,42,.18);
  }
  .afip-tipo-btn{
    border-radius:14px;
  }

  /* Zoom */
  .prod-zoom-overlay{
    backdrop-filter:blur(4px);
  }

  /* Responsivo */
  @media (max-width: 1100px){
    .pos-wrapper{
      gap:12px;
      padding:12px;
    }
    .pos-left{ width:60%; }
    .pos-right{ width:40%; }
    /* En tablet ocultar columna de descripción */
    .prod-desc { display:none; }
  }
  @media (max-width: 860px){
    body{ overflow:auto; }
    .main-content{
      height:auto;
      min-height:100vh;
      overflow:visible;
    }
    .pos-wrapper{
      padding:8px;
      gap:8px;
      /* En mobile: apilar paneles y ocultar uno */
      flex-direction: column;
    }
    .pos-left,
    .pos-right{
      width:100%;
      border-radius:18px;
    }
    /* Mobile: un panel a la vez */
    .pos-left  { display: flex; }
    .pos-right { display: none; }
    .pos-left.panel-hidden  { display: none; }
    .pos-right.panel-visible { display: flex; }

    .pos-topbar{
      flex-wrap:wrap;
      gap:8px;
    }
    .sc-chips{
      width:100%;
      flex-wrap:wrap;
    }
    .sc-chip{
      flex:1;
      justify-content:center;
      min-width:90px;
      font-size:12px;
    }
    /* Ocultar columnas no críticas */
    .prod-desc { display:none; }
    .prod-price-old { display:none; }
    .prod-th.th-stock { display:none; }
    .prod-td:nth-child(3) { display:none; }

    /* FAB — botón flotante para alternar carrito/catálogo */
    .fab-cart {
      display: flex !important;
    }
  }
  @media (max-width: 520px){
    .prod-td-img { display:none; }
    .prod-th.th-img { display:none; }
    .total-highlight-value{ font-size:30px; }
    .sc-chip kbd { display:none; }
    .pos-wrapper { padding:6px; gap:6px; }
  }

  /* FAB flotante — siempre oculto en desktop */
  .fab-cart {
    display: none;
    position: fixed;
    bottom: 20px;
    right: 16px;
    z-index: 300;
    align-items: center;
    gap: 0;
    flex-direction: column;
  }
  .fab-btn {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    border: none;
    background: var(--color-primary);
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 18px rgba(27,79,216,.5);
    transition: transform .15s, box-shadow .15s;
    position: relative;
  }
  .fab-btn:active { transform: scale(.93); }
  .fab-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #fff;
  }
  .fab-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-secondary);
    margin-top: 4px;
    text-align: center;
    letter-spacing: .3px;
  }

  /* Oscuro refinado */
  [data-theme="dark"] .pos-wrapper,
  [data-theme="dark"] .main-content{
    background:#0f1319;
  }
  [data-theme="dark"] .pos-left{
    background:#171b22;
  }
  [data-theme="dark"] .pos-right{
    background:#12171d;
  }
  [data-theme="dark"] .pos-topbar,
  [data-theme="dark"] .cart-header,
  [data-theme="dark"] .cobro-header{
    background:#171b22;
    border-color:rgba(255,255,255,.08);
  }
  [data-theme="dark"] .products-scroll{
    background:#11161c;
  }
  [data-theme="dark"] .prod-card{
    background:#171b22;
  }
  [data-theme="dark"] .prod-card:hover{
    background:#1e2640;
  }
  [data-theme="dark"] .prod-card.in-cart{
    background:#1e2a4a;
  }
  [data-theme="dark"] .prod-thumb-empty{
    background:#1b222c;
    border-color:rgba(255,255,255,.08);
  }
  [data-theme="dark"] .prod-table-head{
    background:#1e3a8a;
  }

  /* ── Dark mode carrito ── */
  [data-theme="dark"] .cart-list { background:transparent; }
  [data-theme="dark"] .cart-header,
  [data-theme="dark"] .cart-cliente-bloque,
  [data-theme="dark"] .cart-footer { background:transparent; border-color:rgba(255,255,255,.07) !important; }
  [data-theme="dark"] .pos-right { background:#12171d; }
  [data-theme="dark"] .pos-left { background:#171b22; }
  [data-theme="dark"] .cart-empty-state { background:#161b24; border-color:rgba(255,255,255,.08); }
  [data-theme="dark"] .cart-card { background:#161b24; border-color:rgba(255,255,255,.08); }
  [data-theme="dark"] .cart-card:hover { background:#1a2133; }
  [data-theme="dark"] .cart-card-name { color:#e2e8f0; }
  [data-theme="dark"] .cart-card-price { color:#60a5fa; }
  [data-theme="dark"] .qty-ctrl { background:#0f1319; border-color:rgba(255,255,255,.1); }
  [data-theme="dark"] .qty-val { color:#e2e8f0; border-color:rgba(255,255,255,.08); }
  [data-theme="dark"] .qty-btn { color:#94a3b8; }
  [data-theme="dark"] .qty-btn:hover { background:rgba(96,165,250,.12); color:#60a5fa; }
  [data-theme="dark"] .comp-btn { background:#161b24; border-color:rgba(255,255,255,.1); color:#94a3b8; }
  [data-theme="dark"] .cart-cliente-inp,
  [data-theme="dark"] .disc-input { background:#0f1319; border-color:rgba(255,255,255,.1); color:#e2e8f0; }
  [data-theme="dark"] .disc-type-btn { background:#161b24; border-color:rgba(255,255,255,.1); color:#94a3b8; }
  [data-theme="dark"] .disc-type-btn.on { background:rgba(96,165,250,.15); border-color:rgba(96,165,250,.4); color:#60a5fa; }
  [data-theme="dark"] .cart-resumen { background:#0f1319; border-color:rgba(255,255,255,.08); }
  [data-theme="dark"] .res-row { border-color:rgba(255,255,255,.06); }
  [data-theme="dark"] .res-row span:first-child { color:#94a3b8; }
  [data-theme="dark"] .res-row span:last-child { color:#e2e8f0; }

  /* ── Modal teclado numérico ── */
  .numpad-overlay { position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:500;display:none;align-items:flex-end;justify-content:center;padding:0 0 0 var(--sidebar-width); }
  .numpad-overlay.open { display:flex; }
  .numpad-modal { background:var(--bg-card);border-radius:20px 20px 0 0;width:100%;max-width:320px;overflow:hidden;box-shadow:0 -8px 32px rgba(0,0,0,.25);animation:numpadIn .2s ease; }
  @keyframes numpadIn { from{transform:translateY(100%)} to{transform:translateY(0)} }
  .numpad-header { padding:12px 16px 8px;border-bottom:1px solid var(--border-color); }
  .numpad-product { font-size:12px;color:var(--text-secondary);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:4px; }
  .numpad-display { font-size:36px;font-weight:900;color:var(--text-primary);font-family:var(--font-mono);text-align:right;letter-spacing:-1px;min-height:44px;line-height:44px; }
  .numpad-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border-color); }
  .numpad-key { padding:16px 8px;border:none;background:var(--bg-card);color:var(--text-primary);font-size:20px;font-weight:700;cursor:pointer;font-family:var(--font-mono);transition:background .1s;text-align:center; }
  .numpad-key:hover { background:var(--bg-hover); }
  .numpad-key:active { background:rgba(27,79,216,.12); }
  .numpad-key.key-del { font-size:14px;font-weight:800;color:var(--text-secondary); }
  .numpad-key.key-ok { background:var(--color-primary);color:#fff;font-size:16px; }
  .numpad-key.key-ok:hover { background:#1540b8; }
  @media (max-width:860px) { .numpad-overlay { padding:0; } }
</style>


