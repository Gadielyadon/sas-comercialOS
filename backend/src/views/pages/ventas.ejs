function focusScanner(){
  document.getElementById('barcodeInput').value='';
  document.getElementById('barcodeInput').focus();
}

function filtrarCards(q){
  if(!q){renderGrid(catActiva?allProducts.filter(p=>p.category===catActiva):allProducts);return;}
  const ql=q.toLowerCase();
  renderGrid(allProducts.filter(p=>
    p.name.toLowerCase().includes(ql)||
    p.sku.toLowerCase().includes(ql)||
    (p.descripcion&&p.descripcion.toLowerCase().includes(ql))||
    (p.barcode&&p.barcode.includes(q))
  ));
}

document.addEventListener('DOMContentLoaded',async()=>{
  await Promise.all([loadCatalog(),loadPaymentMethods(),loadTicketConfig()]);
  limpiarClientePos();
  const input=document.getElementById('barcodeInput'),dot=document.getElementById('scanDot');

  // ── Navegación por teclado en la grilla de productos ──
  let kbCardIdx = -1;

  function getVisibleCards() {
    return [...document.querySelectorAll('#productsGrid .prod-card:not([style*="display:none"]):not(.out-stock)')];
  }

  function kbSelectCard(idx) {
    const cards = getVisibleCards();
    cards.forEach(c => c.classList.remove('kb-selected'));
    if (idx < 0 || idx >= cards.length) { kbCardIdx = -1; return; }
    kbCardIdx = idx;
    cards[idx].classList.add('kb-selected');
    cards[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function kbClearCards() {
    getVisibleCards().forEach(c => c.classList.remove('kb-selected'));
    kbCardIdx = -1;
  }

  input.addEventListener('keydown',async e=>{
    const now=Date.now(),gap=now-lastKeyTime;lastKeyTime=now;
    if(gap<40){keyCount++;if(keyCount>=3){isScanMode=true;dot.classList.add('scanner-mode');}}
    else{isScanMode=false;keyCount=0;dot.classList.remove('scanner-mode');}

    if(e.key==='Escape'){
      if(kbCardIdx >= 0){ kbClearCards(); return; }
      input.value='';filtrarCards('');
      return;
    }

    // Navegación con flechas en la grilla
    const cols = Math.max(1, Math.floor(document.getElementById('productsGrid').offsetWidth / 160));
    const cards = getVisibleCards();

    if(e.key==='ArrowDown'){
      e.preventDefault();
      if(kbCardIdx < 0) kbSelectCard(0);
      else kbSelectCard(Math.min(kbCardIdx + cols, cards.length - 1));
      return;
    }
    if(e.key==='ArrowUp'){
      e.preventDefault();
      if(kbCardIdx < 0) kbSelectCard(0);
      else kbSelectCard(Math.max(kbCardIdx - cols, 0));
      return;
    }
    if(e.key==='ArrowRight'){
      e.preventDefault();
      if(kbCardIdx < 0) kbSelectCard(0);
      else kbSelectCard(Math.min(kbCardIdx + 1, cards.length - 1));
      return;
    }
    if(e.key==='ArrowLeft'){
      e.preventDefault();
      if(kbCardIdx < 0) kbSelectCard(0);
      else kbSelectCard(Math.max(kbCardIdx - 1, 0));
      return;
    }

    if(e.key==='Enter'){
      e.preventDefault();
      isScanMode=false;keyCount=0;dot.classList.remove('scanner-mode');

      // Si hay tarjeta seleccionada con teclado → agregarla
      if(kbCardIdx >= 0 && cards[kbCardIdx]){
        cards[kbCardIdx].click();
        kbClearCards();
        return;
      }

      const query=input.value.trim();
      if(!query){if(cart.length)openCobroModal();return;}

      // ══════════════════════════════════════════════════
      // ⚖️  DETECCIÓN BALANZA — va ANTES de cualquier
      //     búsqueda normal de SKU o barcode
      // ══════════════════════════════════════════════════
      const balanza = tryDecodeBalanza(query);
      if (balanza) {
        // Buscar el producto por PLU (= SKU en tu sistema)
        let prod = allProducts.find(p =>
          p.sku === balanza.sku ||
          String(p.sku) === String(parseInt(balanza.sku, 10))
        ) || await apiBySku(balanza.sku);

        if (prod) {
          // Clonar para no mutar el catálogo
          prod = { ...prod };

         if (BALANZA_CFG.modo === 'precio' && balanza.precio !== null) {
  prod.price           = balanza.precio;
  prod.precio_efectivo = balanza.precio;
  prod.en_promo        = 0;
  prod.price_promo     = null;
}else if (BALANZA_CFG.modo === 'peso' && balanza.peso !== null) {
  const precioBase = Number(prod.price) || 0;
  const precioCalculado = parseFloat((precioBase * balanza.peso).toFixed(2));
  prod.price          = precioCalculado;
  prod.precio_efectivo = precioCalculado;
  prod.en_promo       = 0;
  prod.price_promo    = null;
  prod.name           = `${prod.name} (${balanza.peso.toFixed(3)} kg)`;
}

          // SKU único por escaneo (evita que se incremente qty de otro escaneo)
          prod.sku = `BAL-${balanza.sku}-${Date.now()}`;

          addToCart(prod);
          input.value = '';
          filtrarCards('');
          kbClearCards();
        } else {
          beep('error');
          showToast(`⚖️ PLU ${balanza.sku} no encontrado`, 'error');
          input.select();
        }
        return; // ← siempre salir después de intentar balanza
      }
      // ══════════════════════════════════════════════════

      // Si hay exactamente una tarjeta visible → agregarla directo
      if(cards.length===1){
        cards[0].click();
        input.value='';filtrarCards('');kbClearCards();
        return;
      }

      const exacto=allProducts.find(p=>p.sku.toLowerCase()===query.toLowerCase()||(p.barcode&&p.barcode===query));
      if(exacto){addToCart(exacto);input.value='';filtrarCards('');kbClearCards();return;}
      const vis=allProducts.filter(p=>p.name.toLowerCase().includes(query.toLowerCase())||p.sku.toLowerCase().includes(query.toLowerCase()));
      if(vis.length===1){addToCart(vis[0]);input.value='';filtrarCards('');kbClearCards();return;}
      const prod=await apiBySku(query);
      if(prod){addToCart(prod);input.value='';filtrarCards('');kbClearCards();return;}
      beep('error');showToast(`"${query}" no encontrado`,'error');input.select();
    }

    // Al tipear → resetear selección de teclado
    if(e.key.length === 1) kbClearCards();
  });

  input.addEventListener('input',()=>{
    if(isScanMode)return;
    clearTimeout(searchDeb);
    searchDeb=setTimeout(()=>{if(!isScanMode)filtrarCards(input.value.trim());},100);
  });

  document.addEventListener('click',e=>{
    if(!['button','a','select','input','textarea'].some(t=>e.target.closest(t))) input.focus();
  });
});

document.addEventListener('keydown',e=>{
  const overlayOpen = document.getElementById('cobroOverlay').classList.contains('open');

  if(overlayOpen){
    const activeTag = e.target.tagName;
    const activeId = e.target.id || '';
    const activeEl = document.activeElement;
    const inEditable = ['INPUT','TEXTAREA','SELECT'].includes(activeTag);
    const inNumericInputs = ['cashReceived','mixtoMonto1','mixtoMonto2','recargoCustom'].includes(activeId);

    if(!inEditable || !inNumericInputs){
      if(e.key === 'ArrowRight'){
        e.preventDefault();
        movePmFocus(1);
        return;
      }
      if(e.key === 'ArrowLeft'){
        e.preventDefault();
        movePmFocus(-1);
        return;
      }
      if(e.key === 'ArrowDown'){
        if(activeEl && ['cashReceived','mixtoMonto1','mixtoMonto2','recargoCustom'].includes(activeEl.id)) return;
        e.preventDefault();
        movePmFocusVertical(1);
        return;
      }
      if(e.key === 'ArrowUp'){
        if(activeEl && ['cashReceived','mixtoMonto1','mixtoMonto2','recargoCustom'].includes(activeEl.id)) return;
        e.preventDefault();
        movePmFocusVertical(-1);
        return;
      }
      if(e.key === 'Enter'){
        if(activeEl && activeEl.classList && activeEl.classList.contains('pm-btn')){
          e.preventDefault();
          activeEl.click();
          if(payMethod.toLowerCase() === 'efectivo'){
            setTimeout(()=>document.getElementById('cashReceived')?.focus(),80);
          }
          return;
        }
      }
    }

    if(e.key==='F4'){
      e.preventDefault();
      confirmSale();
      return;
    }

    if(e.key==='Escape'){
      e.preventDefault();
      closeCobroModal();
      return;
    }
  }

  const inInput=['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)&&e.target.id!=='barcodeInput';
  if(inInput)return;

  if(e.key==='F2'){e.preventDefault();focusScanner();showToast('Scanner listo','info');}
  if(e.key==='F4'){e.preventDefault();cart.length?openCobroModal():showToast('Carrito vacío','warn');}
  if(e.key==='F5'){e.preventDefault();const c=document.getElementById('chipDeptos');if(c)toggleDeptosChip(c);}
  if(e.key==='Escape'){
    if(document.getElementById('cobroOverlay').classList.contains('open')){closeCobroModal();return;}
    if(document.getElementById('exitoOverlay').classList.contains('open')){nuevaVenta();return;}
    e.preventDefault();
    clearCart();
    showToast('Venta limpiada','warn');
  }
});

window.addEventListener('load',()=>document.getElementById('barcodeInput').focus());
</script>

