<%- include('../partials/head', { title: 'Ventas' }) %>

<style>
  body { overflow:hidden; }
  .main-content {
    margin-left:var(--sidebar-width);
    height:100vh;
    display:flex; flex-direction:column; overflow:hidden;
  }
  .pos-wrapper { display:flex; flex:1; min-height:0; overflow:hidden; height:100%; }

  /* IZQUIERDA */
  .pos-left { width:62%;display:flex;flex-direction:column;background:var(--bg-body);border-right:2px solid var(--border-strong);overflow:hidden;min-height:0;flex-shrink:0; }
  .pos-topbar { display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border-color);background:var(--bg-card);flex-shrink:0; }  .scan-zone { flex:1;display:flex;align-items:center;gap:9px;background:var(--bg-body);border:1.5px solid var(--border-color);border-radius:var(--radius-md);padding:0 12px;height:42px;transition:border-color .15s,box-shadow .15s; }
  .scan-zone:focus-within { border-color:var(--color-action);box-shadow:0 0 0 3px rgba(0,180,216,.1); }
  .scan-dot { width:7px;height:7px;border-radius:50%;background:var(--color-action);flex-shrink:0;animation:pulseDot 2s ease-in-out infinite; }
  .scan-dot.scanner-mode { background:#10b981;animation:pulseDotGreen 1s ease-in-out infinite; }
  @keyframes pulseDot{0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 rgba(0,180,216,.4)}50%{opacity:.8;transform:scale(1.2);box-shadow:0 0 0 5px rgba(0,180,216,0)}}
  @keyframes pulseDotGreen{0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 rgba(16,185,129,.4)}50%{opacity:.8;transform:scale(1.2);box-shadow:0 0 0 5px rgba(16,185,129,0)}}
  @keyframes shimmer{0%{opacity:.4}50%{opacity:.8}100%{opacity:.4}}
  .scan-icon { font-size:16px;color:var(--color-action);flex-shrink:0; }
  #barcodeInput { flex:1;border:none;background:transparent;font-family:var(--font-body);font-size:14px;font-weight:500;color:var(--text-primary);outline:none; }
  #barcodeInput::placeholder { color:var(--text-secondary);font-weight:400;font-size:13px; }
  .sc-chips { display:flex;gap:6px;flex-shrink:0; }
  .sc-chip {
    display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;
    color:var(--text-secondary);background:var(--bg-card);
    border:1.5px solid var(--border-color);border-radius:8px;
    padding:5px 10px;white-space:nowrap;cursor:pointer;
    transition:all .15s;user-select:none;
  }
  .sc-chip:hover { border-color:var(--color-action);color:var(--color-action);background:rgba(0,180,216,.05); }
  .sc-chip kbd {
    font-family:var(--font-mono);font-size:10px;font-weight:800;
    background:var(--color-primary);color:#fff;
    border-radius:5px;padding:2px 6px;letter-spacing:.3px;
  }
  .sc-chip.chip-cobrar kbd { background:#10b981; }
  .sc-chip.chip-limpiar kbd { background:#6b7280; }
  .sc-chip.chip-deptos {    border-color:rgba(31,60,136,.3);color:var(--color-primary);
    background:rgba(31,60,136,.05);
  }
  .sc-chip.chip-deptos.active {
    border-color:var(--color-primary);background:var(--color-primary);color:#fff;
  }
  .sc-chip.chip-deptos.active kbd { background:rgba(255,255,255,.2); }

  /* Lista de precio */
  .sc-chip.chip-lista { border-color:rgba(16,185,129,.35);color:#059669;background:rgba(16,185,129,.06); }
  .sc-chip.chip-lista:hover { border-color:#10b981;background:rgba(16,185,129,.12); }
  .sc-chip.chip-lista kbd { background:#10b981; }
  .sc-chip.chip-lista.lista-mayorista { border-color:rgba(99,102,241,.4);color:#4f46e5;background:rgba(99,102,241,.07); }
  .sc-chip.chip-lista.lista-mayorista kbd { background:#6366f1; }
  .sc-chip.chip-lista.lista-tarjeta { border-color:rgba(245,158,11,.4);color:#d97706;background:rgba(245,158,11,.07); }
  .sc-chip.chip-lista.lista-tarjeta kbd { background:#f59e0b; }

  .products-scroll { flex:1;overflow-y:auto;padding:0;min-height:0; }

  /* ── TABLA DE PRODUCTOS ── */
  .products-grid { display:table;width:100%;border-collapse:collapse; }

  /* Header fijo de la tabla */
  .prod-table-head {
    display:table-row;
    background:var(--table-head-bg);
    position:sticky;top:0;z-index:10;
  }
  .prod-th {
    display:table-cell;
    padding:10px 14px;
    font-size:10.5px;font-weight:600;
    text-transform:uppercase;letter-spacing:.07em;
    color:var(--table-head-color);
    white-space:nowrap;
    border-bottom:none;
  }
  .prod-th:first-child { border-radius:0; padding-left:14px; }
  .prod-th.th-img   { width:62px;text-align:center; }
  .prod-th.th-stock { width:90px;text-align:center; }
  .prod-th.th-price { width:130px;text-align:right; }

  /* Fila de producto */
  .prod-card {
    display:table-row;
    background:var(--bg-surface);
    cursor:pointer;
    transition:background .12s;
    position:relative;
  }
  .prod-card:hover { background:var(--table-row-hover); }
  .prod-card.in-cart { background:#EEF2FF; }
  .prod-card.in-cart:hover { background:#E0E7FF; }
  .prod-card.out-stock { opacity:.45;cursor:not-allowed; }
  .prod-card.out-stock:hover { background:var(--bg-surface); }
  .prod-card.kb-selected { background:rgba(27,79,216,.08) !important;outline:2px solid var(--color-primary);outline-offset:-1px; }

  /* Celdas */
  .prod-td {
    display:table-cell;
    padding:9px 14px;
    border-bottom:0.5px solid var(--border-color);
    vertical-align:middle;
  }
  .prod-card:last-child .prod-td { border-bottom:none; }

  /* Celda imagen / thumbnail */
  .prod-td-img {
    display:table-cell;
    width:62px;
    padding:6px 8px;
    border-bottom:0.5px solid var(--border-color);
    vertical-align:middle;
    text-align:center;
  }
  .prod-thumb {
    width:46px;height:46px;
    border-radius:8px;
    overflow:hidden;
    border:0.5px solid var(--border-color);
    cursor:zoom-in;
    display:inline-flex;
    align-items:center;justify-content:center;
    background:var(--bg-surface-2);
    transition:box-shadow .15s;
    flex-shrink:0;
  }
  .prod-thumb:hover { box-shadow:0 0 0 2px var(--color-primary); }
  .prod-thumb img { width:100%;height:100%;object-fit:cover;display:block; }
  .prod-thumb-empty {
    width:46px;height:46px;
    border-radius:8px;
    background:var(--bg-surface-2);
    border:0.5px solid var(--border-color);
    display:inline-flex;
    align-items:center;justify-content:center;
    color:var(--text-muted);
    font-size:18px;
  }

  /* Datos del producto */
  .prod-name {
    font-size:13px;font-weight:700;
    color:var(--text-primary);
    line-height:1.3;
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    max-width:260px;
  }
  .prod-desc {
    font-size:11px;color:var(--text-secondary);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    max-width:260px;margin-top:2px;
  }
  .prod-badge-promo {
    display:inline-block;font-size:9px;font-weight:800;
    text-transform:uppercase;background:#f59e0b;color:#fff;
    padding:1px 6px;border-radius:4px;margin-left:6px;vertical-align:middle;
  }
  .prod-badge-qty {
    display:inline-flex;align-items:center;justify-content:center;
    width:18px;height:18px;border-radius:50%;
    background:var(--color-primary);color:#fff;
    font-size:9px;font-weight:800;margin-left:6px;vertical-align:middle;
  }

  /* Stock badge */
  .prod-stock-badge {
    display:inline-flex;align-items:center;justify-content:center;
    min-width:52px;padding:3px 10px;border-radius:20px;
    font-family:var(--font-mono);font-size:12px;font-weight:800;
  }
  .prod-stock-badge.ok   { background:#10b981;color:#fff; }
  .prod-stock-badge.low  { background:#f59e0b;color:#fff; }
  .prod-stock-badge.zero { background:#ef4444;color:#fff; }

  /* Precio */
  .prod-price {
    font-family:var(--font-mono);font-size:14px;font-weight:800;
    color:var(--color-primary);text-align:right;white-space:nowrap;
  }
  .prod-price-old {
    font-family:var(--font-mono);font-size:11px;
    color:var(--text-muted);text-decoration:line-through;
    text-align:right;display:block;
  }
  .prod-sin-stock {
    font-size:10px;font-weight:700;color:#ef4444;
    text-transform:uppercase;letter-spacing:.3px;display:block;
  }

  .products-empty {
    display:flex;flex-direction:column;align-items:center;
    justify-content:center;padding:50px 20px;gap:10px;color:var(--text-secondary);
  }
  .products-empty i { font-size:42px;opacity:.18; }
  .products-empty p { font-size:13px;opacity:.5; }

  /* DERECHA */
  .pos-right { width:38%;display:flex;flex-direction:column;background:var(--bg-card);overflow:hidden;min-height:0;flex-shrink:0;border-left:1px solid var(--border-color); }
  .cart-header { display:flex;align-items:center;justify-content:space-between;padding:12px 18px;border-bottom:1px solid var(--border-color);background:var(--bg-card);flex-shrink:0; }
  .cart-list { flex:1;overflow-y:auto;min-height:0;padding:10px 14px;background:var(--bg-body); }
  .cart-title-wrap { display:flex;align-items:center;gap:9px; }
  .cart-title-icon { width:32px;height:32px;border-radius:8px;background:rgba(0,180,216,.1);display:flex;align-items:center;justify-content:center;color:var(--color-action);font-size:16px; }
  .cart-title-txt  { font-size:15px;font-weight:700;color:var(--text-primary); }
  .cart-count-badge { font-family:var(--font-mono);font-size:11px;font-weight:700;background:rgba(0,180,216,.12);color:var(--color-action);padding:2px 8px;border-radius:20px;margin-left:4px; }
  .cart-sub { font-size:11px;color:var(--text-secondary);margin-top:1px; }
  .btn-clear-sm { padding:5px 11px;border-radius:6px;border:1.5px solid var(--border-color);background:transparent;color:var(--text-secondary);font-size:11.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .12s;font-family:var(--font-body); }
  .btn-clear-sm:hover { border-color:#ef4444;color:#ef4444;background:rgba(239,68,68,.05); }

  .cart-items-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px; }
  .cart-empty-state { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--text-secondary);text-align:center;padding:40px 20px;height:100%; }
  .cart-empty-state i { font-size:48px;opacity:.15; }
  .cart-empty-state p { font-size:13px;opacity:.5;line-height:1.5; }

  /* CARRITO — estilo StartBiz: lista vertical, cada item con precio unitario y controles */
  .cart-items-grid { display:flex;flex-direction:column;gap:3px; }

  .cart-card {
    background:var(--bg-card2, #f9fafb);
    border:1px solid var(--border-color);
    border-left:3px solid rgba(0,180,216,.35);
    border-radius:10px;
    padding:9px 12px;
    display:flex;
    flex-direction:column;
    gap:5px;
    position:relative;
    animation:cardIn .18s ease both;
    transition:border-color .12s,box-shadow .12s;
    cursor:default;
  }
  @keyframes cardIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
  .cart-card:hover { border-left-color:var(--color-action); box-shadow:0 2px 8px rgba(0,180,216,.12); }

  /* Fila superior: nombre + botón eliminar */
  .cart-card-top { display:flex;align-items:flex-start;justify-content:space-between;gap:8px; }
  .cart-card-name { font-size:13px;font-weight:700;color:var(--text-primary);line-height:1.3;flex:1; }

  /* Precio unitario */
  .cart-card-unit { font-size:11px;color:var(--text-secondary);font-weight:500; }
  .cart-card-unit span { font-family:var(--font-mono);font-weight:600;color:var(--text-secondary); }

  /* Fila inferior: qty controles + precio total */
  .cart-card-bottom { display:flex;align-items:center;justify-content:space-between;margin-top:2px; }
  .qty-ctrl { display:inline-flex;align-items:center;border:1.5px solid var(--border-color);border-radius:8px;overflow:hidden;background:var(--bg-body); }
  .qty-btn  { width:28px;height:28px;display:flex;align-items:center;justify-content:center;background:transparent;border:none;color:var(--text-secondary);font-size:14px;cursor:pointer;transition:all .1s;font-weight:700; }
  .qty-btn:hover { background:rgba(0,180,216,.12);color:var(--color-action); }
  .qty-val  { min-width:28px;text-align:center;font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--text-primary);border-left:1px solid var(--border-color);border-right:1px solid var(--border-color);height:28px;line-height:28px; }
  .cart-card-price { font-family:var(--font-mono);font-size:15px;font-weight:800;color:var(--color-action); }
  .cart-card-sub   { font-family:var(--font-mono);font-size:11px;font-weight:600;color:var(--text-secondary);margin-top:1px; }
  .btn-del  { width:26px;height:26px;border:none;background:transparent;color:var(--text-secondary);border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .1s;flex-shrink:0; }
  .btn-del:hover { background:rgba(239,68,68,.1);color:#ef4444; }
  .cart-promo-tag { position:absolute;top:5px;right:38px;font-size:8px;font-weight:800;background:#f59e0b;color:#fff;padding:1px 5px;border-radius:5px;text-transform:uppercase; }
  /* pago mixto oculto por defecto, visible solo cuando se activa */
  .mixto-row { display:none;gap:8px;flex-wrap:wrap;margin-bottom:8px; }
  .mixto-row.visible { display:flex; }
  .mixto-method { flex:1;min-width:120px; }
  .mixto-method label { font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);display:block;margin-bottom:4px; }
  .mixto-method input,
  .mixto-method select {
    width:100%;padding:10px 11px;border:1.5px solid var(--border-color);border-radius:10px;background:var(--bg-body);
    color:var(--text-primary);font-family:var(--font-body);font-size:14px;outline:none;box-sizing:border-box;
  }
  .mixto-method input { font-family:var(--font-mono);font-weight:700; }
  .mixto-method input:focus,
  .mixto-method select:focus { border-color:var(--color-action); }
  .mixto-resto { font-size:14px;font-weight:700;color:#10b981;text-align:left;padding:2px 0 0; }
  .mixto-resto.negativo { color:#ef4444; }

  .cart-footer { flex-shrink:0;border-top:1px solid var(--border-color);background:var(--bg-body);padding:8px 12px;display:flex;flex-direction:column;gap:6px; }
  .field-label { font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:4px; }
  .cart-cliente-wrap { position:relative; }
  .cart-cliente-inp { width:100%;padding:7px 10px 7px 28px;border:1.5px solid var(--border-color);border-radius:var(--radius-sm);background:var(--bg-body);color:var(--text-primary);font-family:var(--font-body);font-size:13px;outline:none;transition:border-color .15s;box-sizing:border-box; }
  .cart-cliente-inp:focus { border-color:var(--color-action); }
  .cart-cliente-ico { position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--text-secondary);font-size:13px;pointer-events:none; }
  .cart-cliente-drop { display:none;position:absolute;bottom:calc(100%+4px);left:0;right:0;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-sm);box-shadow:0 -8px 24px rgba(0,0,0,.1);z-index:60;max-height:140px;overflow-y:auto; }
  .cart-cliente-drop.visible { display:block; }
  .cart-cliente-sel { display:none;margin-top:3px;padding:4px 9px;background:rgba(0,180,216,.07);border:1px solid rgba(0,180,216,.2);border-radius:var(--radius-sm);align-items:center;justify-content:space-between;font-size:11.5px; }
  .disc-bar { display:flex;gap:5px;align-items:center;background:var(--bg-body);border-radius:var(--radius-sm);border:1px solid var(--border-color);padding:5px 9px; }
  .disc-bar label { font-size:11px;color:var(--text-secondary);font-weight:600;flex-shrink:0; }
  .disc-type-btn { padding:2px 7px;border-radius:4px;border:1.5px solid var(--border-color);background:var(--bg-card);font-size:11px;font-weight:700;color:var(--text-secondary);cursor:pointer;transition:all .1s; }
  .disc-type-btn.on { border-color:var(--color-action);background:rgba(0,180,216,.1);color:var(--color-action); }
  .disc-input { flex:1;border:1.5px solid var(--border-color);background:var(--bg-body);border-radius:4px;padding:3px 6px;font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--text-primary);outline:none;text-align:right;width:0; }
  .disc-input:focus { border-color:var(--color-action); }
  .disc-suffix { font-size:12px;font-weight:700;color:var(--text-secondary);flex-shrink:0; }
  /* ── Panel cobro ── */
  .cart-footer {
    background: var(--bg-card) !important;
    border-top: 2px solid var(--border-color) !important;
    padding: 8px 12px !important;
    gap: 6px !important;
  }

  /* Sección cliente */
  .cobro-section-cliente {
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 7px 10px;
  }
  .cobro-section-descuento {
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 7px 10px;
  }

  .totals-block {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #16a34a;
    border: none;
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(22,163,74,.35);
  }

  .tot-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    padding: 9px 16px;
    background: rgba(0,0,0,.12);
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .tot-row span:first-child { color: rgba(255,255,255,.85); font-weight: 600; }
  .tot-row span:last-child { font-weight: 800; color: #fff; font-family: var(--font-mono); }

  .total-highlight {
    padding: 14px 16px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: transparent;
    border-top: none;
    margin-top: 0;
  }

  .total-highlight-label {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .8px;
    color: rgba(255,255,255,.9);
  }

  .total-highlight-value {
    font-size: 32px;
    line-height: 1;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-mono);
    letter-spacing: -1px;
    text-shadow: 0 1px 3px rgba(0,0,0,.15);
  }

  @media (max-width: 860px) {
    .total-highlight-value { font-size: 26px; }
  }

  .btn-confirm { width:100%;padding:11px;border-radius:10px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(239,68,68,.35); }
  .btn-confirm:hover:not(:disabled) { transform:translateY(-1px);box-shadow:0 6px 20px rgba(239,68,68,.5); }
  .btn-confirm:disabled { opacity:.35;cursor:not-allowed;box-shadow:none;transform:none; }
  .kbd-hint { font-size:10px;opacity:.75;background:rgba(255,255,255,.2);border-radius:4px;padding:1px 5px;font-family:var(--font-mono); }

  .pos-toast { position:fixed;bottom:18px;left:calc(var(--sidebar-width)+18px);background:var(--bg-card);border:1px solid var(--border-color);border-left:3px solid var(--color-action);border-radius:var(--radius-sm);padding:9px 13px;display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--text-primary);box-shadow:var(--shadow-lg);z-index:999;transform:translateY(80px);opacity:0;transition:transform .22s ease,opacity .22s ease;min-width:200px; }
  .pos-toast.show { transform:translateY(0);opacity:1; }
  .pos-toast.toast-success { border-left-color:#10b981; }
  .pos-toast.toast-error   { border-left-color:#ef4444; }
  .pos-toast.toast-warn    { border-left-color:var(--color-alert); }
  .pos-toast i { font-size:15px; }
  .pos-toast.toast-success i { color:#10b981; }
  .pos-toast.toast-error   i { color:#ef4444; }
  .pos-toast.toast-warn    i { color:var(--color-alert); }

  /* MODAL COBRO NUEVO */
  .cobro-overlay { position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;display:none;align-items:center;justify-content:center;backdrop-filter:blur(3px); }
  .cobro-overlay.open { display:flex; }
  .cobro-modal {
    background:var(--bg-card);
    border-radius:22px;
    width:min(1040px,96vw);
    max-height:92vh;
    overflow:hidden;
    box-shadow:0 24px 64px rgba(0,0,0,.25);
    animation:modalIn .2s ease;
    display:flex;
    flex-direction:column;
  }
