// ─────────────────────────────────────────────────────────────
// NAVEGACIÓN POR TECLADO EN DROPDOWNS
// ─────────────────────────────────────────────────────────────
const kbState = {
  dropId: null,
  index: -1
};

function getDropItems(dropId) {
  return document.querySelectorAll(`#${dropId} .prod-item`);
}

function kbHighlight(dropId, index) {
  const list = getDropItems(dropId);
  list.forEach((el, i) => el.classList.toggle('kb-focus', i === index));
  if (list[index]) list[index].scrollIntoView({ block: 'nearest' });
  kbState.index = index;
  kbState.dropId = dropId;
}

function kbSelect(dropId) {
  const list = getDropItems(dropId);
  if (kbState.index >= 0 && list[kbState.index]) {
    list[kbState.index].click();
    kbState.index = -1;
  }
}

function attachKbNav(inputId, dropId) {
  const input = document.getElementById(inputId);
  if (!input) return;

  input.addEventListener('keydown', e => {
    const drop = document.getElementById(dropId);
    const isOpen = drop?.classList.contains('open');
    const list = getDropItems(dropId);
    const count = list.length;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (!isOpen || count === 0) return;
      const next = kbState.dropId === dropId ? Math.min(kbState.index + 1, count - 1) : 0;
      kbHighlight(dropId, next);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (!isOpen || count === 0) return;
      const prev = kbState.dropId === dropId ? Math.max(kbState.index - 1, 0) : 0;
      kbHighlight(dropId, prev);
    } else if (e.key === 'Enter') {
      if (isOpen && kbState.dropId === dropId && kbState.index >= 0) {
        e.preventDefault();
        kbSelect(dropId);
      }
    } else if (e.key === 'Escape') {
      drop?.classList.remove('open');
      kbState.index = -1;
      input.blur();
    } else {
      kbState.index = -1;
      if (kbState.dropId === dropId) {
        getDropItems(dropId).forEach(el => el.classList.remove('kb-focus'));
      }
    }
  });
}

attachKbNav('buscadorSistema', 'dropSistema');

