<%- include('../partials/head', { title: presupuesto.numero }) %>

<style>
  .page-body { padding: 24px 32px; max-width: 960px; }
  .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 12px; }
  .top-bar-left { display: flex; align-items: center; gap: 14px; }
  .top-bar-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

  /* Badge estado */
  .badge-estado { display: inline-flex; align-items: center; gap: 5px; padding: 5px 14px; border-radius: 20px; font-size: 12.5px; font-weight: 700; }
  .badge-Borrador  { background: rgba(107,114,128,.1); color: #6b7280; }
  .badge-Enviado   { background: rgba(59,130,246,.1);  color: #3b82f6; }
  .badge-Aprobado  { background: rgba(16,185,129,.1);  color: #10b981; }
  .badge-Rechazado { background: rgba(239,68,68,.1);   color: #ef4444; }

  .btn-act {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 16px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all .15s;
    white-space: nowrap;
  }
  .btn-act:hover { border-color: var(--color-action); color: var(--color-action); background: rgba(0,180,216,.05); }
  .btn-act.primary { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .btn-act.primary:hover { opacity: .88; color: #fff; }
  .btn-act.success { background: #10b981; border-color: #10b981; color: #fff; }
  .btn-act.success:hover { opacity: .88; color: #fff; }

  /* Documento */
  .doc-wrap { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-md); overflow: hidden; }

  /* ═══════════════════════════════════════════════
     ESTILOS DEL DOCUMENTO REAL (A4)
  ═══════════════════════════════════════════════ */
  .doc-a4 {
    padding: 48px 52px;
    font-family: 'Sora', 'Segoe UI', sans-serif;
    color: #1a2332;
    font-size: 13.5px;
    line-height: 1.6;
    background: #fff;
    min-height: 960px;
  }

  .doc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 3px solid #2d7a2d;
  }

  .header-left { display: flex; align-items: center; gap: 16px; }

  .empresa-logo {
    width: 58px;
    height: 58px;
    object-fit: contain;
    border-radius: 10px;
  }

  .empresa-nombre { font-size: 24px; font-weight: 800; color: #1a4a1a; letter-spacing: -.3px; }
  .empresa-datos  { font-size: 12px; color: #5f6c7b; margin-top: 4px; line-height: 1.9; }
  .doc-titulo-wrap { text-align: right; }
  .doc-titulo { font-size: 28px; font-weight: 800; color: #1a4a1a; letter-spacing: -.5px; text-transform: uppercase; }
  .doc-numero { font-size: 16px; font-weight: 700; color: #5f6c7b; margin-top: 4px; }
  .doc-fecha  { font-size: 12px; color: #9ca3af; margin-top: 2px; }

  .doc-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px; }
  .meta-box { padding: 16px 18px; border-radius: 10px; border: 1.5px solid #e8ecf0; }
  .meta-box-title { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .8px; color: #9ca3af; margin-bottom: 8px; }
  .meta-box-nombre { font-size: 17px; font-weight: 800; color: #111; }
  .meta-box-dato { font-size: 12.5px; color: #5f6c7b; margin-top: 3px; }

  .cond-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .cond-item { }
  .cond-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #9ca3af; }
  .cond-val   { font-size: 13px; font-weight: 600; color: #1a2332; }

  /* Tabla ítems */
  .items-tabla { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
  .items-tabla thead th {
    padding: 10px 14px;
    font-size: 10.5px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .6px;
    color: #fff;
    background: #1a4a1a;
  }
  .items-tabla thead th:first-child { border-radius: 8px 0 0 8px; }
  .items-tabla thead th:last-child  { border-radius: 0 8px 8px 0; text-align: right; }
  .items-tabla thead th.right { text-align: right; }
  .items-tabla tbody td { padding: 11px 14px; border-bottom: 1px solid #f0f2f5; font-size: 13px; }
  .items-tabla tbody tr:last-child td { border-bottom: none; }
  .items-tabla tbody tr:nth-child(even) td { background: #fafbfc; }
  .item-nombre { font-weight: 700; color: #1a2332; }
  .item-desc   { font-size: 11.5px; color: #9ca3af; margin-top: 2px; }

  /* Totales */
  .totales-wrap { display: flex; justify-content: flex-end; margin-bottom: 28px; }
  .totales-box { width: 300px; }
  .total-line { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid #f0f2f5; font-size: 13px; }
  .total-line:last-child { border-bottom: none; }
  .total-final-line { display: flex; justify-content: space-between; padding: 12px 16px; background: linear-gradient(135deg, #1a4a1a 0%, #2d7a2d 100%); border-radius: 10px; margin-top: 10px; }
  .total-final-label { font-size: 14px; font-weight: 800; color: rgba(255,255,255,.85); text-transform: uppercase; letter-spacing: .5px; }
  .total-final-valor { font-size: 22px; font-weight: 900; color: #fff; }

  /* Validez y notas */
  .doc-footer-info { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
  .info-box { padding: 14px 16px; border-radius: 8px; background: #f8f9fb; border: 1px solid #e8ecf0; font-size: 12.5px; color: #5f6c7b; white-space: pre-line; }
  .info-box strong { display: block; font-size: 10.5px; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; color: #9ca3af; margin-bottom: 4px; }

  /* ═══════════════════════════════════════════════
     RESPONSIVE MÓVIL
  ═══════════════════════════════════════════════ */
  @media (max-width: 700px) {
    .page-body { padding: 12px 8px; }
    .top-bar { flex-direction: column; align-items: flex-start; gap: 10px; }
    .top-bar-actions { width: 100%; flex-wrap: wrap; }
    .btn-act { flex: 1; justify-content: center; font-size: 12px; padding: 8px 10px; }

    .doc-a4 { padding: 24px 16px; font-size: 12.5px; }

    .doc-header { flex-direction: column; gap: 16px; align-items: flex-start; }
    .doc-titulo-wrap { text-align: left; }
    .doc-titulo { font-size: 22px; }
    .empresa-nombre { font-size: 19px; }

    .doc-meta { grid-template-columns: 1fr; gap: 12px; }
    .cond-grid { grid-template-columns: 1fr 1fr; }

    .items-tabla thead th,
    .items-tabla tbody td { padding: 8px 8px; font-size: 11.5px; }

    .totales-wrap { justify-content: stretch; }
    .totales-box { width: 100%; }

    .doc-footer-info { grid-template-columns: 1fr; }

    .total-final-valor { font-size: 18px; }
  }

  @media (max-width: 480px) {
    .doc-a4 { padding: 16px 10px; }
    .items-tabla thead { display: none; }
    .items-tabla tbody td { display: block; border-bottom: none; padding: 4px 8px; }
    .items-tabla tbody tr { border-bottom: 1px solid #e8ecf0; display: block; padding: 8px 0; }
    .items-tabla tbody td:nth-child(1) { display: none; }
    .items-tabla tbody td:nth-child(3)::before { content: 'Cant: '; color: #9ca3af; font-size: 11px; }
    .items-tabla tbody td:nth-child(4)::before { content: 'Precio: '; color: #9ca3af; font-size: 11px; }
    .items-tabla tbody td:nth-child(5) { text-align: left; font-weight: 700; color: #1a4a1a; }
    .items-tabla tbody td:nth-child(5)::before { content: 'Subtotal: '; color: #9ca3af; font-size: 11px; font-weight: 400; }
  }
</style>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { active: 'presupuestos', user }) %>
  <div class="main-content">
    <%- include('../partials/header', { module: presupuesto.numero, user }) %>
    <div class="page-body">

      <div class="top-bar">
        <div class="top-bar-left">
          <a href="/presupuestos" class="btn-act"><i class="bi bi-arrow-left"></i> Volver</a>
          <span class="badge-estado badge-<%= presupuesto.estado %>">
            <%= presupuesto.estado %>
          </span>
        </div>

        <div class="top-bar-actions">
          <% if (presupuesto.estado === 'Borrador') { %>
            <form method="POST" action="/presupuestos/estado/<%= presupuesto.id %>" style="margin:0">
              <input type="hidden" name="estado" value="Enviado">
              <button type="submit" class="btn-act"><i class="bi bi-send"></i> Marcar enviado</button>
            </form>
          <% } %>

          <% if (presupuesto.estado === 'Enviado') { %>
            <form method="POST" action="/presupuestos/estado/<%= presupuesto.id %>" style="margin:0">
              <input type="hidden" name="estado" value="Aprobado">
              <button type="submit" class="btn-act success"><i class="bi bi-check-circle"></i> Aprobar</button>
            </form>
          <% } %>

          <a href="/presupuestos/editar/<%= presupuesto.id %>" class="btn-act"><i class="bi bi-pencil"></i> Editar</a>
          <button class="btn-act" onclick="imprimirTermica()"><i class="bi bi-receipt"></i> Térmica</button>
          <button class="btn-act primary" onclick="imprimirA4()"><i class="bi bi-printer-fill"></i> Imprimir A4</button>
        </div>
      </div>

      <div class="doc-wrap">
        <div class="doc-a4" id="docA4">

          <div class="doc-header">
            <div class="header-left">
              <% if (config.empresa_logo) { %>
                <img src="<%= config.empresa_logo %>" alt="Logo" class="empresa-logo">
              <% } %>

              <div>
                <div class="empresa-nombre"><%= config.empresa_nombre || 'Mi Comercio' %></div>
                <div class="empresa-datos">
                  <% if (config.empresa_direccion) { %><div><%= config.empresa_direccion %></div><% } %>
                  <% if (config.empresa_telefono) { %><div>Tel: <%= config.empresa_telefono %></div><% } %>
                  <% if (config.empresa_email) { %><div>Email: <%= config.empresa_email %></div><% } %>
                </div>
              </div>
            </div>

            <div class="doc-titulo-wrap">
              <div class="doc-titulo">Presupuesto</div>
              <div class="doc-numero"><%= presupuesto.numero %></div>
              <div class="doc-fecha">
                Fecha:
                <%= new Date(presupuesto.created_at).toLocaleDateString('es-AR') %>
              </div>
            </div>
          </div>

          <div class="doc-meta">
            <div class="meta-box">
              <div class="meta-box-title">Cliente</div>
              <div class="meta-box-nombre"><%= presupuesto.cliente_nombre || 'Sin nombre' %></div>
              <% if (presupuesto.cliente_cuit) { %>
                <div class="meta-box-dato">CUIT / DNI: <%= presupuesto.cliente_cuit %></div>
              <% } %>
              <% if (presupuesto.cliente_email) { %>
                <div class="meta-box-dato">Email: <%= presupuesto.cliente_email %></div>
              <% } %>
              <% if (presupuesto.cliente_tel) { %>
                <div class="meta-box-dato">Teléfono: <%= presupuesto.cliente_tel %></div>
              <% } %>
            </div>

            <div class="meta-box">
              <div class="meta-box-title">Condiciones</div>
              <div class="cond-grid">
                <div class="cond-item">
                  <div class="cond-label">Pago</div>
                  <div class="cond-val"><%= presupuesto.condicion_pago || 'Contado' %></div>
                </div>

                <div class="cond-item">
                  <div class="cond-label">Validez</div>
                  <div class="cond-val">
                    <%= presupuesto.validez_dias ? presupuesto.validez_dias + ' días' : 'Sin vencimiento' %>
                  </div>
                </div>

                <div class="cond-item">
                  <div class="cond-label">Estado</div>
                  <div class="cond-val"><%= presupuesto.estado %></div>
                </div>

                <div class="cond-item">
                  <div class="cond-label">Sucursal</div>
                  <div class="cond-val"><%= presupuesto.sucursal_nombre || 'Casa Central' %></div>
                </div>
              </div>
            </div>
          </div>

          <table class="items-tabla">
            <thead>
              <tr>
                <th style="width:50px;">#</th>
                <th>Descripción</th>
                <th class="right" style="width:110px;">Cantidad</th>
                <th class="right" style="width:140px;">Precio</th>
                <th class="right" style="width:150px;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% (presupuesto.items || []).forEach((item, idx) => { 
                const descPct = Number(item.descuento_item_pct || 0);
                const precioBase = Number(item.precio_unitario || 0);
                const precioConDesc = precioBase * (1 - descPct / 100);
                const subtotalItem = Number(item.cantidad || 0) * precioConDesc;
              %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td>
                    <div class="item-nombre"><%= item.nombre %></div>
                    <% if (item.descripcion) { %>
                      <div class="item-desc"><%= item.descripcion %></div>
                    <% } %>
                    <% if (descPct > 0) { %>
                      <div style="font-size:11px;color:#f59e0b;font-weight:700;margin-top:2px;">Descuento <%= descPct %>%</div>
                    <% } %>
                  </td>
                  <td class="right"><%= Number(item.cantidad || 0).toLocaleString('es-AR') %></td>
                  <td class="right">
                    <% if (descPct > 0) { %>
                      <div style="text-decoration:line-through;font-size:11px;color:#9ca3af;">$<%= precioBase.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></div>
                    <% } %>
                    $<%= precioConDesc.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %>
                  </td>
                  <td class="right">$<%= subtotalItem.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <%
            const subtotal = Number(presupuesto.subtotal || 0);
            const descuento = Number(presupuesto.descuento_monto || 0);
            const totalItemsIva = (presupuesto.items || []).reduce((acc, it) => {
              const descPct = Number(it.descuento_item_pct || 0);
              const base = Number(it.cantidad || 0) * Number(it.precio_unitario || 0) * (1 - descPct / 100);
              const pct = (it.pct_iva !== null && it.pct_iva !== undefined && it.pct_iva !== '') ? Number(it.pct_iva) : 0;
              return acc + (base * pct / 100);
            }, 0);
            const total = Math.max(0, subtotal - descuento + totalItemsIva);
          %>

          <div class="totales-wrap">
            <div class="totales-box">
              <div class="total-line">
                <span>Subtotal</span>
                <strong>$<%= subtotal.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></strong>
              </div>

              <% if (descuento > 0) { %>
                <div class="total-line">
                  <span>Descuento</span>
                  <strong>-$<%= descuento.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></strong>
                </div>
              <% } %>

              <% if (totalItemsIva > 0) { %>
                <div class="total-line">
                  <span>IVA</span>
                  <strong>$<%= totalItemsIva.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></strong>
                </div>
              <% } %>

              <div class="total-final-line">
                <span class="total-final-label">Total</span>
                <span class="total-final-valor">$<%= total.toLocaleString('es-AR', { minimumFractionDigits: 2 }) %></span>
              </div>
            </div>
          </div>

          <% if (presupuesto.validez_dias || presupuesto.condicion_pago_obs || presupuesto.notas) { %>
            <div style="border-top:1px solid #eef2f6;padding-top:16px;">
              <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#9ca3af;margin-bottom:10px;">
                Observaciones y condiciones
              </div>

              <div class="doc-footer-info">
                <% if (presupuesto.validez_dias) { %>
                  <div class="info-box">
                    <strong>Validez del presupuesto</strong>
                    Este presupuesto tiene una validez de <%= presupuesto.validez_dias %> día<%= Number(presupuesto.validez_dias) !== 1 ? 's' : '' %> desde su emisión.
                  </div>
                <% } %>

                <% if (presupuesto.condicion_pago_obs) { %>
                  <div class="info-box">
                    <strong>Condición de pago</strong>
                    <%= presupuesto.condicion_pago_obs %>
                  </div>
                <% } %>

                <% if (presupuesto.notas) { %>
                  <div class="info-box" style="<%= !presupuesto.condicion_pago_obs && !presupuesto.validez_dias ? 'grid-column:1/-1;' : '' %>">
                    <strong>Notas / Aclaraciones</strong>
                    <%= presupuesto.notas %>
                  </div>
                <% } %>
              </div>
            </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
const presupuesto = <%- JSON.stringify(presupuesto) %>;
const config      = <%- JSON.stringify(config) %>;

const fmt  = n => '$' + (Number(n)||0).toLocaleString('es-AR', { minimumFractionDigits: 2 });
const fmt0 = n => '$' + (Number(n)||0).toLocaleString('es-AR', { minimumFractionDigits: 0 });

function calcularSubtotal(p) {
  return Number(p.subtotal || 0);
}

function calcularIva(p) {
  return (p.items || []).reduce((acc, i) => {
    const base = Number(i.subtotal || 0);
    const pct  = (i.pct_iva !== null && i.pct_iva !== undefined && i.pct_iva !== '') ? Number(i.pct_iva) : 0;
    return acc + (base * pct / 100);
  }, 0);
}

function calcularDescuento(p) {
  return Number(p.descuento_monto || 0);
}

function calcularTotal(p) {
  return Math.max(0, calcularSubtotal(p) - calcularDescuento(p) + calcularIva(p));
}

/* ── IMPRIMIR A4 ── */
