      .meta-box-title { font-size:9.5px; font-weight:800; text-transform:uppercase; letter-spacing:.7px; color:#9ca3af; margin-bottom:8px; }
      .meta-box-nombre { font-size:15px; font-weight:800; color:#111; }
      .meta-box-dato { font-size:11px; color:#5f6c7b; margin-top:3px; }

      .cond-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
      .cond-label { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#9ca3af; }
      .cond-val   { font-size:11.5px; font-weight:600; color:#1a2332; }

      table { width:100%; border-collapse:collapse; margin-bottom:20px; }
      thead th {
        padding:9px 10px;
        font-size:10px;
        font-weight:800;
        text-transform:uppercase;
        letter-spacing:.5px;
        color:#fff;
        background:#1a4a1a;
      }
      thead th:first-child { border-radius:7px 0 0 7px; }
      thead th:last-child  { border-radius:0 7px 7px 0; text-align:right; }
      th.right, td.right { text-align:right; }
      tbody td { padding:8px 8px; border-bottom:1px solid #f0f2f5; font-size:11px; vertical-align:top; }
      tbody tr:nth-child(even) td { background:#fafbfc; }
      .item-nombre { font-weight:700; color:#1a2332; }
      .item-desc   { font-size:9.5px; color:#9ca3af; margin-top:2px; }

      .totales-wrap { display:flex; justify-content:flex-end; margin-bottom:20px; }
      .totales-box { width:300px; }
      .total-line { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #f0f2f5; font-size:11.5px; }
      .total-final-line { display:flex; justify-content:space-between; padding:10px 14px; background:linear-gradient(135deg,#1a4a1a 0%,#2d7a2d 100%); border-radius:8px; margin-top:8px; }
      .total-final-label { font-size:13px; font-weight:800; color:rgba(255,255,255,.85); text-transform:uppercase; }
      .total-final-valor { font-size:20px; font-weight:900; color:#fff; }

      .doc-footer-info { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
      .info-box { padding:10px 12px; border-radius:7px; background:#f8f9fb; border:1px solid #e8ecf0; font-size:11px; color:#5f6c7b; white-space:pre-line; }
      .info-box strong { display:block; font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.5px; color:#9ca3af; margin-bottom:3px; }
    </style>
  </head><body><div class="doc-a4">${html}</div></body></html>`);

  w.document.close();
  setTimeout(() => { w.focus(); w.print(); }, 600);
}

/* ── IMPRIMIR TÉRMICA ── */
function imprimirTermica() {
  const p   = presupuesto;
  const emp = config.empresa_nombre || 'Mi Comercio';
  const dir = config.empresa_direccion || '';
  const tel = config.empresa_telefono  || '';

  const itemsHTML = (p.items || []).map(i => `
    <div style="margin-bottom:6px;">
      <div style="font-weight:700;font-size:13px;">${i.nombre || ''}</div>
      ${i.descripcion ? `<div style="font-size:11px;color:#666;">${i.descripcion}</div>` : ''}
      <div style="display:flex;justify-content:space-between;font-size:12px;margin-top:2px;">
        <span>${Number(i.cantidad || 0).toLocaleString('es-AR')} x ${fmt0(i.precio_unitario)}</span>
        <strong>${fmt0(i.subtotal)}</strong>
      </div>
    </div>
    <div style="border-top:1px dashed #ccc;margin:6px 0;"></div>
  `).join('');

  const subtotal = calcularSubtotal(p);
  const descuento = calcularDescuento(p);
  const iva = calcularIva(p);
  const total = calcularTotal(p);

  const obsHTML = (p.condicion_pago_obs || p.notas)
    ? `
      <div style="margin-top:10px;">
        <div style="border-top:1px dashed #ccc;margin:8px 0;"></div>
        ${p.condicion_pago_obs ? `
          <div style="font-size:11px;font-weight:700;margin-bottom:2px;">Condición de pago</div>
          <div style="font-size:11px;margin-bottom:8px;white-space:pre-line;">${p.condicion_pago_obs}</div>
        ` : ''}
        ${p.notas ? `
          <div style="font-size:11px;font-weight:700;margin-bottom:2px;">Notas</div>
          <div style="font-size:11px;white-space:pre-line;">${p.notas}</div>
        ` : ''}
      </div>
    `
    : '';

  const w = window.open('', '_blank', 'width=420,height=800');
  w.document.write(`<!DOCTYPE html>
  <html>
    <head>
      <meta charset="UTF-8">
      <title>${p.numero} — Térmica</title>
      <style>
        * { box-sizing:border-box; }
        body {
          font-family: Arial, sans-serif;
          width: 80mm;
          margin: 0 auto;
          padding: 10px;
          color: #000;
          background: #fff;
        }
        .center { text-align:center; }
        .muted { color:#666; }
        .sep { border-top:1px dashed #ccc; margin:8px 0; }
        .row { display:flex; justify-content:space-between; gap:10px; }
        .strong { font-weight:700; }
        .total { font-size:18px; font-weight:900; }
        @media print {
          body { width: 80mm; }
        }
      </style>
    </head>
    <body>
      <div class="center strong" style="font-size:16px;">${emp}</div>
      ${dir ? `<div class="center muted" style="font-size:11px;">${dir}</div>` : ''}
      ${tel ? `<div class="center muted" style="font-size:11px;">Tel: ${tel}</div>` : ''}
      <div class="sep"></div>

      <div class="center strong">PRESUPUESTO</div>
      <div class="center">${p.numero}</div>
      <div class="center muted" style="font-size:11px;">${new Date(p.created_at).toLocaleDateString('es-AR')}</div>

      <div class="sep"></div>

      <div style="font-size:12px;">
        <div><strong>Cliente:</strong> ${p.cliente_nombre || 'Sin nombre'}</div>
        ${p.cliente_cuit ? `<div><strong>CUIT/DNI:</strong> ${p.cliente_cuit}</div>` : ''}
        ${p.cliente_tel ? `<div><strong>Tel:</strong> ${p.cliente_tel}</div>` : ''}
        ${p.cliente_email ? `<div><strong>Email:</strong> ${p.cliente_email}</div>` : ''}
      </div>

      <div class="sep"></div>

      ${itemsHTML}

      <div class="row" style="font-size:12px;"><span>Subtotal</span><strong>${fmt0(subtotal)}</strong></div>
      ${descuento > 0 ? `<div class="row" style="font-size:12px;"><span>Descuento</span><strong>-${fmt0(descuento)}</strong></div>` : ''}
      ${iva > 0 ? `<div class="row" style="font-size:12px;"><span>IVA</span><strong>${fmt0(iva)}</strong></div>` : ''}
      <div class="sep"></div>
      <div class="row total"><span>TOTAL</span><span>${fmt0(total)}</span></div>

      ${p.condicion_pago ? `<div style="margin-top:10px;font-size:11px;"><strong>Pago:</strong> ${p.condicion_pago}</div>` : ''}
      ${p.validez_dias ? `<div style="font-size:11px;"><strong>Validez:</strong> ${p.validez_dias} día(s)</div>` : ''}

      ${obsHTML}
    </body>
  </html>`);

  w.document.close();
  setTimeout(() => { w.focus(); w.print(); }, 500);
}
</script>