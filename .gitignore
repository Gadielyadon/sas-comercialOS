# ─────────────────────────────────────────────────────────────
# Dependencias
# ─────────────────────────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────────────────────────
# Variables de entorno — NUNCA subir al repo
# ─────────────────────────────────────────────────────────────
.env

# ─────────────────────────────────────────────────────────────
# Certificados AFIP — se suben a la VPS por SFTP, no por git
# ─────────────────────────────────────────────────────────────
backend/certs/*.key
backend/certs/*.crt
backend/certs/*.pem
backend/certs/*.csr
certs/*.key
certs/*.crt
certs/*.pem
certs/*.csr

# ─────────────────────────────────────────────────────────────
# Base de datos SQLite — cada cliente tiene la suya en la VPS
# ─────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ─────────────────────────────────────────────────────────────
# Logs y temporales
# ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─────────────────────────────────────────────────────────────
# Sistema operativo
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
